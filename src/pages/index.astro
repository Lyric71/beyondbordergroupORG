  .draws-from__layer--engine:hover .engine-token { animation-duration: 6s; }
  .draws-from__layer--engine:hover .engine-core { filter: drop-shadow(0 0 12px rgba(95,182,224,0.7)); }

  /* Ops art: 4 service nodes around OPS hub */
  .ops-hub { transition: stroke 0.3s var(--ease); }
  .ops-node { transition: transform 0.3s var(--ease); transform-origin: center; transform-box: fill-box; }
  .ops-node rect { transition: fill 0.3s var(--ease), stroke 0.3s var(--ease); }
  .draws-from__layer--ops:hover .ops-node rect { fill: rgba(95,182,224,0.10); stroke: rgba(95,182,224,0.85); }
  .draws-from__layer--ops:hover .ops-hub { stroke: white; }
  .ops-line { animation: ops-dash 18s linear infinite; }
  @keyframes ops-dash { from { stroke-dashoffset: 0; } to { stroke-dashoffset: -56; } }
  .ops-pulse--1 { animation: ops-pulse-tl 4s ease-in-out infinite; }
  .ops-pulse--2 { animation: ops-pulse-br 4s ease-in-out infinite 2s; }
  @keyframes ops-pulse-tl {
    0% { transform: translate(110px, 110px); opacity: 0; }
