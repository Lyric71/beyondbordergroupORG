  .draws-from__art svg { position: relative; z-index: 1; width: 100%; height: 100%; display: block; }

  /* Engine art: orbiting tokens around HUB core */
  .engine-core { transition: filter 0.4s var(--ease); }
  .engine-glow { fill: #5fb6e0; opacity: 0.20; animation: engine-breathe 3s ease-in-out infinite; }
  @keyframes engine-breathe { 0%, 100% { r: 36; opacity: 0.18; } 50% { r: 46; opacity: 0.32; } }
  .engine-ripple {
    fill: none; stroke: #5fb6e0; stroke-width: 1.4; opacity: 0;
    animation: engine-ripple-out 3.4s linear infinite;
  }
  .engine-ripple--2 { animation-delay: 1.13s; }
  .engine-ripple--3 { animation-delay: 2.27s; }
  @keyframes engine-ripple-out {
    0% { r: 36; opacity: 0.55; stroke: #5fb6e0; }
    100% { r: 96; opacity: 0; stroke: #c8102e; }
  }
  .engine-token {
    transform-origin: 110px 110px;
    animation: engine-orbit 16s linear infinite;
    animation-delay: calc(var(--i) * -4s);
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.35));
