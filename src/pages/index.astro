    .loop, .ripple, .core-glow, .tile--lit, .orbiter, .loop-dot, .matrix-cell__bridge-dot { animation: none; }
  }
</style>

<script>
  // Scroll reveal for pillars
  const pillars = document.querySelectorAll<HTMLElement>('.pillar');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if ('IntersectionObserver' in window && pillars.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -10% 0px' },
    );
    pillars.forEach((p) => io.observe(p));
  } else {
    pillars.forEach((p) => p.classList.add('is-visible'));
  }

  // 3D tilt + glare on hover
  if (!reduceMotion) {
    pillars.forEach((p) => {
      let raf = 0;
      const onMove = (ev: MouseEvent) => {
        const r = p.getBoundingClientRect();
        const x = (ev.clientX - r.left) / r.width;
        const y = (ev.clientY - r.top) / r.height;
        const rx = (0.5 - y) * 5;
        const ry = (x - 0.5) * 5;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          p.style.transform = `translateY(0) rotateX(${rx}deg) rotateY(${ry}deg)`;
          p.style.setProperty('--mx', `${x * 100}%`);
          p.style.setProperty('--my', `${y * 100}%`);
        });
      };
      const onLeave = () => {
        cancelAnimationFrame(raf);
        p.style.transform = '';
      };
      p.addEventListener('mousemove', onMove);
      p.addEventListener('mouseleave', onLeave);
    });
  }
</script>
