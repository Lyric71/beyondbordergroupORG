---
import Layout from '../layouts/Layout.astro';
import AgencyLogo from '../components/AgencyLogo.astro';
import { pathFor } from '../i18n/ui';

const locale = 'en' as const;
const title = 'China and the West, both ways';
const description = 'Seven specialist agencies bridging China and the West in both directions. Brand, channels, web, partner sourcing, content, sales. One ecosystem, one shared spine.';

const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';

const agencies = [
  {
    name: 'BeyondBorderGroup',
    tagline: 'Full-service China entry. Branding through to eCommerce.',
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    tagline: 'Chinese social media. WeChat, Douyin, RedNote, Weibo.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    tagline: 'Websites built for the Chinese web. Baidu, ICP, AI engines.',
    route: 'agencies/chinawebfoundry' as const,
  },
  {
    name: 'BeyondCompass',
    tagline: 'A private database of vetted China distributors, Tmall TPs, Douyin Partners.',
    route: 'agencies/beyondcompass' as const,
  },
  {
    name: 'BeyondBridge',
    tagline: 'The full pipeline for Chinese brands going overseas.',
    route: 'agencies/beyondbridge' as const,
  },
  {
    name: 'HubStudio',
    tagline: 'AIGC image, video, and content. Production at scale.',
    route: 'agencies/hubstudio' as const,
  },
  {
    name: 'Nuvora Studio',
    tagline: 'LinkedIn-only B2B. Strategy, content, ads.',
    route: 'agencies/nuvora-studio' as const,
  },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <video
      class="hero-statement__video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
    </video>
    <div class="hero-statement__scrim" aria-hidden="true"></div>
    <div class="hero-statement__network" aria-hidden="true">
      <svg
        class="hero-statement__lines"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <line x1="72" y1="50" x2="93" y2="50" />
        <line x1="72" y1="50" x2="83" y2="18" />
        <line x1="72" y1="50" x2="61" y2="18" />
        <line x1="72" y1="50" x2="50" y2="50" />
        <line x1="72" y1="50" x2="61" y2="82" />
        <line x1="72" y1="50" x2="83" y2="82" />
        <line x1="93" y1="50" x2="83" y2="18" />
        <line x1="83" y1="18" x2="61" y2="18" />
        <line x1="61" y1="18" x2="50" y2="50" />
        <line x1="50" y1="50" x2="61" y2="82" />
        <line x1="61" y1="82" x2="83" y2="82" />
        <line x1="83" y1="82" x2="93" y2="50" />
      </svg>
      <a class="hero-node" style="left: 72%; top: 50%;" href={pathFor('agencies/beyondbordergroup', locale)} aria-label="BeyondBorderGroup">
        <img src="/AgencyLogos/BBG%20PNG.png" alt="" />
      </a>
      <a class="hero-node" style="left: 93%; top: 50%;" href={pathFor('agencies/hubstudio', locale)} aria-label="HubStudio">
        <img src="/AgencyLogos/hubStudio%20(2).png" alt="" />
      </a>
      <a class="hero-node" style="left: 83%; top: 18%;" href={pathFor('agencies/beyondcompass', locale)} aria-label="BeyondCompass">
        <img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="" />
      </a>
      <a class="hero-node" style="left: 61%; top: 18%;" href={pathFor('agencies/theredscroll', locale)} aria-label="TheRedScroll">
        <img src="/AgencyLogos/TheredScroll%20PNG.png" alt="" />
      </a>
      <a class="hero-node" style="left: 50%; top: 50%;" href={pathFor('agencies/chinawebfoundry', locale)} aria-label="ChinaWebFoundry">
        <img src="/AgencyLogos/Logo-ChinaWebFoundry-transparent.png" alt="" />
      </a>
      <a class="hero-node" style="left: 61%; top: 82%;" href={pathFor('agencies/nuvora-studio', locale)} aria-label="Nuvora Studio">
        <img src="/AgencyLogos/Nuvora%20PNG.png" alt="" />
      </a>
      <a class="hero-node" style="left: 83%; top: 82%;" href={pathFor('agencies/beyondbridge', locale)} aria-label="BeyondBridge">
        <img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="" />
      </a>
    </div>
    <div class="container hero-statement__container">
      <div class="hero-statement__content">
        <span class="eyebrow">Ecosystem</span>
        <h1 class="hero-statement__title balance">We build and grow brands, products, and services across China and the West. Both ways.</h1>
        <p class="hero-statement__lead">
          Six specialist agencies. One thesis. The gap between China and the West is not a translation problem.
          It is a brand problem, a channel problem, an infrastructure problem, and a sales problem. And it runs
          in both directions.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={pathFor('agencies', locale)}>Find the right agency</a>
          <a class="btn btn--ghost" href={pathFor('contact', locale)}>Talk to us</a>
        </div>
        <p class="hero-statement__cite">Shanghai. Hong Kong. Paris. In-market reps in the US, UK, Germany, France.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Two directions</span>
        <h2 class="balance">One bridge. Two flows.</h2>
        <p class="lead">Whichever way you are going, we have already done the work on both sides.</p>
      </header>
      <div class="flows">
        <article class="flow">
          <span class="flow__direction">West to China · Inbound</span>
          <h3>Bringing Western brands into China</h3>
          <p>
            Brand work, channels, web infrastructure, eCommerce, social, KOLs, distribution. From a cross-border
            eCommerce test to a full WeChat, Tmall, and Douyin presence.
          </p>
          <a class="btn btn--ghost" href={pathFor('entering-china', locale)}>See the inbound flow</a>
          <p class="flow__by">Run by BeyondBorderGroup, TheRedScroll, ChinaWebFoundry.</p>
        </article>
        <article class="flow flow--dark">
          <span class="flow__direction">China to the West · Outbound</span>
          <h3>Taking Chinese brands and businesses overseas</h3>
          <p>
            A brand for Western buyers, a real LinkedIn presence, websites built for Western eyes, SEO, GEO,
            Google Ads, and named sales reps in the right time zone.
          </p>
          <a class="btn btn--ghost" href={pathFor('going-overseas', locale)} style="color: var(--bbg-blue-light);">See the outbound flow</a>
          <p class="flow__by">Run by BeyondBridge, Nuvora.studio.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">The stack</span>
        <h2 class="balance">Seven specialists. One ecosystem.</h2>
        <p class="lead">
          Each agency stands alone. Pick the one you need. Most clients start with one, then pull in others
          as the project grows.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Open</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">The logic</span>
        <h2 class="balance">A 2x2, with a foundation underneath.</h2>
        <p class="lead">
          Two columns by direction. Two horizontal layers serving both. Every agency in the group sits in one cell,
          and reaches across the others when the project needs it.
        </p>
      </header>
      <div class="matrix-grid" role="table" aria-label="Agencies by direction and layer">
        <div class="matrix-grid__head" role="row">
          <div class="matrix-grid__corner" aria-hidden="true"></div>
          <div class="matrix-grid__direction matrix-grid__direction--west" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">→</span>
            <span class="matrix-grid__direction-label">West to China</span>
          </div>
          <div class="matrix-grid__direction matrix-grid__direction--east" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">←</span>
            <span class="matrix-grid__direction-label">China to the West</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Full-service</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Lead agency</span>
            <span class="matrix-cell__name">BeyondBorderGroup</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Lead agency</span>
            <span class="matrix-cell__name">BeyondBridge</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Channel specialist</span>
          </div>
          <div class="matrix-cell" role="cell">
            <span class="matrix-cell__name">TheRedScroll</span>
          </div>
          <div class="matrix-cell" role="cell">
            <span class="matrix-cell__name">Nuvora Studio</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Web infrastructure</span>
          </div>
          <div class="matrix-cell" role="cell">
            <span class="matrix-cell__name">ChinaWebFoundry</span>
          </div>
          <div class="matrix-cell" role="cell">
            <span class="matrix-cell__name">BeyondBridge web module</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Partner sourcing</span>
          </div>
          <div class="matrix-cell" role="cell">
            <span class="matrix-cell__name">BeyondCompass</span>
          </div>
          <div class="matrix-cell matrix-cell--empty" role="cell" aria-label="not applicable">
            <span class="matrix-cell__dash" aria-hidden="true">—</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--span" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Production layer</span>
          </div>
          <div class="matrix-cell matrix-cell--span" role="cell">
            <span class="matrix-cell__bridge" aria-hidden="true">
              <span class="matrix-cell__bridge-dot"></span>
              <span class="matrix-cell__bridge-line"></span>
              <span class="matrix-cell__bridge-dot"></span>
            </span>
            <span class="matrix-cell__name">HubStudio</span>
            <span class="matrix-cell__note">cuts across both directions</span>
          </div>
        </div>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>How we work together</a>
      </div>
    </div>
  </section>

  <section class="section pillars-section">
    <div class="pillars-section__bg" aria-hidden="true">
      <span class="pillars-section__blob pillars-section__blob--blue"></span>
      <span class="pillars-section__blob pillars-section__blob--red"></span>
      <span class="pillars-section__grid"></span>
    </div>
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Why one group</span>
        <h2 class="balance">Specialists. <span class="text-gradient">Not silos.</span></h2>
        <p class="lead">Six agencies. One thesis. One production engine.</p>
      </header>
      <div class="pillars">
        <article class="pillar" data-pillar-index="0">
          <div class="pillar__visual">
            <svg class="pillar__art" viewBox="0 0 200 140" aria-hidden="true">
              <defs>
                <linearGradient id="loop-w" x1="0" x2="1" y1="0" y2="1">
                  <stop offset="0%" stop-color="#269ada"/>
                  <stop offset="100%" stop-color="#1e7db0"/>
                </linearGradient>
                <linearGradient id="loop-e" x1="0" x2="1" y1="1" y2="0">
                  <stop offset="0%" stop-color="#c8102e"/>
                  <stop offset="100%" stop-color="#8a0a1d"/>
                </linearGradient>
              </defs>
              <g class="loop">
                <path d="M 60 70 C 60 30, 100 30, 100 70 C 100 110, 140 110, 140 70" stroke="url(#loop-w)" stroke-width="3.5" fill="none" stroke-linecap="round"/>
                <path d="M 140 70 C 140 110, 100 110, 100 70 C 100 30, 60 30, 60 70" stroke="url(#loop-e)" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.85"/>
              </g>
              <circle class="loop-dot loop-dot--w" cx="60" cy="70" r="6" fill="#269ada"/>
              <circle class="loop-dot loop-dot--e" cx="140" cy="70" r="6" fill="#c8102e"/>
              <text x="34" y="74" font-size="9" font-weight="700" fill="#1a1a1a" letter-spacing="1">W</text>
              <text x="158" y="74" font-size="9" font-weight="700" fill="#1a1a1a" letter-spacing="1">E</text>
            </svg>
          </div>
          <div class="pillar__body">
            <span class="pillar__tag">One thesis</span>
            <h3 class="pillar__title">Same shape, both ways.</h3>
            <p class="pillar__copy">West-to-China or China-to-West, the work is the same: brand, channels, infrastructure, content, sales — in the right time zone.</p>
          </div>
        </article>

        <article class="pillar" data-pillar-index="1">
          <div class="pillar__visual">
            <svg class="pillar__art" viewBox="0 0 200 140" aria-hidden="true">
              <g class="tiles">
                <rect class="tile" x="44" y="28" width="32" height="24" rx="5"/>
                <rect class="tile" x="84" y="28" width="32" height="24" rx="5"/>
                <rect class="tile tile--lit" style="animation-delay: 0s" x="124" y="28" width="32" height="24" rx="5"/>
                <rect class="tile tile--lit" style="animation-delay: 1.2s" x="44" y="58" width="32" height="24" rx="5"/>
                <rect class="tile" x="84" y="58" width="32" height="24" rx="5"/>
                <rect class="tile" x="124" y="58" width="32" height="24" rx="5"/>
                <rect class="tile" x="44" y="88" width="32" height="24" rx="5"/>
                <rect class="tile tile--lit" style="animation-delay: 0.6s" x="84" y="88" width="32" height="24" rx="5"/>
                <rect class="tile" x="124" y="88" width="32" height="24" rx="5"/>
              </g>
            </svg>
          </div>
          <div class="pillar__body">
            <span class="pillar__tag">Modular</span>
            <h3 class="pillar__title">Pay for what you need.</h3>
            <p class="pillar__copy">Each agency has its own brand, pricing, and team. Need only a Chinese site? Skip media. Only LinkedIn? Skip the KOL roster.</p>
          </div>
        </article>

        <article class="pillar" data-pillar-index="2">
          <div class="pillar__visual">
            <svg class="pillar__art" viewBox="0 0 200 140" aria-hidden="true">
              <g class="engine">
                <circle class="ripple" cx="100" cy="70" r="18"/>
                <circle class="ripple ripple--2" cx="100" cy="70" r="18"/>
                <circle class="ripple ripple--3" cx="100" cy="70" r="18"/>
                <circle class="core-glow" cx="100" cy="70" r="20"/>
                <circle class="core" cx="100" cy="70" r="12"/>
                <circle class="orbiter" cx="55" cy="70" r="3.5"/>
                <circle class="orbiter orbiter--2" cx="145" cy="70" r="3.5"/>
                <circle class="orbiter orbiter--3" cx="100" cy="25" r="3.5"/>
                <circle class="orbiter orbiter--4" cx="100" cy="115" r="3.5"/>
                <circle class="orbiter orbiter--5" cx="68" cy="38" r="3"/>
                <circle class="orbiter orbiter--6" cx="132" cy="102" r="3"/>
                <line class="spoke" x1="100" y1="70" x2="55" y2="70"/>
                <line class="spoke" x1="100" y1="70" x2="145" y2="70"/>
                <line class="spoke" x1="100" y1="70" x2="100" y2="25"/>
                <line class="spoke" x1="100" y1="70" x2="100" y2="115"/>
              </g>
            </svg>
          </div>
          <div class="pillar__body">
            <span class="pillar__tag">Shared engine</span>
            <h3 class="pillar__title">One core, six agencies.</h3>
            <p class="pillar__copy">Every agency draws on HubStudio's AIGC layer. Per-output cost stays competitive — content ships fast in either direction.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Who is behind this</span>
          <h2 class="balance">One operator. Two decades on both sides.</h2>
          <p class="lead">
            The group is founded and led by Cyril Drouin. Twenty-five years in digital, eCommerce, and brand work
            across Europe and North Asia. Former Chief Digital and eCommerce Officer for Publicis North Asia.
            Founder of HubStudio and Nuvora Studio.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Connect on LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin on LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, founder of BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Tell us which way you are going.</h2>
      <p class="lead" style="margin-inline: auto;">
        Thirty minutes on a call. We will tell you which agency in the group is the right place to start, or whether
        you should start with more than one.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Book a call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- The Stack: consistent logo sizing ---------- */
  .card :global(.agency-card-logo) {
    width: 100%;
    height: 56px;
    max-height: 56px;
    object-fit: contain;
    object-position: left center;
    margin-bottom: var(--space-3);
    background: transparent;
    display: block;
    filter: none;
  }

  /* ---------- Modern matrix grid ---------- */
  .matrix-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .matrix-grid__head,
  .matrix-grid__row {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .matrix-grid__direction {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bbg-ink);
    position: relative;
  }
  .matrix-grid__direction::after {
    content: '';
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: 0;
    height: 2px;
    border-radius: 2px;
  }
  .matrix-grid__direction--west::after { background: linear-gradient(90deg, var(--bbg-blue), transparent); }
  .matrix-grid__direction--east::after { background: linear-gradient(90deg, transparent, #c8102e); }
  .matrix-grid__direction--east { justify-content: flex-end; flex-direction: row-reverse; }
  .matrix-grid__arrow {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--bbg-blue);
  }
  .matrix-grid__direction--east .matrix-grid__arrow { color: #c8102e; }
  .matrix-grid__layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    align-self: center;
  }
  .matrix-grid__layer-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--bbg-text-muted);
  }
  .matrix-grid__layer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 12px;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .matrix-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(15, 23, 42, 0.18);
    border-color: var(--bbg-border-strong);
  }
  .matrix-cell--lead {
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-surface) 100%);
    border-color: rgba(38, 154, 218, 0.25);
  }
  .matrix-cell--lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    border-radius: 0 3px 3px 0;
  }
  .matrix-cell__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .matrix-cell__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell--empty {
    background: transparent;
    border: 1px dashed var(--bbg-border);
    align-items: center;
    justify-content: center;
  }
  .matrix-cell--empty:hover { transform: none; box-shadow: none; }
  .matrix-cell__dash { font-size: 1.25rem; color: var(--bbg-text-muted); }
  .matrix-grid__row--span .matrix-cell--span {
    grid-column: 2 / -1;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    border-color: transparent;
    color: white;
    align-items: center;
    text-align: center;
    padding: var(--space-5);
    overflow: hidden;
  }
  .matrix-grid__row--span .matrix-cell--span::after {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(circle at 30% 50%, rgba(38, 154, 218, 0.15), transparent 40%),
      radial-gradient(circle at 70% 50%, rgba(200, 16, 46, 0.15), transparent 40%);
    pointer-events: none;
  }
  .matrix-grid__row--span .matrix-cell--span > * { position: relative; z-index: 1; }
