---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Beyond Border Group | China Market Entry, eCommerce & Distribution"
  description="We help global brands enter China, grow on Tmall, JD, Douyin, WeChat and RED, and find the right distributor."
>
  <section class="hero-fullbleed">
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>

    <div class="container hero-fullbleed__inner">
      <div class="hero-fullbleed__copy">
        <span class="eyebrow eyebrow--on-dark">
          China market entry, eCommerce &amp; distribution
        </span>
        <h1 class="hero-fullbleed__title">
          Sell in China. Grow in China. Understand China.
        </h1>
        <p class="hero-fullbleed__lead">
          Cross-border eCommerce, social commerce, distribution and market entry
          consulting. One team, three offices.
        </p>
        <div class="hero-fullbleed__actions">
          <a class="btn btn--primary" href="/contact">Talk to us</a>
          <a class="btn btn--ghost-light" href="/work">See our work</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Where to start</span>
        <h2>China is not one problem to solve</h2>
        <p class="lead">
          Three stages, three different problems. Pick the one that matches where
          you are.
        </p>
      </header>

      <div class="grid">
        <article class="card">
          <h3>Enter China</h3>
          <p>
            You have a product that could work in China, but no team there, no
            entity, no store on any platform.
          </p>
          <a href="/enter-china" class="btn btn--ghost">Enter China</a>
        </article>

        <article class="card">
          <h3>Grow in China</h3>
          <p>
            You are in the market, you are selling. Now make eCommerce, social
            commerce, media and brand work compound under one roof.
          </p>
          <a href="/grow-in-china" class="btn btn--ghost">Grow in China</a>
        </article>

        <article class="card">
          <h3>Learn China</h3>
          <p>
            Platform rules keep changing. Get on-the-ground learning expeditions
            and operator-led masterclasses with current market data.
          </p>
          <a href="/learn-china" class="btn btn--ghost">Learn China</a>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
</style>
