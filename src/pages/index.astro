                  <g class="ops-node ops-node--admin" style="--i: 1;">
                    <rect x="138" y="22" width="68" height="46" rx="10" fill="rgba(255,255,255,0.05)" stroke="rgba(95,182,224,0.55)" stroke-width="1.3" />
                    <text x="172" y="44" font-size="11" font-weight="600" fill="white" text-anchor="middle">Admin</text>
                    <text x="172" y="58" font-size="7.5" fill="rgba(255,255,255,0.55)" text-anchor="middle" letter-spacing="0.6">Legal & ops</text>
                  </g>
                  <g class="ops-node ops-node--hr" style="--i: 2;">
                    <rect x="14" y="152" width="68" height="46" rx="10" fill="rgba(255,255,255,0.05)" stroke="rgba(95,182,224,0.55)" stroke-width="1.3" />
                    <text x="48" y="174" font-size="11" font-weight="600" fill="white" text-anchor="middle">HR</text>
                    <text x="48" y="188" font-size="7.5" fill="rgba(255,255,255,0.55)" text-anchor="middle" letter-spacing="0.6">Hiring & care</text>
                  </g>
                  <g class="ops-node ops-node--finance" style="--i: 3;">
                    <rect x="138" y="152" width="68" height="46" rx="10" fill="rgba(255,255,255,0.05)" stroke="rgba(95,182,224,0.55)" stroke-width="1.3" />
                    <text x="172" y="174" font-size="11" font-weight="600" fill="white" text-anchor="middle">Finance</text>
                    <text x="172" y="188" font-size="7.5" fill="rgba(255,255,255,0.55)" text-anchor="middle" letter-spacing="0.6">Books & tax</text>
                  </g>

                  <line class="ops-line ops-line--tl" x1="92" y1="98" x2="80" y2="68" stroke="rgba(95,182,224,0.45)" stroke-dasharray="3 4" />
                  <line class="ops-line ops-line--tr" x1="128" y1="98" x2="138" y2="68" stroke="rgba(95,182,224,0.45)" stroke-dasharray="3 4" />
                  <line class="ops-line ops-line--bl" x1="92" y1="122" x2="80" y2="152" stroke="rgba(95,182,224,0.45)" stroke-dasharray="3 4" />
                  <line class="ops-line ops-line--br" x1="128" y1="122" x2="138" y2="152" stroke="rgba(95,182,224,0.45)" stroke-dasharray="3 4" />

                  <circle class="ops-pulse ops-pulse--1" r="2.6" cx="0" cy="0" fill="#5fb6e0" />
                  <circle class="ops-pulse ops-pulse--2" r="2.6" cx="0" cy="0" fill="#5fb6e0" />
                </g>
              </svg>
            </div>
            <div class="draws-from__copy">
              <span class="draws-from__layer-tag">Layer · Back office</span>
              <h3 class="draws-from__layer-title">Run once, not seven times.</h3>
              <p class="draws-from__layer-body">
                IT, admin, HR, finance. The unsexy parts of running an agency, mutualised across the group.
                Independent agencies upstairs, shared overhead downstairs. Every founder's headache, removed
                from every founder.
              </p>
              <ul class="draws-from__chips" role="list">
                <li>IT</li>
                <li>Admin</li>
                <li>HR</li>
                <li>Finance</li>
              </ul>
            </div>
          </li>

          <li class="draws-from__layer draws-from__layer--voice" style="--i: 2;">
            <div class="draws-from__art">
              <svg viewBox="0 0 220 220" aria-hidden="true">
                <defs>
                  <linearGradient id="brush-grad" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#c8102e" stop-opacity="0.9" />
                    <stop offset="60%" stop-color="#9a3a8a" stop-opacity="0.85" />
                    <stop offset="100%" stop-color="#5fb6e0" stop-opacity="0.85" />
                  </linearGradient>
                </defs>
                <g class="voice-art">
                  <circle class="voice-brand" cx="110" cy="36" r="22" fill="rgba(200,16,46,0.18)" stroke="#c8102e" stroke-width="1.4" />
                  <text x="110" y="42" font-size="18" font-weight="800" fill="#c8102e" text-anchor="middle" font-family="serif">C</text>

                  <path class="voice-brush voice-brush--1" d="M 110 60 Q 60 110, 40 184" stroke="url(#brush-grad)" stroke-width="3.4" fill="none" stroke-linecap="round" />
                  <path class="voice-brush voice-brush--2" d="M 110 60 Q 110 130, 110 184" stroke="url(#brush-grad)" stroke-width="3.4" fill="none" stroke-linecap="round" />
                  <path class="voice-brush voice-brush--3" d="M 110 60 Q 160 110, 180 184" stroke="url(#brush-grad)" stroke-width="3.4" fill="none" stroke-linecap="round" />

                  <g class="voice-target voice-target--1">
                    <circle cx="40" cy="184" r="11" fill="rgba(255,255,255,0.92)" />
                    <text x="40" y="188" font-size="8" font-weight="700" fill="#1a1a1a" text-anchor="middle">Web</text>
                  </g>
                  <g class="voice-target voice-target--2">
                    <circle cx="110" cy="184" r="11" fill="rgba(255,255,255,0.92)" />
                    <text x="110" y="188" font-size="8" font-weight="700" fill="#1a1a1a" text-anchor="middle">Soc.</text>
                  </g>
                  <g class="voice-target voice-target--3">
                    <circle cx="180" cy="184" r="11" fill="rgba(255,255,255,0.92)" />
                    <text x="180" y="188" font-size="8" font-weight="700" fill="#1a1a1a" text-anchor="middle">Ads</text>
                  </g>
                </g>
              </svg>
            </div>
            <div class="draws-from__copy">
              <span class="draws-from__layer-tag">Layer · Voice</span>
              <h3 class="draws-from__layer-title">One brand voice across agencies.</h3>
              <p class="draws-from__layer-body">
                When a brief crosses two or more agencies (most do), group creative direction keeps the work in one
                voice. Same brand on Tmall and on RedNote. Same tone on a Western LinkedIn page and a French Google
                Ads landing.
              </p>
              <ul class="draws-from__chips" role="list">
                <li>Brand</li>
                <li>Tone</li>
                <li>Visual</li>
                <li>Copy</li>
              </ul>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Who is behind this</span>
          <h2 class="balance">One operator. Two decades on both sides.</h2>
          <p class="lead">
            The group is founded and led by Cyril Drouin. Twenty-five years in digital, eCommerce, and brand work
            across Europe and North Asia. Former Chief Digital and eCommerce Officer for Publicis North Asia.
            Founder of HubStudio and Nuvora Studio.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Connect on LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin on LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, founder of BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Tell us which way you are going.</h2>
      <p class="lead" style="margin-inline: auto;">
        Thirty minutes on a call. We will tell you which agency in the group is the right place to start, or whether
        you should start with more than one.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Book a call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- The Stack: consistent logo sizing ---------- */
  .card :global(.agency-card-logo) {
    width: 100%;
    height: 56px;
    max-height: 56px;
    object-fit: contain;
    object-position: left center;
    margin-bottom: var(--space-3);
    background: transparent;
    display: block;
    filter: none;
  }

  /* ---------- Modern matrix grid ---------- */
  .matrix-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .matrix-grid__head,
  .matrix-grid__row {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .matrix-grid__direction {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bbg-ink);
    position: relative;
  }
  .matrix-grid__direction::after {
    content: '';
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: 0;
    height: 2px;
    border-radius: 2px;
  }
  .matrix-grid__direction--west::after { background: linear-gradient(90deg, var(--bbg-blue), transparent); }
  .matrix-grid__direction--east::after { background: linear-gradient(90deg, transparent, #c8102e); }
  .matrix-grid__direction--east { justify-content: flex-end; flex-direction: row-reverse; }
  .matrix-grid__arrow {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--bbg-blue);
  }
  .matrix-grid__direction--east .matrix-grid__arrow { color: #c8102e; }
  .matrix-grid__layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    align-self: center;
  }
  .matrix-grid__layer-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--bbg-text-muted);
  }
  .matrix-grid__layer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 12px;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .matrix-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(15, 23, 42, 0.18);
    border-color: var(--bbg-border-strong);
  }
  .matrix-cell--lead {
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-surface) 100%);
    border-color: rgba(38, 154, 218, 0.25);
  }
  .matrix-cell--lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both {
    grid-column: 2 / -1;
    background: linear-gradient(90deg, rgba(38, 154, 218, 0.06) 0%, rgba(255, 255, 255, 0.5) 50%, rgba(200, 16, 46, 0.06) 100%);
    border-color: rgba(15, 23, 42, 0.10);
    padding: var(--space-3) var(--space-5);
  }
  .matrix-grid__row--both .matrix-cell--both::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue) 0%, #c8102e 100%);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__tag {
    color: transparent;
    background: linear-gradient(90deg, var(--bbg-blue), #c8102e);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__note {
    color: var(--bbg-text-muted);
    font-size: var(--fs-small);
  }
  .matrix-cell__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .matrix-cell__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell--empty {
    background: transparent;
    border: 1px dashed var(--bbg-border);
    align-items: center;
    justify-content: center;
  }
  .matrix-cell--empty:hover { transform: none; box-shadow: none; }
  .matrix-cell__dash { font-size: 1.25rem; color: var(--bbg-text-muted); }
  .matrix-grid__row--span .matrix-cell--span {
    grid-column: 2 / -1;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    border-color: transparent;
    color: white;
    align-items: center;
    text-align: center;
    padding: var(--space-5);
    overflow: hidden;
  }
  .matrix-grid__row--span .matrix-cell--span::after {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(circle at 30% 50%, rgba(38, 154, 218, 0.15), transparent 40%),
      radial-gradient(circle at 70% 50%, rgba(200, 16, 46, 0.15), transparent 40%);
    pointer-events: none;
  }
  .matrix-grid__row--span .matrix-cell--span > * { position: relative; z-index: 1; }
  .matrix-grid__row--span .matrix-cell__name { color: white; font-size: 1.25rem; }
  .matrix-grid__row--span .matrix-cell__note {
    color: rgba(255,255,255,0.7);
    font-size: var(--fs-small);
    margin-top: 2px;
  }
  .matrix-cell__bridge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-2);
  }
  .matrix-cell__bridge-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--bbg-blue);
    box-shadow: 0 0 12px rgba(38, 154, 218, 0.7);
    animation: bridge-pulse 2.5s ease-in-out infinite;
  }
  .matrix-cell__bridge-dot:last-child {
    background: #c8102e;
    box-shadow: 0 0 12px rgba(200, 16, 46, 0.7);
    animation-delay: 1.25s;
  }
  .matrix-cell__bridge-line {
    width: 64px; height: 2px;
    background: linear-gradient(90deg, var(--bbg-blue), #c8102e);
    border-radius: 2px;
  }
  @keyframes bridge-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.6; }
  }
  @media (max-width: 760px) {
    .matrix-grid__head { display: none; }
    .matrix-grid__row { grid-template-columns: 1fr; gap: var(--space-2); padding-bottom: var(--space-4); border-bottom: 1px solid var(--bbg-border); }
    .matrix-grid__row:last-child { border-bottom: none; }
    .matrix-grid__row--span .matrix-cell--span { grid-column: 1 / -1; }
  }

  /* ---------- "What every agency draws from" ---------- */
  .draws-from-section { position: relative; overflow: hidden; }
  .draws-from-section__bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .draws-from-section__blob {
    position: absolute; width: 520px; height: 520px; border-radius: 50%;
    filter: blur(120px); opacity: 0.55;
  }
  .draws-from-section__blob--blue { background: rgba(38, 154, 218, 0.20); top: -180px; left: -160px; }
  .draws-from-section__blob--red { background: rgba(200, 16, 46, 0.14); bottom: -180px; right: -160px; }
  .draws-from-section__grid {
    position: absolute; inset: 0; opacity: 0.4;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }
  .draws-from-section .container { position: relative; z-index: 1; }

  .text-gradient {
    background: linear-gradient(135deg, #269ada 0%, #c8102e 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .draws-from {
    margin-top: var(--space-6);
    display: grid;
    gap: 0;
    perspective: 1400px;
  }

  /* --- Top row of 7 agency tiles --- */
  .draws-from__top {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: clamp(8px, 1.6vw, 18px);
    align-items: end;
    justify-items: center;
    padding-bottom: var(--space-4);
  }
  .draws-from__node {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    text-align: center;
    opacity: 0;
    transform: translateY(-12px);
    transition: opacity 0.6s var(--ease), transform 0.6s var(--ease);
    transition-delay: calc(var(--i) * 70ms);
  }
  .draws-from.is-visible .draws-from__node { opacity: 1; transform: none; }
  .draws-from__chip {
    width: clamp(56px, 7vw, 78px);
    height: clamp(56px, 7vw, 78px);
    border-radius: 50%;
    background: white;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.05),
      0 8px 22px -10px rgba(15, 23, 42, 0.18);
    display: flex; align-items: center; justify-content: center;
    padding: 12px;
    position: relative;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .draws-from__chip::after {
    content: '';
    position: absolute; left: 50%; bottom: -5px;
    transform: translateX(-50%);
    width: 6px; height: 6px; border-radius: 50%;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    box-shadow: 0 0 10px rgba(38, 154, 218, 0.6);
    opacity: 0; transition: opacity 0.3s var(--ease);
  }
  .draws-from__node:hover .draws-from__chip {
    transform: translateY(-4px);
    border-color: var(--bbg-blue);
    box-shadow:
      0 2px 4px rgba(15, 23, 42, 0.06),
      0 18px 36px -12px rgba(38, 154, 218, 0.32);
  }
  .draws-from__node:hover .draws-from__chip::after { opacity: 1; }
  .draws-from__chip img {
    max-width: 100%; max-height: 100%;
    object-fit: contain;
    display: block;
  }
  .draws-from__node-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--bbg-text);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  /* --- Connector bridge SVG --- */
  .draws-from__bridge {
    position: relative;
    height: clamp(56px, 9vw, 80px);
    margin: 0 calc(var(--space-4) * -0.5);
    overflow: visible;
  }
  .draws-from__bridge svg {
    width: 100%; height: 100%;
    display: block;
    overflow: visible;
  }
  .draws-from__line {
    fill: none;
    stroke: url(#draws-grad);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-dasharray: 220;
    stroke-dashoffset: 220;
    transition: stroke-dashoffset 0.9s var(--ease);
    transition-delay: calc(0.4s + var(--li) * 60ms);
  }
  .draws-from.is-visible .draws-from__line { stroke-dashoffset: 0; }
  .draws-from__rail {
    stroke: url(#draws-grad);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 620;
    stroke-dashoffset: 620;
    transition: stroke-dashoffset 1.1s var(--ease) 1s;
    opacity: 0.7;
  }
  .draws-from.is-visible .draws-from__rail { stroke-dashoffset: 0; }
  .draws-from__rail-pulse {
    fill: #269ada;
    filter: drop-shadow(0 0 8px rgba(38, 154, 218, 0.7));
    opacity: 0;
  }
  .draws-from.is-visible .draws-from__rail-pulse {
    opacity: 1;
    animation: rail-pulse 4s linear infinite 1.6s;
  }
  @keyframes rail-pulse {
    0% { transform: translateX(40px); }
    100% { transform: translateX(620px); }
  }

  /* --- 3 layer cards --- */
  .draws-from__layers {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .draws-from__layer {
    position: relative;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-5);
    padding: var(--space-5);
    background: linear-gradient(180deg, #ffffff 0%, #fafbfd 100%);
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 22px;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 14px 36px -18px rgba(15, 23, 42, 0.14);
    overflow: hidden;
    transform-style: preserve-3d;
    will-change: transform;
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.7s var(--ease),
      transform 0.7s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
    transition-delay: calc(0.6s + var(--i) * 0.12s);
  }
  .draws-from.is-visible .draws-from__layer { opacity: 1; transform: translateY(0); }
  .draws-from__layer::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--accent-from, #5fb6e0), var(--accent-to, #1e7db0));
    opacity: 0.85;
  }
  .draws-from__layer::after {
    content: '';
    position: absolute; inset: 0; border-radius: 22px;
    background:
      radial-gradient(ellipse 600px 280px at 12% 50%, var(--accent-glow, rgba(95,182,224,0.10)), transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }
  .draws-from__layer:hover { transform: translateY(-4px); border-color: rgba(15, 23, 42, 0.10); box-shadow: 0 2px 4px rgba(15, 23, 42, 0.05), 0 28px 60px -22px rgba(15, 23, 42, 0.18); }
