    .draws-from__line, .draws-from__rail { stroke-dashoffset: 0; transition: none; }
    .engine-ripple, .engine-glow, .engine-token, .ops-line, .ops-pulse--1, .ops-pulse--2,
    .voice-brand, .voice-brush, .draws-from__rail-pulse { animation: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Scroll reveal for the "What every agency draws from" diagram.
  // Trigger as a single unit so agency tiles, connector lines, and layer cards animate in sequence.
  const drawsFrom = document.querySelector<HTMLElement>('[data-draws-from]');
  if (drawsFrom) {
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
      );
      io.observe(drawsFrom);
    } else {
      drawsFrom.classList.add('is-visible');
    }

    // 3D tilt + parallax on the layer cards
    if (!reduceMotion) {
      const layers = drawsFrom.querySelectorAll<HTMLElement>('.draws-from__layer');
      layers.forEach((card) => {
        let raf = 0;
        const onMove = (ev: MouseEvent) => {
          const r = card.getBoundingClientRect();
          const x = (ev.clientX - r.left) / r.width;
          const y = (ev.clientY - r.top) / r.height;
          const rx = (0.5 - y) * 4;
          const ry = (x - 0.5) * 4;
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(() => {
            card.style.transform = `translateY(-2px) rotateX(${rx}deg) rotateY(${ry}deg)`;
          });
        };
        const onLeave = () => {
          cancelAnimationFrame(raf);
          card.style.transform = '';
        };
        card.addEventListener('mousemove', onMove);
        card.addEventListener('mouseleave', onLeave);
      });

      // Subtle floating pulse on the agency tiles (parallax-on-scroll feel).
      const nodes = drawsFrom.querySelectorAll<HTMLElement>('.draws-from__node');
      let scrollRaf = 0;
      const onScroll = () => {
        cancelAnimationFrame(scrollRaf);
        scrollRaf = requestAnimationFrame(() => {
          const r = drawsFrom.getBoundingClientRect();
          const vh = window.innerHeight;
          // 0 when section is below viewport, 1 when fully past.
          const progress = Math.min(1, Math.max(0, 1 - (r.top + r.height * 0.3) / vh));
          nodes.forEach((node, i) => {
            const phase = (i % 3) * 0.33;
            const offset = Math.sin((progress + phase) * Math.PI * 2) * 3;
            node.style.translate = `0 ${offset.toFixed(2)}px`;
          });
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }
</script>
