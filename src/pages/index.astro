    50% { transform: translate(48px, 45px); opacity: 1; }
    51% { opacity: 0; transform: translate(110px, 110px); }
    100% { opacity: 0; transform: translate(110px, 110px); }
  }
  @keyframes ops-pulse-br {
    0% { transform: translate(110px, 110px); opacity: 0; }
