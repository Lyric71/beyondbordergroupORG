---
import Layout from '../layouts/Layout.astro';
import AgencyLogo from '../components/AgencyLogo.astro';
import { pathFor } from '../i18n/ui';

const locale = 'en' as const;
const title = 'China and the West, both ways';
const description = 'Seven specialist agencies bridging China and the West in both directions. Brand, channels, web, partner sourcing, content, sales. One ecosystem, one shared spine.';

const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';

const agencies = [
  {
    name: 'BeyondBorderGroup',
    tagline: 'Full-service China entry. Branding through to eCommerce.',
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    tagline: 'Chinese social media. WeChat, Douyin, RedNote, Weibo.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    tagline: 'Websites built for the Chinese web. Baidu, ICP, AI engines.',
    route: 'agencies/chinawebfoundry' as const,
  },
  {
    name: 'BeyondCompass',
    tagline: 'A private database of vetted China distributors, Tmall TPs, Douyin Partners.',
    route: 'agencies/beyondcompass' as const,
  },
  {
    name: 'BeyondBridge',
    tagline: 'The full pipeline for Chinese brands going overseas.',
    route: 'agencies/beyondbridge' as const,
  },
  {
    name: 'HubStudio',
    tagline: 'Image, video, and content production at scale.',
    route: 'agencies/hubstudio' as const,
  },
  {
    name: 'Nuvora Studio',
    tagline: 'LinkedIn-only B2B. Strategy, content, ads.',
    route: 'agencies/nuvora-studio' as const,
  },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <video
      class="hero-statement__video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
    </video>
    <div class="hero-statement__scrim" aria-hidden="true"></div>
    <div class="hero-statement__rail">
      <aside class="rail" aria-label="Seven agencies in the group">
        <header class="rail__head">
          <span class="rail__head-tag">Ecosystem</span>
          <span class="rail__head-count">Seven specialists</span>
        </header>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Lead agencies</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 0;">
              <a class="rail__link" href={pathFor('agencies/beyondbordergroup', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BBG%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBorderGroup</span>
                  <span class="rail__tagline">Full-service West to China</span>
                </span>
                <span class="rail__stripe rail__stripe--w" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 1;">
              <a class="rail__link" href={pathFor('agencies/beyondbridge', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBridge</span>
                  <span class="rail__tagline">Full-service China to West</span>
                </span>
                <span class="rail__stripe rail__stripe--e" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Specialists, both ways</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 2;">
              <a class="rail__link" href={pathFor('agencies/theredscroll', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/TheredScroll%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">TheRedScroll</span>
                  <span class="rail__tagline">Chinese social media</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 3;">
              <a class="rail__link" href={pathFor('agencies/chinawebfoundry', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Logo-ChinaWebFoundry-transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">ChinaWebFoundry</span>
                  <span class="rail__tagline">Built for Chinese web</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 4;">
              <a class="rail__link" href={pathFor('agencies/beyondcompass', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondCompass</span>
                  <span class="rail__tagline">Vetted China partners</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 5;">
              <a class="rail__link" href={pathFor('agencies/nuvora-studio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Nuvora%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">Nuvora Studio</span>
                  <span class="rail__tagline">LinkedIn B2B specialists</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Production</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 6;">
              <a class="rail__link" href={pathFor('agencies/hubstudio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/hubStudio%20(2).png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">HubStudio</span>
                  <span class="rail__tagline">Cuts across both</span>
                </span>
                <span class="rail__stripe rail__stripe--c" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>
      </aside>
    </div>
    <div class="container hero-statement__container">
      <div class="hero-statement__content">
        <span class="eyebrow">Ecosystem</span>
        <h1 class="hero-statement__title balance">We build and grow brands, products, and services across China and the West. Both ways.</h1>
        <p class="hero-statement__lead">
          Six specialist agencies. One thesis. The gap between China and the West is not a translation problem.
          It is a brand problem, a channel problem, an infrastructure problem, and a sales problem. And it runs
          in both directions.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={pathFor('agencies', locale)}>Find the right agency</a>
          <a class="btn btn--ghost" href={pathFor('contact', locale)}>Talk to us</a>
        </div>
        <p class="hero-statement__cite">Shanghai. Hong Kong. Paris. In-market reps in the US, UK, Germany, France.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Two flows. One page.</span>
        <h2 class="balance">Both directions now live on a single page.</h2>
        <p class="lead">
          Same spine of agencies behind both. Six typical openings on each side. Pick the side you are coming
          from, or read the whole bridge end to end.
        </p>
      </header>

      <div class="bridge-panel">
        <span class="bridge-panel__spine" aria-hidden="true">
          <span class="bridge-panel__spine-line"></span>
          <span class="bridge-panel__spine-mark">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 16h22" />
              <path d="M22 11l5 5-5 5" />
              <path d="M10 21l-5-5 5-5" />
            </svg>
          </span>
        </span>

        <a class="bridge-panel__side bridge-panel__side--inbound" href={`${pathFor('two-flows', locale)}#inbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">→</span>
            West to China · Inbound
          </span>
          <h3 class="bridge-panel__title">Bringing Western brands into China.</h3>
          <p class="bridge-panel__body">
            Brand, WeChat, RedNote, Douyin, Tmall, JD, Baidu, KOLs, distribution. From a single landing page
            to the full stack.
          </p>
          <span class="bridge-panel__by">BeyondBorderGroup · TheRedScroll · ChinaWebFoundry · BeyondCompass · HubStudio</span>
          <span class="bridge-panel__cta">
            Jump to inbound
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>

        <a class="bridge-panel__side bridge-panel__side--outbound" href={`${pathFor('two-flows', locale)}#outbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">←</span>
            China to the West · Outbound
          </span>
          <h3 class="bridge-panel__title">Taking Chinese brands overseas.</h3>
          <p class="bridge-panel__body">
            A brand for Western buyers, a real LinkedIn presence, a website built for Western eyes, SEO, GEO,
            Google Ads, and named sales reps in the right time zone.
          </p>
          <span class="bridge-panel__by">BeyondBridge · Nuvora Studio</span>
          <span class="bridge-panel__cta">
            Jump to outbound
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>
      </div>

      <div class="btn-row" style="margin-top: var(--space-6); justify-content: center;">
        <a class="btn btn--primary" href={pathFor('two-flows', locale)}>Open the full Two-flows page</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">The stack</span>
        <h2 class="balance">Seven specialists. One ecosystem.</h2>
        <p class="lead">
          Each agency stands alone. Pick the one you need. Most clients start with one, then pull in others
          as the project grows.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Open</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">The logic</span>
        <h2 class="balance">Two leads. Five specialists. One engine.</h2>
        <p class="lead">
          Two lead agencies, one per direction. Five specialists that plug into either direction.
          One production engine running across both.
        </p>
      </header>
      <div class="matrix-grid" role="table" aria-label="Agencies by direction and layer">
        <div class="matrix-grid__head" role="row">
          <div class="matrix-grid__corner" aria-hidden="true"></div>
          <div class="matrix-grid__direction matrix-grid__direction--west" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">→</span>
            <span class="matrix-grid__direction-label">West to China</span>
          </div>
          <div class="matrix-grid__direction matrix-grid__direction--east" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">←</span>
            <span class="matrix-grid__direction-label">China to the West</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Full-service</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Lead agency</span>
            <span class="matrix-cell__name">BeyondBorderGroup</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Lead agency</span>
            <span class="matrix-cell__name">BeyondBridge</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Social media</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Both ways</span>
            <span class="matrix-cell__name">TheRedScroll</span>
            <span class="matrix-cell__note">WeChat, Douyin, RedNote, Weibo. For Western or Chinese clients.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">LinkedIn B2B</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Both ways</span>
            <span class="matrix-cell__name">Nuvora Studio</span>
            <span class="matrix-cell__note">LinkedIn-only. For Western or Chinese clients.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Web infrastructure</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Both ways</span>
            <span class="matrix-cell__name">ChinaWebFoundry</span>
            <span class="matrix-cell__note">Baidu-ready, ICP, Chinese AI engines. For Western or Chinese clients.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Partner sourcing</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Both ways</span>
            <span class="matrix-cell__name">BeyondCompass</span>
            <span class="matrix-cell__note">Vetted China distributors, Tmall TPs, Douyin Partners.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--span" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Production</span>
          </div>
          <div class="matrix-cell matrix-cell--span" role="cell">
            <span class="matrix-cell__bridge" aria-hidden="true">
              <span class="matrix-cell__bridge-dot"></span>
              <span class="matrix-cell__bridge-line"></span>
              <span class="matrix-cell__bridge-dot"></span>
            </span>
            <span class="matrix-cell__name">HubStudio</span>
            <span class="matrix-cell__note">Content production engine. Runs across both directions.</span>
          </div>
        </div>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>How we work together</a>
      </div>
    </div>
  </section>

  <section class="section draws-from-section">
    <div class="draws-from-section__bg" aria-hidden="true">
      <span class="draws-from-section__blob draws-from-section__blob--blue"></span>
      <span class="draws-from-section__blob draws-from-section__blob--red"></span>
      <span class="draws-from-section__grid"></span>
    </div>
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What every agency draws from</span>
        <h2 class="balance">Specialists. <span class="text-gradient">Not silos.</span></h2>
        <p class="lead">
          Seven independent agencies on top. Three shared layers underneath, every one of them draws from all
          three. None billed twice.
        </p>
      </header>

      <div class="draws-from" data-draws-from>
        <ol class="draws-from__top" aria-label="Seven agencies in the group">
          <li class="draws-from__node" style="--i: 0;">
            <span class="draws-from__chip"><img src="/AgencyLogos/BBG%20PNG.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">BeyondBorderGroup</span>
          </li>
          <li class="draws-from__node" style="--i: 1;">
            <span class="draws-from__chip"><img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">BeyondBridge</span>
          </li>
          <li class="draws-from__node" style="--i: 2;">
            <span class="draws-from__chip"><img src="/AgencyLogos/TheredScroll%20PNG.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">TheRedScroll</span>
          </li>
          <li class="draws-from__node" style="--i: 3;">
            <span class="draws-from__chip"><img src="/AgencyLogos/Logo-ChinaWebFoundry-transparent.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">ChinaWebFoundry</span>
          </li>
          <li class="draws-from__node" style="--i: 4;">
            <span class="draws-from__chip"><img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">BeyondCompass</span>
          </li>
          <li class="draws-from__node" style="--i: 5;">
            <span class="draws-from__chip"><img src="/AgencyLogos/Nuvora%20PNG.png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">Nuvora Studio</span>
          </li>
          <li class="draws-from__node" style="--i: 6;">
            <span class="draws-from__chip"><img src="/AgencyLogos/hubStudio%20(2).png" alt="" loading="lazy" /></span>
            <span class="draws-from__node-name">HubStudio</span>
          </li>
        </ol>

        <div class="draws-from__bridge" aria-hidden="true">
          <svg viewBox="0 0 700 80" preserveAspectRatio="none">
            <defs>
              <linearGradient id="draws-grad" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0%" stop-color="rgba(38, 154, 218, 0.85)" />
                <stop offset="100%" stop-color="rgba(200, 16, 46, 0.0)" />
              </linearGradient>
            </defs>
            <path class="draws-from__line" style="--li: 0;" d="M 50 0 Q 50 38, 350 70" />
            <path class="draws-from__line" style="--li: 1;" d="M 150 0 Q 150 38, 350 70" />
            <path class="draws-from__line" style="--li: 2;" d="M 250 0 Q 250 38, 350 70" />
            <path class="draws-from__line" style="--li: 3;" d="M 350 0 L 350 70" />
            <path class="draws-from__line" style="--li: 4;" d="M 450 0 Q 450 38, 350 70" />
            <path class="draws-from__line" style="--li: 5;" d="M 550 0 Q 550 38, 350 70" />
            <path class="draws-from__line" style="--li: 6;" d="M 650 0 Q 650 38, 350 70" />
            <line class="draws-from__rail" x1="40" y1="76" x2="660" y2="76" />
            <circle class="draws-from__rail-pulse" r="3" cx="0" cy="76" />
          </svg>
        </div>

        <ol class="draws-from__layers">
          <li class="draws-from__layer draws-from__layer--engine" style="--i: 0;">
            <div class="draws-from__art">
              <svg viewBox="0 0 220 220" aria-hidden="true">
                <defs>
                  <radialGradient id="engine-core-grad" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#5fb6e0" stop-opacity="0.95" />
                    <stop offset="100%" stop-color="#1e7db0" stop-opacity="0.95" />
                  </radialGradient>
                </defs>
                <g class="engine-art">
                  <circle class="engine-ripple" cx="110" cy="110" r="44" />
                  <circle class="engine-ripple engine-ripple--2" cx="110" cy="110" r="44" />
                  <circle class="engine-ripple engine-ripple--3" cx="110" cy="110" r="44" />
                  <circle class="engine-glow" cx="110" cy="110" r="40" />
                  <circle class="engine-core" cx="110" cy="110" r="30" fill="url(#engine-core-grad)" />
                  <text x="110" y="115" font-size="10" font-weight="700" fill="white" text-anchor="middle" letter-spacing="1.2">HUB</text>

                  <g class="engine-token engine-token--image" style="--i: 0;">
                    <rect x="22" y="98" width="34" height="24" rx="4" fill="white" />
                    <circle cx="32" cy="108" r="2.5" fill="#5fb6e0" />
                    <polygon points="30,118 42,107 50,118" fill="#5fb6e0" />
                  </g>
                  <g class="engine-token engine-token--video" style="--i: 1;">
                    <rect x="164" y="98" width="34" height="24" rx="4" fill="white" />
                    <polygon points="174,103 188,110 174,117" fill="#c8102e" />
                  </g>
                  <g class="engine-token engine-token--text" style="--i: 2;">
                    <rect x="93" y="20" width="34" height="24" rx="4" fill="white" />
                    <line x1="98" y1="28" x2="122" y2="28" stroke="#1a1a1a" stroke-width="1.6" />
                    <line x1="98" y1="33" x2="118" y2="33" stroke="#1a1a1a" stroke-width="1.4" />
                    <line x1="98" y1="38" x2="120" y2="38" stroke="#1a1a1a" stroke-width="1.4" />
                  </g>
                  <g class="engine-token engine-token--design" style="--i: 3;">
                    <rect x="93" y="176" width="34" height="24" rx="4" fill="white" />
                    <circle cx="103" cy="188" r="3.5" fill="#c8102e" />
                    <circle cx="113" cy="188" r="3.5" fill="#5fb6e0" />
                    <circle cx="118" cy="195" r="2" fill="#1a1a1a" />
                  </g>
                </g>
              </svg>
            </div>
            <div class="draws-from__copy">
              <span class="draws-from__layer-tag">Layer · Engine</span>
              <h3 class="draws-from__layer-title">HubStudio. The content engine.</h3>
              <p class="draws-from__layer-body">
                AIGC image, video, copy, design, motion. Every brief that needs production runs through this layer.
                Cost stays competitive even at the volume Chinese channels demand: daily Douyin, weekly RedNote,
                monthly campaign refresh.
              </p>
              <ul class="draws-from__chips" role="list">
                <li>Image</li>
                <li>Video</li>
                <li>Copy</li>
                <li>Design</li>
                <li>Motion</li>
              </ul>
            </div>
          </li>

          <li class="draws-from__layer draws-from__layer--ops" style="--i: 1;">
            <div class="draws-from__art">
              <svg viewBox="0 0 220 220" aria-hidden="true">
                <g class="ops-art">
                  <circle class="ops-hub" cx="110" cy="110" r="22" fill="rgba(255,255,255,0.04)" stroke="rgba(95,182,224,0.7)" stroke-width="1.4" />
                  <text x="110" y="114" font-size="9" font-weight="700" fill="#5fb6e0" text-anchor="middle" letter-spacing="1.2">OPS</text>

                  <g class="ops-node ops-node--it" style="--i: 0;">
