---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'zh' as const;
const title = '这座桥';
const description = '中国与西方之间隔的那道沟，不是语言。是品牌、渠道、基础设施、搜索和销售。我们这家专业集团，就围着这件事搭起来。';

const gaps = [
  { title: '品牌', body: '一个市场里代表"靠谱"的信号，到另一个市场就成了"杂乱"。中国网站把信任凭据、认证、合作伙伴 logo、奖项铺在前面；西方网站只放一个清晰的动作和大片留白。两边互相看，都觉得对方"做错了"。' },
  { title: '渠道', body: '西方 B2B 买家先看 LinkedIn。中国消费者先打开小红书和微信。哪个渠道先用，跟你说什么内容一样重要。' },
  { title: '基础设施', body: 'Google 索引西方网站，百度索引中国网站。规则不同、机器不同、备案路径也不同。在境外托管，墙后加载又慢、插件又坏；在境内托管，又卡在没有 ICP 上。' },
  { title: '搜索', body: 'ChatGPT、Perplexity、Gemini 引用的是西方来源；DeepSeek、豆包、Kimi 引用的是中国来源。AI 已经成了买家路径上的第一站，而这一站早就被切成两半。' },
  { title: '销售', body: '柏林客户上午十点要联系一个柏林本地的人；上海客户晚上九点要在微信上找到一个能聊的人。等到深圳团队上班时，德国客户已经发消息给三个竞品了。' },
];
---

<Layout locale={locale} route="bridge" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">这座桥</span>
      <h1 class="hero-editorial__title balance">
        这座连接中国与西方的桥，由两岸都干过活儿的人来搭。
      </h1>
      <p class="hero-editorial__lead">
        在中国二十年，给西方买家做生意也是二十年。我们既坐过那种屋子——西方 CEO 问，为什么中国市场怎么也起不来；也坐过那种屋子——中国厂家老板问，为什么柏林那边的线索一直不来。同一个问题，两面镜子。
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">那道沟</span>
        <h2 class="balance">那道沟不是语言，是底下五件事。</h2>
        <p class="lead">
          一个在上海响亮的名字，到法兰克福可能落地无声；一个在中国代表"高端"的 logo，到芝加哥可能传成另一个品类；一句翻译过来的 tagline，两个方向读起来都怪。
        </p>
      </header>
      <div class="grid-2">
        {gaps.map((g) => (
          <article class="card">
            <h3 class="card__title">{g.title}</h3>
            <p>{g.body}</p>
          </article>
        ))}
      </div>
      <p class="lead" style="margin-top: var(--space-7);">
        每一岸都有自己的基础设施。每一岸都需要自己的专业团队。集团就是围绕这件事搭起来的。
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="编辑风对页。东与西，互成镜像。" />
        <div class="prose">
          <span class="eyebrow">为什么是一个集团，而不是一家通才</span>
          <h2 class="balance">大多数公司只解决一块。我们把整条链跑下来，再分块交付。</h2>
          <p>
            说自己"两边都做"的通才公司，结果往往两边都做不好。在西方开了办公室的中国专家，慕尼黑没有母语销售；在上海开了办公室的西方专家，没有真正能跑的微信广告户。组织架构上写着"有"，执行端写着"没有"。
          </p>
          <p>
            客户不一定每次都要全套。有时只需要一个中文网站；有时只需要一台 LinkedIn 引擎。把这些当作单件向专业公司买，比塞进通才公司的合约里更便宜，也更早能跑。
          </p>
          <p>
            而专业公司聚成一组，比单兵作战更强。同一台 AIGC 生产引擎，既能做中文小红书帖，也能做德文 Google Ads 着陆页。同一套内容逻辑——从买家出发，落到行动——两个方向都用得上。共享一根脊柱的专家，胜过各自为战的专家。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">工作的形状</span>
        <h2 class="balance">同一种形状，左右互为镜像。</h2>
        <p class="lead">
          无论 brief 是"进入中国"还是"走出去"，工作拆下来都长一样。
        </p>
      </header>
      <ol class="numbered">
        <li>
          <div>
            <p class="numbered__title">为目的市场重做品牌策略。</p>
            <p>不是翻译，是重建。</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">在买家真正使用的渠道上，按原生格式出现。</p>
            <p>这边是微信、抖音、小红书；那边是 LinkedIn。原生，而不是临时改造。</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">让目的地的算法能找到的网站和搜索基础设施。</p>
            <p>这边是百度、ICP、中国 AI；那边是 Google 与西方 AI。</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">跟得上现代渠道节奏的内容产能。</p>
            <p>由 HubStudio 的 AIGC 层供给，两个方向共用。</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">一支会接电话的团队，用对的语言、在对的时区。</p>
            <p>上海、香港、巴黎的运营团队，加上美国、英国、德国、法国的具名现场代表。</p>
          </div>
        </li>
      </ol>
      <div style="margin-top: var(--space-7);">
        <a class="btn btn--primary" href={pathFor('how-we-work-together', locale)}>查看两条流向</a>
      </div>
    </div>
  </section>
</Layout>
