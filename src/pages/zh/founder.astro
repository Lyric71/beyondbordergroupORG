---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'zh' as const;
const title = '创始人';
const description = 'BeyondBorderGroup、HubStudio 与 Nuvora Studio 的创始人。在中国与西方之间这座桥的两岸，做了二十五年的数字和电商。';
---

<Layout locale={locale} route="founder" title={title} description={description}>
  <section class="hero-editorial hero-editorial--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">创始人</span>
          <h1 class="hero-editorial__title balance">一个真正的操盘手，两岸都跑了二十年。</h1>
          <p class="hero-editorial__lead">
            BeyondBorderGroup 由 Cyril Drouin 创立并领导。集团之所以存在，是因为他用了二十五年时间，在中国与西方之间这座桥的两岸搭建品牌；他亲眼看到同一类企业，在两个方向上撞到同样的墙。集团里的每一家公司，都是他至少为某个客户亲手做过一遍的事情，最后被沉淀成一个标准化版本。
          </p>
        </div>
        <ImagePlaceholder ratio="4x5" label="创始人编辑风肖像。" dark />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">为什么有这个集团</span>
      <h2 class="balance">两种屋子，二十年。</h2>
      <p>这套方法论不是空想。它来自二十年里坐过的两种屋子。</p>
      <p>
        第一种屋子：一位巴黎的西方 CMO 问，为什么六个月过去了、网站翻译过来了，中国市场还是没有转化。
      </p>
      <p>
        第二种屋子：一位深圳的中国厂家老板问，日内瓦展会都开完了，为什么柏林那边的线索还是不来。
      </p>
      <p>
        同一个问题，两面镜子。基础设施完全不一样。但两种情形里，那道沟从来不是语言。是品牌、是渠道、是网站、是内容、是"谁来接电话"。
      </p>
      <p>
        他建 BeyondBorderGroup 的初衷，就是把整条链路在两岸都跑通——靠的是真正住在目的市场里的专家团队。
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">背景</span>
        <h2 class="balance">二十五年数字、传播与电商。</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <h3 class="card__title">语言与教育</h3>
          <p>计算机与数学硕士。法语母语，英语流利，中文工作级。</p>
        </article>
        <article class="card">
          <h3 class="card__title">阳狮北亚</h3>
          <p>
            前阳狮北亚首席数字与电商官，主管 Google、Amazon、Instagram、Facebook、Tmall、京东、微信以及中国其他平台上的整套业务。
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">独立公司</h3>
          <p>
            自创公司，业务横跨欧洲与北亚。聚焦数字化转型、电商技术（Adobe、Salesforce 与主流开源平台的 Gold Partner）以及在主要平台和广告交易市场上的媒介策划与采买。
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">HubStudio 与 Nuvora Studio</h3>
          <p>
            HubStudio 的创始人——这家 AI 原生的内容工作室，是集团里所有公司共用的生产引擎。Nuvora Studio 的创始人——只做 LinkedIn 的 B2B 公司，为 BeyondBridge 内的 LinkedIn 模块提供动力。
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div class="prose">
          <span class="eyebrow">合作过的品牌</span>
          <h2 class="balance">二十年间，他在两岸合作过的品牌。</h2>
          <p>
            Apple、GSK、雅诗兰黛、百加得、拜耳、赛诺菲、欧莱雅、达能、联想、拜尔斯道夫、Nike、费列罗、高露洁、喜力、雀巢、贝亲、西门子、开云。
          </p>
          <p class="muted">
            刻意混搭的一份名单：他带进中国的西方品牌、他在区域内做大的亚洲品牌、他同时在两岸操盘的全球品牌。
          </p>
        </div>
        <div class="prose">
          <span class="eyebrow">行业身份与资格</span>
          <h2 class="balance">他的名字还出现在这些地方。</h2>
          <ul>
            <li>Google Ads、Google Analytics、Amazon Advertising、LinkedIn 认证讲师。</li>
            <li>Adfest 与 DMAA International Digital Marketing Awards 评审。</li>
            <li>欧盟在华商会传播与营销论坛主席，任期七年。</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="阶梯教室：Cyril 在 Executive MBA 上课。" />
        <div class="prose">
          <span class="eyebrow">教学</span>
          <h2 class="balance">超过十年的数字与电商教学。</h2>
          <p>面向 Executive MBA 学员，授课于：</p>
          <ul>
            <li>巴黎 HEC。</li>
            <li>巴黎与新加坡 ESSEC。</li>
            <li>巴黎 ESMOD。</li>
            <li>上海交通大学。</li>
          </ul>
          <p>
            常驻数字与电商主题的全球 keynote 演讲者。BeyondBorderGroup 内部的培训项目、masterclass、高管 workshop 与中国学习考察，都是从这套教学实践里直接长出来的。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">为什么这件事对客户重要</span>
      <h2 class="balance">仍在亲自跑业务的操盘手。</h2>
      <p>
        大多数公司的创始人，要么是操盘手，要么是销售。Cyril 是仍在亲自跑业务的那种。他坐在集团各家公司的策略会议上，他写了团队今天在执行的 playbook。客户问"这事以前做过吗？"，答案多半是"做过——给 Apple、给雅诗兰黛、给喜力，或者给一家大多数人还没听说过的中国品牌。"
      </p>
      <p>
        这种连续性，正是关键。集团不是七家共用一个 logo 的独立供应商，而是七支共享一套方法论、共享一个领导团队、共享同一种执行标准的专业团队。这个标准，由一个在中国与西方之间双向跑了二十五年的人定下来。
      </p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">联系。</h2>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>预约与 Cyril 通话</a>
        <a class="btn btn--ghost-light" href="https://www.linkedin.com/in/cyril-d-68835729" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>
