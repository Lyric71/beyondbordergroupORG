---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'zh' as const;
const title = '创始人';
const description = 'BeyondBorderGroup、HubStudio 与 Nuvora Studio 的创始人。二十五年数字与电商经验，覆盖中国与西方两边。';
---

<Layout locale={locale} route="founder" title={title} description={description}>
  <section class="hero-editorial hero-editorial--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">创始人</span>
          <h1 class="hero-editorial__title balance">一个操盘手。两个方向，二十年。</h1>
          <p class="hero-editorial__lead">
            BeyondBorderGroup 由 Cyril Drouin 创立并领导。集团之所以存在，是因为他用了二十五年时间，在中国与西方两边搭建品牌，看着同一类企业在两个方向撞上同一面墙。生态里的每一家公司，都是他至少为某个客户亲手做过一次的事的"标准化版本"。
          </p>
        </div>
        <ImagePlaceholder ratio="4x5" label="创始人编辑风肖像。" dark />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">为什么有这个集团</span>
      <h2 class="balance">两种屋子，二十年。</h2>
      <p>这套逻辑不是空想。是在两种屋子里坐了二十年得出来的。</p>
      <p>
        第一种屋子：巴黎一位 CMO，问为什么六个月过去了，那个翻译版网站没在中国转化。
      </p>
      <p>
        第二种屋子：深圳一位工厂老板，问为什么日内瓦展会之后，柏林那边的 lead 没来。
      </p>
      <p>
        同一道题。两个镜像。基建不一样。两种情形里，鸿沟从来都不是语言。是品牌、渠道、网站、内容，以及谁来接电话。
      </p>
      <p>
        他建 BeyondBorderGroup，是为了在两边都把整条链跑下来，由真正住在目标市场里的专家团队执行。
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">背景</span>
        <h2 class="balance">二十五年数字、传播与电商经验。</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <h3 class="card__title">语言与教育</h3>
          <p>IT 与数学硕士。法语母语。英语流利。中文工作级。</p>
        </article>
        <article class="card">
          <h3 class="card__title">阳狮北亚</h3>
          <p>
            前阳狮北亚首席数字与电商官。在 Google、Amazon、Instagram、Facebook、Tmall、京东、微信以及中国其他平台上统筹整套业务。
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">独立公司</h3>
          <p>
            在欧洲与北亚自创公司。聚焦数字化转型、电商技术（与 Adobe、Salesforce 与主流开源平台的金牌合作伙伴）以及主要平台和广告交易市场的媒介策划与采买。
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">HubStudio 与 Nuvora Studio</h3>
          <p>
            HubStudio 的创始人——为生态里每一家公司提供生产引擎的 AI 原生内容工作室。Nuvora Studio 的创始人——为 BeyondBridge 内的 LinkedIn 模块提供动力的"只做 LinkedIn"B2B 公司。
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div class="prose">
          <span class="eyebrow">合作过的品牌</span>
          <h2 class="balance">二十年间，他在两边搭建过的品牌。</h2>
          <p>
            Apple。GSK。雅诗兰黛。百加得。拜耳。赛诺菲。欧莱雅。达能。联想。拜尔斯道夫。Nike。费列罗。高露洁。喜力。雀巢。贝亲。西门子。开云。
          </p>
          <p class="muted">
            故意混搭的名单。带进中国的西方品牌。在区域内做大的亚洲品牌。两边同时跑的全球品牌。
          </p>
        </div>
        <div class="prose">
          <span class="eyebrow">行业角色与认证</span>
          <h2 class="balance">他的名字还出现在哪里。</h2>
          <ul>
            <li>Google Ads、Google Analytics、Amazon Advertising、LinkedIn 认证讲师。</li>
            <li>Adfest 与 DMAA International Digital Marketing Awards 评审。</li>
            <li>欧盟在华商会传播与营销论坛主席，七年。</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="阶梯教室。Cyril 在 Executive MBA 上课。" />
        <div class="prose">
          <span class="eyebrow">教学</span>
          <h2 class="balance">超过十年的数字与电商教学。</h2>
          <p>面向 Executive MBA 学员，授课于：</p>
          <ul>
            <li>巴黎 HEC。</li>
            <li>巴黎与新加坡 ESSEC。</li>
            <li>巴黎 ESMOD。</li>
            <li>上海交通大学。</li>
          </ul>
          <p>
            常驻数字与电商主题的全球 keynote 演讲者。BeyondBorderGroup 内部的培训项目、masterclass、高管 workshop、以及中国学习考察，都是从这套教学实践里直接生出来的。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">这件事对客户为什么重要</span>
      <h2 class="balance">仍然亲自跑业务的操盘手。</h2>
      <p>
        大多数公司创始人要么是操盘手要么是销售。Cyril 是仍然亲自跑业务的那种。他坐在集团里每家公司的策略会议上。他写了团队现在执行的 playbook。当客户问"这件事以前做过吗？"，答案多半是"做过。给 Apple 做过。或者给雅诗兰黛、给喜力、或者给一家大多数人还没听说过的中国品牌。"
      </p>
      <p>
        这种连续性正是要点。集团不是七家共用一个 logo 的独立供应商。它是七支共享一套逻辑、一支领导团队和一套执行标准的专家团队。这套标准来自一个在中国与西方之间，两个方向都做了二十五年的人。
      </p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">连接。</h2>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>预约与 Cyril 通话</a>
        <a class="btn btn--ghost-light" href="https://www.linkedin.com/in/cyril-d-68835729" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>
