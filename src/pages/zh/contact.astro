---
import Layout from '../../layouts/Layout.astro';

const locale = 'zh' as const;
const title = '联系';
const description = '三十分钟一通电话。我们告诉你应该从哪一家入手，或者要不要几家同时开跑。直接答案，没有 pitch deck。';
---

<Layout locale={locale} route="contact" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">联系</span>
      <h1 class="hero-editorial__title balance">告诉我们，你正在往哪边走。</h1>
      <p class="hero-editorial__lead">
        三十分钟一通电话。我们告诉你应该从集团里的哪一家入手，或者要不要几家同时开跑。不发 deck，不做 pitch，直接答案。
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <form id="contact-form" class="form" method="post" action="/api/contact" novalidate>
          <input type="hidden" name="locale" value="zh" />

          <div class="form-step">
            <span class="form-step__heading">第 1 步</span>
            <h2 class="form-step__title">你正在往哪边走？</h2>
            <div class="choice-list">
              <label class="choice"><input type="radio" name="direction" value="inbound" /> <span>我想进入或在中国扩规模。<span class="muted">（西方进入中国）</span></span></label>
              <label class="choice"><input type="radio" name="direction" value="outbound" /> <span>我想把中国品牌做到海外。<span class="muted">（中国走向西方）</span></span></label>
              <label class="choice"><input type="radio" name="direction" value="content" /> <span>我只要内容生产。<span class="muted">（HubStudio）</span></span></label>
              <label class="choice"><input type="radio" name="direction" value="linkedin" /> <span>我只要把 LinkedIn 跑好。<span class="muted">（Nuvora Studio）</span></span></label>
              <label class="choice"><input type="radio" name="direction" value="unsure" /> <span>还没想好。</span></label>
            </div>
          </div>

          <div class="form-step">
            <span class="form-step__heading">第 2 步</span>
            <h2 class="form-step__title">你目前到哪一步了？</h2>
            <div class="choice-list">
              <label class="choice"><input type="radio" name="stage" value="exploring" /> <span>还在摸索，处于早期阶段。</span></label>
              <label class="choice"><input type="radio" name="stage" value="planning" /> <span>规划中，准备一到三个月内启动。</span></label>
              <label class="choice"><input type="radio" name="stage" value="launching" /> <span>正在启动，需要 30 天内开始。</span></label>
              <label class="choice"><input type="radio" name="stage" value="operating" /> <span>已经在跑，需要修正或扩规模。</span></label>
            </div>
          </div>

          <div class="form-step">
            <span class="form-step__heading">第 3 步</span>
            <h2 class="form-step__title">关于贵司。</h2>
            <div class="form-row">
              <div class="form-field">
                <label for="company">公司</label>
                <input id="company" name="company" type="text" />
              </div>
              <div class="form-field">
                <label for="role">您的职位</label>
                <input id="role" name="role" type="text" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="industry">行业</label>
                <input id="industry" name="industry" type="text" />
              </div>
              <div class="form-field">
                <label for="hq">总部所在国</label>
                <input id="hq" name="hq" type="text" />
              </div>
            </div>
            <div class="form-field">
              <label for="website">网址</label>
              <input id="website" name="website" type="url" placeholder="https://" />
            </div>
          </div>

          <div class="form-step">
            <span class="form-step__heading">第 4 步</span>
            <h2 class="form-step__title">brief。</h2>
            <div class="form-field">
              <label for="brief">几句话就够。</label>
              <textarea id="brief" name="brief" rows="5"></textarea>
            </div>
          </div>

          <div class="form-step">
            <span class="form-step__heading">第 5 步</span>
            <h2 class="form-step__title">如何联系您。</h2>
            <div class="form-row">
              <div class="form-field">
                <label for="name">姓名</label>
                <input id="name" name="name" type="text" required />
              </div>
              <div class="form-field">
                <label for="email">邮箱</label>
                <input id="email" name="email" type="email" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-field">
                <label for="phone">电话（可选）</label>
                <input id="phone" name="phone" type="tel" />
              </div>
              <div class="form-field">
                <label for="tz">您方便的时区</label>
                <input id="tz" name="tz" type="text" placeholder="例如 CST、CET、PT" />
              </div>
            </div>
            <div class="form-field">
              <label for="lang">通话语言</label>
              <select id="lang" name="lang">
                <option value="zh">中文</option>
                <option value="en">English</option>
                <option value="fr">Français</option>
                <option value="es">Español</option>
                <option value="de">Deutsch</option>
              </select>
            </div>
          </div>

          <p id="contact-status" class="form-status" role="status" aria-live="polite" hidden></p>

          <div class="btn-row" style="justify-content: flex-end;">
            <button id="contact-submit" class="btn btn--primary" type="submit">发送</button>
          </div>
        </form>

        <aside class="prose">
          <span class="eyebrow">或者直接联系某家公司</span>
          <h3>如果你已经知道要找哪一家。</h3>
          <ul>
            <li>BeyondBorderGroup。<a href="https://beyondbordergroup.com/contact" target="_blank" rel="noreferrer">beyondbordergroup.com/contact</a></li>
            <li>TheRedScroll。<a href="https://theredscroll.com/contact" target="_blank" rel="noreferrer">theredscroll.com/contact</a></li>
            <li>ChinaWebFoundry。<a href="https://chinawebfoundry.com/contact" target="_blank" rel="noreferrer">chinawebfoundry.com/contact</a></li>
            <li>BeyondBridge。<a href="https://beyondbridge.com/contact" target="_blank" rel="noreferrer">beyondbridge.com/contact</a></li>
            <li>HubStudio。<a href="https://hubstudio.ai/contact" target="_blank" rel="noreferrer">hubstudio.ai/contact</a></li>
            <li>Nuvora Studio。<a href="https://nuvora.studio/contact" target="_blank" rel="noreferrer">nuvora.studio/contact</a></li>
          </ul>

          <h3 style="margin-top: var(--space-6);">办公室</h3>
          <p>上海（集团总部）、香港、巴黎、杭州。</p>
          <p>
            BeyondBridge 在当地的具名销售代表：Jenny 在美国，Scott 在英国，Eike 在德国，Stéphane 在法国。
          </p>
          <p class="muted">我们在 24 小时内回复，按你的时区。</p>
        </aside>
      </div>
    </div>
  </section>
</Layout>
