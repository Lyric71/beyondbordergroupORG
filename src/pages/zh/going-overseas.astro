---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'zh' as const;
const title = '走向海外';
const description = '中国品牌出海的整条链路。品牌、LinkedIn、网站、SEO、Google Ads，再加上美国、英国、德国、法国的具名销售代表。';

const requirements = [
  { h: '一个西方买家一眼就认得出来的品牌', body: '不是从中文翻过去的版本。名字立得住、tagline 不别扭、视觉系统在法兰克福和芝加哥都不需要解释。' },
  { h: 'LinkedIn 上真的有内容', body: '西方 B2B 买家在打电话之前先翻 LinkedIn。页面是空的，电话就不会响。LinkedIn 自家研究：82% 的买家说，看到高管在 LinkedIn 上发内容，会更信任这家公司。空账号，等于丢单。' },
  { h: '一份按西方眼光做的网站', body: '干净、留白、每页只有一个明确动作。在中国境外托管。打开要快——三秒钟，超过一半访客就走了。' },
  { h: '在西方搜索引擎里被看到', body: 'Google 排名，加上在 ChatGPT、Perplexity、Gemini 里被引用。大多数中国公司出海时几乎没有"权威值"：没有外链、没有英文内容、没有 AI 引用。竞争对手早就把排名和答案拿走了。' },
  { h: '搜索结果第一页', body: 'Google Ads 在前面跑，让 SEO 在后面慢慢累积。Landing page 用西方版本，不要做翻译稿。很多中国公司把广告预算烧在过宽的关键词、错的地区，以及为中国市场写的着陆页上。' },
  { h: '在对的时区接电话的销售', body: '德国买家上午十点发询盘，深圳还在睡觉。等天一亮，那位买家已经发给三个竞品了。在西方市场，谁先回复，谁就接得到下一步。' },
];

const services = [
  { n: '01', h: '品牌策略', body: '为西方买家而建，不是翻译。' },
  { n: '02', h: 'LinkedIn', body: '西方 B2B 第一站。由集团里的 LinkedIn 专家 Nuvora Studio 操盘。' },
  { n: '03', h: '网站', body: '按西方眼光来。在中国境外托管。' },
  { n: '04', h: 'SEO 与 GEO', body: '冲 Google 排名，被西方 AI 引用。' },
  { n: '05', h: 'Google Ads', body: '上线第一天，就上第一页。' },
  { n: '06', h: '外置销售队伍', body: '美国、英国、德国、法国的具名母语销售代表。' },
];
---

<Layout locale={locale} route="going-overseas" title={title} description={description}>
  <section class="hero-editorial hero-editorial--dark">
    <div class="container">
      <span class="eyebrow eyebrow--on-dark">流向 2 · 出境 · 中国走向西方</span>
      <h1 class="hero-editorial__title balance">
        产品好。价格好。工厂好。海外没人接住。
      </h1>
      <p class="hero-editorial__lead">
        每一家出海的中国公司，都撞上同一面墙。品牌是给中国买家做的；网站在西方眼里嫌挤；LinkedIn 一片空；柏林上午十点发来的询盘，没人回。这条桥的另一岸，我们做了二十年。
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">真正需要的东西</span>
        <h2 class="balance">在海外落地，靠的是这些。</h2>
      </header>
      <div class="grid-2">
        {requirements.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">一家公司，六项服务</span>
        <h2 class="balance">BeyondBridge：完整链路。</h2>
        <p class="lead">
          专门为出海的中国品牌而建。六项服务，叠成三个套餐。
        </p>
      </header>
      <ol class="numbered">
        {services.map((s) => (
          <li>
            <div>
              <p class="numbered__title">{s.h}</p>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">三个套餐</span>
        <h2 class="balance">先选一个套餐，需要时再叠下一层。</h2>
      </header>
      <div class="grid-3">
        <article class="card">
          <span class="card__index">Starter · 存在感</span>
          <h3 class="card__title">品牌 + LinkedIn + 网站</h3>
          <p>在西方买家面前看着可信的最低线。给第一次出海的公司用。</p>
        </article>
        <article class="card">
          <span class="card__index">Growth · 能见度</span>
          <h3 class="card__title">Starter + SEO/GEO + Google Ads</h3>
          <p>有存在感，也有流量。买家在 Google、ChatGPT 和付费搜索里都能找到你。</p>
        </article>
        <article class="card">
          <span class="card__index">Full Pipeline · 收入</span>
          <h3 class="card__title">Growth + 外置销售队伍</h3>
          <p>每一条 inbound lead 都被筛选、跟进，并以"可签状态"交到你团队手里。</p>
        </article>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--primary" href={pathFor('agencies/beyondbridge', locale)}>访问 BeyondBridge</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">客户通常怎么开始</span>
        <h2 class="balance">四种最常见的入口。</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>"三个月后我们要在德国参展，可线上没有任何看着可信的东西。"</blockquote>
          <p><strong>Starter 套餐。</strong>九十天交付品牌、LinkedIn 和一个面向西方的网站。</p>
        </article>
        <article class="card">
          <blockquote>"我们已经有存在感，但 inbound 是零。"</blockquote>
          <p><strong>Growth 套餐。</strong>在 Starter 基础上叠 SEO、GEO 和 Ads。</p>
        </article>
        <article class="card">
          <blockquote>"我们有 lead，但欧洲没人接。"</blockquote>
          <p><strong>Full Pipeline。</strong>把现场销售队伍接上去。</p>
        </article>
        <article class="card">
          <blockquote>"我们也不知道从哪里开始。"</blockquote>
          <p>三十分钟一通电话，我们告诉你应该走哪个套餐，以及九十天具体长什么样。<a href={pathFor('contact', locale)}>预约通话</a>。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow">
      <span class="eyebrow eyebrow--on-dark">等待的代价</span>
      <h2 class="balance">排名会复利。关系会复利。权威值也会复利。</h2>
      <p class="lead">
        每多一个月没有西方端的存在感，就有一笔生意被先到的竞品拿走。每多一个季度没有 pipeline，就有预算烧在展会、翻译和打不到水花的 cold outreach 上。等得越久，追赶成本翻得越快。今天在海外赢的中国公司，两年前就开始动了。
      </p>
      <div class="btn-row" style="margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>预约通话</a>
        <a class="btn btn--ghost-light" href={pathFor('agencies/beyondbridge', locale)}>访问 BeyondBridge</a>
      </div>
    </div>
  </section>
</Layout>
