---
import Layout from '../../../layouts/Layout.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'zh' as const;
const route = 'agencies/beyondbridge' as const;

type LaneKey = 'build' | 'demand' | 'close';
const lanes: Array<{
  key: LaneKey;
  title: string;
  intro: string;
  image: string;
  items: { name: string; body: string }[];
}> = [
  {
    key: 'build',
    title: '搭建',
    intro: '一个西方买家会信的品牌，一份读起来不像翻译的网站。',
    image: '/images/bb-bridge-build.webp',
    items: [
      { name: '咨询', body: '在大决策上给资深咨询。市场选择、定位、定价、上或不上。也可以单独买：只要思路、不要执行的客户。' },
      { name: '面向海外的品牌策略', body: '按你进入的市场来做，不是从中国品牌里改一改。' },
      { name: '网站', body: 'UX 和 UI 按西方眼光来，不是按中国眼光。托管在墙外。在汉堡和休斯顿都能秒开。' },
    ],
  },
  {
    key: 'demand',
    title: '引流',
    intro: '让你出现在那些已经在找的买家面前的渠道。',
    image: '/images/bb-bridge-demand.webp',
    items: [
      { name: 'LinkedIn', body: '西方 B2B 买家就在那儿。创始人主页、公司主页、内容和触达。' },
      { name: 'SEO 与 GEO', body: '在 Google 上被找到，在 ChatGPT、Perplexity 和 Claude 里被引用。按用英文、德文、法文搜索的买家来做。' },
      { name: 'Google Ads', body: '付费搜索先把合格线索带进来，让 SEO 慢慢堆复利。报告用人民币。' },
    ],
  },
  {
    key: 'close',
    title: '成交',
    intro: '七个市场都有真人。他们接第一通电话。订单值得一张机票时，他们亲自飞过去握手。',
    image: '/images/bb-bridge-sell.webp',
    items: [
      { name: '外部销售团队', body: '法国、德国、意大利、英国、美国、澳大利亚、拉美的母语代表。你的团队，在他们的市场里，按你的合约。' },
    ],
  },
];

const visitUrl = 'https://beyondbridge.com';
const visitLabel = '访问 beyondbridge.com';
---

<Layout
  locale={locale}
  route={route}
  title="BeyondBridge。我们把中国企业带到海外，做起来。"
  description="我们帮中国企业找到西方买家。品牌、网站、LinkedIn、广告，以及在七个国家里真人做销售。一套阵列。一条链路。"
>
  <!-- ====================================================================== -->
  <!-- HERO                                                                   -->
  <!-- ====================================================================== -->
  <section class="bb-hero" data-hero>
    <div class="bb-hero__bg" aria-hidden="true">
      <img src="/images/bb-bridge-hero-bg.webp" alt="" class="bb-hero__bg-img" data-parallax-bg />
      <div class="bb-hero__bg-scrim"></div>
      <div class="bb-hero__bg-grain"></div>
      <div class="bb-hero__bg-grid"></div>
    </div>

    <div class="container bb-hero__main">
      <div class="bb-hero__content">
        <img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="BeyondBridge" class="bb-hero__logo" width="240" height="48" loading="eager" decoding="async" />

        <h1 class="bb-hero__title">
          <span class="bb-hero__line" data-anim="word">我们把</span>
          <span class="bb-hero__line" data-anim="word">
            <em class="bb-hero__phrase">中国企业</em>
          </span>
          <span class="bb-hero__line" data-anim="word">带到海外，做起来。</span>
        </h1>

        <p class="bb-hero__lead" data-anim="fade">多数中国企业出海，要先丢掉两年，才肯承认旧打法已经失效。我们把好产品和买家之间的距离合上。</p>

        <div class="bb-hero__cta-row" data-anim="fade">
          <a class="bb-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-magnet>
            <span class="bb-magnet__bg"></span>
            <span class="bb-magnet__label">{visitLabel}</span>
            <span class="bb-magnet__arrow" aria-hidden="true">→</span>
          </a>
          <a class="bb-hero__secondary" href={pathFor('contact', locale)} data-anim="fade">
            <span>预约通话</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="bb-hero__feature" data-tilt>
        <div class="bb-hero__feature-frame">
          <img src="/images/bb-bridge-hero-feature.webp" alt="一位中国高管，黄昏时分走出慕尼黑的办公楼" class="bb-hero__feature-img" width="1408" height="832" loading="eager" decoding="async" />
          <div class="bb-hero__feature-scrim"></div>

          <div class="bb-hero__chip bb-hero__chip--stack">
            <span class="bb-hero__chip-label">阵列</span>
            <span>品牌 · 网站 · LinkedIn · SEO · 广告 · 销售</span>
          </div>
          <div class="bb-hero__chip bb-hero__chip--cities">
            <span class="bb-hero__chip-label">在地</span>
            <span>巴黎 · 慕尼黑 · 米兰 · 伦敦 · 纽约 · 悉尼 · 圣保罗</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#track" class="bb-hero__scroll" aria-label="向下滚动">
      <span>向下</span>
      <span class="bb-hero__scroll-line"></span>
    </a>
  </section>

  <!-- ====================================================================== -->
  <!-- TRACK RECORD                                                           -->
  <!-- ====================================================================== -->
  <section class="bb-track" id="track">
    <div class="container">
      <div class="bb-track__grid">
        <div class="bb-track__numeral" aria-hidden="true">
          <span class="bb-track__num" data-count="7">0</span>
          <span class="bb-track__num-shadow">7</span>
        </div>
        <div class="bb-track__copy">
          <span class="eyebrow">这些年做过的事</span>
          <h2 class="bb-track__title balance">七个城市。一支团队。从你的工厂，跑到你签下第一单。</h2>
          <p class="bb-track__lead">
            我们不是写完一份 PPT 就走人的咨询。我们是亲自动手的操盘手。我们的 CEO 在中国带了好几年阳狮电商。我们建品牌、建网站、做 LinkedIn、做搜索、做广告。然后把真人放到当地，接电话。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- THE GAP — editorial dark statement                                     -->
  <!-- ====================================================================== -->
  <section class="bb-gap">
    <div class="bb-gap__bg" aria-hidden="true"></div>
    <div class="container bb-gap__container">
      <span class="eyebrow eyebrow--on-dark">那道沟</span>
      <h2 class="bb-gap__title">
        <span class="bb-gap__line" data-line>把首页翻译过来。</span>
        <span class="bb-gap__line" data-line>在法兰克福招一个人。</span>
        <span class="bb-gap__line" data-line>每年派创始人出去两次。</span>
        <span class="bb-gap__line" data-line>等着分销商打电话来。</span>
      </h2>
      <div class="bb-gap__statement" data-line>
        <p>电话很少打来。</p>
        <p>网站看上去像 2014 年。招来的人六个月内辞职。工厂还在做好产品，但对的买家从没听说过。</p>
        <p class="bb-gap__emphasis">公司就死在这里。死在好产品和汉堡或休斯顿那个真会接电话的买家之间，那道沟里。</p>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- SERVICES                                                               -->
  <!-- ====================================================================== -->
  <section class="bb-services" id="services">
    <div class="container">
      <header class="bb-services__header">
        <span class="eyebrow">我们做什么</span>
        <h2 class="bb-services__title">
          七个模块。<em>一条链路。</em><br />
          整套来，或者单独买一块。
        </h2>
        <p class="bb-services__lead">按季度收费，带一次启动期。挑一条最贴合你当下的，或者三条一起跑。</p>
      </header>

      <div class="bb-services__shell" data-tabs>
        <div class="bb-services__nav" role="tablist" aria-label="服务线">
          {lanes.map((s, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`bb-services__tab bb-services__tab--${s.key} ${i === 0 ? 'is-active' : ''}`}
              data-tab={s.key}
              id={`bb-tab-${s.key}`}
              aria-controls={`bb-panel-${s.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="bb-services__tab-pip" aria-hidden="true"></span>
              <span class="bb-services__tab-label">{s.title}</span>
              <span class="bb-services__tab-count">{s.items.length} 项服务</span>
            </button>
          ))}
          <span class="bb-services__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="bb-services__panels">
          {lanes.map((s, i) => (
            <div
              class={`bb-services__panel bb-services__panel--${s.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`bb-panel-${s.key}`}
              aria-labelledby={`bb-tab-${s.key}`}
              data-panel={s.key}
              hidden={i !== 0}
            >
              <div class="bb-services__panel-grid">
                <div class="bb-services__panel-image">
                  <div class="bb-services__panel-frame">
                    <img src={s.image} alt={`${s.title} 编辑图`} loading="lazy" decoding="async" />
                    <div class={`bb-services__panel-tag bb-services__panel-tag--${s.key}`}>
                      <span>{s.title}</span>
                    </div>
                  </div>
                  <div class={`bb-services__panel-stamp bb-services__panel-stamp--${s.key}`} aria-hidden="true">
                    {s.key === 'build' && '立'}
                    {s.key === 'demand' && '引'}
                    {s.key === 'close' && '成'}
                  </div>
                </div>

                <div class="bb-services__panel-content">
                  <p class="bb-services__panel-intro">{s.intro}</p>
                  <ul class="bb-services__list">
                    {s.items.map((it) => (
                      <li class="bb-services__item">
                        <span class={`bb-services__item-pip bb-services__item-pip--${s.key}`} aria-hidden="true"></span>
                        <span class="bb-services__item-text">
                          <span class="bb-services__item-name">{it.name}。</span>
                          <span class="bb-services__item-body">{it.body}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- HOW WE OPERATE                                                         -->
  <!-- ====================================================================== -->
  <section class="bb-operate">
    <div class="bb-operate__bg" aria-hidden="true"></div>
    <div class="container bb-operate__container">
      <span class="eyebrow eyebrow--on-dark">我们怎么做事</span>
      <h2 class="bb-operate__title">
        <span class="bb-operate__line" data-line>一套阵列。</span>
        <span class="bb-operate__line" data-line>一支团队。</span>
        <span class="bb-operate__line" data-line>一条链路。</span>
      </h2>
      <div class="bb-operate__statement" data-line>
        <p>从你的工厂，跑到你签下第一单。</p>
        <p class="bb-operate__emphasis">你多等一个季度，体量更小的对手就离你的买家更近一步。</p>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- FINAL CTA                                                              -->
  <!-- ====================================================================== -->
  <section class="bb-cta">
    <div class="bb-cta__bg" aria-hidden="true">
      <img src="/images/bb-bridge-hero-bg.webp" alt="" />
      <div class="bb-cta__bg-scrim"></div>
    </div>
    <div class="container bb-cta__content">
      <span class="eyebrow eyebrow--on-dark">你准备好，我们就动</span>
      <h2 class="bb-cta__title balance">预约通话。<br />我们告诉你，前九十天是什么样子。</h2>
      <div class="bb-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>聊一聊</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* BeyondBridge palette                                                   */
  /* ===================================================================== */
  .bb-hero,
  .bb-track,
  .bb-gap,
  .bb-services,
  .bb-operate,
  .bb-cta {
    --bb-build: #4f46e5;
    --bb-build-soft: #818cf8;
    --bb-demand: #f97316;
    --bb-demand-soft: #fdba74;
    --bb-close: #10b981;
    --bb-close-soft: #6ee7b7;
    --bb-ink: #0c1220;
  }

  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .bb-hero {
    position: relative;
    min-height: 88vh;
    padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    background: var(--bb-ink);
  }

  .bb-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .bb-hero__bg-img {
    position: absolute;
    inset: -8% -4% -4% -4%;
    width: 108%;
    height: 112%;
    object-fit: cover;
    object-position: center 50%;
    will-change: transform;
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04);
    filter: saturate(0.9) contrast(1.05) brightness(0.62);
  }
  .bb-hero__bg-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(8, 12, 24, 0.88) 0%, rgba(8, 12, 24, 0.66) 38%, rgba(8, 12, 24, 0.32) 65%, rgba(8, 12, 24, 0.6) 100%),
      linear-gradient(180deg, rgba(8, 12, 24, 0.55) 0%, rgba(8, 12, 24, 0.05) 30%, rgba(8, 12, 24, 0) 60%, rgba(8, 12, 24, 0.85) 100%);
  }
  .bb-hero__bg-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1200px 600px at 18% 28%, rgba(99, 102, 241, 0.20), transparent 65%),
      radial-gradient(900px 500px at 92% 78%, rgba(249, 115, 22, 0.15), transparent 70%);
    mix-blend-mode: screen;
  }
  .bb-hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.55;
  }

  .bb-hero__main {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .bb-hero__content { min-width: 0; max-width: 36rem; }
  .bb-hero__logo {
    display: block;
    width: auto;
    height: 44px;
    filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.4));
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.1s forwards;
  }

  .bb-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.2s forwards;
    max-width: 100%;
    white-space: normal;
  }
  .bb-hero__eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--bb-close);
    box-shadow: 0 0 0 0 rgba(16,185,129,0.5);
    animation: bbPulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  .bb-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 600;
    color: #fff;
    margin: 0 0 var(--space-5);
    max-width: 14ch;
    text-wrap: balance;
  }
  .bb-hero__line {
    display: block;
    overflow: hidden;
  }
  .bb-hero__line[data-anim="word"] {
    transform: translateY(110%);
    opacity: 0;
    animation: bbWordIn 880ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
  }
  .bb-hero__line[data-anim="word"]:nth-child(1) { animation-delay: 0.30s; }
  .bb-hero__line[data-anim="word"]:nth-child(2) { animation-delay: 0.42s; }
  .bb-hero__line[data-anim="word"]:nth-child(3) { animation-delay: 0.54s; }
  @keyframes bbWordIn {
    from { transform: translateY(110%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .bb-hero__phrase {
    font-style: normal;
    background-image: linear-gradient(120deg, var(--bb-build-soft) 0%, var(--bb-build) 50%, var(--bb-demand) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .bb-hero__lead {
    max-width: 46ch;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    margin: 0 0 var(--space-5);
    opacity: 0;
    animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.85s forwards;
  }

  .bb-hero__cta-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0;
    animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 1s forwards;
  }

  .bb-magnet {
    --x: 0px; --y: 0px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px 16px 28px;
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    isolation: isolate;
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1);
    transform: translate(var(--x), var(--y));
  }
  .bb-magnet__bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, var(--bb-build) 0%, #3730a3 100%);
    box-shadow: 0 16px 36px -10px rgba(79,70,229,0.55), inset 0 1px 0 rgba(255,255,255,0.2);
    z-index: -1;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bb-magnet:hover .bb-magnet__bg { transform: scale(1.04); }
  .bb-magnet__arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bb-magnet:hover .bb-magnet__arrow { transform: translateX(4px); }

  .bb-hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.92);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .bb-hero__secondary svg { transition: transform 220ms ease; }
  .bb-hero__secondary:hover { color: var(--bb-build-soft); }
  .bb-hero__secondary:hover svg { transform: translateX(3px); }

  /* Hero feature image (right column) */
  .bb-hero__feature {
    position: relative;
    perspective: 1600px;
    min-width: 0;
    opacity: 0;
    animation: bbFadeIn 900ms cubic-bezier(0.2,0.8,0.2,1) 0.5s forwards;
  }
  .bb-hero__feature-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 20px;
    overflow: visible;
    transform-style: preserve-3d;
    transform: rotateY(var(--tilt-x, -3deg)) rotateX(var(--tilt-y, 2deg));
    transition: transform 600ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bb-hero__feature-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
    display: block;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 40px 80px -28px rgba(0,0,0,0.55),
      0 12px 28px -8px rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.10);
  }
  .bb-hero__feature-scrim {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    background: linear-gradient(180deg, transparent 50%, rgba(8,12,24,0.45) 100%);
    pointer-events: none;
  }

  .bb-hero__chip {
    position: absolute;
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.94);
    color: var(--bbg-ink);
