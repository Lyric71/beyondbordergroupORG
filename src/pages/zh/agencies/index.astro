---
import Layout from '../../../layouts/Layout.astro';
import AgencyLogo from '../../../components/AgencyLogo.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'zh' as const;
const title = '七家公司';
const description =
  'BeyondBorderGroup 由七家专业公司组成：西方进入中国、中国走向西方，以及两端通用。每一家都独立运转。多数客户从一家开始，随项目展开再把别的拉进来。';

type Group = '西方 → 中国' | '中国 → 西方' | '两端通用';

type AgencyRoute =
  | 'agencies/beyondbordergroup'
  | 'agencies/theredscroll'
  | 'agencies/chinawebfoundry'
  | 'agencies/beyondcompass'
  | 'agencies/beyondbridge'
  | 'agencies/hubstudio'
  | 'agencies/nuvora-studio';

interface Agency {
  slug: string;
  route: AgencyRoute;
  name: string;
  group: Group;
  category: string;
  tagline: string;
  lead: string;
  lanes: { name: string; body: string }[];
  signal?: string;
  visit: { url: string; label: string };
  based: string;
  accent: string;
}

const agencies: Agency[] = [
  {
    slug: 'beyondbordergroup',
    route: 'agencies/beyondbordergroup',
    name: 'BeyondBorderGroup',
    group: '西方 → 中国',
    category: '中国市场全案公司',
    tagline: '进入中国。在中国生长。读懂中国。',
    lead:
      '在中国电商生态里待了十五年。天猫开店、抖音起势、ICP 改写，中间每一次算法变动都没漏过。我们既做咨询，也亲手把方案跑下来。没有模板。没有翻新的旧 PPT。只有活儿本身。',
    lanes: [
      {
        name: '进入',
        body: '市场进入咨询、品牌与本地化、跨境电商搭建（天猫国际、京东全球购、抖音），加上线下分销。',
      },
      {
        name: '生长',
        body: '店铺日常运营，小红书、抖音上的社交电商和微信电商，付费媒介，墙内的中文站，公关、活动与展会。',
      },
      {
        name: '读懂',
        body: '半天与全天的大师课，上海与深圳的多日学习考察，按需做的消费者研究。',
      },
    ],
    signal: '天猫 · 京东 · 抖音 · 小红书 · 微信',
    visit: { url: 'https://beyondbordergroup.com', label: 'beyondbordergroup.com' },
    based: '上海。香港。巴黎。',
    accent: '#269ada',
  },
  {
    slug: 'theredscroll',
    route: 'agencies/theredscroll',
    name: 'TheRedScroll',
    group: '西方 → 中国',
    category: '中国社交媒体专家',
    tagline: '我们在中国的平台上发声。每一天。从现场发。',
    lead:
      '中国跑在自己的平台上：微信、抖音、小红书、微博，再加另外十四个。在 PPT 上读懂这一点，和每天早上打开这些 app，是两回事。坦白说，多数公司并不打开。',
    lanes: [
      {
        name: '规划',
        body: '策略、竞品研究、内容日历，以及与业务目标挂钩的 KPI。账号开通、认证、命名，并把天猫、京东和抖音小店的电商对接做完。',
      },
      {
        name: '运营',
        body: '微信、抖音、小红书、微博四个核心。B 站、快手、知乎按加项处理。原生中文文案，媒介投放零加价，达人合作全部核过身份。',
      },
      {
        name: '沉淀',
        body: '企业微信与微信 CRM、私域、社群与客服流程。在我们运营的每一个平台上，提供大师课和战略咨询。',
      },
    ],
    signal: '范围固定。价格固定。每个套餐对一个数字。',
    visit: { url: 'https://theredscroll.com', label: 'theredscroll.com' },
    based: '上海。香港。',
    accent: '#c8102e',
  },
  {
    slug: 'chinawebfoundry',
    route: 'agencies/chinawebfoundry',
    name: 'ChinaWebFoundry',
    group: '西方 → 中国',
    category: '面向中国互联网的网站基础设施',
    tagline: '为中国互联网而建的网站，不是事后改造出来的。',
    lead:
      '某个普通的周二，一款 Google 字体被屏，上海所有访客打开你的首页，看见的是一团乱。伦敦的团队要等到客户开始抱怨那一刻才知道。我们在墙内建站、托管并监控，让这种对话永远不必发生。',
    lanes: [
      {
        name: '规划',
        body: '在北京、上海、深圳，用真实浏览器做一次中国就绪审计。迁移包含 ICP 备案、DNS 切换以及一份并行的预发环境，切换前你可以先验。',
      },
      {
        name: '建设',
        body: '为中文读者打磨的 UX 与 UI。微信、支付宝、银联收银。为大陆本地化过的 WooCommerce。替换掉技术栈里所有被屏的 Google 调用。',
      },
      {
        name: '触达',
        body: '原生中文内容，百度搜索资源平台的提交与跟踪，以及面向 DeepSeek、豆包、Kimi、文小言等生成式引擎的 GEO。',
      },
      {
        name: '运维',
        body: '中国境内托管，覆盖阿里云、腾讯云、华为云。备案处理期间提供香港过渡托管。维护与可用性监控都在中国网络里跑。',
      },
    ],
    signal: '百度 2025 年 1 月在中国搜索市场占 60.1%。来源：StatCounter。',
    visit: { url: 'https://chinawebfoundry.com', label: 'chinawebfoundry.com' },
    based: '上海。杭州。',
    accent: '#d99a3a',
  },
  {
    slug: 'beyondcompass',
    route: 'agencies/beyondcompass',
    name: 'BeyondCompass',
    group: '西方 → 中国',
    category: '伙伴搜寻与背调',
    tagline: '先找对中国伙伴。',
    lead:
      '一份私有名册：分销商、天猫 TP、抖音 Partner、进口商，全部都是我们亲自见过、亲自核过、亲自合作过的。价值不在那份 CSV，而在每一个名字背后的脉络、判断和暖介绍。',
    lanes: [
      {
        name: '短名单',
        body: '三到五位核过身份的合作方，深度简报，直接安排见面。给已经清楚自己分销路径的品牌。两到三周。',
      },
      {
        name: '市场地图',
        body: '十五到二十位合作方，按品类、渠道、覆盖范围绘制，配上结构化对比，再按顺序给一份短名单。三到六周。',
      },
      {
        name: '更换',
        body: '给已经签了错伙伴的品牌。背调标准不变，约束更紧，提供合同退出支持，默认全程保密。',
      },
    ],
    signal: '书面交付物，一次工作会议，暖介绍，坦诚的判断。',
    visit: { url: 'https://beyondcompass.beyondbordergroup.com', label: 'beyondcompass.beyondbordergroup.com' },
    based: '上海。二十年现场背调经验。',
    accent: '#1e7db0',
  },
  {
    slug: 'beyondbridge',
    route: 'agencies/beyondbridge',
    name: 'BeyondBridge',
    group: '中国 → 西方',
    category: '中国企业出海的整条链路',
    tagline: '我们把中国企业带到海外，把它们做起来。',
    lead:
      '多数中国企业出海，要先丢掉两年时间，才肯承认旧打法已经失效。我们用同一套阵列、同一条线索链路，把好产品和买家之间的距离合上。',
    lanes: [
      {
        name: '搭建',
        body: '在大决策上给资深咨询。品牌策略按你进入的市场来做，不是从中国版改一改。网站在汉堡和休斯顿都能秒开，UX 按西方读者的眼光打磨。',
      },
      {
        name: '需求',
        body: '面向 B2B 买家的 LinkedIn。SEO 与 GEO 让你在 Google 被找到，在 ChatGPT、Perplexity、Claude 里被引用。Google Ads 先把合格线索带进来，等 SEO 慢慢长出复利。',
      },
      {
        name: '成交',
        body: '法国、德国、意大利、英国、美国、澳大利亚、拉美都有本地销售代表，他们接第一通电话。订单值得一张机票时，亲自飞过去握手。',
      },
    ],
    signal: '巴黎 · 慕尼黑 · 米兰 · 伦敦 · 纽约 · 悉尼 · 圣保罗',
    visit: { url: 'https://beyondbridge.com', label: 'beyondbridge.com' },
    based: '中国总部。在七个市场设有本地代表。',
    accent: '#22c55e',
  },
  {
    slug: 'hubstudio',
    route: 'agencies/hubstudio',
    name: 'HubStudio',
    group: '两端通用',
    category: '内容生产公司，规模化 AIGC',
    tagline: '为现在的内容形态而建的生产公司。',
    lead:
      '去年一家全球家电品牌找上门，过审率只有 22%。六个月后，过审率升到 78%。产出乘以七，成本下来 60%。那就是旧的内容生产方式，和今天它必须长出来的样子，之间的距离。',
    lanes: [
      {
        name: '生产',
        body: '合规于品牌的视觉，单条 35 美元起，最终交付物 405 美元封顶。短视频和长视频，从一条 200 美元的脚本起步。上海实拍棚。3D、CGI、动效。可生成、可拍摄、可混合。',
      },
      {
        name: '平台',
        body: 'Hub4You，搭在专属 GPU 服务器上的内容工作室，跟你的 DAM 与 PIM 对接。品牌训练的模型、定制 LoRA，跑在 ComfyUI、Flux、Wan、Veo、Hunyuan 等框架上。',
      },
      {
        name: '主导',
        body: '内容策略、品牌与视觉识别。由住在目标文化里的创意人做转写创作。还有给内部团队的实操培训。',
      },
    ],
    signal: '马自达、雀巢、万豪、Bobbi Brown 等都在用。',
    visit: { url: 'https://hubstudio.ai', label: 'hubstudio.ai' },
    based: '上海工作室。全球交付。',
    accent: '#ff7a8a',
  },
  {
    slug: 'nuvora-studio',
    route: 'agencies/nuvora-studio',
    name: 'Nuvora Studio',
    group: '两端通用',
    category: '只做 LinkedIn 的 B2B',
    tagline: '你的客户在看。你的候选人在看。你的投资人在看。',
    lead:
      'LinkedIn 有超过十亿用户，是全世界的职业档案。我们让你在它上面持续生长。每一天。策略先行，永远不锁客。',
    lanes: [
      {
        name: '搭建',
        body: '为带来线索而策划、撰写并发布的 LinkedIn 内容。给创始人、CEO 和高管的个人品牌。让团队成为内容引擎的员工发声计划。',
      },
      {
        name: '转化',
        body: '锚定收入、不是虚荣指标的 LinkedIn 广告。对的定向、对的创意、对的报表，把合格线索送进你的销售管线。预算不会烧在错的人群上。',
      },
      {
        name: '学习',
        body: '围绕算法、个人主页和内容策略的实操培训与工作坊。给现有 LinkedIn 状态做一次完整审计，然后给一份长出来的路线图。',
      },
    ],
    signal: '面向全球各地的 B2B 企业。',
    visit: { url: 'https://nuvora.studio', label: 'nuvora.studio' },
    based: '全球。',
    accent: '#7c3aed',
  },
];

const groups: { id: Group; label: string; intro: string }[] = [
  {
    id: '西方 → 中国',
    label: '西方 → 中国',
    intro: '给进入中国，或者在中国扩规模的品牌。',
  },
  {
    id: '中国 → 西方',
    label: '中国 → 西方',
    intro: '给出海的中国企业。',
  },
  {
    id: '两端通用',
    label: '两端通用',
    intro: '给任何公司，任何地方。内容生产与 LinkedIn。',
  },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <!-- ===================================================================== -->
  <!-- HERO                                                                  -->
  <!-- ===================================================================== -->
  <section class="ag-hero">
    <div class="ag-hero__bg" aria-hidden="true"></div>
    <div class="container ag-hero__container">
      <span class="eyebrow eyebrow--on-dark">集团</span>
      <h1 class="ag-hero__title balance">
        七家专业公司。<br />
        <em>一个生态。</em>
      </h1>
      <p class="ag-hero__lead">
        每一家公司都独立运转。各有各的品牌、各有各的报价、各有各的交付物。挑一家最匹配你需要的。多数客户从一家开始，随着项目展开再把别的拉进来。
      </p>

      <ul class="ag-hero__logos" aria-label="公司 logo">
        {agencies.map((a) => (
          <li>
            <a href={`#${a.slug}`} aria-label={`前往 ${a.name}`}>
              <AgencyLogo slug={a.slug} name={a.name} class="ag-hero__logo" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- INDEX BY GROUP                                                        -->
  <!-- ===================================================================== -->
  <section class="section section--alt">
    <div class="container">
      <div class="ag-index">
        {groups.map((g) => (
          <div class="ag-index__col">
            <span class="eyebrow">{g.label}</span>
            <p class="ag-index__intro">{g.intro}</p>
            <ul class="ag-index__list">
              {agencies
                .filter((a) => a.group === g.id)
                .map((a) => (
                  <li>
                    <a href={`#${a.slug}`} class="ag-index__link">
                      <span class="ag-index__name">{a.name}</span>
                      <span class="ag-index__cat">{a.category}</span>
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- AGENCY SECTIONS                                                       -->
  <!-- ===================================================================== -->
  {agencies.map((a, i) => (
    <section
      id={a.slug}
      class={`ag-feature ${i % 2 === 1 ? 'ag-feature--alt' : ''}`}
      style={`--accent: ${a.accent};`}
    >
      <div class="container">
        <header class="ag-feature__head">
          <div class="ag-feature__head-left">
            <AgencyLogo slug={a.slug} name={a.name} class="ag-feature__logo" />
            <span class="ag-feature__group">{a.group} · {a.category}</span>
          </div>
          <a class="ag-feature__visit" href={a.visit.url} target="_blank" rel="noreferrer">
            {a.visit.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M7 7h10v10"/></svg>
          </a>
        </header>

        <div class="ag-feature__pitch">
          <h2 class="ag-feature__tagline">{a.tagline}</h2>
          <p class="ag-feature__lead">{a.lead}</p>
        </div>

        <ol class={`ag-feature__lanes ag-feature__lanes--${a.lanes.length}`}>
          {a.lanes.map((lane) => (
            <li class="ag-feature__lane">
              <h3 class="ag-feature__lane-title">{lane.name}</h3>
              <p class="ag-feature__lane-body">{lane.body}</p>
            </li>
          ))}
        </ol>

        <footer class="ag-feature__foot">
          <div class="ag-feature__foot-meta">
            <span><strong>所在地。</strong> {a.based}</span>
            {a.signal && <span class="ag-feature__signal">{a.signal}</span>}
          </div>
          <div class="ag-feature__foot-cta">
            <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>进入 {a.name}</a>
          </div>
        </footer>
      </div>
    </section>
  ))}

  <!-- ===================================================================== -->
  <!-- HOW THEY FIT TOGETHER                                                 -->
  <!-- ===================================================================== -->
  <section class="ag-stacks">
    <div class="ag-stacks__bg" aria-hidden="true"></div>
    <div class="container ag-stacks__container">
      <header class="ag-stacks__head">
        <span class="eyebrow eyebrow--on-dark">彼此如何衔接</span>
        <h2 class="ag-stacks__title balance">
          一个项目。<br />
          <em>需要几家公司，就上几家。</em>
        </h2>
        <p class="ag-stacks__lead">
          你不用去猜顺序。打开此刻最贴合的那一家公司。什么时候该把下一家拉进来，什么时候不用，我们会告诉你。
        </p>
      </header>

      <div class="ag-stacks__grid">
        {[
          {
            scenario: '一家法国护肤品牌。进入中国。',
            steps: [
              { slug: 'beyondcompass', name: 'BeyondCompass', role: '选对分销商。' },
              { slug: 'chinawebfoundry', name: 'ChinaWebFoundry', role: '把中国站建好，ICP 备案下来。' },
              { slug: 'beyondbordergroup', name: 'BeyondBorderGroup', role: '运营天猫，跑媒介。' },
              { slug: 'theredscroll', name: 'TheRedScroll', role: '微信、抖音、小红书，每天发。' },
            ],
          },
          {
            scenario: '一家中国机器人公司。走向海外。',
            steps: [
              { slug: 'beyondbridge', name: 'BeyondBridge', role: '品牌、网站、需求，加上美国与德国的本地代表。' },
              { slug: 'hubstudio', name: 'HubStudio', role: '规模化的内容生产，品牌不走样。' },
              { slug: 'nuvora-studio', name: 'Nuvora Studio', role: '创始人的 LinkedIn，每天发。' },
            ],
          },
        ].map((stack) => (
          <article class="ag-stack">
            <h3 class="ag-stack__scenario">{stack.scenario}</h3>
            <ol class="ag-stack__steps">
              {stack.steps.map((step) => (
                <li class="ag-stack__step">
                  <a class="ag-stack__step-link" href={`#${step.slug}`}>
                    <span class="ag-stack__step-logo">
                      <AgencyLogo slug={step.slug} name={step.name} class="ag-stack__logo" />
                    </span>
                    <span class="ag-stack__step-text">
                      <span class="ag-stack__step-name">{step.name}</span>
                      <span class="ag-stack__step-role">{step.role}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </article>
        ))}
      </div>

      <div class="ag-stacks__cta">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>聊一聊</a>
        <a class="btn btn--ghost-light" href={pathFor('how-we-work-together', locale)}>看我们如何配合</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .ag-hero {
    position: relative;
    color: #fff;
    background: var(--bbg-ink);
    padding: clamp(4rem, 9vh, 7rem) 0 clamp(3rem, 7vh, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .ag-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(900px 500px at 12% 18%, rgba(38,154,218,0.22), transparent 65%),
      radial-gradient(800px 500px at 88% 82%, rgba(200,16,46,0.16), transparent 70%),
      linear-gradient(180deg, #0c1220 0%, #1a1a1a 100%);
  }
  .ag-hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.6;
  }
  .ag-hero__container { max-width: 920px; }
  .ag-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: var(--space-3) 0 var(--space-5);
    font-weight: 600;
  }
  .ag-hero__title em {
    font-style: normal;
    background: linear-gradient(120deg, #59c2ee, #ff7a8a 50%, #ffcf6f);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .ag-hero__lead {
