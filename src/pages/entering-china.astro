---
import Layout from '../layouts/Layout.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import AgencyLogo from '../components/AgencyLogo.astro';
import { pathFor } from '../i18n/ui';

const locale = 'en' as const;
const title = 'Entering China';
const description = 'Brand, channels, websites, search, and commerce, run from inside China by three specialist agencies. The full stack to enter or scale in the Chinese market.';

const requirements = [
  {
    h: 'Brand that reads as quality to a Chinese audience',
    body: 'Trust signals up front. Certifications. Partner logos. Third-party validation. The kind of dense, credentialed home page that reads as cluttered to a Western eye, and reads as serious to a Chinese one. Western minimalism reads as empty here.',
  },
  {
    h: 'Channels Chinese consumers actually use',
    body: 'WeChat for trust. RedNote for the shortlist. Douyin for discovery and live commerce. Weibo for mass reach. Each one needs its own format, its own tempo, its own team running it.',
  },
  {
    h: 'Web infrastructure built behind the Firewall',
    body: 'ICP-licensed hosting on Aliyun, Tencent or Huawei. A site Baidu can actually index. UX tested inside the WeChat in-app browser, where most of your traffic will read it. Mobile-only, in practice. Over 95 percent of Chinese users access the web from a phone.',
  },
  {
    h: 'Search visibility in the engines Chinese buyers use',
    body: 'Baidu still owns more than half the search market in China, according to Statcounter. Google sits under 3 percent. And buyers under 35 are increasingly skipping search entirely for AI engines: DeepSeek, Doubao, Kimi, Yuanbao.',
  },
  {
    h: 'Commerce where the buying actually happens',
    body: 'Tmall, JD, Douyin Shop, RED, plus social commerce on WeChat. eCommerce and social are the same surface in China. They are not separate funnels.',
  },
];

const agencies = [
  {
    name: 'BeyondBorderGroup',
    role: 'The full-service operator',
    body: "Twenty years on the ground. Branding, media, social, KOLs, content studio, PR, websites, events, eCommerce, social commerce, distribution, plus consulting. One accountable team. Pick the whole stack, or pick the module.",
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    role: 'The social media specialist',
    body: 'Chinese social media run from Shanghai and Hong Kong. WeChat, Douyin, RedNote, Weibo, and 14 more. Strategy, content, KOLs, advertising, CRM, training. Fixed scope. Fixed price. Two-week onboarding.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    role: 'The web infrastructure specialist',
    body: 'Websites built for the Chinese web. Strategy and audit, China migration, native Chinese content, mobile-first UX, ICP-licensed hosting, Baidu SEO, GEO for Chinese AI engines, ongoing maintenance. WordPress, Astro, WeChat. All from one Shanghai team.',
    route: 'agencies/chinawebfoundry' as const,
  },
];
---

<Layout locale={locale} route="entering-china" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Flow 1 · Inbound · West to China</span>
      <h1 class="hero-editorial__title balance">
        You have a brand. China has 1.1 billion internet users. Closing that gap is not a translation job.
      </h1>
      <p class="hero-editorial__lead">
        The Chinese internet runs on its own stack. Different platforms, different search engines, different
        infrastructure, different content density, different buyer signals. We have been working inside it for
        twenty years.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What it actually takes</span>
        <h2 class="balance">What it takes to land in China.</h2>
      </header>
      <div class="grid-2">
        {requirements.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Three agencies. One flow.</span>
        <h2 class="balance">Pick the whole stack, or pick the piece.</h2>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <span class="card__index">{a.role}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.body}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Visit</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">How clients usually start</span>
        <h2 class="balance">Four typical openings.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>"I just need a Chinese website that actually works."</blockquote>
          <p><strong>ChinaWebFoundry.</strong> Six-week migration. ICP filed. Baidu-indexable.</p>
        </article>
        <article class="card">
          <blockquote>"I need to be on RedNote and Douyin in 90 days."</blockquote>
          <p><strong>TheRedScroll.</strong> Two-week onboarding. First content live in a fortnight.</p>
        </article>
        <article class="card">
          <blockquote>"I need everything: brand, channels, eCommerce, KOLs."</blockquote>
          <p><strong>BeyondBorderGroup.</strong> Full-service entry. Twenty-year playbook.</p>
        </article>
        <article class="card">
          <blockquote>"I am not sure where to start."</blockquote>
          <p>Thirty minutes on a call. We will tell you. <a href={pathFor('contact', locale)}>Book a call</a>.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--text-first">
        <div class="prose">
          <span class="eyebrow">What you also get</span>
          <h2 class="balance">A production engine the agencies share.</h2>
          <p>
            Every inbound engagement plugs into HubStudio's AIGC production layer. That is what keeps content
            cost competitive at the volume Chinese channels demand: three to five RedNote posts a week, daily
            Douyin video, a weekly WeChat newsletter, a monthly Tmall campaign refresh. Without an AI-native
            content engine behind it, the math does not work.
          </p>
          <a class="btn btn--ghost" href={pathFor('agencies/hubstudio', locale)}>Visit HubStudio</a>
        </div>
        <ImagePlaceholder ratio="4x5" label="Studio still life. Production setup. AIGC + real assets." />
      </div>
    </div>
  </section>
</Layout>
