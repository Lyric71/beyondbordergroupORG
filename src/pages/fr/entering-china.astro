---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'fr' as const;
const title = 'Entrer en Chine';
const description = "Marque, canaux, sites, recherche et commerce, opérés depuis l’intérieur de la Chine par trois agences spécialisées. La pile complète pour entrer ou se développer sur le marché chinois.";

const requirements = [
  { h: 'Une marque qui dit qualité aux yeux chinois', body: "Preuves de confiance dès le haut de page. Certifications. Logos partenaires. Validation par des tiers. Le genre de page d’accueil dense et créditée qui paraît surchargée à un œil occidental, et sérieuse à un œil chinois. Le minimalisme occidental se lit comme du vide ici." },
  { h: 'Des canaux que les consommateurs chinois utilisent vraiment', body: "WeChat pour la confiance. RedNote pour la liste courte. Douyin pour la découverte et le live commerce. Weibo pour la portée massive. Chacun a son format, son rythme, son équipe dédiée." },
  { h: 'Une infrastructure web faite pour vivre derrière le Firewall', body: "Hébergement avec licence ICP chez Aliyun, Tencent ou Huawei. Un site que Baidu peut indexer. Une UX testée dans le navigateur intégré à WeChat, là où la majorité de votre trafic vous lira. En pratique : mobile first. Plus de 95% des internautes chinois passent par téléphone." },
  { h: 'Une visibilité dans les moteurs que les acheteurs chinois utilisent', body: "Baidu détient encore plus de la moitié des recherches en Chine, selon Statcounter. Google se traîne sous 3%. Et les moins de 35 ans sautent de plus en plus la recherche traditionnelle pour passer aux IA : DeepSeek, Doubao, Kimi, Yuanbao." },
  { h: 'Du commerce là où l’achat se fait', body: "Tmall, JD, Douyin Shop, RED, plus le social commerce sur WeChat. En Chine, eCommerce et social, c’est la même surface. Pas deux entonnoirs séparés." },
];

const agencies = [
  { name: 'BeyondBorderGroup', role: 'L’opérateur full-service', body: "Vingt ans sur le terrain. Branding, média, social, KOL, studio de contenu, RP, sites, événements, eCommerce, social commerce, distribution, plus le conseil. Une équipe responsable. Prenez la pile entière, ou un module.", route: 'agencies/beyondbordergroup' as const },
  { name: 'TheRedScroll', role: 'Le spécialiste des réseaux sociaux', body: "Réseaux sociaux chinois opérés depuis Shanghai et Hong Kong. WeChat, Douyin, RedNote, Weibo, plus 14 autres. Stratégie, contenu, KOL, publicité, CRM, formation. Périmètre fixe. Prix fixe. Onboarding en deux semaines.", route: 'agencies/theredscroll' as const },
  { name: 'ChinaWebFoundry', role: 'Le spécialiste de l’infrastructure web', body: "Sites pensés pour le web chinois. Stratégie et audit, migration vers la Chine, contenu chinois natif, UX mobile first, hébergement avec licence ICP, SEO Baidu, GEO pour les IA chinoises, maintenance. WordPress, Astro, WeChat. Une seule équipe à Shanghai.", route: 'agencies/chinawebfoundry' as const },
];
---

<Layout locale={locale} route="entering-china" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Flux 1 · Entrant · Occident vers Chine</span>
      <h1 class="hero-editorial__title balance">
        Vous avez une marque. La Chine compte 1,1 milliard d’internautes. Combler cet écart n’est pas un travail de traduction.
      </h1>
      <p class="hero-editorial__lead">
        Internet chinois tourne sur sa propre pile. Plateformes différentes, moteurs de recherche différents,
        infrastructure différente, densité de contenu différente, signaux d’achat différents. On y travaille
        depuis vingt ans.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Ce qu’il faut vraiment</span>
        <h2 class="balance">Ce qu’il faut pour se poser en Chine.</h2>
      </header>
      <div class="grid-2">
        {requirements.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Trois agences. Un flux.</span>
        <h2 class="balance">Prenez la pile entière, ou la pièce.</h2>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <span class="card__index">{a.role}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.body}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Visiter</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Comment les clients commencent</span>
        <h2 class="balance">Quatre points de départ classiques.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>« Il me faut juste un site chinois qui fonctionne vraiment. »</blockquote>
          <p><strong>ChinaWebFoundry.</strong> Migration en six semaines. ICP déposée. Indexable par Baidu.</p>
        </article>
        <article class="card">
          <blockquote>« Je dois être sur RedNote et Douyin dans 90 jours. »</blockquote>
          <p><strong>TheRedScroll.</strong> Onboarding en deux semaines. Premier contenu en ligne en quinze jours.</p>
        </article>
        <article class="card">
          <blockquote>« Il me faut tout : marque, canaux, eCommerce, KOL. »</blockquote>
          <p><strong>BeyondBorderGroup.</strong> Entrée full-service. Le playbook accumulé depuis vingt ans.</p>
        </article>
        <article class="card">
          <blockquote>« Je ne sais pas par où commencer. »</blockquote>
          <p>Trente minutes au téléphone. Nous vous le dirons. <a href={pathFor('contact', locale)}>Réserver un appel</a>.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--text-first">
        <div class="prose">
          <span class="eyebrow">Ce que vous obtenez en plus</span>
          <h2 class="balance">Un moteur de production que les agences partagent.</h2>
          <p>
            Chaque mission entrante se branche sur la couche de production AIGC de HubStudio. C’est ce qui
            maintient le coût du contenu compétitif au volume qu’imposent les canaux chinois : trois à cinq
            posts RedNote par semaine, vidéo Douyin quotidienne, newsletter WeChat hebdomadaire, refonte
            campagne Tmall mensuelle. Sans moteur de contenu IA-natif derrière, les calculs ne tiennent pas.
          </p>
          <a class="btn btn--ghost" href={pathFor('agencies/hubstudio', locale)}>Visiter HubStudio</a>
        </div>
        <ImagePlaceholder ratio="4x5" label="Nature morte de studio. Setup de production. AIGC + actifs réels." />
      </div>
    </div>
  </section>
</Layout>
