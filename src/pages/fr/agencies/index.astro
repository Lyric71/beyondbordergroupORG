---
import Layout from '../../../layouts/Layout.astro';
import AgencyLogo from '../../../components/AgencyLogo.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'fr' as const;
const title = 'Sept agences';
const description =
  "BeyondBorderGroup, ce sont sept agences spécialistes. Occident vers Chine, Chine vers Occident, et transversales. Chacune se tient seule. La majorité de nos clients démarrent par une, et ouvrent le périmètre à mesure que le projet grandit.";

type Group = 'Occident → Chine' | 'Chine → Occident' | 'Transversal';

type AgencyRoute =
  | 'agencies/beyondbordergroup'
  | 'agencies/theredscroll'
  | 'agencies/chinawebfoundry'
  | 'agencies/beyondcompass'
  | 'agencies/beyondbridge'
  | 'agencies/hubstudio'
  | 'agencies/nuvora-studio';

interface Agency {
  slug: string;
  route: AgencyRoute;
  name: string;
  group: Group;
  category: string;
  tagline: string;
  lead: string;
  lanes: { name: string; body: string }[];
  signal?: string;
  visit: { url: string; label: string };
  based: string;
  accent: string;
}

const agencies: Agency[] = [
  {
    slug: 'beyondbordergroup',
    route: 'agencies/beyondbordergroup',
    name: 'BeyondBorderGroup',
    group: 'Occident → Chine',
    category: 'Agence Chine intégrée',
    tagline: 'Entrer en Chine. Grandir en Chine. Comprendre la Chine.',
    lead:
      "Quinze ans à l'intérieur de l'écosystème commerce chinois. Lancements Tmall, déferlantes Douyin, refontes ICP, et chaque virage d'algorithme entre les deux. Nous conseillons, et nous opérons ce que nous recommandons. Pas de modèle. Pas de présentation recyclée. Le travail, point.",
    lanes: [
      {
        name: 'Entrer',
        body: "Conseil en accès au marché, branding et localisation, mise en place du e-commerce transfrontalier sur Tmall Global, JD Worldwide et Douyin, distribution offline.",
      },
      {
        name: 'Grandir',
        body: "Opérations boutique au quotidien, social commerce sur Xiaohongshu, Douyin et WeChat, achat média, site chinois à l'intérieur du Firewall, RP, événements et salons.",
      },
      {
        name: 'Comprendre',
        body: "Masterclasses d'une demi-journée ou d'une journée complète, expéditions d'apprentissage de plusieurs jours à Shanghai et Shenzhen, études consommateurs à la demande.",
      },
    ],
    signal: 'Tmall · JD · Douyin · RED · WeChat',
    visit: { url: 'https://beyondbordergroup.com', label: 'beyondbordergroup.com' },
    based: 'Shanghai. Hong Kong. Paris.',
    accent: '#269ada',
  },
  {
    slug: 'theredscroll',
    route: 'agencies/theredscroll',
    name: 'TheRedScroll',
    group: 'Occident → Chine',
    category: 'Spécialiste des réseaux sociaux chinois',
    tagline: "Nous publions sur les plateformes chinoises. Tous les jours. Depuis le terrain.",
    lead:
      "La Chine tourne sur ses propres plateformes. WeChat, Douyin, RedNote, Weibo, et quatorze autres. Le savoir par un slide n'a rien à voir avec ouvrir ces applis chaque matin, ce que, franchement, la plupart des agences ne font pas.",
    lanes: [
      {
        name: 'Concevoir',
        body: "Stratégie, étude concurrentielle, calendriers éditoriaux et KPI alignés sur les objectifs business. Création des comptes, vérification, naming, intégration e-commerce avec Tmall, JD et Douyin Shop.",
      },
      {
        name: 'Opérer',
        body: "WeChat, Douyin, RedNote et Weibo au cœur. Bilibili, Kuaishou, Zhihu et d'autres en option. Textes en chinois natif, achat média sans marge sur le budget, engagement d'influenceurs vérifiés.",
      },
      {
        name: 'Faire durer',
        body: "WeCom et CRM WeChat, domaine privé, communauté et flux service client. Masterclasses et conseil stratégique sur chacune des plateformes que nous opérons.",
      },
    ],
    signal: "Périmètre fixe. Prix fixe. Un chiffre par offre.",
    visit: { url: 'https://theredscroll.com', label: 'theredscroll.com' },
    based: 'Shanghai. Hong Kong.',
    accent: '#c8102e',
  },
  {
    slug: 'chinawebfoundry',
    route: 'agencies/chinawebfoundry',
    name: 'ChinaWebFoundry',
    group: 'Occident → Chine',
    category: "Infrastructure web pour l'internet chinois",
    tagline: "Des sites pensés pour l'internet chinois, pas rapiécés pour lui.",
    lead:
      "Une Google Font se fait bloquer un mardi sans raison et votre page d'accueil devient illisible pour tout Shanghai. À Londres, votre équipe ne le sait pas avant qu'un client ne se plaigne. Nous construisons, hébergeons et surveillons les sites depuis l'intérieur du Firewall pour que cette conversation n'ait jamais lieu.",
    lanes: [
      {
        name: 'Cadrer',
        body: "Audits China readiness depuis de vrais navigateurs à Pékin, Shanghai et Shenzhen. Migration avec dépôt ICP Bei'an, bascule DNS et environnement de staging en parallèle, testable avant de basculer.",
      },
      {
        name: 'Construire',
        body: "UX et UI pensées pour les lecteurs chinois. Paiement WeChat et Alipay, UnionPay, WooCommerce localisé pour le continent, et remplacement de chaque appel Google bloqué dans votre stack.",
      },
      {
        name: 'Trouver',
        body: "Contenu chinois natif, soumission et suivi sur Baidu Search Resource Platform, optimisation pour les moteurs génératifs DeepSeek, Doubao, Kimi, Yuanbao et Baidu AI.",
      },
      {
        name: 'Opérer',
        body: "Hébergement Chine sur Alibaba Cloud, Tencent Cloud et Huawei Cloud. Hébergement passerelle à Hong Kong pendant le traitement du Bei'an. Maintenance et supervision depuis les réseaux chinois.",
      },
    ],
    signal: "Baidu détenait 60,1 % de la recherche chinoise en janvier 2025. Source : StatCounter.",
    visit: { url: 'https://chinawebfoundry.com', label: 'chinawebfoundry.com' },
    based: 'Shanghai. Hangzhou.',
    accent: '#d99a3a',
  },
  {
    slug: 'beyondcompass',
    route: 'agencies/beyondcompass',
    name: 'BeyondCompass',
    group: 'Occident → Chine',
    category: 'Sourcing et qualification de partenaires',
    tagline: "Trouver le bon partenaire chinois, d'abord.",
    lead:
      "Un fichier privé de distributeurs, TP Tmall, Douyin Partners et importateurs que nous avons réellement rencontrés, qualifiés et avec qui nous avons travaillé. La valeur, c'est le contexte autour des noms, les verdicts et les présentations chaleureuses, pas l'accès à un fichier CSV.",
    lanes: [
      {
        name: 'Présélection',
        body: "Trois à cinq noms qualifiés, briefés en profondeur, prêts à rencontrer. Pour les marques qui savent déjà à quoi doit ressembler leur distribution. Deux à trois semaines.",
      },
      {
        name: 'Cartographie',
        body: "Quinze à vingt noms cartographiés par catégorie, canal et empreinte, comparaison structurée et shortlist séquencée tirée des noms qui survivent à l'analyse. Trois à six semaines.",
      },
      {
        name: 'Remplacement',
        body: "Pour les marques qui ont signé avec le mauvais partenaire. Même qualification, contraintes plus serrées, accompagnement à la sortie de contrat, discrétion par défaut.",
      },
    ],
    signal: "Livrable écrit, séance de travail, présentations chaleureuses, verdicts honnêtes.",
    visit: { url: 'https://beyondcompass.beyondbordergroup.com', label: 'beyondcompass.beyondbordergroup.com' },
    based: 'Shanghai. Vingt ans de qualification terrain.',
    accent: '#1e7db0',
  },
  {
    slug: 'beyondbridge',
    route: 'agencies/beyondbridge',
    name: 'BeyondBridge',
    group: 'Chine → Occident',
    category: "Pipeline export pour les entreprises chinoises",
    tagline: "Nous faisons grandir les entreprises chinoises à l'étranger.",
    lead:
      "La plupart des entreprises chinoises qui partent à l'étranger perdent deux ans avant d'admettre que la méthode ne fonctionne pas. Nous comblons l'écart entre un excellent produit et un acheteur, avec une seule stack et un seul pipeline.",
    lanes: [
      {
        name: 'Construire',
        body: "Conseil senior sur les grandes décisions. Stratégie de marque pensée pour les marchés que vous adressez, pas reprise du référentiel chinois. Un site qui charge vite à Hambourg comme à Houston, avec une UX taillée pour l'œil occidental.",
      },
      {
        name: 'Demande',
        body: "LinkedIn pour les acheteurs B2B. SEO et GEO pour être trouvé sur Google et cité par ChatGPT, Perplexity et Claude. Google Ads pour amener des leads qualifiés pendant que le SEO monte en puissance.",
      },
      {
        name: 'Conclure',
        body: "Représentants commerciaux natifs en France, Allemagne, Italie, Royaume-Uni, États-Unis, Australie et Amérique latine. Ils prennent le premier appel. Quand l'affaire vaut un avion, ils vont serrer la main de l'acheteur.",
      },
    ],
    signal: 'Paris · Munich · Milan · Londres · New York · Sydney · São Paulo',
    visit: { url: 'https://beyondbridge.com', label: 'beyondbridge.com' },
    based: 'Siège en Chine. Représentants dans sept marchés.',
    accent: '#22c55e',
  },
  {
    slug: 'hubstudio',
    route: 'agencies/hubstudio',
    name: 'HubStudio',
    group: 'Transversal',
    category: "Maison de production, AIGC à l'échelle",
    tagline: "Une maison de production taillée pour ce qu'est devenu le contenu.",
    lead:
      "Une grande marque mondiale d'électroménager est arrivée chez nous l'an dernier avec un taux de validation de 22 %. Six mois plus tard, il atteignait 78 %. Volume multiplié par sept. Coûts en baisse de 60 %. C'est à peu près l'écart entre l'ancienne manière de produire du contenu et la façon dont il faut désormais travailler.",
    lanes: [
      {
        name: 'Produire',
        body: "Visuels fidèles à la marque, de 35 $ par brief à 405 $ par pièce finalisée. Vidéos courtes et longues à partir de 200 $ par script. Studio prises de vues à Shanghai. 3D, CGI et motion. Génératif, tourné, ou hybride.",
      },
      {
        name: 'Plateforme',
        body: "Hub4You, votre studio de contenu sur serveurs GPU dédiés, intégré à votre DAM et à votre PIM. Modèles entraînés à votre marque, LoRAs sur mesure, pipelines bâtis sur ComfyUI, Flux, Wan, Veo, Hunyuan.",
      },
      {
        name: 'Diriger',
        body: "Stratégie de contenu, identité de marque et identité visuelle, transcréation par des créatifs qui vivent à l'intérieur de la culture cible, formation pratique des équipes internes.",
      },
    ],
    signal: "Mazda, Nescafé, Marriott, Bobbi Brown et d'autres nous font confiance.",
    visit: { url: 'https://hubstudio.ai', label: 'hubstudio.ai' },
    based: 'Studio à Shanghai. Livraison mondiale.',
    accent: '#ff7a8a',
  },
  {
    slug: 'nuvora-studio',
    route: 'agencies/nuvora-studio',
    name: 'Nuvora Studio',
    group: 'Transversal',
    category: 'B2B, exclusivement LinkedIn',
    tagline: "Vos acheteurs y vont. Vos recrues y vont. Vos investisseurs y vont.",
    lead:
      "Avec plus d'un milliard de membres, LinkedIn est le registre professionnel du monde. Nous y faisons grandir votre présence. Tous les jours. La stratégie d'abord, sans vous enfermer.",
    lanes: [
      {
        name: 'Construire',
        body: "Contenu LinkedIn pensé, écrit et publié pour générer des leads. Marque personnelle pour fondateurs, dirigeants et seniors. Des ambassadeurs en interne qui transforment votre équipe en moteur de contenu.",
      },
      {
        name: 'Convertir',
        body: "Publicité LinkedIn arrimée au revenu, pas aux métriques de vanité. Ciblage, créa et reporting qui orientent les leads qualifiés vers votre pipeline. Aucun budget brûlé sur la mauvaise audience.",
      },
      {
        name: 'Apprendre',
        body: "Formations et ateliers pratiques sur l'algorithme, le profil et la stratégie de contenu. Audit complet de votre présence LinkedIn et feuille de route pour la faire grandir.",
      },
    ],
    signal: 'Les entreprises B2B, partout dans le monde.',
    visit: { url: 'https://nuvora.studio', label: 'nuvora.studio' },
    based: 'Mondial.',
    accent: '#7c3aed',
  },
];

const groups: { id: Group; label: string; intro: string }[] = [
  {
    id: 'Occident → Chine',
    label: 'Occident → Chine',
    intro: "Pour les marques qui entrent en Chine ou qui changent d'échelle.",
  },
  {
    id: 'Chine → Occident',
    label: 'Chine → Occident',
    intro: "Pour les entreprises chinoises qui partent à l'étranger.",
  },
  {
    id: 'Transversal',
    label: 'Transversal',
    intro: 'Pour toute entreprise, partout. Production de contenu et LinkedIn.',
  },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <!-- ===================================================================== -->
  <!-- HERO                                                                  -->
  <!-- ===================================================================== -->
  <section class="ag-hero">
    <div class="ag-hero__bg" aria-hidden="true"></div>
    <div class="container ag-hero__container">
      <span class="eyebrow eyebrow--on-dark">Le groupe</span>
      <h1 class="ag-hero__title balance">
        Sept agences spécialistes.<br />
        <em>Un seul écosystème.</em>
      </h1>
      <p class="ag-hero__lead">
        Chaque agence est autonome. Sa marque, ses tarifs, ses livrables. Vous prenez celle qui correspond à
        votre sujet. La majorité de nos clients démarrent par une seule, puis ouvrent le périmètre à mesure
        que le projet grandit.
      </p>

      <ul class="ag-hero__logos" aria-label="Logos des agences">
        {agencies.map((a) => (
          <li>
            <a href={`#${a.slug}`} aria-label={`Aller à ${a.name}`}>
              <AgencyLogo slug={a.slug} name={a.name} class="ag-hero__logo" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- INDEX BY GROUP                                                        -->
  <!-- ===================================================================== -->
  <section class="section section--alt">
    <div class="container">
      <div class="ag-index">
        {groups.map((g) => (
          <div class="ag-index__col">
            <span class="eyebrow">{g.label}</span>
            <p class="ag-index__intro">{g.intro}</p>
            <ul class="ag-index__list">
              {agencies
                .filter((a) => a.group === g.id)
                .map((a) => (
                  <li>
                    <a href={`#${a.slug}`} class="ag-index__link">
                      <span class="ag-index__name">{a.name}</span>
                      <span class="ag-index__cat">{a.category}</span>
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- AGENCY SECTIONS                                                       -->
  <!-- ===================================================================== -->
  {agencies.map((a, i) => (
    <section
      id={a.slug}
      class={`ag-feature ${i % 2 === 1 ? 'ag-feature--alt' : ''}`}
      style={`--accent: ${a.accent};`}
    >
      <div class="container">
        <header class="ag-feature__head">
          <div class="ag-feature__head-left">
            <AgencyLogo slug={a.slug} name={a.name} class="ag-feature__logo" />
            <span class="ag-feature__group">{a.group} · {a.category}</span>
          </div>
          <a class="ag-feature__visit" href={a.visit.url} target="_blank" rel="noreferrer">
            {a.visit.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M7 7h10v10"/></svg>
          </a>
        </header>

        <div class="ag-feature__pitch">
          <h2 class="ag-feature__tagline">{a.tagline}</h2>
          <p class="ag-feature__lead">{a.lead}</p>
        </div>

        <ol class={`ag-feature__lanes ag-feature__lanes--${a.lanes.length}`}>
          {a.lanes.map((lane) => (
            <li class="ag-feature__lane">
              <h3 class="ag-feature__lane-title">{lane.name}</h3>
              <p class="ag-feature__lane-body">{lane.body}</p>
            </li>
          ))}
        </ol>

        <footer class="ag-feature__foot">
          <div class="ag-feature__foot-meta">
            <span><strong>Implantation.</strong> {a.based}</span>
            {a.signal && <span class="ag-feature__signal">{a.signal}</span>}
          </div>
          <div class="ag-feature__foot-cta">
            <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>Ouvrir {a.name}</a>
          </div>
        </footer>
      </div>
    </section>
  ))}

  <!-- ===================================================================== -->
  <!-- HOW THEY FIT TOGETHER                                                 -->
  <!-- ===================================================================== -->
  <section class="ag-stacks">
    <div class="ag-stacks__bg" aria-hidden="true"></div>
    <div class="container ag-stacks__container">
      <header class="ag-stacks__head">
        <span class="eyebrow eyebrow--on-dark">Comment elles s'articulent</span>
        <h2 class="ag-stacks__title balance">
          Un seul projet.<br />
          <em>Autant d'agences que le travail l'exige.</em>
        </h2>
        <p class="ag-stacks__lead">
          Vous n'avez pas à deviner l'ordre. Ouvrez l'agence qui correspond à votre moment. Nous vous dirons
          quand il faut en faire entrer une autre, et quand ce n'est pas nécessaire.
        </p>
      </header>

      <div class="ag-stacks__grid">
        {[
          {
            scenario: "Une marque française de soins. Entrée en Chine.",
            steps: [
              { slug: 'beyondcompass', name: 'BeyondCompass', role: 'Choisir le bon distributeur.' },
              { slug: 'chinawebfoundry', name: 'ChinaWebFoundry', role: 'Construire le site Chine, ICP déposé.' },
              { slug: 'beyondbordergroup', name: 'BeyondBorderGroup', role: 'Opérer Tmall, piloter le média.' },
              { slug: 'theredscroll', name: 'TheRedScroll', role: 'WeChat, Douyin, RedNote, au quotidien.' },
            ],
          },
          {
            scenario: "Une entreprise chinoise de robotique. Cap sur l'export.",
            steps: [
              { slug: 'beyondbridge', name: 'BeyondBridge', role: 'Marque, site, demande, représentants aux États-Unis et en Allemagne.' },
              { slug: 'hubstudio', name: 'HubStudio', role: "Production de contenu à l'échelle, dans la marque." },
              { slug: 'nuvora-studio', name: 'Nuvora Studio', role: 'LinkedIn du fondateur, tous les jours.' },
            ],
          },
        ].map((stack) => (
          <article class="ag-stack">
            <h3 class="ag-stack__scenario">{stack.scenario}</h3>
            <ol class="ag-stack__steps">
              {stack.steps.map((step) => (
                <li class="ag-stack__step">
                  <a class="ag-stack__step-link" href={`#${step.slug}`}>
                    <span class="ag-stack__step-logo">
                      <AgencyLogo slug={step.slug} name={step.name} class="ag-stack__logo" />
                    </span>
                    <span class="ag-stack__step-text">
                      <span class="ag-stack__step-name">{step.name}</span>
                      <span class="ag-stack__step-role">{step.role}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </article>
        ))}
      </div>

      <div class="ag-stacks__cta">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Parler à l'équipe</a>
        <a class="btn btn--ghost-light" href={pathFor('how-we-work-together', locale)}>Comment on travaille ensemble</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .ag-hero {
    position: relative;
    color: #fff;
    background: var(--bbg-ink);
    padding: clamp(4rem, 9vh, 7rem) 0 clamp(3rem, 7vh, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .ag-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(900px 500px at 12% 18%, rgba(38,154,218,0.22), transparent 65%),
      radial-gradient(800px 500px at 88% 82%, rgba(200,16,46,0.16), transparent 70%),
      linear-gradient(180deg, #0c1220 0%, #1a1a1a 100%);
  }
  .ag-hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.6;
  }
  .ag-hero__container { max-width: 920px; }
  .ag-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: var(--space-3) 0 var(--space-5);
    font-weight: 600;
  }
  .ag-hero__title em {
    font-style: normal;
    background: linear-gradient(120deg, #59c2ee, #ff7a8a 50%, #ffcf6f);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .ag-hero__lead {
    font-size: clamp(1.05rem, 0.5vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    max-width: 60ch;
    margin: 0 0 var(--space-7);
  }
  .ag-hero__logos {
    list-style: none;
    margin: 0;
    padding: var(--space-5) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-3);
    align-items: stretch;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  @media (min-width: 1024px) {
    .ag-hero__logos { grid-template-columns: repeat(7, minmax(0, 1fr)); }
  }
  .ag-hero__logos a {
    display: grid;
    place-items: center;
    height: 72px;
    padding: var(--space-3) var(--space-4);
    background: #fff;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.18);
    transition: transform 220ms cubic-bezier(0.2,0.85,0.2,1), box-shadow 220ms ease;
    box-shadow: 0 10px 30px -16px rgba(0,0,0,0.45);
  }
  .ag-hero__logos a:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -18px rgba(0,0,0,0.55);
  }
  .ag-hero__logos :global(.ag-hero__logo) {
    max-height: 36px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  /* ===================================================================== */
  /* INDEX                                                                  */
  /* ===================================================================== */
  .ag-index {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  @media (min-width: 768px) {
    .ag-index { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .ag-index__intro {
    margin: var(--space-3) 0 var(--space-4);
    color: var(--bbg-text);
    font-size: 1.05rem;
  }
  .ag-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--bbg-border);
  }
  .ag-index__list li { border-bottom: 1px solid var(--bbg-border); }
  .ag-index__link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
