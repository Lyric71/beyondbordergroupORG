---
import Layout from '../../../layouts/Layout.astro';
import ImagePlaceholder from '../../../components/ImagePlaceholder.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'fr' as const;
const title = 'Sept agences';
const description = "BeyondBorderGroup, ce sont sept agences spécialistes. Vous prenez celle qu’il vous faut. Chacune se tient debout seule. La majorité de nos clients démarrent par une seule, et étoffent ensuite.";

const agencies = [
  { n: '01', slug: 'beyondbordergroup', route: 'agencies/beyondbordergroup' as const, name: 'BeyondBorderGroup', badge: 'Occident → Chine · Couverture intégrale', body: "Agence Chine intégrée. Vingt ans de terrain. Branding, média, social, KOL, contenu, RP, sites, événementiel, eCommerce, distribution.", fit: "Marques en quête d’une équipe unique pour entrer ou changer d’échelle en Chine.", based: 'Shanghai · Hong Kong · Paris.' },
  { n: '02', slug: 'theredscroll', route: 'agencies/theredscroll' as const, name: 'TheRedScroll', badge: 'Occident → Chine · Spécialiste de canal', body: "Réseaux sociaux chinois opérés depuis le terrain. WeChat, Douyin, RED, Weibo, plus quatorze autres plateformes. Périmètre fixe, prix fixe.", fit: "Marques qui exigent que leurs réseaux sociaux chinois soient enfin tenus correctement.", based: 'Shanghai · Hong Kong.' },
  { n: '03', slug: 'chinawebfoundry', route: 'agencies/chinawebfoundry' as const, name: 'ChinaWebFoundry', badge: 'Occident → Chine · Infrastructure web', body: "Sites taillés pour le web chinois. ICP, Baidu, IA chinoises, parcours testés dans le navigateur de WeChat. WordPress, Astro, WeChat.", fit: "Marques dont le site doit véritablement fonctionner en Chine.", based: 'Shanghai · Hangzhou.' },
  { n: '04', slug: 'beyondcompass', route: 'agencies/beyondcompass' as const, name: 'BeyondCompass', badge: 'Occident → Chine · Sourcing partenaires', body: "Une base privée de distributeurs, TP Tmall, Douyin Partners et importateurs que nous avons rencontrés et qualifiés sur le terrain. Trois mois de prospection en moins.", fit: "Marques qui choisissent un partenaire chinois pour la première fois, ou qui reconstruisent leur dispositif de distribution.", based: 'Shanghai. Quinze ans de qualification terrain.' },
  { n: '05', slug: 'beyondbridge', route: 'agencies/beyondbridge' as const, name: 'BeyondBridge', badge: 'Chine → Occident · Filière complète', body: "L’export clé en main pour les marques chinoises. Marque, LinkedIn, site, SEO/GEO, Ads, représentants nominatifs sur place.", fit: "Marques chinoises qui veulent un vrai pipeline à l’étranger, et pas seulement une présence en salon.", based: 'Chine. Représentants aux États-Unis, au Royaume-Uni, en Allemagne et en France.' },
  { n: '06', slug: 'hubstudio', route: 'agencies/hubstudio' as const, name: 'HubStudio', badge: 'Transversal · Production de contenu', body: "Image, vidéo et contenu IA. Qualité agence, vitesse IA.", fit: "Marques, retailers, agences et industriels qui produisent du contenu à grande échelle.", based: 'Mondial. Siège à Shanghai.' },
  { n: '07', slug: 'nuvora-studio', route: 'agencies/nuvora-studio' as const, name: 'Nuvora Studio', badge: 'Transversal · LinkedIn B2B', body: "Exclusivement LinkedIn. Stratégie, contenu, achats média, employee advocacy, personal branding dirigeants.", fit: "Entreprises B2B partout dans le monde.", based: 'Mondial.' },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Agences</span>
      <h1 class="hero-editorial__title balance">Sept agences spécialistes. Un seul écosystème.</h1>
      <p class="hero-editorial__lead">
        Chacune est autonome : sa marque, ses tarifs, ses livrables. Vous prenez celle qui correspond au sujet
        du jour. La majorité de nos clients démarrent par une, puis ouvrent le périmètre quand le projet
        l’exige.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="grid-2">
        {agencies.map((a) => (
          <article class="card" style="gap: var(--space-4);">
            <div style="display: flex; gap: var(--space-4); align-items: flex-start;">
              <ImagePlaceholder ratio="1x1" label={a.name} class="img-ph" />
            </div>
            <div class="card__meta">
              <span class="card__tag card__tag--brand">{a.n}</span>
              <span class="card__tag">{a.badge}</span>
            </div>
            <h2 class="card__title" style="font-size: var(--fs-h3);">{a.name}</h2>
            <p>{a.body}</p>
            <p class="muted"><strong>Pour qui :</strong> {a.fit}</p>
            <p class="muted"><strong>Implantation :</strong> {a.based}</p>
            <div class="btn-row" style="margin-top: var(--space-3);">
              <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>Ouvrir la fiche de l’agence</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .card .img-ph {
    width: 80px;
    height: 80px;
    aspect-ratio: 1 / 1;
  }
</style>
