---
import Layout from '../../../layouts/Layout.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'fr' as const;
const route = 'agencies/theredscroll' as const;

const platforms = ['WeChat', 'Douyin', 'RedNote', 'Weibo', '+14 autres'];

const services = [
  {
    key: 'plan',
    title: 'Concevoir',
    items: [
      { name: 'Stratégie, campagnes et analytics', body: "Étude de marché et concurrence, sélection des plateformes, calendrier éditorial, KPI alignés sur les objectifs business, tableaux de bord et social listening." },
      { name: 'Entrée sur le marché chinois', body: "Création des comptes, vérification, intégration e-commerce avec Tmall, JD et Douyin Shop, naming chinois et packs d'assets prêts pour chaque plateforme." },
    ],
  },
  {
    key: 'run',
    title: 'Opérer',
    items: [
      { name: 'Couverture des plateformes', body: "WeChat, Douyin, RedNote et Weibo au cœur. Bilibili, Kuaishou, Zhihu, Toutiao et d'autres en option transparente." },
      { name: 'Production de contenu', body: 'Stratégie pilotée par des humains. Visuels et vidéos AIGC via HubStudio.ai. Tournages réels en Chine. Relecture native chinoise.' },
      { name: 'Planification et achat média', body: 'Achat média sur WeChat, Douyin, RedNote, Weibo et Baidu. Reporting hebdo et mensuel CPM, CPC, CPA, ROAS. Aucune marge sur le budget média.' },
      { name: "Marketing d'influence", body: "Données d'engagement vérifiées, détection de faux abonnés, ciblage par niche. Briefs, co-création, publication, live commerce et reporting ROI." },
    ],
  },
  {
    key: 'sustain',
    title: 'Faire durer',
    items: [
      { name: 'CRM et domaine privé', body: 'Mise en place de WeCom, CRM WeChat, gestion de communauté, flux service client et programmes de fidélité.' },
      { name: 'Formation et conseil', body: "Masterclasses WeChat, Douyin, RedNote et Weibo. Ateliers contenu, influence et achat média. Conseil stratégique." },
    ],
  },
];

const visitUrl = 'https://theredscroll.com';
const visitLabel = 'Visiter theredscroll.com';
---

<Layout
  locale={locale}
  route={route}
  title="Agence réseaux sociaux chinois. Périmètre fixe. Prix fixe."
  description="Nous développons les réseaux sociaux en Chine des marques internationales. Périmètre fixe. Prix fixe. Équipe sur le terrain à Shanghai et Hong Kong. Prenez rendez-vous."
>
  <section class="trs-hero">
    <div class="trs-hero__bg" aria-hidden="true">
      <span class="trs-hero__blob trs-hero__blob--a"></span>
      <span class="trs-hero__blob trs-hero__blob--b"></span>
      <span class="trs-hero__blob trs-hero__blob--c"></span>
      <span class="trs-hero__grid-lines"></span>
    </div>

    <div class="container trs-hero__container">
      <div class="trs-hero__grid">
        <div class="trs-hero__content">
          <img src="/AgencyLogos/TheredScroll%20PNG.png" alt="Logo TheRedScroll" class="trs-hero__logo" width="180" height="40" loading="eager" decoding="async" />
          <span class="eyebrow eyebrow--rule">Réseaux sociaux chinois · Périmètre fixe · Prix fixe</span>
          <h1 class="trs-hero__title">
            Nous publions sur les
            <span class="trs-hero__phrase trs-hero__phrase--platforms">plateformes chinoises</span>.
            <span class="trs-hero__phrase trs-hero__phrase--daily">Tous les jours</span>.
            <span class="trs-hero__phrase trs-hero__phrase--ground">Depuis le terrain</span>.
          </h1>
          <p class="trs-hero__lead">La Chine tourne sur ses propres plateformes. WeChat, Douyin, RedNote, Weibo, et quatorze autres. Le savoir par un slide n'a rien à voir avec ouvrir ces applis chaque matin, ce que, franchement, la plupart des agences ne font pas.</p>
          <div class="trs-hero__actions">
            <a class="btn btn--primary trs-hero__cta" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
          </div>
          <div class="trs-hero__clients">
            <span class="trs-hero__clients-label">En activité sur</span>
            <ul class="trs-hero__clients-list">
              {platforms.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </div>

        <div class="trs-hero__media">
          <a class="browser-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
            <div class="browser">
              <div class="browser__chrome">
                <span class="browser__dots">
                  <span class="browser__dot browser__dot--r"></span>
                  <span class="browser__dot browser__dot--y"></span>
                  <span class="browser__dot browser__dot--g"></span>
                </span>
                <span class="browser__url">theredscroll.com</span>
              </div>
              <div class="browser__viewport">
                <img src="/images/theredscroll-home.webp" alt="Page d'accueil theredscroll.com" class="browser__shot" width="1408" height="832" loading="eager" decoding="async" />
                <span class="browser__visit" aria-hidden="true">
                  <span>Voir le site</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                </span>
              </div>
            </div>
          </a>

          <div class="trs-hero__chip trs-hero__chip--cities">
            <span class="trs-hero__chip-dot"></span>
            Shanghai · Hong Kong · Équipe native
          </div>
          <div class="trs-hero__chip trs-hero__chip--ai">
            HubStudio.ai · AIGC à l'échelle
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="eyebrow">Notre méthode</span>
      <p class="lead">Chaque post, vidéo, campagne et rapport est défini en amont dans un périmètre écrit. Un chiffre par offre. Pas de coûts cachés, pas de scope creep. Notre équipe travaille depuis Shanghai et Hong Kong, avec des locuteurs natifs, un vrai accès aux plateformes et des relations directes avec les influenceurs chinois. Nous avons construit HubStudio.ai pour produire visuels, vidéos et copy à une fraction du coût d'avant. La stratégie reste humaine.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Ce que nous faisons</span>
        <h2 class="balance">Trois voies. Huit piliers. De bout en bout.</h2>
      </header>
      <div class="services">
        {services.map((s) => (
          <article class={`service-card service-card--${s.key}`}>
            <header class="service-card__head">
              <span class={`service-card__pip service-card__pip--${s.key}`} aria-hidden="true"></span>
              <h3 class="service-card__title">{s.title}</h3>
            </header>
            <ul class="service-card__list">
              {s.items.map((it) => (
                <li class="service-card__item">
                  <span class="service-card__name">{it.name}.</span>
                  <span class="service-card__body">{it.body}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="eyebrow">Nos offres</span>
      <p class="lead">Trois paliers, tous chiffrés en amont. Discovery, pour les marques qui testent la Chine : trois mois sur une plateforme. Growth, pour les marques qui changent d'échelle : six mois sur deux ou trois plateformes. Premium, pour les marques qui parient gros sur la Chine : douze mois sur quatre plateformes ou plus. Chaque palier est livré avec un périmètre écrit et un prix fixe.</p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">Plus d'abonnés. Plus d'engagement. Plus de leads. Plus de conversions.</h2>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Parler à l'équipe</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .trs-hero {
    position: relative;
    padding: clamp(5rem, 10vh, 7.5rem) 0 clamp(3rem, 6vh, 5rem);
    background: linear-gradient(180deg, #ffffff 0%, #fdf5f2 100%);
    overflow: hidden;
    isolation: isolate;
  }
  .trs-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .trs-hero__blob {
    position: absolute;
    display: block;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.55;
    will-change: transform;
  }
  .trs-hero__blob--a {
    width: 520px; height: 520px;
    top: -180px; left: -120px;
    background: radial-gradient(circle, rgba(200,16,46,0.45), transparent 65%);
    animation: trsFloatA 18s ease-in-out infinite;
  }
  .trs-hero__blob--b {
    width: 460px; height: 460px;
    top: 30%; right: -180px;
    background: radial-gradient(circle, rgba(217,154,58,0.38), transparent 65%);
    animation: trsFloatB 22s ease-in-out infinite;
  }
  .trs-hero__blob--c {
    width: 380px; height: 380px;
    bottom: -160px; left: 35%;
    background: radial-gradient(circle, rgba(45,106,79,0.30), transparent 65%);
    animation: trsFloatC 26s ease-in-out infinite;
  }
  @keyframes trsFloatA { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,30px)} }
  @keyframes trsFloatB { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,40px)} }
  @keyframes trsFloatC { 0%,100%{transform:translate(0,0)} 50%{transform:translate(20px,-40px)} }

  .trs-hero__grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(15,23,42,0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(15,23,42,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 30%, transparent 75%);
  }

  .trs-hero__container { position: relative; z-index: 1; }
  .trs-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .trs-hero__content { min-width: 0; }
  .trs-hero__logo {
    display: block;
    width: auto;
    height: 40px;
    object-fit: contain;
    margin-bottom: var(--space-3);
  }

  .trs-hero__title {
    font-size: clamp(2.4rem, 4.4vw + 0.6rem, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--bbg-ink);
    margin: var(--space-4) 0 var(--space-5);
    max-width: 18ch;
  }
  .trs-hero__phrase {
    position: relative;
    white-space: nowrap;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .trs-hero__phrase--platforms { background-image: linear-gradient(120deg, #c8102e 0%, #ff5e75 100%); }
  .trs-hero__phrase--daily     { background-image: linear-gradient(120deg, #d99a3a 0%, #ffcf6f 100%); }
  .trs-hero__phrase--ground    { background-image: linear-gradient(120deg, #2d6a4f 0%, #52b788 100%); }
  .trs-hero__phrase::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -0.08em;
    height: 0.18em;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.18;
    transform: scaleX(0.65);
    transform-origin: left;
    transition: transform 480ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .trs-hero__phrase--platforms::after { background: #c8102e; }
  .trs-hero__phrase--daily::after     { background: #d99a3a; }
  .trs-hero__phrase--ground::after    { background: #2d6a4f; }
  .trs-hero:hover .trs-hero__phrase::after { transform: scaleX(1); }

  .trs-hero__lead {
    max-width: 52ch;
    font-size: var(--fs-lead);
    color: var(--bbg-text);
    margin-bottom: var(--space-5);
  }

  .trs-hero__actions { margin-bottom: var(--space-6); }
  .trs-hero__cta {
    box-shadow: 0 12px 28px -14px rgba(200,16,46,0.55);
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1), box-shadow 220ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .trs-hero__cta:hover { transform: translateY(-2px); box-shadow: 0 18px 36px -14px rgba(200,16,46,0.65); }

  .trs-hero__clients {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(15,23,42,0.08);
  }
  .trs-hero__clients-label {
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bbg-text-muted);
  }
  .trs-hero__clients-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
  }
  .trs-hero__clients-list li {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--bbg-ink);
    letter-spacing: -0.005em;
    position: relative;
  }
  .trs-hero__clients-list li + li::before {
    content: "";
    position: absolute;
    left: calc(var(--space-5) * -0.5);
    top: 50%;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #c8102e;
    transform: translate(-50%, -50%);
    opacity: 0.6;
  }

  .trs-hero__media { position: relative; min-width: 0; perspective: 1600px; }
  .browser-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 14px;
  }
  .browser-link:focus-visible { outline: 2px solid #c8102e; outline-offset: 4px; }
  .browser-link:hover .browser__visit { opacity: 1; transform: translateY(0); }
  .browser-link:hover .browser { transform: rotate(0deg) translateY(-2px); }
  .browser__visit {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(15,23,42,0.85);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2,0.8,0.2,1);
    pointer-events: none;
    z-index: 2;
  }
  .browser {
    position: relative;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 28px 60px -22px rgba(15,23,42,0.30),
      0 6px 18px -6px rgba(15,23,42,0.16);
    border: 1px solid rgba(15,23,42,0.08);
    transform: rotate(-1.2deg) translateZ(0);
    transition: transform 480ms cubic-bezier(0.2,0.8,0.2,1), box-shadow 480ms cubic-bezier(0.2,0.8,0.2,1);
    animation: trsBrowserIn 720ms cubic-bezier(0.2,0.8,0.2,1) 0.1s backwards;
  }
  @keyframes trsBrowserIn {
    from { opacity: 0; transform: rotate(-1.2deg) translateY(24px); }
    to { opacity: 1; transform: rotate(-1.2deg) translateY(0); }
  }
  .trs-hero__media:hover .browser {
    transform: rotate(0deg) translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 36px 70px -22px rgba(15,23,42,0.34),
      0 8px 22px -6px rgba(15,23,42,0.18);
  }
  .browser__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
    border-bottom: 1px solid rgba(15,23,42,0.08);
  }
  .browser__dots { display: inline-flex; gap: 6px; }
  .browser__dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .browser__dot--r { background: #ff5f57; }
  .browser__dot--y { background: #febc2e; }
  .browser__dot--g { background: #28c840; }
  .browser__url {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--bbg-text-muted);
    background: rgba(15,23,42,0.04);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
    max-width: 360px;
    margin: 0 auto;
  }
  .browser__viewport {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #f7f9fb;
    overflow: hidden;
  }
  .browser__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .trs-hero__chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(15,23,42,0.08);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--bbg-ink);
    letter-spacing: 0.01em;
    box-shadow: 0 12px 28px -14px rgba(15,23,42,0.25);
    white-space: nowrap;
  }
  .trs-hero__chip--cities {
    top: -18px; left: -10px;
    animation: trsChipIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.35s backwards, trsChipBobA 7s ease-in-out 1s infinite;
  }
  .trs-hero__chip--ai {
    bottom: -18px; right: -10px;
    animation: trsChipIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.5s backwards, trsChipBobB 8s ease-in-out 1.5s infinite;
  }
  .trs-hero__chip-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34,197,94,0.5);
    animation: trsChipPulse 2.4s ease-in-out infinite;
  }
  @keyframes trsChipIn {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes trsChipBobA { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @keyframes trsChipBobB { 0%,100% { transform: translateY(0); } 50% { transform: translateY(6px); } }
  @keyframes trsChipPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
  }

  @media (max-width: 1023px) {
    .trs-hero__grid { grid-template-columns: 1fr; gap: var(--space-7); }
    .trs-hero__title { max-width: none; }
    .trs-hero__chip--cities { left: 8px; top: -14px; }
    .trs-hero__chip--ai { right: 8px; bottom: -14px; }
  }
  @media (max-width: 639px) {
    .trs-hero__chip { font-size: 0.7rem; padding: 6px 10px; }
    .trs-hero__chip--cities { display: none; }
  }

  .services {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 1023px) { .services { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 767px) { .services { grid-template-columns: 1fr; } }

  .service-card {
    position: relative;
    background: #ffffff;
    border: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    border-radius: 18px;
    padding: var(--space-5) var(--space-5) var(--space-6);
    overflow: hidden;
    transition:
      transform 280ms cubic-bezier(0.2,0.8,0.2,1),
      box-shadow 280ms cubic-bezier(0.2,0.8,0.2,1),
      border-color 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .service-card::before {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    opacity: 0.6;
  }
  .service-card--plan    { color: #2d6a4f; }
  .service-card--run     { color: #c8102e; }
  .service-card--sustain { color: #d99a3a; }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: currentColor;
    box-shadow: 0 22px 44px -22px rgba(15,23,42,0.22);
  }
  .service-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--space-4);
  }
  .service-card__pip {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 14%, transparent);
  }
  .service-card__title {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--bbg-ink);
    margin: 0;
  }
  .service-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .service-card__item {
    display: block;
    color: var(--bbg-text);
    font-size: 0.95rem;
    line-height: 1.55;
    padding-left: 18px;
    position: relative;
  }
  .service-card__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 1px;
    background: currentColor;
    opacity: 0.7;
  }
  .service-card__name {
    font-weight: 600;
    color: var(--bbg-ink);
    margin-right: 0.25rem;
  }
  .service-card__body { color: var(--bbg-text); }

  @media (prefers-reduced-motion: reduce) {
    .trs-hero__blob, .trs-hero__chip, .trs-hero__chip-dot, .browser, .service-card {
      animation: none !important;
