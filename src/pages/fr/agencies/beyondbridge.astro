            e.preventDefault();
            const dir = e.key === 'ArrowRight' ? 1 : -1;
            const next = (i + dir + tabs.length) % tabs.length;
            tabs[next].focus(); activate(next);
          }
        });
      });
    }

    if (!reduced) {
      const hero = document.querySelector<HTMLElement>('[data-hero]');
      const tilt = document.querySelector<HTMLElement>('[data-tilt] .bb-hero__feature-frame');
      const bg = document.querySelector<HTMLElement>('[data-parallax-bg]');
      if (hero && tilt) {
        let raf = 0; let mx = 0, my = 0; let cx = 0, cy = 0;
        const onMove = (e: MouseEvent) => {
          const rect = hero.getBoundingClientRect();
          mx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
          my = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
          if (!raf) raf = requestAnimationFrame(loop);
        };
        const onLeave = () => { mx = 0; my = 0; if (!raf) raf = requestAnimationFrame(loop); };
        const loop = () => {
          cx += (mx - cx) * 0.08; cy += (my - cy) * 0.08;
          tilt.style.setProperty('--tilt-x', `${(-cx * 5).toFixed(2)}deg`);
          tilt.style.setProperty('--tilt-y', `${(cy * 4).toFixed(2)}deg`);
          if (Math.abs(mx - cx) > 0.001 || Math.abs(my - cy) > 0.001) { raf = requestAnimationFrame(loop); } else { raf = 0; }
        };
        hero.addEventListener('mousemove', onMove);
        hero.addEventListener('mouseleave', onLeave);
      }
      if (bg) {
        const onScroll = () => {
          const rect = bg.getBoundingClientRect();
          const offset = Math.max(-200, Math.min(200, rect.top * -0.18));
          (bg as HTMLElement).style.setProperty('--parallax-y', `${offset}px`);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    }

    if (!reduced) {
      const magnets = document.querySelectorAll<HTMLElement>('[data-magnet]');
      magnets.forEach((m) => {
        m.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = m.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          m.style.setProperty('--x', `${(x * 0.18).toFixed(1)}px`);
          m.style.setProperty('--y', `${(y * 0.18).toFixed(1)}px`);
        });
        m.addEventListener('mouseleave', () => {
          m.style.setProperty('--x', '0px');
          m.style.setProperty('--y', '0px');
        });
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
