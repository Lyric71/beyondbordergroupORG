---
import Layout from '../../../layouts/Layout.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'fr' as const;
const route = 'agencies/beyondbridge' as const;

type LaneKey = 'build' | 'demand' | 'close';
const lanes: Array<{
  key: LaneKey;
  title: string;
  intro: string;
  image: string;
  items: { name: string; body: string }[];
}> = [
  {
    key: 'build',
    title: 'Construire',
    intro: "Une marque à laquelle un acheteur occidental fera confiance, sur un site qui ne sent pas la traduction.",
    image: '/images/bb-bridge-build.webp',
    items: [
      { name: 'Conseil', body: "Conseil senior sur les grandes décisions. Choix de marché, positionnement, tarification, feu vert ou non. En autonome pour les entreprises qui veulent la réflexion sans l'exécution." },
      { name: "Stratégie de marque pour l'export", body: 'Pensée pour les marchés que vous adressez, pas reprise du référentiel chinois.' },
      { name: 'Site web', body: "UX et UI taillées pour l'œil occidental, pas pour le chinois. Hébergement hors Firewall, rapide à Hambourg comme à Houston." },
    ],
  },
  {
    key: 'demand',
    title: 'Demande',
    intro: 'Les canaux qui vous placent face aux acheteurs déjà en recherche.',
    image: '/images/bb-bridge-demand.webp',
    items: [
      { name: 'LinkedIn', body: "Là où vivent les acheteurs B2B occidentaux. Profil du fondateur, page entreprise, contenu et prospection." },
      { name: 'SEO et GEO', body: "Trouvé sur Google, cité par ChatGPT, Perplexity et Claude. Pensé pour les acheteurs qui cherchent en anglais, allemand, français." },
      { name: 'Google Ads', body: 'Référencement payant qui amène des leads qualifiés pendant que le SEO monte en puissance. Compte-rendu en RMB.' },
    ],
  },
  {
    key: 'close',
    title: 'Conclure',
    intro: "De vraies personnes dans sept marchés. Elles prennent le premier appel. Quand l'affaire vaut un avion, elles vont serrer la main de l'acheteur.",
    image: '/images/bb-bridge-sell.webp',
    items: [
      { name: 'Force de vente externalisée', body: "Représentants natifs en France, Allemagne, Italie, Royaume-Uni, États-Unis, Australie et Amérique latine. Votre équipe sur place, sur chaque marché." },
    ],
  },
];

const visitUrl = 'https://beyondbridge.com';
const visitLabel = 'Visiter beyondbridge.com';
---

<Layout
  locale={locale}
  route={route}
  title="BeyondBridge. Nous faisons grandir les entreprises chinoises à l'étranger."
  description="Nous aidons les entreprises chinoises à trouver leurs acheteurs occidentaux. Marque, site, LinkedIn, ads et de vrais commerciaux dans sept pays. Une seule stack. Un seul pipeline."
>
  <section class="bb-hero" data-hero>
    <div class="bb-hero__bg" aria-hidden="true">
      <img src="/images/bb-bridge-hero-bg.webp" alt="" class="bb-hero__bg-img" data-parallax-bg />
      <div class="bb-hero__bg-scrim"></div>
      <div class="bb-hero__bg-grain"></div>
      <div class="bb-hero__bg-grid"></div>
    </div>

    <div class="container bb-hero__main">
      <div class="bb-hero__content">
        <img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="BeyondBridge" class="bb-hero__logo" width="240" height="48" loading="eager" decoding="async" />

        <h1 class="bb-hero__title">
          <span class="bb-hero__line" data-anim="word">Nous faisons grandir</span>
          <span class="bb-hero__line" data-anim="word">
            <em class="bb-hero__phrase">les entreprises chinoises</em>
          </span>
          <span class="bb-hero__line" data-anim="word">à l'étranger.</span>
        </h1>

        <p class="bb-hero__lead" data-anim="fade">La plupart des entreprises chinoises qui partent à l'étranger perdent deux ans avant d'admettre que la méthode ne fonctionne pas. Nous comblons l'écart entre un excellent produit et un acheteur.</p>

        <div class="bb-hero__cta-row" data-anim="fade">
          <a class="bb-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-magnet>
            <span class="bb-magnet__bg"></span>
            <span class="bb-magnet__label">{visitLabel}</span>
            <span class="bb-magnet__arrow" aria-hidden="true">→</span>
          </a>
          <a class="bb-hero__secondary" href={pathFor('contact', locale)} data-anim="fade">
            <span>Prendre rendez-vous</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="bb-hero__feature" data-tilt>
        <div class="bb-hero__feature-frame">
          <img src="/images/bb-bridge-hero-feature.webp" alt="Un dirigeant chinois sortant d'une tour de bureaux à Munich au crépuscule" class="bb-hero__feature-img" width="1408" height="832" loading="eager" decoding="async" />
          <div class="bb-hero__feature-scrim"></div>

          <div class="bb-hero__chip bb-hero__chip--stack">
            <span class="bb-hero__chip-label">La stack</span>
            <span>Marque · Site · LinkedIn · SEO · Ads · Vente</span>
          </div>
          <div class="bb-hero__chip bb-hero__chip--cities">
            <span class="bb-hero__chip-label">Sur le terrain</span>
            <span>Paris · Munich · Milan · Londres · New York · Sydney · São Paulo</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#track" class="bb-hero__scroll" aria-label="Défiler">
      <span>Défiler</span>
      <span class="bb-hero__scroll-line"></span>
    </a>
  </section>

  <section class="bb-track" id="track">
    <div class="container">
      <div class="bb-track__grid">
        <div class="bb-track__numeral" aria-hidden="true">
          <span class="bb-track__num" data-count="7">0</span>
          <span class="bb-track__num-shadow">7</span>
        </div>
        <div class="bb-track__copy">
          <span class="eyebrow">Référence</span>
          <h2 class="bb-track__title balance">Sept villes. Une équipe. Un pipeline qui va de l'usine au premier contrat signé.</h2>
          <p class="bb-track__lead">
            Nous ne sommes pas des consultants qui rendent une présentation et disparaissent. Nous sommes des opérateurs. Notre PDG a dirigé Publicis Commerce en Chine pendant des années. Nous construisons la marque, le site, la présence LinkedIn, la recherche et les ads. Puis nous mettons de vraies personnes sur le terrain, qui décrochent le téléphone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bb-gap">
    <div class="bb-gap__bg" aria-hidden="true"></div>
    <div class="container bb-gap__container">
      <span class="eyebrow eyebrow--on-dark">L'écart</span>
      <h2 class="bb-gap__title">
        <span class="bb-gap__line" data-line>Traduire la page d'accueil.</span>
        <span class="bb-gap__line" data-line>Recruter quelqu'un à Francfort.</span>
        <span class="bb-gap__line" data-line>Envoyer le fondateur sur place deux fois par an.</span>
        <span class="bb-gap__line" data-line>Attendre qu'un distributeur appelle.</span>
      </h2>
      <div class="bb-gap__statement" data-line>
        <p>L'appel arrive rarement.</p>
        <p>Le site a une tête de 2014. La recrue démissionne avant six mois. Et l'usine continue de fabriquer d'excellents produits dont les bons acheteurs n'ont jamais entendu parler.</p>
        <p class="bb-gap__emphasis">C'est là que les entreprises meurent. Dans l'écart entre un excellent produit et un acheteur à Hambourg ou à Houston qui décroche vraiment.</p>
      </div>
    </div>
  </section>

  <section class="bb-services" id="services">
    <div class="container">
      <header class="bb-services__header">
        <span class="eyebrow">Ce que nous faisons</span>
        <h2 class="bb-services__title">
          Sept modules. <em>Un pipeline.</em><br />
          Prenez la stack entière, ou un module à l'unité.
        </h2>
        <p class="bb-services__lead">Forfait trimestriel avec une phase de mise en place. Choisissez la voie qui correspond à votre moment, ou prenez les trois.</p>
      </header>

      <div class="bb-services__shell" data-tabs>
        <div class="bb-services__nav" role="tablist" aria-label="Voies de service">
          {lanes.map((s, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`bb-services__tab bb-services__tab--${s.key} ${i === 0 ? 'is-active' : ''}`}
              data-tab={s.key}
              id={`bb-tab-${s.key}`}
              aria-controls={`bb-panel-${s.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="bb-services__tab-pip" aria-hidden="true"></span>
              <span class="bb-services__tab-label">{s.title}</span>
              <span class="bb-services__tab-count">{s.items.length} {s.items.length === 1 ? 'service' : 'services'}</span>
            </button>
          ))}
          <span class="bb-services__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="bb-services__panels">
          {lanes.map((s, i) => (
            <div
              class={`bb-services__panel bb-services__panel--${s.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`bb-panel-${s.key}`}
              aria-labelledby={`bb-tab-${s.key}`}
              data-panel={s.key}
              hidden={i !== 0}
            >
              <div class="bb-services__panel-grid">
                <div class="bb-services__panel-image">
                  <div class="bb-services__panel-frame">
                    <img src={s.image} alt={`${s.title}`} loading="lazy" decoding="async" />
                    <div class={`bb-services__panel-tag bb-services__panel-tag--${s.key}`}>
                      <span>{s.title}</span>
                    </div>
                  </div>
                  <div class={`bb-services__panel-stamp bb-services__panel-stamp--${s.key}`} aria-hidden="true">
                    {s.key === 'build' && '立'}
                    {s.key === 'demand' && '引'}
                    {s.key === 'close' && '成'}
                  </div>
                </div>

                <div class="bb-services__panel-content">
                  <p class="bb-services__panel-intro">{s.intro}</p>
                  <ul class="bb-services__list">
                    {s.items.map((it) => (
                      <li class="bb-services__item">
                        <span class={`bb-services__item-pip bb-services__item-pip--${s.key}`} aria-hidden="true"></span>
                        <span class="bb-services__item-text">
                          <span class="bb-services__item-name">{it.name}.</span>
                          <span class="bb-services__item-body">{it.body}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bb-operate">
    <div class="bb-operate__bg" aria-hidden="true"></div>
    <div class="container bb-operate__container">
      <span class="eyebrow eyebrow--on-dark">Notre fonctionnement</span>
      <h2 class="bb-operate__title">
        <span class="bb-operate__line" data-line>Une seule stack.</span>
        <span class="bb-operate__line" data-line>Une seule équipe.</span>
        <span class="bb-operate__line" data-line>Un seul pipeline.</span>
      </h2>
      <div class="bb-operate__statement" data-line>
        <p>De votre usine à votre premier contrat signé.</p>
        <p class="bb-operate__emphasis">Chaque trimestre d'attente, un concurrent plus petit se rapproche de votre acheteur.</p>
      </div>
    </div>
  </section>

  <section class="bb-cta">
    <div class="bb-cta__bg" aria-hidden="true">
      <img src="/images/bb-bridge-hero-bg.webp" alt="" />
      <div class="bb-cta__bg-scrim"></div>
    </div>
    <div class="container bb-cta__content">
      <span class="eyebrow eyebrow--on-dark">Quand vous êtes prêts</span>
      <h2 class="bb-cta__title balance">Prendre rendez-vous.<br />Nous vous dirons à quoi ressembleront vos quatre-vingt-dix premiers jours.</h2>
      <div class="bb-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Parler à l'équipe</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .bb-hero, .bb-track, .bb-gap, .bb-services, .bb-operate, .bb-cta {
    --bb-build: #4f46e5; --bb-build-soft: #818cf8; --bb-demand: #f97316; --bb-demand-soft: #fdba74; --bb-close: #10b981; --bb-close-soft: #6ee7b7; --bb-ink: #0c1220;
  }

  .bb-hero { position: relative; min-height: 88vh; padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem); overflow: hidden; isolation: isolate; color: #fff; background: var(--bb-ink); }
  .bb-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .bb-hero__bg-img { position: absolute; inset: -8% -4% -4% -4%; width: 108%; height: 112%; object-fit: cover; object-position: center 50%; will-change: transform; transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04); filter: saturate(0.9) contrast(1.05) brightness(0.62); }
  .bb-hero__bg-scrim { position: absolute; inset: 0; background: linear-gradient(110deg, rgba(8,12,24,0.88) 0%, rgba(8,12,24,0.66) 38%, rgba(8,12,24,0.32) 65%, rgba(8,12,24,0.6) 100%), linear-gradient(180deg, rgba(8,12,24,0.55) 0%, rgba(8,12,24,0.05) 30%, rgba(8,12,24,0) 60%, rgba(8,12,24,0.85) 100%); }
  .bb-hero__bg-grain { position: absolute; inset: 0; background-image: radial-gradient(1200px 600px at 18% 28%, rgba(99,102,241,0.20), transparent 65%), radial-gradient(900px 500px at 92% 78%, rgba(249,115,22,0.15), transparent 70%); mix-blend-mode: screen; }
  .bb-hero__bg-grid { position: absolute; inset: 0; background-image: linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 88px 88px; mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%); opacity: 0.55; }
  .bb-hero__main { position: relative; z-index: 3; display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr); gap: clamp(2rem, 5vw, 5rem); align-items: center; }
  .bb-hero__content { min-width: 0; max-width: 36rem; }
  .bb-hero__logo { display: block; width: auto; height: 44px; filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.4)); margin-bottom: var(--space-5); opacity: 0; animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.1s forwards; }
  .bb-hero__title { font-size: clamp(2.5rem, 5vw + 0.5rem, 5.4rem); line-height: 0.98; letter-spacing: -0.035em; font-weight: 600; color: #fff; margin: 0 0 var(--space-5); max-width: 14ch; text-wrap: balance; }
  .bb-hero__line { display: block; overflow: hidden; }
  .bb-hero__line[data-anim="word"] { transform: translateY(110%); opacity: 0; animation: bbWordIn 880ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards; }
  .bb-hero__line[data-anim="word"]:nth-child(1) { animation-delay: 0.30s; }
  .bb-hero__line[data-anim="word"]:nth-child(2) { animation-delay: 0.42s; }
  .bb-hero__line[data-anim="word"]:nth-child(3) { animation-delay: 0.54s; }
  @keyframes bbWordIn { from { transform: translateY(110%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .bb-hero__phrase { font-style: normal; background-image: linear-gradient(120deg, var(--bb-build-soft) 0%, var(--bb-build) 50%, var(--bb-demand) 100%); background-clip: text; -webkit-background-clip: text; color: transparent; -webkit-text-fill-color: transparent; }
  .bb-hero__lead { max-width: 46ch; font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.2rem); color: rgba(255,255,255,0.82); margin: 0 0 var(--space-5); opacity: 0; animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.85s forwards; }
  .bb-hero__cta-row { display: inline-flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; opacity: 0; animation: bbFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 1s forwards; }
  .bb-magnet { --x: 0px; --y: 0px; position: relative; display: inline-flex; align-items: center; gap: 14px; padding: 16px 26px 16px 28px; border-radius: 999px; color: #fff; text-decoration: none; font-family: var(--font-display); font-size: 1rem; font-weight: 600; letter-spacing: -0.005em; overflow: hidden; isolation: isolate; transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1); transform: translate(var(--x), var(--y)); }
  .bb-magnet__bg { position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(120deg, var(--bb-build) 0%, #3730a3 100%); box-shadow: 0 16px 36px -10px rgba(79,70,229,0.55), inset 0 1px 0 rgba(255,255,255,0.2); z-index: -1; transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1); }
  .bb-magnet:hover .bb-magnet__bg { transform: scale(1.04); }
  .bb-magnet__arrow { display: inline-block; transform: translateX(0); transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1); }
  .bb-magnet:hover .bb-magnet__arrow { transform: translateX(4px); }
  .bb-hero__secondary { display: inline-flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.92); font-family: var(--font-display); font-size: 1rem; font-weight: 500; text-decoration: none; transition: color 220ms ease; }
  .bb-hero__secondary svg { transition: transform 220ms ease; }
  .bb-hero__secondary:hover { color: var(--bb-build-soft); }
  .bb-hero__secondary:hover svg { transform: translateX(3px); }
  .bb-hero__feature { position: relative; perspective: 1600px; min-width: 0; opacity: 0; animation: bbFadeIn 900ms cubic-bezier(0.2,0.8,0.2,1) 0.5s forwards; }
  .bb-hero__feature-frame { position: relative; aspect-ratio: 4 / 5; border-radius: 20px; overflow: visible; transform-style: preserve-3d; transform: rotateY(var(--tilt-x, -3deg)) rotateX(var(--tilt-y, 2deg)); transition: transform 600ms cubic-bezier(0.2,0.8,0.2,1); }
  .bb-hero__feature-img { width: 100%; height: 100%; object-fit: cover; border-radius: 20px; display: block; box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset, 0 40px 80px -28px rgba(0,0,0,0.55), 0 12px 28px -8px rgba(0,0,0,0.35); border: 1px solid rgba(255,255,255,0.10); }
  .bb-hero__feature-scrim { position: absolute; inset: 0; border-radius: 20px; background: linear-gradient(180deg, transparent 50%, rgba(8,12,24,0.45) 100%); pointer-events: none; }
  .bb-hero__chip { position: absolute; display: inline-flex; flex-direction: column; gap: 2px; padding: 10px 14px; background: rgba(255,255,255,0.94); color: var(--bbg-ink); border: 1px solid rgba(255,255,255,0.5); border-radius: 14px; font-family: var(--font-display); font-size: 0.84rem; font-weight: 600; letter-spacing: -0.005em; box-shadow: 0 24px 50px -18px rgba(0,0,0,0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transform: translateZ(40px); max-width: 18rem; }
  .bb-hero__chip-label { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--bb-build); }
  .bb-hero__chip--stack { top: -20px; left: -28px; animation: bbFloatA 9s ease-in-out infinite; }
  .bb-hero__chip--cities { bottom: -24px; right: -20px; animation: bbFloatB 11s ease-in-out infinite; }
  .bb-hero__chip--cities .bb-hero__chip-label { color: var(--bb-close); }
  @keyframes bbFloatA { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(-7px); } }
  @keyframes bbFloatB { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(8px); } }
  .bb-hero__scroll { position: absolute; bottom: clamp(1rem, 3vh, 2rem); left: 50%; transform: translateX(-50%); z-index: 4; display: inline-flex; flex-direction: column; align-items: center; gap: 8px; color: rgba(255,255,255,0.7); text-decoration: none; font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; transition: color 220ms ease; }
  .bb-hero__scroll:hover { color: #fff; }
  .bb-hero__scroll-line { width: 1px; height: 36px; background: linear-gradient(180deg, rgba(255,255,255,0.7), rgba(255,255,255,0)); position: relative; overflow: hidden; }
  .bb-hero__scroll-line::after { content: ""; position: absolute; top: -36px; left: 0; right: 0; height: 36px; background: linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.95)); animation: bbScrollLine 1.8s ease-in-out infinite; }
  @keyframes bbScrollLine { 0% { top: -36px; } 100% { top: 36px; } }
  @keyframes bbFadeIn { to { opacity: 1; } }
  @keyframes bbPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.55); } 50% { box-shadow: 0 0 0 7px rgba(16,185,129,0); } }
  @media (max-width: 1023px) {
    .bb-hero__main { grid-template-columns: 1fr; gap: var(--space-7); }
    .bb-hero__title { max-width: none; }
    .bb-hero__chip--stack { top: -14px; left: 8px; }
    .bb-hero__chip--cities { bottom: -14px; right: 8px; }
  }
  @media (max-width: 639px) {
    .bb-hero__chip { font-size: 0.72rem; padding: 8px 10px; }
    .bb-hero__chip--stack { display: none; }
    .bb-hero__scroll { display: none; }
  }

  .bb-track { padding: clamp(5rem, 10vh, 8rem) 0 clamp(4rem, 8vh, 6rem); background: linear-gradient(180deg, #ffffff 0%, var(--bbg-paper) 100%); position: relative; }
  .bb-track__grid { display: grid; grid-template-columns: minmax(0, auto) minmax(0, 1fr); gap: clamp(2rem, 5vw, 4rem); align-items: center; padding-bottom: var(--space-4); }
  @media (max-width: 1023px) { .bb-track__grid { grid-template-columns: 1fr; gap: var(--space-6); } }
  .bb-track__numeral { position: relative; line-height: 0.85; letter-spacing: -0.06em; font-family: var(--font-display); font-weight: 600; color: var(--bbg-ink); }
  .bb-track__num { position: relative; z-index: 2; display: inline-block; font-size: clamp(7rem, 18vw, 16rem); background: linear-gradient(180deg, var(--bbg-ink) 0%, #3a3f4f 100%); background-clip: text; -webkit-background-clip: text; color: transparent; -webkit-text-fill-color: transparent; font-variant-numeric: tabular-nums; }
  .bb-track__num-shadow { position: absolute; top: 4px; left: 5px; font-size: clamp(7rem, 18vw, 16rem); color: transparent; -webkit-text-stroke: 1px rgba(79,70,229,0.18); z-index: 1; pointer-events: none; user-select: none; }
  .bb-track__copy { max-width: 56ch; }
