  .cwf-hero__scroll { position: absolute; bottom: clamp(0.5rem, 2vh, 1.25rem); left: 50%; transform: translateX(-50%); z-index: 4; display: inline-flex; flex-direction: column; align-items: center; gap: 8px; color: rgba(255,255,255,0.7); text-decoration: none; font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; transition: color 220ms ease; }
