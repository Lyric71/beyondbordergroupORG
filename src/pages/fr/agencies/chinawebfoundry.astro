  @media (prefers-reduced-motion: reduce) {
    .cwf-hero__bg-img, .cwf-hero__line[data-anim="word"], .cwf-hero__lead, .cwf-hero__cta-row, .cwf-hero__logo, .cwf-hero__chip, .cwf-services__panel.is-active .cwf-services__item, [data-anim] {
      animation: none !important; transition: none !important; opacity: 1 !important; transform: none !important;
    }
  }
</style>

<script>
  const init = () => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const counter = document.querySelector<HTMLElement>('[data-cwf-count]');
    if (counter) {
      const target = Number(counter.dataset.cwfCount || '0');
      if (reduced) {
        counter.textContent = String(target);
      } else {
        const cio = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const start = performance.now();
                const dur = 1600;
                const tick = (now: number) => {
                  const t = Math.min(1, (now - start) / dur);
                  const eased = 1 - Math.pow(1 - t, 3);
                  counter.textContent = String(Math.round(eased * target));
                  if (t < 1) requestAnimationFrame(tick);
                };
                requestAnimationFrame(tick);
                cio.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.4 }
        );
        cio.observe(counter);
      }
    }

    const tabsRoot = document.querySelector<HTMLElement>('[data-cwf-tabs]');
    if (tabsRoot) {
      const tabs = Array.from(tabsRoot.querySelectorAll<HTMLButtonElement>('.cwf-services__tab'));
      const panels = Array.from(tabsRoot.querySelectorAll<HTMLElement>('.cwf-services__panel'));
      const indicator = tabsRoot.querySelector<HTMLElement>('.cwf-services__tab-indicator');
      const setIndicator = (idx: number) => {
        if (!indicator) return;
        indicator.style.transform = `translateX(${idx * 100}%)`;
        indicator.style.width = `calc((100% - 12px) / ${tabs.length})`;
      };
      const activate = (idx: number) => {
        tabs.forEach((t, i) => {
          const active = i === idx;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          t.tabIndex = active ? 0 : -1;
        });
        panels.forEach((p, i) => {
          const active = i === idx;
          p.classList.toggle('is-active', active);
          if (active) { p.removeAttribute('hidden'); } else { p.setAttribute('hidden', ''); }
        });
        setIndicator(idx);
      };
      setIndicator(Math.max(0, tabs.findIndex((t) => t.classList.contains('is-active'))));
      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activate(i));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
            e.preventDefault();
            const dir = e.key === 'ArrowRight' ? 1 : -1;
            const next = (i + dir + tabs.length) % tabs.length;
            tabs[next].focus();
            activate(next);
          }
        });
      });
    }

    if (!reduced) {
      const hero = document.querySelector<HTMLElement>('[data-cwf-hero]');
      const tilt = document.querySelector<HTMLElement>('[data-cwf-tilt] .cwf-hero__preview-frame');
      const bg = document.querySelector<HTMLElement>('[data-cwf-parallax-bg]');
      if (hero && tilt) {
        let raf = 0; let mx = 0, my = 0; let cx = 0, cy = 0;
        const onMove = (e: MouseEvent) => {
          const rect = hero.getBoundingClientRect();
          mx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
          my = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
          if (!raf) raf = requestAnimationFrame(loop);
        };
        const onLeave = () => { mx = 0; my = 0; if (!raf) raf = requestAnimationFrame(loop); };
        const loop = () => {
          cx += (mx - cx) * 0.08; cy += (my - cy) * 0.08;
          tilt.style.setProperty('--tilt-x', `${(-cx * 5).toFixed(2)}deg`);
          tilt.style.setProperty('--tilt-y', `${(cy * 4).toFixed(2)}deg`);
          if (Math.abs(mx - cx) > 0.001 || Math.abs(my - cy) > 0.001) { raf = requestAnimationFrame(loop); } else { raf = 0; }
        };
        hero.addEventListener('mousemove', onMove);
        hero.addEventListener('mouseleave', onLeave);
      }
      if (bg) {
        const onScroll = () => {
          const rect = bg.getBoundingClientRect();
          const offset = Math.max(-200, Math.min(200, rect.top * -0.18));
          (bg as HTMLElement).style.setProperty('--parallax-y', `${offset}px`);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    }

    if (!reduced) {
      const magnets = document.querySelectorAll<HTMLElement>('[data-cwf-magnet]');
      magnets.forEach((m) => {
        m.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = m.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          m.style.setProperty('--x', `${(x * 0.18).toFixed(1)}px`);
          m.style.setProperty('--y', `${(y * 0.18).toFixed(1)}px`);
        });
        m.addEventListener('mouseleave', () => {
          m.style.setProperty('--x', '0px');
          m.style.setProperty('--y', '0px');
        });
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
