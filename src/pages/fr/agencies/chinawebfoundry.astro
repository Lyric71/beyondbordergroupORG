  .cwf-hero__chip { position: absolute; display: inline-flex; flex-direction: column; gap: 2px; padding: 10px 14px; background: rgba(255,255,255,0.92); color: var(--bbg-ink); border: 1px solid rgba(255,255,255,0.5); border-radius: 14px; font-family: var(--font-display); font-size: 0.84rem; font-weight: 600; letter-spacing: -0.005em; box-shadow: 0 24px 50px -18px rgba(0,0,0,0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transform: translateZ(40px); max-width: 16rem; }
