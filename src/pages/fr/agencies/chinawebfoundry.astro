---
import Layout from '../../../layouts/Layout.astro';

const locale = 'fr' as const;
const route = 'agencies/chinawebfoundry' as const;

type PhaseKey = 'plan' | 'build' | 'find' | 'run';

const phases: Array<{
  key: PhaseKey;
  title: string;
  stamp: string;
  image: string;
  imageAlt: string;
  intro: string;
  items: { name: string; body: string; quote?: { text: string; source: string } }[];
}> = [
  {
    key: 'plan',
    title: 'Cadrer',
    stamp: '策',
    image: '/images/cwf-plan-audit.webp',
    imageAlt: 'Tableau de bord China readiness, navigateurs à Pékin, Shanghai et Shenzhen.',
    intro: "Où votre site se situe aujourd'hui en Chine, et ce qu'il faut en faire.",
    items: [
      {
        name: 'Stratégie & audit',
        body: 'Nous testons votre site actuel depuis de vrais navigateurs à Pékin, Shanghai et Shenzhen. Chaque ressource bloquée, chaque écart de conformité, chaque angle mort sur Baidu, documenté. Vous repartez avec une feuille de route. Deux à quatre semaines, prix fixe.',
      },
      {
        name: 'Migration',
        body: "Déplacer un site existant vers la Chine sans perdre l'équité SEO ni le contenu. ICP Bei'an, bascule DNS, transfert de base, environnement de staging en parallèle pour tester depuis l'intérieur du Firewall avant de basculer.",
      },
    ],
  },
  {
    key: 'build',
    title: 'Construire',
    stamp: '建',
    image: '/images/cwf-build-workshop.webp',
    imageAlt: 'Atelier à Shanghai, double écran avec du code, notes en mandarin sur un tableau blanc.',
    intro: "Design, code et tuyauterie pensés pour l'internet chinois, pas rapiécés pour lui.",
    items: [
      {
        name: 'Design UX/UI',
        body: 'Un design qui sonne juste pour un visiteur chinois. Mobile-first. Mises en page denses. Typographie chinoise lisible sur UC Browser et QQ Browser. Parcours de paiement qui supposent WeChat (微信) et Alipay (支付宝) avant Visa.',
      },
      {
        name: 'Intégration technique',
        body: "La tuyauterie. Connexion WeChat, paiement Alipay et UnionPay (银联), WooCommerce localisé pour le continent, fournisseurs de cartographie et analytics non-Google. Si c'est bloqué, nous avons une alternative.",
      },
      {
        name: 'Plugins et extensions',
        body: "Une grande part des plugins WordPress populaires appellent Google. Polices, reCAPTCHA, Maps. Nous corrigeons ce qui peut l'être. Nous réécrivons le reste.",
        quote: {
          text: 'Près de 40 % des cent plugins WordPress les plus utilisés font des appels sortants vers des services Google bloqués depuis la Chine continentale.',
          source: 'Audit plugins ChinaWebFoundry, 2024',
        },
      },
    ],
  },
  {
    key: 'find',
    title: 'Trouver',
    stamp: '见',
    image: '/images/cwf-find-baidu.webp',
    imageAlt: 'Téléphone affichant une page de résultats chinois, onglets Baidu et DeepSeek.',
    intro: 'Être lu sur Baidu, être cité par DeepSeek, être trouvé par les gens qui vivent déjà ici.',
    items: [
      {
        name: 'Contenu chinois',
        body: 'Écrit pour le lecteur chinois, pas traduit pour lui. Fiches produit, landing pages, articles de blog, campagnes zhongcao (种草). Rédigé par des gens qui vivent ici.',
      },
      {
        name: 'SEO Baidu',
        body: 'Soumission et vérification sur Baidu Search Resource Platform (百度搜索资源平台). Recherche de mots-clés avec Baidu Index (百度指数) et 5118. Mesure via Baidu Tongji (百度统计).',
        quote: {
          text: 'Baidu détenait 60,1 % du marché chinois des moteurs de recherche en janvier 2025.',
          source: 'StatCounter Global Stats, 2025',
        },
      },
      {
        name: 'GEO Chine',
        body: 'Optimisation pour les moteurs génératifs chinois. DeepSeek, Doubao (豆包), Kimi, Yuanbao (元宝), Baidu AI. Nous optimisons pour être cités, pas seulement classés. Service récent, en forte croissance.',
      },
    ],
  },
  {
    key: 'run',
    title: 'Opérer',
    stamp: '营',
    image: '/images/cwf-run-monitor.webp',
    imageAlt: 'Tableau de bord de supervision avec courbes de latence mesurées depuis les réseaux chinois.',
    intro: "Un site n'est pas fini au lancement. Il l'est le jour où quelqu'un à Shanghai cesse de l'ouvrir.",
    items: [
      {
        name: 'Hébergement Chine',
        body: "Le mauvais hébergement ruine tout le reste. Nous déployons sur Alibaba Cloud (阿里云), Tencent Cloud (腾讯云) et Huawei Cloud (华为云). Hébergement passerelle à Hong Kong disponible pendant le traitement du Bei'an.",
      },
      {
        name: 'Maintenance et support',
        body: "Une Google Font se fait bloquer un mardi sans raison et votre page d'accueil devient illisible pour tout Shanghai. À Londres, votre équipe ne le sait pas avant qu'un client ne se plaigne. Nous surveillons depuis les réseaux chinois pour que cette conversation n'ait jamais lieu.",
      },
    ],
  },
];

const engageOptions: Array<{ key: 'project' | 'retainer' | 'audit'; label: string; lead: string; meta: string; tag: string }> = [
  {
    key: 'project',
    label: 'Projet',
    lead: 'Périmètre défini, calendrier fixe.',
    meta: 'De six semaines à quatre mois.',
    tag: 'Un build',
  },
  {
    key: 'retainer',
    label: 'Forfait mensuel',
    lead: 'Contenu, SEO, GEO et maintenance en continu.',
    meta: 'Mensuel, sur douze mois ou plus. La manière dont la plupart de nos clients travaillent avec nous.',
    tag: 'Le plus courant',
  },
  {
    key: 'audit',
    label: 'Audit',
    lead: 'Un regard ponctuel et approfondi. Performance, conformité, visibilité Baidu et IA.',
    meta: 'Deux à quatre semaines, prix fixe.',
    tag: 'Commencez ici',
  },
];

const visitUrl = 'https://chinawebfoundry.com';
const visitLabel = 'Visiter chinawebfoundry.com';
---

<Layout
  locale={locale}
  route={route}
  title="Sites web en Chine | WordPress, Astro, hébergés sur place"
  description="Agence web à Shanghai. Nous concevons, construisons, hébergeons et exploitons des sites en Chine sur WordPress ou Astro. Licence ICP, prêts pour Baidu, rapides derrière le Firewall."
>
  <section class="cwf-hero" data-cwf-hero>
    <div class="cwf-hero__bg" aria-hidden="true">
      <img
        src="/images/bbg-shanghai-twilight.webp"
        alt=""
        class="cwf-hero__bg-img"
        data-cwf-parallax-bg
      />
      <div class="cwf-hero__bg-scrim"></div>
      <div class="cwf-hero__bg-grain"></div>
      <div class="cwf-hero__bg-grid"></div>
    </div>

    <div class="container cwf-hero__main">
      <div class="cwf-hero__content">
        <img
          src="/AgencyLogos/Logo-ChinaWebFoundry-light.png"
          alt="ChinaWebFoundry"
          class="cwf-hero__logo"
          width="220"
          height="44"
          loading="eager"
          decoding="async"
        />

        <h1 class="cwf-hero__title">
          <span class="cwf-hero__line" data-anim="word">Nous construisons des sites qui</span>
          <span class="cwf-hero__line" data-anim="word">
            <em class="cwf-hero__phrase">fonctionnent en Chine</em>.
          </span>
        </h1>

        <p class="cwf-hero__lead" data-anim="fade">
          Pas depuis un slide deck à Paris. Pas depuis un argumentaire à New York. Depuis un bureau à Shanghai, avec une équipe qui construit pour l'internet chinois depuis plus de vingt ans.
        </p>

        <div class="cwf-hero__cta-row" data-anim="fade">
          <a class="cwf-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-cwf-magnet>
            <span class="cwf-magnet__bg"></span>
            <span class="cwf-magnet__label">{visitLabel}</span>
            <span class="cwf-magnet__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div class="cwf-hero__preview" data-cwf-tilt>
        <div class="cwf-hero__preview-frame">
          <a class="cwf-browser-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
            <div class="cwf-browser">
              <div class="cwf-browser__chrome">
                <span class="cwf-browser__dots">
                  <span class="cwf-browser__dot cwf-browser__dot--r"></span>
                  <span class="cwf-browser__dot cwf-browser__dot--y"></span>
                  <span class="cwf-browser__dot cwf-browser__dot--g"></span>
                </span>
                <span class="cwf-browser__url">chinawebfoundry.com</span>
                <span class="cwf-browser__region" aria-hidden="true">CN · Shanghai</span>
              </div>
              <div class="cwf-browser__viewport">
                <img
                  class="cwf-browser__shot"
                  src="/images/chinawebfoundry-home.png"
                  alt="Page d'accueil chinawebfoundry.com"
                  width="1422"
                  height="14825"
                  loading="eager"
                  decoding="async"
                />
                <span class="cwf-browser__live">
                  <span class="cwf-browser__live-dot"></span>
                  En ligne · {new Date().toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' })}
                </span>
                <span class="cwf-browser__visit" aria-hidden="true">
                  <span>Voir le site</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                </span>
              </div>
            </div>
          </a>

          <div class="cwf-hero__chip cwf-hero__chip--compliance">
            <span class="cwf-hero__chip-label">Conformité</span>
            <span>ICP · Bei'an · MIIT</span>
          </div>
          <div class="cwf-hero__chip cwf-hero__chip--search">
            <span class="cwf-hero__chip-label">Recherche & GEO</span>
            <span>Baidu · DeepSeek · Doubao · Kimi · Yuanbao</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#manifesto" class="cwf-hero__scroll" aria-label="Défiler">
      <span>Défiler</span>
      <span class="cwf-hero__scroll-line"></span>
    </a>
  </section>

  <section class="cwf-manifesto" id="manifesto">
    <div class="container">
      <div class="cwf-manifesto__grid">
        <div class="cwf-manifesto__numeral" aria-hidden="true">
          <span class="cwf-manifesto__num-row">
            <span class="cwf-manifesto__num" data-cwf-count="80">0</span>
            <span class="cwf-manifesto__num-plus">+</span>
          </span>
          <span class="cwf-manifesto__num-shadow">80+</span>
          <span class="cwf-manifesto__num-caption">sites livrés pour des marques internationales et chinoises</span>
        </div>
        <div class="cwf-manifesto__copy">
          <span class="eyebrow">Ce que nous croyons</span>
          <h2 class="cwf-manifesto__title balance">L'écart entre les tableaux de bord verts à Francfort et une page d'accueil qui met dix-sept secondes à charger à Shanghai. Cet écart, c'est notre raison d'être.</h2>
        </div>
      </div>

      <figure class="cwf-manifesto__story">
        <blockquote class="cwf-manifesto__story-quote" cite="https://www.chinawebfoundry.com">
          <p>Un groupe de luxe français nous a appelés au printemps dernier. Leur site mondial mettait dix-sept secondes à charger depuis Shanghai. Leur directrice marketing à Paris n'en savait rien : son tableau de bord montrait du vert partout parce qu'il mesurait depuis Francfort.</p>
        </blockquote>
        <figcaption class="cwf-manifesto__story-cite">
          <span class="cwf-manifesto__story-cite-rule" aria-hidden="true"></span>
          <span class="cwf-manifesto__story-cite-text">Conversation client, ChinaWebFoundry, Shanghai · 2025</span>
        </figcaption>

        <div class="cwf-manifesto__story-body">
          <div class="cwf-manifesto__story-col">
            <p>
              Cet écart, entre ce qui semble correct depuis l'extérieur de la Chine et ce qui se passe vraiment à l'intérieur, c'est notre raison d'être.
            </p>
          </div>
          <div class="cwf-manifesto__story-col">
            <p>
              La plupart des sites « pensés pour la Chine » ne le sont pas vraiment. Conçus ailleurs, traduits, hébergés à Singapour, avec des plugins qui appellent des services bloqués que personne n'a signalés. Six mois plus tard : techniquement en ligne, fonctionnellement invisible.
            </p>
            <p class="cwf-manifesto__story-emphasis">
              La Chine n'est pas un patch qu'on applique sur un build global. La Chine <em>est</em> le build. Quelqu'un doit surveiller le site depuis l'intérieur du pays. C'est nous.
            </p>
          </div>
        </div>
      </figure>
    </div>
  </section>

  <section class="cwf-services" id="services">
    <div class="container">
      <header class="cwf-services__header">
        <span class="eyebrow">Ce que nous faisons</span>
        <h2 class="cwf-services__title">
          Dix services. <em>Quatre phases.</em><br />
          Une équipe.
        </h2>
        <p class="cwf-services__lead">
          Cadrer d'abord. Puis construire. Puis se faire trouver. Puis opérer pendant toute la durée de vie. Vous prenez un module, ou les dix : la plupart de nos clients démarrent par deux ou trois.
        </p>
      </header>

      <div class="cwf-services__shell" data-cwf-tabs>
        <div class="cwf-services__nav" role="tablist" aria-label="Phases du cycle de vie">
          {phases.map((p, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`cwf-services__tab cwf-services__tab--${p.key} ${i === 0 ? 'is-active' : ''}`}
              data-cwf-tab={p.key}
              id={`cwf-tab-${p.key}`}
              aria-controls={`cwf-panel-${p.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="cwf-services__tab-pip" aria-hidden="true"></span>
              <span class="cwf-services__tab-label">{p.title}</span>
              <span class="cwf-services__tab-count">{p.items.length} services</span>
            </button>
          ))}
          <span class="cwf-services__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="cwf-services__panels">
          {phases.map((p, i) => (
            <div
              class={`cwf-services__panel cwf-services__panel--${p.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`cwf-panel-${p.key}`}
              aria-labelledby={`cwf-tab-${p.key}`}
              data-cwf-panel={p.key}
              hidden={i !== 0}
            >
              <div class="cwf-services__panel-grid">
                <div class="cwf-services__panel-image">
                  <div class={`cwf-services__panel-frame cwf-services__panel-frame--${p.key}`}>
                    <span class="cwf-services__panel-stamp" aria-hidden="true">{p.stamp}</span>
                    <span class="cwf-services__panel-grid-lines" aria-hidden="true"></span>
                    <div class="cwf-services__panel-tag">
                      <span>{p.title}</span>
                    </div>
                    <div class="cwf-services__panel-meta">
                      <span class="cwf-services__panel-meta-label">Phase</span>
                      <span class="cwf-services__panel-meta-value">{i + 1} sur {phases.length}</span>
                    </div>
                  </div>
                </div>

                <div class="cwf-services__panel-content">
                  <p class="cwf-services__panel-intro">{p.intro}</p>
                  <ul class="cwf-services__list">
                    {p.items.map((it) => (
                      <li class="cwf-services__item">
                        <span class={`cwf-services__item-pip cwf-services__item-pip--${p.key}`} aria-hidden="true"></span>
                        <span class="cwf-services__item-text">
                          <span class="cwf-services__item-name">{it.name}.</span>
                          <span class="cwf-services__item-body">{it.body}</span>
                          {it.quote && (
                            <span class="cwf-services__item-quote">
                              <span class="cwf-services__item-quote-mark" aria-hidden="true">“</span>
                              <span class="cwf-services__item-quote-text">{it.quote.text}</span>
                              <span class="cwf-services__item-quote-source">Source : {it.quote.source}</span>
                            </span>
                          )}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cwf-tech">
    <div class="container">
      <header class="cwf-tech__header">
        <span class="eyebrow">Comment nous construisons</span>
        <h2 class="cwf-tech__title balance">
          WordPress, Astro ou WeChat. Voici comment nous choisissons.
        </h2>
      </header>

      <div class="cwf-tech__grid">
        <article class="cwf-tech__card cwf-tech__card--wp">
          <figure class="cwf-tech__card-banner cwf-tech__card-banner--logo">
            <img
              src="/AgencyLogos/tech/wordpress.svg"
              alt="Logo WordPress"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <header class="cwf-tech__card-head">
            <h3 class="cwf-tech__card-title">Choisir WordPress</h3>
          </header>
          <p class="cwf-tech__card-body">
            Si votre équipe marketing doit publier sans développeur, ou si votre workflow éditorial implique plus de trois contributeurs. Nous le durcissons pour le Firewall et retirons ce qui n'a rien à faire en Chine.
          </p>
          <ul class="cwf-tech__card-traits">
            <li>Workflow éditorial, multi-auteurs.</li>
            <li>Cœur durci, plugins China-safe.</li>
            <li>WooCommerce localisé pour le continent.</li>
          </ul>
        </article>

        <article class="cwf-tech__card cwf-tech__card--astro">
          <figure class="cwf-tech__card-banner cwf-tech__card-banner--logo">
            <img
              src="/AgencyLogos/tech/astro.svg"
              alt="Logo Astro"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <header class="cwf-tech__card-head">
            <h3 class="cwf-tech__card-title">Choisir Astro</h3>
          </header>
          <p class="cwf-tech__card-body">
            Si la vitesse est la priorité et que votre contenu ne bouge pas chaque jour. Sites marketing, documentation, landing pages. Sortie statique, temps de chargement quasi instantanés, beaucoup moins à maintenir.
          </p>
          <ul class="cwf-tech__card-traits">
            <li>Sortie statique, TTFB quasi instantané.</li>
            <li>Documentation, landing, marketing.</li>
            <li>Hébergé sur Aliyun ou Tencent Cloud.</li>
          </ul>
        </article>

        <article class="cwf-tech__card cwf-tech__card--wechat">
          <figure class="cwf-tech__card-banner cwf-tech__card-banner--logo">
            <img
              src="/AgencyLogos/tech/wechat.svg"
              alt="Logo WeChat"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <header class="cwf-tech__card-head">
            <h3 class="cwf-tech__card-title">Choisir WeChat</h3>
          </header>
          <p class="cwf-tech__card-body">
            Si votre audience vit déjà à l'intérieur de WeChat (微信) et qu'un site sur le web ouvert n'est pas l'endroit où la conversation se déroule. Comptes officiels, mini-programmes, pages H5 : du contenu là où les utilisateurs chinois sont déjà.
          </p>
          <ul class="cwf-tech__card-traits">
            <li>Compte officiel, contenu et CRM.</li>
            <li>Mini-programme pour le commerce ou le service.</li>
            <li>Pages H5 pour les campagnes et les KOL.</li>
          </ul>
        </article>
      </div>

      <p class="cwf-tech__footnote">Si vous n'êtes pas sûr, c'est précisément ce que l'audit sert à clarifier.</p>
    </div>
  </section>

  <section class="cwf-engage">
    <div class="cwf-engage__bg" aria-hidden="true"></div>
    <div class="container">
      <header class="cwf-engage__header">
        <span class="eyebrow eyebrow--on-dark">Comment on travaille ensemble</span>
        <h2 class="cwf-engage__title">Trois façons de démarrer.</h2>
        <p class="cwf-engage__lead">
          Vous pouvez prendre un module, ou les dix. La plupart de nos clients démarrent par deux ou trois. Choisissez le point d'entrée qui correspond à votre moment.
        </p>
      </header>

      <div class="cwf-engage__grid">
        {engageOptions.map((o) => (
          <article class={`cwf-engage__card cwf-engage__card--${o.key}`}>
            <span class="cwf-engage__card-tag">{o.tag}</span>
            <h3 class="cwf-engage__card-title">{o.label}</h3>
            <p class="cwf-engage__card-lead">{o.lead}</p>
            <p class="cwf-engage__card-meta">{o.meta}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cwf-cta">
    <div class="cwf-cta__bg" aria-hidden="true">
      <img src="/images/bbg-shanghai-twilight.webp" alt="" />
      <div class="cwf-cta__bg-scrim"></div>
    </div>
    <div class="container cwf-cta__content">
      <span class="eyebrow eyebrow--on-dark">Quand vous êtes prêts</span>
      <h2 class="cwf-cta__title balance">Un site qui charge à Shanghai.<br />Construit par une équipe qui y vit.</h2>
      <div class="cwf-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cwf-hero {
    position: relative;
    min-height: 92vh;
    padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    background: #0c1220;
  }
  .cwf-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .cwf-hero__bg-img {
    position: absolute;
    inset: -8% -4% -4% -4%;
    width: 108%;
    height: 112%;
    object-fit: cover;
    object-position: center 40%;
    will-change: transform;
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04);
    filter: saturate(0.85) contrast(1.05) brightness(0.72);
  }
  .cwf-hero__bg-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(110deg, rgba(8,12,24,0.88) 0%, rgba(8,12,24,0.62) 38%, rgba(8,12,24,0.30) 65%, rgba(8,12,24,0.55) 100%),
      linear-gradient(180deg, rgba(8,12,24,0.55) 0%, rgba(8,12,24,0.05) 30%, rgba(8,12,24,0.0) 60%, rgba(8,12,24,0.85) 100%);
  }
  .cwf-hero__bg-grain {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1200px 600px at 20% 30%, rgba(38,154,218,0.18), transparent 65%),
      radial-gradient(900px 500px at 90% 80%, rgba(200,16,46,0.14), transparent 70%);
    mix-blend-mode: screen;
  }
  .cwf-hero__bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
