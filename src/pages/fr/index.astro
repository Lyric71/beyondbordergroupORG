---
import Layout from '../../layouts/Layout.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'fr' as const;
const title = "Marques, produits et services conçus pour circuler entre la Chine et l'Occident, dans les deux sens.";
const description = "Sept agences spécialistes qui font passer marques, produits et services entre la Chine et l'Occident, dans les deux sens. Marque, canaux, web, sourcing de partenaires, contenu, vente. Un écosystème, une colonne vertébrale partagée.";

const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';

const agencies = [
  {
    name: 'BeyondBorderGroup',
    tagline: "Entrée en Chine intégrée. Du branding au e-commerce.",
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    tagline: 'Réseaux sociaux chinois. WeChat, Douyin, RedNote, Weibo.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    tagline: "Sites pensés pour le web chinois. Baidu, ICP, moteurs IA.",
    route: 'agencies/chinawebfoundry' as const,
  },
  {
    name: 'BeyondCompass',
    tagline: 'Base privée de distributeurs chinois qualifiés, TP Tmall, Douyin Partners.',
    route: 'agencies/beyondcompass' as const,
  },
  {
    name: 'BeyondBridge',
    tagline: "Pipeline complet pour les marques chinoises à l'export.",
    route: 'agencies/beyondbridge' as const,
  },
  {
    name: 'HubStudio',
    tagline: "Production d'image, vidéo et contenu à l'échelle.",
    route: 'agencies/hubstudio' as const,
  },
  {
    name: 'Nuvora Studio',
    tagline: 'B2B exclusivement LinkedIn. Stratégie, contenu, ads.',
    route: 'agencies/nuvora-studio' as const,
  },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <video
      class="hero-statement__video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
    </video>
    <div class="hero-statement__scrim" aria-hidden="true"></div>
    <div class="hero-statement__rail">
      <aside class="rail" aria-label="Sept agences du groupe">
        <header class="rail__head">
          <span class="rail__head-tag">Écosystème</span>
          <span class="rail__head-count">Sept spécialistes</span>
        </header>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Agences leaders</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 0;">
              <a class="rail__link" href={pathFor('agencies/beyondbordergroup', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BBG%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBorderGroup</span>
                  <span class="rail__tagline">Couverture intégrale Occident → Chine</span>
                </span>
                <span class="rail__stripe rail__stripe--w" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 1;">
              <a class="rail__link" href={pathFor('agencies/beyondbridge', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBridge</span>
                  <span class="rail__tagline">Couverture intégrale Chine → Occident</span>
                </span>
                <span class="rail__stripe rail__stripe--e" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Spécialistes, dans les deux sens</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 2;">
              <a class="rail__link" href={pathFor('agencies/theredscroll', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/TheredScroll%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">TheRedScroll</span>
                  <span class="rail__tagline">Réseaux sociaux chinois</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 3;">
              <a class="rail__link" href={pathFor('agencies/chinawebfoundry', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Logo-ChinaWebFoundry-transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">ChinaWebFoundry</span>
                  <span class="rail__tagline">Bâti pour le web chinois</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 4;">
              <a class="rail__link" href={pathFor('agencies/beyondcompass', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondCompass</span>
                  <span class="rail__tagline">Partenaires chinois qualifiés</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 5;">
              <a class="rail__link" href={pathFor('agencies/nuvora-studio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Nuvora%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">Nuvora Studio</span>
                  <span class="rail__tagline">Spécialistes LinkedIn B2B</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Production</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 6;">
              <a class="rail__link" href={pathFor('agencies/hubstudio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/hubStudio%20(2).png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">HubStudio</span>
                  <span class="rail__tagline">Traverse les deux sens</span>
                </span>
                <span class="rail__stripe rail__stripe--c" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>
      </aside>
    </div>
    <div class="container hero-statement__container">
      <div class="hero-statement__content">
        <span class="eyebrow">Écosystème</span>
        <h1 class="hero-statement__title balance">Nous construisons et faisons grandir des marques, produits et services entre la Chine et l'Occident. Dans les deux sens.</h1>
        <p class="hero-statement__lead">
          Sept agences spécialistes, une même conviction. L'écart entre la Chine et l'Occident n'a jamais été
          un problème de traduction. C'est une affaire de marque, de canaux, d'infrastructure et de vente. Et
          cela se joue dans les deux sens, chaque jour.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={pathFor('agencies', locale)}>Trouver l'agence qu'il vous faut</a>
          <a class="btn btn--ghost" href={pathFor('contact', locale)}>Parler à l'équipe</a>
        </div>
        <p class="hero-statement__cite">Shanghai. Hong Kong. Paris. Représentants aux États-Unis, au Royaume-Uni, en Allemagne et en France.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Deux flux</span>
        <h2 class="balance">Partez du côté où vous êtes.</h2>
      </header>

      <div class="bridge-panel">
        <span class="bridge-panel__spine" aria-hidden="true">
          <span class="bridge-panel__spine-line"></span>
          <span class="bridge-panel__spine-mark">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 16h22" />
              <path d="M22 11l5 5-5 5" />
              <path d="M10 21l-5-5 5-5" />
            </svg>
          </span>
        </span>

        <a class="bridge-panel__side bridge-panel__side--inbound" href={`${pathFor('two-flows', locale)}#inbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">→</span>
            Occident vers Chine · Entrant
          </span>
          <h3 class="bridge-panel__title">Faire entrer les marques occidentales en Chine.</h3>
          <p class="bridge-panel__body">
            Marque, WeChat, RedNote, Douyin, Tmall, JD, Baidu, KOL, distribution. D'une landing page seule à la
            stack complète.
          </p>
          <span class="bridge-panel__by">BeyondBorderGroup · TheRedScroll · ChinaWebFoundry · BeyondCompass · HubStudio</span>
          <span class="bridge-panel__cta">
            Aller au flux entrant
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>

        <a class="bridge-panel__side bridge-panel__side--outbound" href={`${pathFor('two-flows', locale)}#outbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">←</span>
            Chine vers Occident · Sortant
          </span>
          <h3 class="bridge-panel__title">Faire sortir les marques chinoises à l'étranger.</h3>
          <p class="bridge-panel__body">
            Une marque pensée pour les acheteurs occidentaux, une vraie présence LinkedIn, un site bâti pour
            l'œil occidental, SEO, GEO, Google Ads, et des commerciaux nommés dans le bon fuseau horaire.
          </p>
          <span class="bridge-panel__by">BeyondBridge · Nuvora Studio</span>
          <span class="bridge-panel__cta">
            Aller au flux sortant
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>
      </div>

      <div class="btn-row" style="margin-top: var(--space-6); justify-content: center;">
        <a class="btn btn--primary" href={pathFor('two-flows', locale)}>Ouvrir la page complète des deux flux</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">La stack</span>
        <h2 class="balance">Sept spécialistes. Un seul écosystème.</h2>
        <p class="lead">
          Chaque agence est autonome. Prenez celle qu'il vous faut. La majorité de nos clients démarrent par
          une seule, puis ouvrent le périmètre quand le projet grandit.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Ouvrir</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">La logique</span>
        <h2 class="balance">Deux leaders. Cinq spécialistes. Un moteur.</h2>
        <p class="lead">
          Deux agences leaders, une par direction. Cinq spécialistes qui se branchent dans les deux sens.
          Un seul moteur de production qui traverse les deux.
        </p>
      </header>
      <div class="matrix-grid" role="table" aria-label="Agences par direction et par couche">
        <div class="matrix-grid__head" role="row">
          <div class="matrix-grid__corner" aria-hidden="true"></div>
          <div class="matrix-grid__direction matrix-grid__direction--west" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">→</span>
            <span class="matrix-grid__direction-label">Occident vers Chine</span>
          </div>
          <div class="matrix-grid__direction matrix-grid__direction--east" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">←</span>
            <span class="matrix-grid__direction-label">Chine vers Occident</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Couverture intégrale</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Agence leader</span>
            <span class="matrix-cell__name">BeyondBorderGroup</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Agence leader</span>
            <span class="matrix-cell__name">BeyondBridge</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Réseaux sociaux</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Dans les deux sens</span>
            <span class="matrix-cell__name">TheRedScroll</span>
            <span class="matrix-cell__note">WeChat, Douyin, RedNote, Weibo. Pour clients occidentaux ou chinois.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">LinkedIn B2B</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Dans les deux sens</span>
            <span class="matrix-cell__name">Nuvora Studio</span>
            <span class="matrix-cell__note">Exclusivement LinkedIn. Pour clients occidentaux ou chinois.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Infrastructure web</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Dans les deux sens</span>
            <span class="matrix-cell__name">ChinaWebFoundry</span>
            <span class="matrix-cell__note">Prêt pour Baidu, ICP, moteurs IA chinois. Pour clients occidentaux ou chinois.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Sourcing de partenaires</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Dans les deux sens</span>
            <span class="matrix-cell__name">BeyondCompass</span>
            <span class="matrix-cell__note">Distributeurs chinois qualifiés, TP Tmall, Douyin Partners.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--span" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Production</span>
          </div>
          <div class="matrix-cell matrix-cell--span" role="cell">
            <span class="matrix-cell__bridge" aria-hidden="true">
              <span class="matrix-cell__bridge-dot"></span>
              <span class="matrix-cell__bridge-line"></span>
              <span class="matrix-cell__bridge-dot"></span>
            </span>
            <span class="matrix-cell__name">HubStudio</span>
            <span class="matrix-cell__note">Moteur de production de contenu. Traverse les deux directions.</span>
          </div>
        </div>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>Comment on travaille ensemble</a>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Derrière ce groupe</span>
          <h2 class="balance">Un opérateur. Deux décennies des deux côtés.</h2>
          <p class="lead">
            Le groupe est fondé et dirigé par Cyril Drouin. Vingt-cinq ans de digital, e-commerce et marque en
            Europe et en Asie du Nord. Ancien Chief Digital and eCommerce Officer pour Publicis North Asia.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Suivre sur LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin sur LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, fondateur de BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Dites-nous dans quel sens vous allez.</h2>
      <p class="lead" style="margin-inline: auto;">
        Trente minutes au téléphone. Nous vous dirons quelle agence du groupe est le bon point de départ, ou
        s'il faut en démarrer plusieurs en même temps.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Prendre rendez-vous</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.agency-card-logo) {
    width: 100%;
    height: 56px;
    max-height: 56px;
    object-fit: contain;
    object-position: left center;
    margin-bottom: var(--space-3);
    background: transparent;
    display: block;
    filter: none;
  }

  .matrix-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .matrix-grid__head,
  .matrix-grid__row {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .matrix-grid__direction {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bbg-ink);
    position: relative;
  }
  .matrix-grid__direction::after {
    content: '';
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: 0;
    height: 2px;
    border-radius: 2px;
  }
  .matrix-grid__direction--west::after { background: linear-gradient(90deg, var(--bbg-blue), transparent); }
  .matrix-grid__direction--east::after { background: linear-gradient(90deg, transparent, #c8102e); }
  .matrix-grid__direction--east { justify-content: flex-end; flex-direction: row-reverse; }
  .matrix-grid__arrow {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--bbg-blue);
  }
  .matrix-grid__direction--east .matrix-grid__arrow { color: #c8102e; }
  .matrix-grid__layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    align-self: center;
  }
  .matrix-grid__layer-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--bbg-text-muted);
  }
  .matrix-grid__layer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 12px;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .matrix-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(15, 23, 42, 0.18);
    border-color: var(--bbg-border-strong);
  }
  .matrix-cell--lead {
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-surface) 100%);
    border-color: rgba(38, 154, 218, 0.25);
  }
  .matrix-cell--lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both {
    grid-column: 2 / -1;
    background: linear-gradient(90deg, rgba(38, 154, 218, 0.06) 0%, rgba(255, 255, 255, 0.5) 50%, rgba(200, 16, 46, 0.06) 100%);
    border-color: rgba(15, 23, 42, 0.10);
    padding: var(--space-3) var(--space-5);
  }
  .matrix-grid__row--both .matrix-cell--both::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue) 0%, #c8102e 100%);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__tag {
    color: transparent;
    background: linear-gradient(90deg, var(--bbg-blue), #c8102e);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__note {
    color: var(--bbg-text-muted);
    font-size: var(--fs-small);
  }
  .matrix-cell__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .matrix-cell__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell--empty {
    background: transparent;
    border: 1px dashed var(--bbg-border);
    align-items: center;
    justify-content: center;
  }
  .matrix-cell--empty:hover { transform: none; box-shadow: none; }
  .matrix-cell__dash { font-size: 1.25rem; color: var(--bbg-text-muted); }
  .matrix-grid__row--span .matrix-cell--span {
    grid-column: 2 / -1;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    border-color: transparent;
    color: white;
    align-items: center;
    text-align: center;
