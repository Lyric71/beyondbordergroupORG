---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'fr' as const;
const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';
const title = 'Chine et Occident, dans les deux sens';
const description = 'Sept agences spécialisées qui relient la Chine et l’Occident, à l’aller comme au retour. Marque, canaux, web, sourcing, contenu, ventes. Un seul écosystème, une même colonne vertébrale.';

const agencies = [
  { n: '01', name: 'BeyondBorderGroup', tagline: 'Implantation en Chine, de bout en bout. De la marque à l’eCommerce.', route: 'agencies/beyondbordergroup' as const },
  { n: '02', name: 'TheRedScroll', tagline: 'Réseaux sociaux chinois. WeChat, Douyin, RED, Weibo.', route: 'agencies/theredscroll' as const },
  { n: '03', name: 'ChinaWebFoundry', tagline: 'Des sites taillés pour le web chinois. Baidu, ICP, IA locales.', route: 'agencies/chinawebfoundry' as const },
  { n: '04', name: 'BeyondCompass', tagline: 'Une base privée de distributeurs, TP Tmall et Douyin Partners qualifiés.', route: 'agencies/beyondcompass' as const },
  { n: '05', name: 'BeyondBridge', tagline: 'L’export clé en main pour les marques chinoises.', route: 'agencies/beyondbridge' as const },
  { n: '06', name: 'HubStudio', tagline: 'Image, vidéo, contenu IA. Production à grande échelle.', route: 'agencies/hubstudio' as const },
  { n: '07', name: 'Nuvora Studio', tagline: 'B2B, exclusivement sur LinkedIn. Stratégie, contenu, média.', route: 'agencies/nuvora-studio' as const },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <div class="container">
      <div class="hero-statement__grid">
        <div>
          <span class="eyebrow">Écosystème</span>
          <h1 class="hero-statement__title balance">Construire des marques entre la Chine et l’Occident. À l’aller comme au retour.</h1>
          <p class="hero-statement__lead">
            Sept agences spécialisées, une même conviction. Le fossé entre la Chine et l’Occident ne tient pas
            à la traduction. Il tient à la marque, aux canaux, à l’infrastructure et à la vente. Et il fonctionne
            dans les deux sens.
          </p>
          <div class="btn-row">
            <a class="btn btn--primary" href={pathFor('agencies', locale)}>Trouver la bonne agence</a>
            <a class="btn btn--ghost" href={pathFor('contact', locale)}>Nous parler</a>
          </div>
          <p class="hero-statement__cite">Shanghai · Hong Kong · Paris. Représentants commerciaux aux États-Unis, au Royaume-Uni, en Allemagne et en France.</p>
        </div>
        <div class="hero-statement__visual">
          <ImagePlaceholder ratio="3x4" label="Portrait éditorial. Un opérateur transfrontalier en pleine action." />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Deux directions</span>
        <h2 class="balance">Un pont. Deux sens de circulation.</h2>
        <p class="lead">Quel que soit votre point de départ, nous avons déjà fait le chemin de l’autre côté.</p>
      </header>
      <div class="flows">
        <article class="flow">
          <span class="flow__direction">De l’Occident vers la Chine · Entrant</span>
          <h3>Faire entrer une marque occidentale en Chine</h3>
          <p>
            Marque, canaux, infrastructure web, eCommerce, social, KOL, distribution. D’un simple test en
            cross-border jusqu’à une présence complète sur WeChat, Tmall et Douyin.
          </p>
          <a class="btn btn--ghost" href={pathFor('entering-china', locale)}>Voir le flux entrant</a>
          <p class="flow__by">Opéré par BeyondBorderGroup, TheRedScroll et ChinaWebFoundry.</p>
        </article>
        <article class="flow flow--dark">
          <span class="flow__direction">De la Chine vers l’Occident · Sortant</span>
          <h3>Emmener les marques et les industriels chinois à l’international</h3>
          <p>
            Une marque pensée pour des acheteurs occidentaux, une vraie vitrine LinkedIn, un site lisible par
            des yeux occidentaux, du SEO, du GEO, du Google Ads, et des commerciaux qui décrochent dans le bon
            fuseau horaire.
          </p>
          <a class="btn btn--ghost" href={pathFor('going-overseas', locale)} style="color: var(--bbg-blue-light);">Voir le flux sortant</a>
          <p class="flow__by">Opéré par BeyondBridge.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Le dispositif</span>
        <h2 class="balance">Sept spécialistes, un seul écosystème.</h2>
        <p class="lead">
          Chaque agence est autonome. Vous prenez celle dont vous avez besoin. La majorité de nos clients
          démarrent avec une seule, puis ajoutent les autres au gré du projet.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <span class="card__index">{a.n}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Ouvrir</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">L’architecture</span>
        <h2 class="balance">Une matrice 2x2, posée sur un socle commun.</h2>
        <p class="lead">
          Deux colonnes par direction. Deux strates horizontales qui irriguent les deux. Chaque agence occupe
          une case, et déborde sur les autres quand le projet l’exige.
        </p>
      </header>
      <div style="overflow-x: auto;">
        <table class="matrix">
          <thead>
            <tr>
              <th></th>
              <th>De l’Occident vers la Chine</th>
              <th>De la Chine vers l’Occident</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Couverture intégrale</th>
              <td><strong>BeyondBorderGroup</strong></td>
              <td><strong>BeyondBridge</strong></td>
            </tr>
            <tr>
              <th>Spécialiste de canal</th>
              <td>TheRedScroll</td>
              <td>Nuvora Studio</td>
            </tr>
            <tr>
              <th>Infrastructure web</th>
              <td>ChinaWebFoundry</td>
              <td>Module web BeyondBridge</td>
            </tr>
            <tr>
              <th>Sourcing partenaires</th>
              <td>BeyondCompass</td>
              <td class="muted">—</td>
            </tr>
            <tr>
              <th>Production</th>
              <td colspan="2" style="text-align:center; background: var(--bbg-blue-light); color: var(--bbg-ink); font-weight: 600;">HubStudio irrigue les deux côtés</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>Voir comment nous nous coordonnons</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Pourquoi un groupe</span>
        <h2 class="balance">Des spécialistes. Pas une nébuleuse.</h2>
      </header>
      <div class="grid-3">
        <div class="prose">
          <h3>Une thèse, une seule, déclinée des deux côtés.</h3>
          <p>
            Que vous soyez une maison de luxe française qui s’installe en Chine ou un groupe industriel chinois
            qui débarque en Allemagne, le travail prend exactement la même forme. Refonder la marque pour
            l’audience cible. Bâtir les bons canaux. Bâtir la bonne infrastructure. Produire le contenu qui va
            avec. Mettre une équipe au téléphone, dans le bon fuseau et dans la bonne langue.
          </p>
        </div>
        <div class="prose">
          <h3>Des spécialistes, jamais un grand fourre-tout.</h3>
          <p>
            Chaque agence a sa marque, son tarif, ses livrables, ses équipes. Un client qui veut juste un site
            chinois ne paie pas pour un département média. Un client qui veut juste du LinkedIn ne paie pas un
            roster de KOL chinois.
          </p>
        </div>
        <div class="prose">
          <h3>Un atelier de production en partage.</h3>
          <p>
            Toutes les agences du groupe puisent dans la couche AIGC de HubStudio. C’est ce qui permet
            d’aligner le coût unitaire des livrables, et c’est ce qui fait qu’une marque chinoise peut publier
            à l’étranger au même rythme qu’une marque occidentale en Chine.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Aux commandes</span>
          <h2 class="balance">Un opérateur. Vingt ans des deux côtés.</h2>
          <p class="lead">
            Le groupe est fondé et dirigé par Cyril Drouin. Vingt-cinq années dans le digital, l’eCommerce et
            la marque, partagées entre l’Europe et l’Asie du Nord. Ancien Chief Digital and eCommerce Officer
            de Publicis North Asia. Fondateur de HubStudio et de Nuvora Studio.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Voir sur LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin sur LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, fondateur de BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Dites-nous dans quel sens vous allez.</h2>
      <p class="lead" style="margin-inline: auto;">
        Trente minutes au téléphone. Nous vous indiquerons par quelle agence commencer, ou s’il vaut mieux en
        activer plusieurs en parallèle.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Réserver un appel</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.agency-card-logo) {
    height: 48px;
    width: auto;
    max-width: 180px;
    margin-bottom: var(--space-3);
  }
</style>
