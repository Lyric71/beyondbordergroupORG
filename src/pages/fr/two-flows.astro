---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'fr' as const;
const title = 'Deux flux';
const description = "Un pont, deux directions. La pile complète pour entrer ou changer d’échelle en Chine, et l’export clé en main pour les marques chinoises qui partent à l’international.";

const inboundReq = [
  { h: 'Une marque qui inspire la qualité aux yeux d’un public chinois', body: "Les preuves de confiance d’abord. Certifications, logos partenaires, validations tierces. Cette page d’accueil dense, qu’un œil occidental juge surchargée, est précisément ce qu’un œil chinois lit comme du sérieux. Le minimalisme à l’occidentale, ici, passe pour du vide." },
  { h: 'Des canaux que les consommateurs chinois utilisent vraiment', body: "WeChat pour la confiance. RED pour la short-list. Douyin pour la découverte et le live commerce. Weibo pour la portée. Chacun a son format, sa cadence, son équipe dédiée. Les confondre, c’est perdre la conversation." },
  { h: 'Une infrastructure web pensée pour vivre derrière le pare-feu', body: "Hébergement avec licence ICP chez Aliyun, Tencent ou Huawei. Un site que Baidu peut véritablement indexer. Une UX testée dans le navigateur intégré de WeChat, là où l’essentiel de votre trafic vous lira. En pratique, mobile-first : plus de 95 % des internautes chinois passent par leur téléphone." },
  { h: 'Une visibilité dans les moteurs que les acheteurs chinois fréquentent', body: "Baidu détient toujours plus de la moitié du marché de la recherche en Chine, selon Statcounter. Google plafonne sous les 3 %. Et les moins de 35 ans contournent de plus en plus la recherche classique au profit des IA : DeepSeek, Doubao, Kimi, Yuanbao." },
  { h: 'Du commerce là où l’achat se déclenche', body: "Tmall, JD, Douyin Shop, RED, sans oublier le social commerce sur WeChat. En Chine, eCommerce et social ne sont pas deux entonnoirs distincts : c’est la même surface, lue d’un seul geste du pouce." },
];

const inboundAgencies = [
  { name: 'BeyondBorderGroup', role: 'L’opérateur intégré', body: "Vingt ans de terrain. Branding, média, social, KOL, studio de contenu, RP, sites, événementiel, eCommerce, social commerce, distribution, conseil. Une équipe responsable de bout en bout. Vous prenez le tout, ou un module.", route: 'agencies/beyondbordergroup' as const },
  { name: 'TheRedScroll', role: 'Le spécialiste des réseaux', body: "Réseaux sociaux chinois opérés depuis Shanghai et Hong Kong. WeChat, Douyin, RED, Weibo, plus quatorze autres plateformes. Stratégie, contenu, KOL, achats média, CRM, formation. Périmètre fixe, prix fixe, onboarding en deux semaines.", route: 'agencies/theredscroll' as const },
  { name: 'ChinaWebFoundry', role: 'Le bâtisseur de sites', body: "Des sites pensés pour le web chinois. Audit, migration, contenu chinois natif, UX mobile-first, hébergement avec licence ICP, SEO Baidu, GEO pour les IA chinoises, maintenance. WordPress, Astro, WeChat. Une seule équipe, basée à Shanghai.", route: 'agencies/chinawebfoundry' as const },
];

const outboundReq = [
  { h: 'Une marque que les acheteurs occidentaux reconnaissent', body: "Pas une transposition depuis la Chine. Des noms qui tiennent debout, des accroches qui ne sonnent pas faux, une identité visuelle qui passe la frontière de Francfort et de Chicago sans avoir besoin d’une note de bas de page." },
  { h: 'Une présence sur LinkedIn', body: "L’acheteur B2B occidental ouvre LinkedIn avant même de prendre l’appel. Page muette, conversation morte. 82 % des acheteurs déclarent accorder davantage de confiance aux entreprises dont les dirigeants publient sur LinkedIn, chiffre tiré de l’étude maison du réseau. Profil vide, deal perdu." },
  { h: 'Un site fait pour des yeux occidentaux', body: "Sobre, aéré, une seule action claire par page. Hébergé hors de Chine. Rapide. Trois secondes de chargement et plus de la moitié des visiteurs s’en vont." },
  { h: 'Une visibilité dans les moteurs occidentaux', body: "Du classement sur Google, et des citations sur ChatGPT, Perplexity et Gemini. La plupart des entreprises chinoises arrivent à l’étranger sans aucune autorité : pas de backlinks, aucun contenu en anglais, zéro citation IA. Vos concurrents ont déjà la place et la réponse." },
  { h: 'Des annonces qui passent en première page', body: "Du Google Ads pendant que le SEO se construit. Des landing pages occidentales, jamais de simples traductions. Beaucoup de marques chinoises brûlent leur budget sur des mots-clés trop larges, dans la mauvaise géographie, vers des pages pensées pour la Chine." },
  { h: 'Des commerciaux dans le bon fuseau', body: "Un acheteur en Allemagne envoie un message à 10 h, heure de Berlin. Shenzhen dort encore. Au matin, votre concurrent a déjà répondu à sa place. Sur les marchés occidentaux, c’est le premier qui répond qui rafle la suite." },
];

const outboundServices = [
  { h: 'Stratégie de marque', body: "Pensée pour les acheteurs occidentaux, pas traduite depuis le chinois." },
  { h: 'LinkedIn', body: "Le canal que le B2B occidental ouvre en premier. Opéré avec Nuvora Studio, le spécialiste LinkedIn du groupe." },
  { h: 'Site web', body: "Pour des yeux occidentaux. Hébergé hors de Chine." },
  { h: 'SEO et GEO', body: "Se classer sur Google. Être cité par les IA occidentales." },
  { h: 'Google Ads', body: "Première page dès le jour 1." },
  { h: 'Force de vente externalisée', body: "Des représentants natifs, nominatifs, aux États-Unis, au Royaume-Uni, en Allemagne et en France." },
];
---

<Layout locale={locale} route="two-flows" title={title} description={description}>
  <section class="hero-twoflows">
    <div class="container hero-twoflows__inner">
      <span class="eyebrow eyebrow--rule">Deux directions</span>
      <h1 class="hero-twoflows__title balance">
        Un pont. <span class="hero-twoflows__accent">Deux flux.</span>
      </h1>
      <p class="hero-twoflows__lead">
        Quelle que soit votre direction, nous avons déjà fait le travail des deux côtés. Choisissez le côté du pont d’où vous venez.
      </p>

      <div class="hero-twoflows__bridge" aria-hidden="true">
        <span class="hero-twoflows__bank">Occident</span>
        <svg class="hero-twoflows__arc" viewBox="0 0 600 100" preserveAspectRatio="none">
          <path d="M0 86 Q300 4 600 86" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="60" y1="76" x2="60" y2="92" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="180" y1="50" x2="180" y2="92" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="300" y1="40" x2="300" y2="92" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="420" y1="50" x2="420" y2="92" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          <line x1="540" y1="76" x2="540" y2="92" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <span class="hero-twoflows__bank">Chine</span>
      </div>

      <div class="hero-twoflows__jumps">
        <a class="hero-twoflows__jump" href="#inbound">
          Flux entrant
          <span class="hero-twoflows__jump-meta">Occident vers Chine</span>
        </a>
        <a class="hero-twoflows__jump" href="#outbound">
          Flux sortant
          <span class="hero-twoflows__jump-meta">Chine vers Occident</span>
        </a>
      </div>
    </div>
  </section>

  <section id="inbound" class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Flux 1 · Entrant · De l’Occident vers la Chine</span>
      <h2 class="hero-editorial__title balance">
        Vous avez une marque. La Chine compte 1,1 milliard d’internautes. Combler cet écart n’est pas un travail de traduction.
      </h2>
      <p class="hero-editorial__lead">
        Internet chinois fonctionne sur sa propre pile. Plateformes, moteurs, infrastructure, densité du
        contenu, signaux d’achat : tout y est différent. Nous y travaillons depuis vingt ans.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Ce qu’il faut vraiment</span>
        <h2 class="balance">Ce qu’il faut pour atterrir en Chine.</h2>
      </header>
      <div class="grid-2">
        {inboundReq.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Trois agences, un seul flux</span>
        <h2 class="balance">Prendre la pile entière, ou la pièce qui manque.</h2>
      </header>
      <div class="grid-3">
        {inboundAgencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <span class="card__index">{a.role}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.body}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Visiter</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Comment nos clients démarrent</span>
        <h2 class="balance">Quatre points d’entrée que nous voyons revenir.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>« Il me faut un site chinois qui fonctionne vraiment. »</blockquote>
          <p><strong>ChinaWebFoundry.</strong> Migration en six semaines, ICP déposée, indexable par Baidu.</p>
        </article>
        <article class="card">
          <blockquote>« Je dois être sur RED et Douyin dans 90 jours. »</blockquote>
          <p><strong>TheRedScroll.</strong> Onboarding en deux semaines, premières publications en ligne sous quinzaine.</p>
        </article>
        <article class="card">
          <blockquote>« Il me faut tout : marque, canaux, eCommerce, KOL. »</blockquote>
          <p><strong>BeyondBorderGroup.</strong> Implantation intégrale. Vingt ans de playbook au service du brief.</p>
        </article>
        <article class="card">
          <blockquote>« Je ne sais pas par où commencer. »</blockquote>
          <p>Trente minutes au téléphone et nous tranchons à votre place. <a href={pathFor('contact', locale)}>Réserver un appel</a>.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--text-first">
        <div class="prose">
          <span class="eyebrow">Ce qu’on vous offre, sans l’afficher</span>
          <h2 class="balance">Un atelier de production que toutes les agences se partagent.</h2>
          <p>
            Chaque mission entrante est branchée sur la couche de production AIGC de HubStudio. C’est ce qui
            tient le coût du contenu au niveau qu’imposent les canaux chinois : trois à cinq publications RED
            par semaine, une vidéo Douyin par jour, une newsletter WeChat hebdomadaire, un grand rendez-vous
            Tmall par mois. Sans moteur de contenu IA-natif derrière, l’équation ne tient plus.
          </p>
          <a class="btn btn--ghost" href={pathFor('agencies/hubstudio', locale)}>Visiter HubStudio</a>
        </div>
        <ImagePlaceholder ratio="4x5" label="Plan de studio. Décor de production, mêlant assets IA et prises de vue réelles." />
      </div>
    </div>
  </section>

  <section id="outbound" class="hero-editorial hero-editorial--dark">
    <div class="container">
      <span class="eyebrow eyebrow--on-dark">Flux 2 · Sortant · De la Chine vers l’Occident</span>
      <h2 class="hero-editorial__title balance">
        Bon produit. Bon prix. Bonne usine. Et personne en face, à l’étranger.
      </h2>
      <p class="hero-editorial__lead">
        Toutes les entreprises chinoises qui partent à l’international butent sur le même mur. La marque a été
        bâtie pour des acheteurs chinois. Le site paraît surchargé aux yeux occidentaux. La page LinkedIn est
        vide. Et personne ne répond à la demande venue de Berlin à 10 h locale. Cette deuxième rive du pont,
        cela fait vingt ans que nous la travaillons.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Ce qu’il faut vraiment</span>
        <h2 class="balance">Ce qu’il faut pour atterrir à l’étranger.</h2>
      </header>
      <div class="grid-2">
        {outboundReq.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Une agence, six services</span>
        <h2 class="balance">BeyondBridge. La filière complète.</h2>
        <p class="lead">
          Conçue spécifiquement pour les marques chinoises qui partent à l’international. Six services qui se
          combinent en trois formules.
        </p>
      </header>
      <ol class="numbered">
        {outboundServices.map((s) => (
          <li>
            <div>
              <p class="numbered__title">{s.h}</p>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Trois formules</span>
        <h2 class="balance">Choisir la formule. Empiler la suivante quand le projet le réclame.</h2>
      </header>
      <div class="grid-3">
        <article class="card">
          <span class="card__index">Starter · Présence</span>
          <h3 class="card__title">Marque + LinkedIn + site</h3>
          <p>Le minimum pour être crédible aux yeux d’un acheteur occidental. Pour les premières sorties à l’international.</p>
        </article>
        <article class="card">
          <span class="card__index">Growth · Visibilité</span>
          <h3 class="card__title">Starter + SEO/GEO + Google Ads</h3>
          <p>Présence et trafic. Vos prospects vous trouvent sur Google, sur ChatGPT et via la recherche payante.</p>
        </article>
        <article class="card">
          <span class="card__index">Full Pipeline · Revenu</span>
          <h3 class="card__title">Growth + force de vente externalisée</h3>
          <p>Chaque lead entrant est qualifié, appelé et remis à votre équipe en état de signer.</p>
        </article>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--primary" href={pathFor('agencies/beyondbridge', locale)}>Visiter BeyondBridge</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Comment nos clients démarrent</span>
        <h2 class="balance">Quatre points d’entrée que nous voyons revenir.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>« Nous avons un salon en Allemagne dans trois mois et rien de crédible en ligne. »</blockquote>
          <p><strong>Formule Starter.</strong> Quatre-vingt-dix jours pour la marque, LinkedIn et un site tourné Occident.</p>
        </article>
        <article class="card">
          <blockquote>« Nous avons une présence, mais aucun lead entrant. »</blockquote>
          <p><strong>Formule Growth.</strong> SEO, GEO et Ads viennent s’ajouter à la base Starter.</p>
        </article>
        <article class="card">
          <blockquote>« Nous avons des leads, mais personne en Europe pour les traiter. »</blockquote>
          <p><strong>Full Pipeline.</strong> On greffe la force de vente sur place.</p>
        </article>
        <article class="card">
          <blockquote>« Nous ne savons pas par où commencer. »</blockquote>
          <p>Trente minutes au téléphone, et nous vous disons quelle formule pour quels 90 jours. <a href={pathFor('contact', locale)}>Réserver un appel</a>.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow">
      <span class="eyebrow eyebrow--on-dark">Le coût d’attendre</span>
      <h2 class="balance">Le référencement compose. Les relations composent. L’autorité compose.</h2>
      <p class="lead">
        Chaque mois sans présence à l’international, ce sont des deals perdus au profit du concurrent arrivé
        avant vous. Chaque trimestre sans pipeline, c’est du budget brûlé en salons, en traducteurs et en
        prospection à froid sans suite. Chaque année supplémentaire, le coût du rattrapage double. Les
        entreprises chinoises qui réussissent à l’export aujourd’hui s’y sont mises il y a deux ans.
      </p>
      <div class="btn-row" style="margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Réserver un appel</a>
        <a class="btn btn--ghost-light" href={pathFor('agencies/beyondbridge', locale)}>Visiter BeyondBridge</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.agency-card-logo) {
    height: 48px;
    width: auto;
    max-width: 180px;
    margin-bottom: var(--space-3);
  }
</style>
