---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Ins Ausland';
const description = "Die komplette Auslands-Pipeline für chinesische Marken. Marke, LinkedIn, Website, SEO, Google Ads und benannte Vertriebsleute in den USA, Großbritannien, Deutschland und Frankreich.";

const requirements = [
  { h: 'Eine Marke, die westliche Käufer wiedererkennen', body: "Nicht aus China übersetzt. Namen, die funktionieren, Slogans, die nicht falsch klingen, eine visuelle Identität, die in Frankfurt und Chicago ohne Sternchen ankommt." },
  { h: 'Präsenz auf LinkedIn', body: "Westliche B2B-Käufer prüfen LinkedIn, bevor sie zum Telefon greifen. Leere Seite — kein Gespräch. 82 Prozent der Käufer sagen laut LinkedIns eigener Studie, dass sie Unternehmen mehr vertrauen, wenn deren Führungskräfte auf LinkedIn posten. Leeres Profil — verlorener Deal." },
  { h: 'Eine Website für westliche Augen', body: "Klar. Großzügig. Eine eindeutige Aktion pro Seite. Außerhalb Chinas gehostet. Schnell. Drei Sekunden Ladezeit kosten Sie über die Hälfte der Besucher." },
  { h: 'Sichtbarkeit in westlichen Suchmaschinen', body: "Google-Rankings plus Zitate in ChatGPT, Perplexity und Gemini. Die meisten chinesischen Unternehmen starten im Ausland mit null Autorität. Keine Backlinks. Keine englischen Inhalte. Keine KI-Zitate. Wettbewerber besitzen die Rankings und die Antworten bereits." },
  { h: 'Anzeigen auf Seite eins', body: "Google Ads, während SEO sich aufbaut. Westliche Landingpages, keine übersetzten. Die meisten chinesischen Unternehmen verbrennen ihr Werbebudget mit zu breiten Keywords, falschen Geografien und für China gebauten Landingpages." },
  { h: 'Vertriebsleute in der richtigen Zeitzone', body: "Ein Käufer in Deutschland fragt um 10 Uhr Berlin an. Shenzhen schläft. Bis zum Morgen hat der Käufer schon drei Wettbewerbern geschrieben. Westliche Käufer wählen den, der zuerst antwortet." },
];

const services = [
  { n: '01', h: 'Markenstrategie', body: "Für westliche Käufer gebaut, nicht übersetzt." },
  { n: '02', h: 'LinkedIn', body: "Der Kanal, den westliches B2B zuerst prüft. Betrieben mit Nuvora Studio, dem LinkedIn-Spezialisten der Gruppe." },
  { n: '03', h: 'Website', body: "Westliche Augen. Außerhalb Chinas gehostet." },
  { n: '04', h: 'SEO und GEO', body: "Bei Google ranken. Von westlichen KIs zitiert werden." },
  { n: '05', h: 'Google Ads', body: "Seite eins ab Tag eins." },
  { n: '06', h: 'Externe Vertriebsmannschaft', body: "Benannte Native-Vertriebsleute in den USA, Großbritannien, Deutschland und Frankreich." },
];
---

<Layout locale={locale} route="going-overseas" title={title} description={description}>
  <section class="hero-editorial hero-editorial--dark">
    <div class="container">
      <span class="eyebrow eyebrow--on-dark">Flow 2 · Outbound · China nach Westen</span>
      <h1 class="hero-editorial__title balance">
        Gutes Produkt. Guter Preis. Gute Fabrik. Keine Pipeline im Ausland.
      </h1>
      <p class="hero-editorial__lead">
        Jedes chinesische Unternehmen, das ins Ausland geht, läuft gegen dieselbe Wand. Die Marke wurde für
        chinesische Käufer gebaut. Die Website wirkt für westliche Augen überladen. Die LinkedIn-Seite ist
        leer. Und niemand antwortet auf die Anfrage aus Berlin um 10 Uhr Ortszeit. Wir bauen die andere Seite
        dieser Brücke seit zwanzig Jahren.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Was es wirklich braucht</span>
        <h2 class="balance">Was es braucht, um im Ausland zu landen.</h2>
      </header>
      <div class="grid-2">
        {requirements.map((r) => (
          <article class="card">
            <h3 class="card__title">{r.h}</h3>
            <p>{r.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Eine Agentur. Sechs Services.</span>
        <h2 class="balance">BeyondBridge. Die komplette Pipeline.</h2>
        <p class="lead">
          Speziell für chinesische Marken im Ausland gebaut. Sechs Services, die in drei Pakete gestapelt sind.
        </p>
      </header>
      <ol class="numbered">
        {services.map((s) => (
          <li>
            <div>
              <p class="numbered__title">{s.h}</p>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Drei Pakete</span>
        <h2 class="balance">Wählen Sie das Paket. Sie können später ergänzen.</h2>
      </header>
      <div class="grid-3">
        <article class="card">
          <span class="card__index">Starter · Präsenz</span>
          <h3 class="card__title">Marke + LinkedIn + Website</h3>
          <p>Das Minimum, um vor einem westlichen Käufer glaubwürdig zu wirken. Für Unternehmen, die zum ersten Mal ins Ausland gehen.</p>
        </article>
        <article class="card">
          <span class="card__index">Growth · Sichtbarkeit</span>
          <h3 class="card__title">Starter + SEO/GEO + Google Ads</h3>
          <p>Präsenz und Traffic. Käufer finden Sie über Google, ChatGPT und bezahlte Suche.</p>
        </article>
        <article class="card">
          <span class="card__index">Full Pipeline · Umsatz</span>
          <h3 class="card__title">Growth + externe Vertriebsmannschaft</h3>
          <p>Jeder eingehende Lead qualifiziert, angerufen und an Ihr Team abschlussreif übergeben.</p>
        </article>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--primary" href={pathFor('agencies/beyondbridge', locale)}>BeyondBridge besuchen</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Wie Kunden meist starten</span>
        <h2 class="balance">Vier typische Einstiege.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <blockquote>„Wir haben in drei Monaten eine Messe in Deutschland und nichts Glaubwürdiges online.“</blockquote>
          <p><strong>Starter-Paket.</strong> 90 Tage bis zu Marke, LinkedIn und einer westlich ausgerichteten Website.</p>
        </article>
        <article class="card">
          <blockquote>„Wir haben Präsenz, aber keine Anfragen.“</blockquote>
          <p><strong>Growth-Paket.</strong> SEO, GEO und Ads auf der Starter-Basis.</p>
        </article>
        <article class="card">
          <blockquote>„Wir haben Anfragen. Niemanden in Europa, der sie bearbeitet.“</blockquote>
          <p><strong>Full Pipeline.</strong> Wir setzen die Vertriebsmannschaft vor Ort drauf.</p>
        </article>
        <article class="card">
          <blockquote>„Wir wissen nicht, wo wir anfangen sollen.“</blockquote>
          <p>Dreißig Minuten am Telefon. Wir sagen Ihnen, welches Paket — und wie 90 Tage aussehen. <a href={pathFor('contact', locale)}>Termin buchen</a>.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow">
      <span class="eyebrow eyebrow--on-dark">Die Kosten des Wartens</span>
      <h2 class="balance">Rankings kompoundieren. Beziehungen kompoundieren. Autorität kompoundiert.</h2>
      <p class="lead">
        Jeder Monat ohne westliche Präsenz sind Deals, die an Wettbewerber gehen, die früher dort waren. Jedes
        Quartal ohne Pipeline ist Budget, das in Messen, Übersetzern und Cold Outreach ohne Wirkung verbrennt.
        Jedes Jahr, das Sie warten, verdoppeln sich die Aufholkosten. Die chinesischen Unternehmen, die im
        Ausland heute gewinnen, haben vor zwei Jahren begonnen.
      </p>
      <div class="btn-row" style="margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Termin buchen</a>
        <a class="btn btn--ghost-light" href={pathFor('agencies/beyondbridge', locale)}>BeyondBridge besuchen</a>
      </div>
    </div>
  </section>
</Layout>
