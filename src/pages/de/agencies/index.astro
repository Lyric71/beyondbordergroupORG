---
import Layout from '../../../layouts/Layout.astro';
import AgencyLogo from '../../../components/AgencyLogo.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'de' as const;
const title = 'Sieben Agenturen';
const description = "BeyondBorderGroup, das sind sieben spezialisierte Agenturen. Sie nehmen die, die Sie brauchen. Jede steht eigenständig. Die meisten Kunden starten mit einer und nehmen weitere hinzu, sobald das Projekt sich öffnet.";

const agencies = [
  { n: '01', slug: 'beyondbordergroup', route: 'agencies/beyondbordergroup' as const, name: 'BeyondBorderGroup', badge: 'Vom Westen nach China · Vollumfänglich', body: "Vollumfängliche China-Agentur. Zwanzig Jahre vor Ort. Branding, Mediaeinkauf, Social, KOLs, Content, PR, Websites, Events, eCommerce, Distribution.", fit: "Marken, die ein verantwortliches Team brauchen, um in China einzutreten oder zu wachsen.", based: 'Shanghai · Hongkong · Paris.' },
  { n: '02', slug: 'theredscroll', route: 'agencies/theredscroll' as const, name: 'TheRedScroll', badge: 'Vom Westen nach China · Kanal-Spezialist', body: "Chinesische Social Media, betrieben vor Ort. WeChat, Douyin, RED, Weibo und vierzehn weitere Plattformen. Fester Scope, fester Preis.", fit: "Marken, die ihre chinesischen Social-Kanäle endlich sauber geführt haben wollen.", based: 'Shanghai · Hongkong.' },
  { n: '03', slug: 'chinawebfoundry', route: 'agencies/chinawebfoundry' as const, name: 'ChinaWebFoundry', badge: 'Vom Westen nach China · Web-Infrastruktur', body: "Websites, gebaut für das chinesische Web. ICP, Baidu, KI-Engines, geprüft im WeChat-Browser. WordPress, Astro und WeChat.", fit: "Marken, deren Website in China wirklich funktionieren muss.", based: 'Shanghai · Hangzhou.' },
  { n: '04', slug: 'beyondcompass', route: 'agencies/beyondcompass' as const, name: 'BeyondCompass', badge: 'Vom Westen nach China · Partnerwahl', body: "Eine private Datenbank aus Distributoren, Tmall TPs, Douyin Partnern und Importeuren, die wir vor Ort getroffen und geprüft haben. Drei Monate Vorlauf weniger.", fit: "Marken, die zum ersten Mal einen chinesischen Partner wählen oder ihre Distributionsaufstellung neu denken.", based: 'Shanghai. Aufgebaut auf fünfzehn Jahren Vor-Ort-Prüfung.' },
  { n: '05', slug: 'beyondbridge', route: 'agencies/beyondbridge' as const, name: 'BeyondBridge', badge: 'Von China in den Westen · Komplette Kette', body: "Auslandsexpansion aus einer Hand für chinesische Marken. Marke, LinkedIn, Website, SEO/GEO, Ads und namentliche Vertriebsrepräsentanten vor Ort.", fit: "Chinesische Marken, die im Ausland eine echte Pipeline aufbauen wollen – nicht nur Messepräsenz.", based: 'China. Repräsentanten in den USA, in Großbritannien, Deutschland und Frankreich.' },
  { n: '06', slug: 'hubstudio', route: 'agencies/hubstudio' as const, name: 'HubStudio', badge: 'Horizontal · Content-Produktion', body: "AIGC-Bild, -Video und -Content. Agenturqualität, KI-Geschwindigkeit.", fit: "Marken, Händler, Agenturen und Industriebetriebe, die Content in Skala brauchen.", based: 'Weltweit. Hauptsitz Shanghai.' },
  { n: '07', slug: 'nuvora-studio', route: 'agencies/nuvora-studio' as const, name: 'Nuvora Studio', badge: 'Horizontal · LinkedIn-B2B', body: "Ausschließlich LinkedIn. Strategie, Content, Mediaeinkauf, Employee Advocacy und persönliche Markenbildung von Führungskräften.", fit: "B2B-Unternehmen weltweit.", based: 'Weltweit.' },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Agenturen</span>
      <h1 class="hero-editorial__title balance">Sieben spezialisierte Agenturen. Ein Ökosystem.</h1>
      <p class="hero-editorial__lead">
        Jede Agentur steht eigenständig: ihre Marke, ihre Preise, ihre Liefergegenstände. Sie wählen die, die
        zur Aufgabe des Tages passt. Die meisten Kunden starten mit einer und öffnen den Umfang, sobald das
        Projekt es verlangt.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="grid-2">
        {agencies.map((a) => (
          <article class="card" style="gap: var(--space-4);">
            <div style="display: flex; gap: var(--space-4); align-items: flex-start;">
              <AgencyLogo slug={a.slug} name={a.name} class="card__logo" />
            </div>
            <div class="card__meta">
              <span class="card__tag card__tag--brand">{a.n}</span>
              <span class="card__tag">{a.badge}</span>
            </div>
            <h2 class="card__title" style="font-size: var(--fs-h3);">{a.name}</h2>
            <p>{a.body}</p>
            <p class="muted"><strong>Für wen:</strong> {a.fit}</p>
            <p class="muted"><strong>Sitz:</strong> {a.based}</p>
            <div class="btn-row" style="margin-top: var(--space-3);">
              <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>Agenturseite öffnen</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.card__logo) {
    height: 64px;
    width: auto;
    max-width: 200px;
  }
</style>
