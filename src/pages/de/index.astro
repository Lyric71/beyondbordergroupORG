---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';
const title = 'China und der Westen, in beide Richtungen';
const description = 'Sieben spezialisierte Agenturen, die China und den Westen in beide Richtungen verbinden. Marke, Kanäle, Web, Partnerwahl, Content, Vertrieb. Ein Ökosystem mit gemeinsamem Rückgrat.';

const agencies = [
  { n: '01', name: 'BeyondBorderGroup', tagline: 'China-Markteintritt von Anfang bis Ende. Von der Marke bis zum eCommerce.', route: 'agencies/beyondbordergroup' as const },
  { n: '02', name: 'TheRedScroll', tagline: 'Chinesische Social Media. WeChat, Douyin, RED, Weibo.', route: 'agencies/theredscroll' as const },
  { n: '03', name: 'ChinaWebFoundry', tagline: 'Websites, gebaut für das chinesische Web. Baidu, ICP, lokale KI-Engines.', route: 'agencies/chinawebfoundry' as const },
  { n: '04', name: 'BeyondCompass', tagline: 'Eine private Datenbank geprüfter Distributoren, Tmall TPs und Douyin Partner.', route: 'agencies/beyondcompass' as const },
  { n: '05', name: 'BeyondBridge', tagline: 'Auslandsexpansion aus einer Hand für chinesische Marken.', route: 'agencies/beyondbridge' as const },
  { n: '06', name: 'HubStudio', tagline: 'Bild, Video und Content per AIGC. Produktion in Skala.', route: 'agencies/hubstudio' as const },
  { n: '07', name: 'Nuvora Studio', tagline: 'B2B, ausschließlich auf LinkedIn. Strategie, Content, Media.', route: 'agencies/nuvora-studio' as const },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <div class="container">
      <div class="hero-statement__grid">
        <div>
          <span class="eyebrow">Ökosystem</span>
          <h1 class="hero-statement__title balance">Marken bauen zwischen China und dem Westen. In beide Richtungen.</h1>
          <p class="hero-statement__lead">
            Sieben spezialisierte Agenturen, eine Überzeugung. Was zwischen China und dem Westen liegt, ist
            kein Übersetzungsproblem. Es ist ein Markenproblem, ein Kanalproblem, ein Infrastrukturproblem
            und ein Vertriebsproblem. Und es wirkt in beide Richtungen.
          </p>
          <div class="btn-row">
            <a class="btn btn--primary" href={pathFor('agencies', locale)}>Die passende Agentur finden</a>
            <a class="btn btn--ghost" href={pathFor('contact', locale)}>Mit uns sprechen</a>
          </div>
          <p class="hero-statement__cite">Shanghai · Hongkong · Paris. Vertriebsrepräsentanten in den USA, Großbritannien, Deutschland und Frankreich.</p>
        </div>
        <div class="hero-statement__visual">
          <ImagePlaceholder ratio="3x4" label="Editorial-Porträt. Operator, der grenzüberschreitend arbeitet." />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Zwei Richtungen. Eine Seite.</span>
        <h2 class="balance">Beide Richtungen liegen jetzt auf einer einzigen Seite.</h2>
        <p class="lead">
          Dasselbe Rückgrat aus Agenturen für beide Richtungen. Sechs typische Einstiege je Seite. Wählen Sie
          Ihr Ufer, oder lesen Sie die ganze Brücke von einem Ende zum anderen.
        </p>
      </header>

      <div class="bridge-panel">
        <span class="bridge-panel__spine" aria-hidden="true">
          <span class="bridge-panel__spine-line"></span>
          <span class="bridge-panel__spine-mark">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 16h22" />
              <path d="M22 11l5 5-5 5" />
              <path d="M10 21l-5-5 5-5" />
            </svg>
          </span>
        </span>

        <a class="bridge-panel__side bridge-panel__side--inbound" href={`${pathFor('two-flows', locale)}#inbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">→</span>
            Vom Westen nach China · Inbound
          </span>
          <h3 class="bridge-panel__title">Westliche Marken nach China bringen.</h3>
          <p class="bridge-panel__body">
            Marke, WeChat, RedNote, Douyin, Tmall, JD, Baidu, KOLs, Distribution. Von einer einzigen
            Landingpage bis zum kompletten Stack.
          </p>
          <span class="bridge-panel__by">BeyondBorderGroup · TheRedScroll · ChinaWebFoundry · BeyondCompass · HubStudio</span>
          <span class="bridge-panel__cta">
            Zum Inbound-Flow
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>

        <a class="bridge-panel__side bridge-panel__side--outbound" href={`${pathFor('two-flows', locale)}#outbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">←</span>
            Von China in den Westen · Outbound
          </span>
          <h3 class="bridge-panel__title">Chinesische Marken ins Ausland tragen.</h3>
          <p class="bridge-panel__body">
            Eine Marke für westliche Käufer, ein gepflegter LinkedIn-Auftritt, eine Website für westliche
            Augen, SEO, GEO, Google Ads, und namentliche Vertriebsleute vor Ort.
          </p>
          <span class="bridge-panel__by">BeyondBridge · Nuvora Studio</span>
          <span class="bridge-panel__cta">
            Zum Outbound-Flow
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>
      </div>

      <div class="btn-row" style="margin-top: var(--space-6); justify-content: center;">
        <a class="btn btn--primary" href={pathFor('two-flows', locale)}>Die Seite „Zwei Richtungen“ öffnen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Aufstellung</span>
        <h2 class="balance">Sieben Spezialisten, ein Ökosystem.</h2>
        <p class="lead">
          Jede Agentur steht eigenständig. Sie nehmen die, die Sie brauchen. Die meisten Kunden starten mit
          einer und ziehen weitere hinzu, sobald das Projekt sich öffnet.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <span class="card__index">{a.n}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Öffnen</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Logik</span>
        <h2 class="balance">Eine 2×2-Matrix, getragen von einem gemeinsamen Sockel.</h2>
        <p class="lead">
          Zwei Spalten nach Richtung. Zwei waagerechte Schichten, die beide Seiten bedienen. Jede Agentur
          besetzt ein Feld – und greift in die übrigen Felder, sobald das Projekt es verlangt.
        </p>
      </header>
      <div style="overflow-x: auto;">
        <table class="matrix">
          <thead>
            <tr>
              <th></th>
              <th>Vom Westen nach China</th>
              <th>Von China in den Westen</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Vollumfänglich</th>
              <td><strong>BeyondBorderGroup</strong></td>
              <td><strong>BeyondBridge</strong></td>
            </tr>
            <tr>
              <th>Kanal-Spezialist</th>
              <td>TheRedScroll</td>
              <td>Nuvora Studio</td>
            </tr>
            <tr>
              <th>Web-Infrastruktur</th>
              <td>ChinaWebFoundry</td>
              <td>BeyondBridge Web-Modul</td>
            </tr>
            <tr>
              <th>Partnerwahl</th>
              <td>BeyondCompass</td>
              <td class="muted">-</td>
            </tr>
            <tr>
              <th>Produktion</th>
              <td colspan="2" style="text-align:center; background: var(--bbg-blue-light); color: var(--bbg-ink); font-weight: 600;">HubStudio durchquert beide Seiten</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>Wie wir uns abstimmen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Warum eine Gruppe</span>
        <h2 class="balance">Spezialisten. Keine Silos.</h2>
      </header>
      <div class="grid-3">
        <div class="prose">
          <h3>Eine These, gespiegelt umgesetzt.</h3>
          <p>
            Ob Sie als französisches Luxushaus nach China gehen oder als chinesischer Industriekonzern in
            Deutschland landen: die Arbeit hat dieselbe Form. Die Marke für die Zielgruppe neu denken. Die
            richtigen Kanäle aufbauen. Die richtige Infrastruktur stellen. Den passenden Content produzieren.
            Ein Team in der richtigen Zeitzone ans Telefon setzen.
          </p>
        </div>
        <div class="prose">
          <h3>Spezialisten, kein Megapaket.</h3>
          <p>
            Jede Agentur hat ihre Marke, ihre Preise, ihre Liefergegenstände, ihr Team. Wer nur eine
            chinesische Website braucht, zahlt kein Media-Team mit. Wer nur LinkedIn betrieben haben will,
            zahlt kein chinesisches KOL-Roster mit.
          </p>
        </div>
        <div class="prose">
          <h3>Eine geteilte Produktions-Engine.</h3>
          <p>
            Sämtliche Agenturen der Gruppe greifen auf die AIGC-Schicht von HubStudio zu. Daraus folgt der
            stabile Stückpreis – und genau deshalb kann eine chinesische Marke im Ausland im selben Takt
            veröffentlichen wie eine westliche Marke in China.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Wer dahintersteht</span>
          <h2 class="balance">Ein Operator. Zwei Jahrzehnte auf beiden Seiten.</h2>
          <p class="lead">
            Die Gruppe wird von Cyril Drouin gegründet und geführt. Fünfundzwanzig Jahre Digital, eCommerce
            und Markenarbeit zwischen Europa und Nordasien. Ehemaliger Chief Digital and eCommerce Officer
            für Publicis North Asia. Gründer von HubStudio und Nuvora Studio.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Auf LinkedIn vernetzen</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin auf LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, Gründer von BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Sagen Sie uns, in welche Richtung Sie gehen.</h2>
      <p class="lead" style="margin-inline: auto;">
        Dreißig Minuten am Telefon. Wir sagen Ihnen, mit welcher Agentur Sie starten sollten – oder ob es
        klüger ist, mehrere parallel zu aktivieren.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Termin buchen</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.agency-card-logo) {
    height: 48px;
    width: auto;
    max-width: 180px;
    margin-bottom: var(--space-3);
  }
</style>
