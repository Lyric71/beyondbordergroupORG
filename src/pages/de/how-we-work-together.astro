---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Wie wir uns abstimmen';
const description = "Eigenständige Agenturen, eine gemeinsame Leitung, eine geteilte Produktions-Engine. Die Struktur, die den Agenturen des BeyondBorderGroup-Ökosystems erlaubt, gemeinsam vorzugehen, ohne in einen Generalisten zu kollabieren.";
---

<Layout locale={locale} route="how-we-work-together" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Wie das Ganze trägt</span>
      <h1 class="hero-editorial__title balance">Sieben Agenturen. Eine Wirbelsäule.</h1>
      <p class="hero-editorial__lead">
        Die Agenturen sind eigenständig: ihre Marke, ihre Preise, ihre Teams. Sie teilen jedoch eine
        gemeinsame Leitung, dieselbe Produktions-Engine und eine einheitliche Arbeitsweise. Hier ist die
        Struktur, die sie zusammenhält, ohne sie zu einem Generalisten zu verschmelzen.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Matrix</span>
        <h2 class="balance">Zwei Spalten nach Richtung. Zwei waagerechte Schichten.</h2>
      </header>
      <div style="overflow-x: auto;">
        <table class="matrix">
          <thead>
            <tr>
              <th></th>
              <th>Vom Westen nach China</th>
              <th>Von China in den Westen</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Vollumfänglicher Operator</th>
              <td><strong>BeyondBorderGroup</strong></td>
              <td><strong>BeyondBridge</strong></td>
            </tr>
            <tr>
              <th>Kanal-Spezialist</th>
              <td>TheRedScroll · WeChat, Douyin, RED, Weibo.</td>
              <td>Nuvora Studio · LinkedIn.</td>
            </tr>
            <tr>
              <th>Web-Infrastruktur</th>
              <td>ChinaWebFoundry · Baidu, ICP, KI-Engines.</td>
              <td>BeyondBridge Web-Modul · Google, westliche KIs.</td>
            </tr>
            <tr>
              <th>Partnerwahl</th>
              <td>BeyondCompass · Geprüfte Distributoren, Tmall TPs, Douyin Partner.</td>
              <td class="muted">-</td>
            </tr>
            <tr>
              <th>Produktion</th>
              <td colspan="2" style="text-align:center; background: var(--bbg-blue-light); color: var(--bbg-ink); font-weight: 600;">HubStudio</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Was zwischen den Agenturen läuft</span>
        <h2 class="balance">Drei Dinge teilt die ganze Gruppe.</h2>
      </header>
      <div class="grid-3">
        <article class="card">
          <h3 class="card__title">Leitung</h3>
          <p>
            Gründer Cyril Drouin verantwortet die Strategie der sieben Agenturen. Fünfundzwanzig Jahre
            Erfahrung zwischen Europa und Nordasien, mit einer Station als Chief Digital and eCommerce
            Officer von Publicis North Asia. Alle Agenturen arbeiten unter einer strategischen Linie.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Die AIGC-Schicht von HubStudio</h3>
          <p>
            Sämtliche Agenturen greifen auf dieselbe KI-native Produktions-Engine zu. Genau das macht es
            möglich, drei wöchentliche RED-Posts für eine chinesische Beauty-Marke und fünf wöchentliche
            LinkedIn-Carousels für einen chinesischen Industriebetrieb beim Eintritt nach Deutschland zum
            gleichen Stückpreis zu produzieren.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Ein Konto, eine Steuerung</h3>
          <p>
            Aktiviert ein Kunde zwei oder mehr Agenturen, übernimmt eine einzige Account-Leitung die
            Steuerung. Ein eingehendes Briefing. Ein Status-Termin. Ein Monatsreport. Kein Kontextverlust
            zwischen Dienstleistern.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">In der Praxis</span>
        <h2 class="balance">Wie die Kombinationen aussehen.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <h3 class="card__title">Der vollständige Inbound-Stack</h3>
          <p>
            BeyondBorderGroup an der Spitze, TheRedScroll am Social, ChinaWebFoundry am Web, HubStudio in
            der Produktion. Ein Kunde. Eine Pipeline. Eine Kennzahl, an der gemessen wird.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Der vollständige Outbound-Stack</h3>
          <p>
            BeyondBridge an der Spitze, Nuvora Studio auf LinkedIn, HubStudio in der Produktion. Die
            Vertriebsleute vor Ort übernehmen das Closing-Gespräch.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Der rein horizontale Kunde</h3>
          <p>
            Ein US-amerikanisches B2B-SaaS, das LinkedIn sauber geführt haben will, beauftragt direkt
            Nuvora – die China-Seite bleibt unberührt. Ein französischer Händler, der quartalsweise 5.000
            Produktbilder braucht, beauftragt direkt HubStudio – die Social-Seite bleibt unberührt.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Der Einzel-Modul-Kunde</h3>
          <p>
            Eine schweizerische Uhrenmarke, die einzig will, dass ihre WordPress-Site in Shanghai unter zwei
            Sekunden lädt, beauftragt ChinaWebFoundry. Genau das, mehr nicht.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div class="prose">
          <span class="eyebrow">Die Honorare</span>
          <h3>Jede Agentur veröffentlicht ihre eigenen.</h3>
          <p>
            Jede Agentur veröffentlicht ihre Tarife auf der eigenen Website. Die Gruppe bündelt nicht. Drei
            beauftragte Agenturen sind drei abgerechnete Leistungsumfänge. Die Account-Steuerung ist
            geteilt; die Produktionsschicht ist dieselbe.
          </p>
        </div>
        <div class="prose">
          <span class="eyebrow">Sprachen und Standorte</span>
          <h3>Wo die Arbeit stattfindet.</h3>
          <p>Strategie und Account-Steuerung in Englisch, Mandarin und Französisch.</p>
          <ul>
            <li>Shanghai – Sitz von BeyondBorderGroup, TheRedScroll, ChinaWebFoundry und HubStudio.</li>
            <li>Hongkong – TheRedScroll und BeyondBorderGroup.</li>
            <li>Paris – BeyondBorderGroup und Konzernleitung.</li>
            <li>Hangzhou – Nebenstandort von ChinaWebFoundry.</li>
            <li>Vertriebsrepräsentanten für BeyondBridge in den USA, in Großbritannien, Deutschland und Frankreich.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">Sie wollen wissen, mit welcher Agentur Sie starten sollten?</h2>
      <a class="btn btn--primary" href={pathFor('contact', locale)}>Termin buchen</a>
    </div>
  </section>
</Layout>
