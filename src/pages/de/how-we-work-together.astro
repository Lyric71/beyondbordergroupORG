<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function wireGrid(grid: HTMLElement | null, cardSelector: string) {
    if (!grid) return;
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
      );
      io.observe(grid);
    } else {
      grid.classList.add('is-visible');
    }
    if (!reduceMotion) {
      grid.querySelectorAll<HTMLElement>(cardSelector).forEach((card) => {
        let raf = 0;
        const onMove = (ev: MouseEvent) => {
          const r = card.getBoundingClientRect();
          const x = (ev.clientX - r.left) / r.width;
          const y = (ev.clientY - r.top) / r.height;
          const rx = (0.5 - y) * 4;
          const ry = (x - 0.5) * 4;
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(() => {
            card.style.transform = `translateY(0) rotateX(${rx}deg) rotateY(${ry}deg)`;
          });
        };
        const onLeave = () => {
          cancelAnimationFrame(raf);
          card.style.transform = '';
        };
        card.addEventListener('mousemove', onMove);
        card.addEventListener('mouseleave', onLeave);
      });
    }
  }

  wireGrid(document.querySelector<HTMLElement>('[data-draws]'), '.draws-card');

  const playbooks = document.querySelector<HTMLElement>('[data-playbooks]');
  if (playbooks) {
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
      );
      io.observe(playbooks);
    } else {
      playbooks.classList.add('is-visible');
    }

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduceMotion) {
      const cards = playbooks.querySelectorAll<HTMLElement>('.playbook');
      cards.forEach((card) => {
        const diagram = card.querySelector<HTMLElement>('.playbook__diagram');
        let raf = 0;
        const onMove = (ev: MouseEvent) => {
          const r = card.getBoundingClientRect();
          const x = (ev.clientX - r.left) / r.width;
          const y = (ev.clientY - r.top) / r.height;
          const rx = (0.5 - y) * 4;
          const ry = (x - 0.5) * 4;
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(() => {
            card.style.transform = `translateY(0) rotateX(${rx}deg) rotateY(${ry}deg)`;
            if (diagram) {
              const px = (x - 0.5) * 8;
              const py = (y - 0.5) * 8;
              diagram.style.setProperty('background-position', `calc(50% + ${px}px) calc(50% + ${py}px)`);
            }
          });
        };
        const onLeave = () => {
          cancelAnimationFrame(raf);
          card.style.transform = '';
          if (diagram) diagram.style.removeProperty('background-position');
        };
        card.addEventListener('mousemove', onMove);
        card.addEventListener('mouseleave', onLeave);
      });
    }
  }
</script>
