---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Wie wir zusammenarbeiten';
const description = 'Unabhängige Agenturen, gemeinsame Leitung, gemeinsamer Produktionsmotor. Wie sich die Agenturen im BeyondBorderGroup-Ökosystem koordinieren, ohne ihre Eigenständigkeit zu verlieren.';
---

<Layout locale={locale} route="how-we-work-together" title={title} description={description}>
  <section class="hero-image">
    <div class="hero-image__bg" aria-hidden="true"></div>
    <div class="hero-image__scrim" aria-hidden="true"></div>
    <div class="container hero-image__inner">
      <span class="eyebrow eyebrow--rule eyebrow--on-dark">Wie es zusammenpasst</span>
      <h1 class="hero-image__title balance">Sechs Agenturen. Ein Rückgrat.</h1>
      <p class="hero-image__lead">
        Die Agenturen sind unabhängig. Eigene Marke, eigene Preise, eigenes Team. Sie teilen sich eine
        Führungsebene, einen Produktionsmotor und eine Arbeitsweise. Hier ist die Struktur, die sie
        koordiniert hält, ohne sie zu einer Generalistin zusammenzuschmelzen.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Logik</span>
        <h2 class="balance">Zwei Leitagenturen. Fünf Spezialisten. Ein Motor.</h2>
        <p class="lead">
          Zwei Leitagenturen, je eine pro Richtung. Fünf Spezialisten, die sich in beide Richtungen
          einklinken. Ein Produktionsmotor, der quer durch beide läuft.
        </p>
      </header>
      <div class="matrix-grid" role="table" aria-label="Agenturen nach Richtung und Ebene">
        <div class="matrix-grid__head" role="row">
          <div class="matrix-grid__corner" aria-hidden="true"></div>
          <div class="matrix-grid__direction matrix-grid__direction--west" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">→</span>
            <span class="matrix-grid__direction-label">Vom Westen nach China</span>
          </div>
          <div class="matrix-grid__direction matrix-grid__direction--east" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">←</span>
            <span class="matrix-grid__direction-label">Von China in den Westen</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Vollservice</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Leitagentur</span>
            <span class="matrix-cell__name">BeyondBorderGroup</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Leitagentur</span>
            <span class="matrix-cell__name">BeyondBridge</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Social Media</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Beide Richtungen</span>
            <span class="matrix-cell__name">TheRedScroll</span>
            <span class="matrix-cell__note">WeChat, Douyin, RedNote, Weibo. Für westliche oder chinesische Kunden.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">LinkedIn B2B</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Beide Richtungen</span>
            <span class="matrix-cell__name">Nuvora Studio</span>
            <span class="matrix-cell__note">Ausschließlich LinkedIn. Für westliche oder chinesische Kunden.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Web-Infrastruktur</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Beide Richtungen</span>
            <span class="matrix-cell__name">ChinaWebFoundry</span>
            <span class="matrix-cell__note">Baidu-tauglich, ICP, chinesische KI-Engines. Für westliche oder chinesische Kunden.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Partner-Sourcing</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Beide Richtungen</span>
            <span class="matrix-cell__name">BeyondCompass</span>
            <span class="matrix-cell__note">Geprüfte China-Distributoren, Tmall-TPs, Douyin Partners.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--span" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Produktion</span>
          </div>
          <div class="matrix-cell matrix-cell--span" role="cell">
            <span class="matrix-cell__bridge" aria-hidden="true">
              <span class="matrix-cell__bridge-dot"></span>
              <span class="matrix-cell__bridge-line"></span>
              <span class="matrix-cell__bridge-dot"></span>
            </span>
            <span class="matrix-cell__name">HubStudio</span>
            <span class="matrix-cell__note">Content-Produktionsmotor. Quer zu beiden Richtungen.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section draws-section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Woraus jede Agentur schöpft</span>
        <h2 class="balance">Vier Dinge, die sich die Gruppe teilt.</h2>
        <p class="lead">Unabhängige Agenturen oben, gemeinsames Rückgrat unten. Nichts davon wird zweimal berechnet.</p>
      </header>

      <ol class="draws-grid" data-draws>
        <li class="draws-card draws-card--engine" style="--i: 0;">
          <span class="draws-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3l1.8 5.4L19 10l-5.2 1.6L12 17l-1.8-5.4L5 10l5.2-1.6L12 3z" />
              <path d="M19 4l.4 1.2L20.6 5.6l-1.2.4L19 7.2l-.4-1.2L17.4 5.6l1.2-.4L19 4z" />
              <path d="M5 17l.4 1.2L6.6 18.6l-1.2.4L5 20.2l-.4-1.2L3.4 18.6l1.2-.4L5 17z" />
            </svg>
          </span>
          <span class="draws-card__tag">Motor</span>
          <h3 class="draws-card__title">HubStudio. Der Content-Motor.</h3>
          <p class="draws-card__body">
            AIGC-Bild, -Video, -Text, -Design und Motion. Jedes Briefing, das Produktion braucht, läuft durch
            diese Ebene. Die Kosten bleiben wettbewerbsfähig, selbst im Volumen, das chinesische Kanäle
            verlangen.
          </p>
          <ul class="draws-card__chips" role="list">
            <li>Bild</li>
            <li>Video</li>
            <li>Text</li>
            <li>Design</li>
            <li>Motion</li>
          </ul>
        </li>

        <li class="draws-card draws-card--ops" style="--i: 1;">
          <span class="draws-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="8" height="8" rx="1.6" />
              <rect x="13" y="3" width="8" height="8" rx="1.6" />
              <rect x="3" y="13" width="8" height="8" rx="1.6" />
              <rect x="13" y="13" width="8" height="8" rx="1.6" />
            </svg>
          </span>
          <span class="draws-card__tag">Backoffice</span>
          <h3 class="draws-card__title">Verwaltung, Finanzen, IT, HR.</h3>
          <p class="draws-card__body">
            Die unscheinbaren Teile, eine Agentur zu führen, gebündelt in der Gruppe. Einmal gemacht für
            sieben Agenturen, nicht siebenmal. Das Kopfweh jedes Gründers, jedem Gründer abgenommen.
          </p>
          <ul class="draws-card__chips" role="list">
            <li>Verwaltung</li>
            <li>Finanzen</li>
            <li>IT</li>
            <li>HR</li>
          </ul>
        </li>

        <li class="draws-card draws-card--voice" style="--i: 2;">
          <span class="draws-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22a10 10 0 110-20c5.5 0 9 3.5 9 8 0 3-2 5-5 5h-2a2 2 0 100 4 2 2 0 01-2 2z" />
              <circle cx="7.5" cy="11.5" r="1.2" fill="currentColor" stroke="none" />
              <circle cx="9.5" cy="7.5" r="1.2" fill="currentColor" stroke="none" />
              <circle cx="14.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
              <circle cx="17" cy="9.5" r="1.2" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span class="draws-card__tag">Kreation</span>
          <h3 class="draws-card__title">Eine Stimme über alle Agenturen.</h3>
          <p class="draws-card__body">
            Wenn ein Briefing zwei oder mehr Agenturen umfasst (das gilt für die meisten), hält die Group
            Creative Direction die Arbeit in einer Stimme. Dieselbe Marke auf Tmall und auf RedNote. Derselbe
            Ton auf einer westlichen LinkedIn-Seite und einer französischen Google-Ads-Landingpage.
          </p>
          <ul class="draws-card__chips" role="list">
            <li>Marke</li>
            <li>Ton</li>
            <li>Visuell</li>
            <li>Text</li>
          </ul>
        </li>

        <li class="draws-card draws-card--lead" style="--i: 3;">
          <span class="draws-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4" />
              <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" />
            </svg>
          </span>
          <span class="draws-card__tag">Leitung</span>
          <h3 class="draws-card__title">Gruppenführung über alle sieben.</h3>
          <p class="draws-card__body">
            Jede Agentur läuft unter eigener Senior-Leitung. Die Gruppenführung koordiniert Strategie,
            Recruiting und Richtung über alle sieben, damit ein Briefing, das Agenturgrenzen überschreitet,
            weiterhin einen verantwortlichen Inhaber und ein gemeinsames Playbook hat.
          </p>
          <ul class="draws-card__chips" role="list">
            <li>Strategie</li>
            <li>Richtung</li>
            <li>Agenturübergreifende Aufsicht</li>
          </ul>
        </li>
      </ol>
    </div>
  </section>

  <section class="section section--alt playbook-section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">In der Praxis</span>
        <h2 class="balance">Vier Wege, die Agenturen zu stapeln.</h2>
        <p class="lead">Dasselbe Briefing, andere Mischung. Nehmen Sie das Muster, das Ihrem am nächsten kommt.</p>
      </header>

      <ol class="playbooks" data-playbooks>
        <li class="playbook playbook--inbound" style="--i: 0;">
          <span class="playbook__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 3 21 7.5 12 12 3 7.5 12 3" />
              <polyline points="3 12 12 16.5 21 12" />
              <polyline points="3 16.5 12 21 21 16.5" />
            </svg>
          </span>
          <span class="playbook__tag">Lead · BeyondBorderGroup</span>
          <h3 class="playbook__title">Der vollständige Inbound-Stack.</h3>
          <p class="playbook__copy">
            BeyondBorderGroup führt das Briefing, mit TheRedScroll auf Social, ChinaWebFoundry im Web,
            BeyondCompass für die Distribution und HubStudio in der Content-Produktion. Ein Kunde. Eine
            Pipeline. Eine Zahl, an der gemessen wird.
          </p>
        </li>

        <li class="playbook playbook--outbound" style="--i: 1;">
          <span class="playbook__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12h18" />
              <path d="M12 3a14 14 0 010 18" />
              <path d="M12 3a14 14 0 000 18" />
            </svg>
          </span>
          <span class="playbook__tag">Lead · BeyondBridge</span>
          <h3 class="playbook__title">Der vollständige Outbound-Stack.</h3>
          <p class="playbook__copy">
            BeyondBridge führt das Briefing, mit Nuvora Studio auf LinkedIn, ChinaWebFoundry beim Bau der
            westlich ausgerichteten Website und HubStudio in der Content-Produktion. Namentlich benannte
            Vertriebsleute vor Ort in den USA, Großbritannien, Deutschland und Frankreich übernehmen das
            Abschlussgespräch.
          </p>
        </li>

        <li class="playbook playbook--horizontal" style="--i: 2;">
          <span class="playbook__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="8" height="12" rx="1.6" />
              <rect x="13" y="6" width="8" height="12" rx="1.6" />
            </svg>
          </span>
          <span class="playbook__tag">Direkt · Ohne Lead</span>
          <h3 class="playbook__title">Der rein horizontale Kunde.</h3>
          <p class="playbook__copy">
            Ein US-amerikanisches B2B-SaaS-Unternehmen, das einfach nur LinkedIn ordentlich geführt haben
            will, beauftragt Nuvora direkt. Es rührt die China-Seite nie an. Ein französischer Einzelhändler,
            der pro Quartal 5.000 Produktbilder braucht, beauftragt HubStudio direkt. Er rührt die
            Social-Seite nie an.
          </p>
        </li>

        <li class="playbook playbook--module" style="--i: 3;">
          <span class="playbook__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="6" width="12" height="12" rx="2" />
              <path d="M3 12h2M19 12h2M12 3v2M12 19v2" />
            </svg>
          </span>
          <span class="playbook__tag">Nur eine Agentur</span>
          <h3 class="playbook__title">Der Ein-Modul-Kunde.</h3>
          <p class="playbook__copy">
            Eine Schweizer Uhrenmarke, die nur möchte, dass ihre WordPress-Seite in Shanghai in zwei
            Sekunden lädt, beauftragt ChinaWebFoundry. Genau das. Nichts weiter.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">Wissen Sie, mit welcher Agentur Sie anfangen sollen?</h2>
      <a class="btn btn--primary" href={pathFor('contact', locale)}>Termin buchen</a>
    </div>
  </section>
</Layout>

<style>
  .hero-image {
    position: relative;
    isolation: isolate;
    color: var(--bbg-white);
    padding: clamp(8rem, 18vh, 13rem) 0 clamp(5rem, 11vh, 7.5rem);
    min-height: 72vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero-image__bg {
    position: absolute;
    inset: 0;
    background-image: url('https://www.theredscroll.com/images/team/team-photo.png');
    background-size: cover;
    background-position: center;
    background-color: #0a1320;
    z-index: -2;
    transform: scale(1.05);
    animation: hero-image-drift 32s ease-in-out infinite alternate;
  }
  @keyframes hero-image-drift {
    from { transform: scale(1.05) translate3d(0, 0, 0); }
    to   { transform: scale(1.10) translate3d(-1.5%, -1%, 0); }
  }
  .hero-image__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(10, 19, 32, 0.82) 0%, rgba(10, 19, 32, 0.55) 50%, rgba(10, 19, 32, 0.30) 100%),
      radial-gradient(ellipse at 22% 32%, rgba(38, 154, 218, 0.20), transparent 60%);
    z-index: -1;
  }
  .hero-image__inner { max-width: 760px; }
  .hero-image__title {
    font-size: clamp(2.5rem, 4.6vw + 0.5rem, 4.25rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--bbg-white);
    margin: var(--space-4) 0 var(--space-5);
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
    font-weight: 600;
  }
  .hero-image__lead {
    font-size: var(--fs-lead);
    color: rgba(255, 255, 255, 0.88);
    max-width: 60ch;
  }

  .matrix-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .matrix-grid__head,
  .matrix-grid__row {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .matrix-grid__direction {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bbg-ink);
    position: relative;
  }
  .matrix-grid__direction::after {
    content: '';
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: 0;
    height: 2px;
    border-radius: 2px;
  }
  .matrix-grid__direction--west::after { background: linear-gradient(90deg, var(--bbg-blue), transparent); }
  .matrix-grid__direction--east::after { background: linear-gradient(90deg, transparent, #c8102e); }
  .matrix-grid__direction--east { justify-content: flex-end; flex-direction: row-reverse; }
  .matrix-grid__arrow {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--bbg-blue);
  }
  .matrix-grid__direction--east .matrix-grid__arrow { color: #c8102e; }
  .matrix-grid__layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    align-self: center;
  }
  .matrix-grid__layer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 12px;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .matrix-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(15, 23, 42, 0.18);
    border-color: var(--bbg-border-strong);
  }
  .matrix-cell--lead {
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-surface) 100%);
    border-color: rgba(38, 154, 218, 0.25);
  }
  .matrix-cell--lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both {
    grid-column: 2 / -1;
    background: linear-gradient(90deg, rgba(38, 154, 218, 0.06) 0%, rgba(255, 255, 255, 0.5) 50%, rgba(200, 16, 46, 0.06) 100%);
    border-color: rgba(15, 23, 42, 0.10);
    padding: var(--space-3) var(--space-5);
  }
  .matrix-grid__row--both .matrix-cell--both::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue) 0%, #c8102e 100%);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__tag {
    color: transparent;
    background: linear-gradient(90deg, var(--bbg-blue), #c8102e);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__note {
    color: var(--bbg-text-muted);
    font-size: var(--fs-small);
  }
  .matrix-cell__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .matrix-cell__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-grid__row--span .matrix-cell--span {
    grid-column: 2 / -1;
    background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
    border-color: transparent;
    color: white;
    align-items: center;
    text-align: center;
    padding: var(--space-5);
    overflow: hidden;
  }
  .matrix-grid__row--span .matrix-cell--span::after {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(circle at 30% 50%, rgba(38, 154, 218, 0.15), transparent 40%),
      radial-gradient(circle at 70% 50%, rgba(200, 16, 46, 0.15), transparent 40%);
    pointer-events: none;
  }
  .matrix-grid__row--span .matrix-cell--span > * { position: relative; z-index: 1; }
  .matrix-grid__row--span .matrix-cell__name { color: white; font-size: 1.25rem; }
  .matrix-grid__row--span .matrix-cell__note {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--fs-small);
    margin-top: 2px;
  }
  .matrix-cell__bridge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-2);
  }
  .matrix-cell__bridge-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--bbg-blue);
    box-shadow: 0 0 12px rgba(38, 154, 218, 0.7);
    animation: bridge-pulse 2.5s ease-in-out infinite;
  }
  .matrix-cell__bridge-dot:last-child {
    background: #c8102e;
    box-shadow: 0 0 12px rgba(200, 16, 46, 0.7);
    animation-delay: 1.25s;
