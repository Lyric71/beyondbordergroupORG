---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Die Brücke';
const description = "Die Lücke zwischen China und dem Westen ist nicht die Sprache. Es sind Marke, Kanal, Infrastruktur, Suche und Vertrieb. Eine Spezialgruppe ist um diesen Punkt herum gebaut.";

const gaps = [
  { title: 'Marke', body: "Was im einen Markt Qualität signalisiert, signalisiert im anderen Unordnung. Chinesische Sites führen mit Vertrauenssignalen, Zertifikaten, Partnerlogos, Auszeichnungen. Westliche Sites führen mit einer klaren Aktion und viel Weißraum. Beide Seiten lesen die andere als falsch." },
  { title: 'Kanal', body: "Westliche B2B-Käufer schauen zuerst auf LinkedIn. Chinesische Konsumenten öffnen RedNote und WeChat zuerst. Die Reihenfolge der Kanäle wiegt so schwer wie die Botschaft." },
  { title: 'Infrastruktur', body: "Google indexiert westliche Sites. Baidu indexiert chinesische Sites. Andere Regeln, andere Maschinen, andere Anträge. Hosting außerhalb Chinas: langsame Ladezeit und kaputte Plug-ins hinter der Firewall. Hosting im Westen: keine ICP-Lizenz, die Sie haben." },
  { title: 'Suche', body: "ChatGPT, Perplexity, Gemini zitieren westliche Quellen. DeepSeek, Doubao, Kimi zitieren chinesische. Die neue Schicht — KI als erster Stopp — ist bereits geteilt." },
  { title: 'Vertrieb', body: "Ein Berliner Käufer um 10 Uhr braucht jemanden in Berlin. Ein Shanghaier Käufer um 21 Uhr braucht jemanden auf WeChat. Bis Ihr Team in Shenzhen aufgewacht ist, hat der deutsche Käufer schon drei Mitbewerbern geschrieben." },
];
---

<Layout locale={locale} route="bridge" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Die Brücke</span>
      <h1 class="hero-editorial__title balance">
        Die Brücke zwischen China und dem Westen, gebaut von Leuten, die auf beiden Seiten gearbeitet haben.
      </h1>
      <p class="hero-editorial__lead">
        Zwanzig Jahre in China. Zwanzig Jahre Vertrieb an westliche Käufer. Wir saßen in den Räumen, in denen
        der westliche CEO fragt, warum der China-Launch nicht wächst, und in den Räumen, in denen der
        chinesische Fabrikbesitzer fragt, warum die Leads aus Berlin nicht kommen. Dieselbe Frage. Spiegelbild.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Lücke</span>
        <h2 class="balance">Die Lücke ist nicht die Sprache. Es sind fünf Dinge darunter.</h2>
        <p class="lead">
          Ein Name, der in Shanghai funktioniert, kann in Frankfurt verpuffen. Ein Logo, das in China Qualität
          signalisiert, kann in Chicago die falsche Kategorie signalisieren. Eine übersetzte Tagline klingt
          falsch, in beide Richtungen.
        </p>
      </header>
      <div class="grid-2">
        {gaps.map((g) => (
          <article class="card">
            <h3 class="card__title">{g.title}</h3>
            <p>{g.body}</p>
          </article>
        ))}
      </div>
      <p class="lead" style="margin-top: var(--space-7);">
        Jede Seite hat ihre eigene Infrastruktur. Jede Seite braucht ihr eigenes Spezialteam. Die Gruppe ist um
        diesen Fakt herum gebaut.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="Editorial-Diptychon. Ost und West, gespiegelt." />
        <div class="prose">
          <span class="eyebrow">Warum eine Gruppe und kein Generalist</span>
          <h2 class="balance">Die meisten Agenturen lösen eine Stelle. Wir betreiben die ganze Kette, in Stücken.</h2>
          <p>
            Eine Generalistenagentur, die „beides macht“, macht meist beides schlecht. China-Spezialisten, die
            ein Westbüro eröffnen, haben keine nativen Vertriebsleute in München. Westliche Spezialisten, die
            ein Shanghai-Büro eröffnen, haben kein laufendes WeChat-Werbekonto. Das Organigramm sagt ja. Die
            Ausführung sagt nein.
          </p>
          <p>
            Ein Kunde braucht nicht immer den ganzen Stack. Manchmal nur eine chinesische Website. Manchmal nur
            eine LinkedIn-Maschine. Das als Einzelstück bei einem Spezialisten zu kaufen kostet weniger und
            geht schneller los als innerhalb eines Generalisten-Retainers.
          </p>
          <p>
            Die Stücke sind zusammen stärker als einzeln. Dieselbe AIGC-Produktions-Engine speist chinesische
            RedNote-Posts und deutsche Google-Ads-Landingpages. Dieselbe Content-Logik — beim Käufer beginnen
            und mit der Aktion enden — läuft in beide Richtungen. Spezialisten mit gemeinsamem Rückgrat
            schlagen Spezialisten ohne.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Form der Arbeit</span>
        <h2 class="balance">Gleiche Form, gespiegelt.</h2>
        <p class="lead">
          Ob das Briefing „nach China rein“ oder „nach außen“ heißt, die Arbeit zerfällt gleich.
        </p>
      </header>
      <ol class="numbered">
        <li>
          <div>
            <p class="numbered__title">Strategie und Marke für das Zielpublikum.</p>
            <p>Nicht übersetzt. Neu gebaut.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Kanalpräsenz im Format, das Käufer wirklich nutzen.</p>
            <p>WeChat, Douyin und RED auf der einen Seite. LinkedIn auf der anderen. Nativ, nicht angepasst.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Web- und Such-Infrastruktur, die die Algorithmen am Zielort finden.</p>
            <p>Baidu, ICP, chinesische KIs auf der einen Seite. Google und westliche KIs auf der anderen.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Content-Produktion in dem Volumen, das moderne Kanäle verlangen.</p>
            <p>Gespeist durch die AIGC-Schicht von HubStudio, geteilt zwischen beiden Flows.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Ein Team, das ans Telefon geht — in der richtigen Sprache und Zeitzone.</p>
            <p>Operatoren in Shanghai, Hongkong, Paris. Plus benannte Repräsentanten in den USA, Großbritannien, Deutschland und Frankreich.</p>
          </div>
        </li>
      </ol>
      <div style="margin-top: var(--space-7);">
        <a class="btn btn--primary" href={pathFor('how-we-work-together', locale)}>Beide Flows ansehen</a>
      </div>
    </div>
  </section>
</Layout>
