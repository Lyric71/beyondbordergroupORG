---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Die Brücke';
const description = "Was zwischen China und dem Westen liegt, ist keine Sprachbarriere. Es sind Marke, Kanäle, Infrastruktur, Suche und Vertrieb. Eine spezialisierte Gruppe, die genau um diesen Befund herum gebaut ist.";

const gaps = [
  { title: 'Die Marke', body: "Was im einen Markt Qualität signalisiert, signalisiert im anderen Unruhe. Chinesische Sites führen mit Zertifikaten, Partnerlogos, Auszeichnungen und Vertrauensnachweisen. Westliche Sites führen mit einer einzigen klaren Handlung und viel Weißraum drumherum. Jede Seite liest die andere als Stilbruch." },
  { title: 'Der Kanal', body: "Der westliche B2B-Käufer beginnt bei LinkedIn. Der chinesische Konsument beginnt bei RED und WeChat. Welche Reihenfolge der Kanäle Sie wählen, wiegt mindestens so schwer wie die Botschaft, die Sie auf ihnen platzieren." },
  { title: 'Die Infrastruktur', body: "Google indexiert westliche Sites. Baidu indexiert chinesische Sites. Andere Regeln, andere Server, andere Behördengänge. Außerhalb Chinas gehostet: lange Ladezeiten hinter der Firewall und gebrochene Plug-ins. Im Westen gehostet: keine ICP-Lizenz." },
  { title: 'Die Suche', body: "ChatGPT, Perplexity und Gemini zitieren westliche Quellen. DeepSeek, Doubao und Kimi zitieren chinesische. Die neue Schicht im Kaufpfad – die KI als erste Anlaufstelle – ist bereits in zwei Welten geteilt." },
  { title: 'Der Vertrieb', body: "Ein Käufer in Berlin um zehn Uhr braucht jemanden in Berlin. Ein Käufer in Shanghai um neun Uhr abends braucht jemanden auf WeChat. Bis Ihr Team in Shenzhen den Tag begonnen hat, hat der deutsche Käufer bereits drei Wettbewerber angeschrieben." },
];
---

<Layout locale={locale} route="bridge" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Die Brücke</span>
      <h1 class="hero-editorial__title balance">
        Eine Brücke zwischen China und dem Westen, gebaut von Leuten, die auf beiden Ufern gearbeitet haben.
      </h1>
      <p class="hero-editorial__lead">
        Zwanzig Jahre in China. Zwanzig Jahre Vertrieb an westliche Käufer. Wir saßen in den Räumen, in denen
        der westliche Vorstand fragt, warum der China-Launch nicht in die Spur kommt – und in den Räumen, in
        denen der chinesische Fabrikinhaber fragt, warum die Leads aus Berlin nicht eintreffen. Dieselbe Frage.
        Zwei Spiegel.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Der Spalt</span>
        <h2 class="balance">Der Spalt ist nicht die Sprache. Darunter liegen fünf Schichten, die ihn tragen.</h2>
        <p class="lead">
          Ein Name, der in Shanghai zündet, kann in Frankfurt verpuffen. Ein Logo, das in China für Qualität
          steht, kann in Chicago die falsche Kategorie signalisieren. Ein übersetzter Claim klingt in beiden
          Richtungen schief.
        </p>
      </header>
      <div class="grid-2">
        {gaps.map((g) => (
          <article class="card">
            <h3 class="card__title">{g.title}</h3>
            <p>{g.body}</p>
          </article>
        ))}
      </div>
      <p class="lead" style="margin-top: var(--space-7);">
        Jede Seite hat ihre eigene Infrastruktur. Jede Seite braucht ihr eigenes Spezialteam. Genau um diesen
        Befund herum ist die Gruppe gebaut.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="Editorial-Diptychon. Ost und West, gespiegelt." />
        <div class="prose">
          <span class="eyebrow">Warum eine Gruppe und kein Generalist</span>
          <h2 class="balance">Die meisten Agenturen lösen ein Stück. Wir betreiben die ganze Kette – in Stücken.</h2>
          <p>
            Eine Generalistenagentur, die behauptet, beides zu können, kann am Ende beides nicht richtig.
            China-Spezialisten, die ein westliches Büro eröffnen, haben keine muttersprachlichen
            Vertriebsleute in München. Westliche Spezialisten, die ein Büro in Shanghai aufmachen, haben kein
            funktionierendes WeChat-Ads-Konto. Das Organigramm sagt ja, die Ausführung sagt nein.
          </p>
          <p>
            Sie brauchen nicht immer den ganzen Stack. Manchmal genügt eine chinesische Website. Manchmal
            genügt ein LinkedIn-Motor. Wer das einzeln bei einem Spezialisten kauft, zahlt weniger und ist
            schneller live, als wenn dasselbe in einem Generalisten-Retainer versteckt wäre.
          </p>
          <p>
            Zusammen sind die Stücke stärker als die Summe der Teile. Dieselbe AIGC-Produktions-Engine
            beliefert chinesische RED-Posts und deutsche Google-Ads-Landingpages. Dieselbe Content-Logik –
            beim Käufer beginnen, mit der Handlung enden – funktioniert in beide Richtungen. Spezialisten mit
            gemeinsamem Rückgrat schlagen Spezialisten ohne.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Die Form der Arbeit</span>
        <h2 class="balance">Dieselbe Form, gespiegelt gelesen.</h2>
        <p class="lead">
          Ob das Briefing „Eintritt nach China“ oder „Schritt ins Ausland“ heißt: die Arbeit zerlegt sich
          gleich.
        </p>
      </header>
      <ol class="numbered">
        <li>
          <div>
            <p class="numbered__title">Strategie und Marke für das Zielpublikum.</p>
            <p>Keine Übersetzung. Eine Neugründung.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Präsenz in den Kanälen, die die Käufer wirklich nutzen.</p>
            <p>WeChat, Douyin und RED auf der einen Seite. LinkedIn auf der anderen. Nativ, nicht angepasst.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Web- und Such-Infrastruktur, die die jeweiligen Algorithmen finden.</p>
            <p>Baidu, ICP und chinesische KIs auf einer Seite. Google und westliche KIs auf der anderen.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Content-Produktion in dem Takt, den moderne Kanäle einfordern.</p>
            <p>Gespeist von der AIGC-Schicht aus HubStudio, geteilt zwischen beiden Flows.</p>
          </div>
        </li>
        <li>
          <div>
            <p class="numbered__title">Ein Team, das in der richtigen Sprache und Zeitzone abnimmt.</p>
            <p>Operatoren in Shanghai, Hongkong und Paris; namentliche Vertriebsleute in den USA, in Großbritannien, Deutschland und Frankreich.</p>
          </div>
        </li>
      </ol>
      <div style="margin-top: var(--space-7);">
        <a class="btn btn--primary" href={pathFor('how-we-work-together', locale)}>Beide Flows ansehen</a>
      </div>
    </div>
  </section>
</Layout>
