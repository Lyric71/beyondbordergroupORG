---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'de' as const;
const title = 'Der Gründer';
const description = "Gründer von BeyondBorderGroup, HubStudio und Nuvora Studio. Fünfundzwanzig Jahre in Digital und eCommerce auf beiden Seiten der Brücke zwischen China und dem Westen.";
---

<Layout locale={locale} route="founder" title={title} description={description}>
  <section class="hero-editorial hero-editorial--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Der Gründer</span>
          <h1 class="hero-editorial__title balance">Ein Operator. Zwei Jahrzehnte auf beiden Seiten.</h1>
          <p class="hero-editorial__lead">
            BeyondBorderGroup wird von Cyril Drouin gegründet und geführt. Die Gruppe existiert, weil er
            fünfundzwanzig Jahre damit verbracht hat, Marken auf beiden Seiten der Brücke zwischen China und
            dem Westen aufzubauen — und gesehen hat, wie dieselben Unternehmen in beide Richtungen gegen
            dieselben Wände laufen. Jede Agentur im Ökosystem ist die Kodifizierung von etwas, das er
            mindestens einmal für einen Kunden bauen musste.
          </p>
        </div>
        <ImagePlaceholder ratio="4x5" label="Editorial-Porträt des Gründers." dark />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">Warum die Gruppe existiert</span>
      <h2 class="balance">Zwei Arten von Räumen, über zwei Jahrzehnte.</h2>
      <p>Die These ist nicht theoretisch. Sie kommt aus zwanzig Jahren in zwei Arten von Räumen.</p>
      <p>
        Erste Art: eine westliche CMO in Paris, die fragt, warum der China-Launch nach sechs Monaten und einer
        übersetzten Website nicht konvertiert.
      </p>
      <p>
        Zweite Art: ein chinesischer Fabrikbesitzer in Shenzhen, der fragt, warum nach der Genfer Messe keine
        Leads aus Berlin kommen.
      </p>
      <p>
        Dieselbe Frage. Spiegelbild. Andere Infrastruktur. Und in beiden Fällen war die Lücke nie die Sprache.
        Es waren Marke, Kanäle, Web, Content und wer ans Telefon geht.
      </p>
      <p>
        Er hat BeyondBorderGroup aufgebaut, um die ganze Kette auf beiden Seiten zu betreiben — mit
        Spezialteams, die wirklich im Zielmarkt leben.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Hintergrund</span>
        <h2 class="balance">Fünfundzwanzig Jahre in Digital, Kommunikation und eCommerce.</h2>
      </header>
      <div class="grid-2">
        <article class="card">
          <h3 class="card__title">Sprachen und Ausbildung</h3>
          <p>Master in Informatik und Mathematik. Französisch als Muttersprache. Fließend Englisch. Solides Chinesisch.</p>
        </article>
        <article class="card">
          <h3 class="card__title">Publicis North Asia</h3>
          <p>
            Ehemaliger Chief Digital and eCommerce Officer für Publicis North Asia. Hat die Praxis über Google,
            Amazon, Instagram, Facebook, Tmall, JD, WeChat und den Rest des chinesischen Stacks geführt.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">Eigene Agentur</h3>
          <p>
            Gründer einer eigenen Agentur in Europa und Nordasien. Fokus auf digitale Transformation,
            eCommerce-Technologien (Gold Partner mit Adobe, Salesforce und führenden Open-Source-Plattformen)
            sowie Mediaplanung und -einkauf über die wichtigsten Plattformen und Ad-Exchanges.
          </p>
        </article>
        <article class="card">
          <h3 class="card__title">HubStudio und Nuvora Studio</h3>
          <p>
            Gründer von HubStudio, dem KI-nativen Content-Studio, das als Produktions-Engine für jede Agentur
            im Ökosystem dient. Gründer von Nuvora Studio, der reinen LinkedIn-B2B-Agentur, die das
            LinkedIn-Modul innerhalb von BeyondBridge antreibt.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div class="prose">
          <span class="eyebrow">Marken</span>
          <h2 class="balance">Marken, für die er gearbeitet hat — über zwei Jahrzehnte, auf beiden Seiten der Brücke.</h2>
          <p>
            Apple. GSK. Estée Lauder. Bacardi. Bayer. Sanofi. L’Oréal. Danone. Lenovo. Beiersdorf. Nike.
            Ferrero. Colgate. Heineken. Nestlé. Pigeon. Siemens. Kering.
          </p>
          <p class="muted">
            Bewusst gemischte Liste. Westliche Marken, die er nach China gebracht hat. Asiatische Marken, die
            er in der Region skaliert hat. Globale Marken, bei denen die Arbeit beide Seiten gleichzeitig
            durchquerte.
          </p>
        </div>
        <div class="prose">
          <span class="eyebrow">Branchenrollen und Zertifikate</span>
          <h2 class="balance">Wo sein Name sonst noch auftaucht.</h2>
          <ul>
            <li>Zertifiziert in Google Ads, Google Analytics, Amazon Advertising und LinkedIn.</li>
            <li>Jurymitglied bei Adfest und den DMAA International Digital Marketing Awards.</li>
            <li>Vorsitzender des Communication and Marketing Forums der EU-Handelskammer in China. Sieben Jahre.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="split split--media-first">
        <ImagePlaceholder ratio="4x5" label="Hörsaal. Cyril unterrichtet im Executive MBA." />
        <div class="prose">
          <span class="eyebrow">Lehre</span>
          <h2 class="balance">Über zehn Jahre Lehrtätigkeit in Digital und eCommerce.</h2>
          <p>An Executive-MBA-Studierende an:</p>
          <ul>
            <li>HEC, Paris.</li>
            <li>ESSEC, Paris und Singapur.</li>
            <li>ESMOD, Paris.</li>
            <li>Shanghai Jiaotong University.</li>
          </ul>
          <p>
            Regelmäßiger Keynote-Speaker zu Digital und eCommerce weltweit. Die Trainingsprogramme innerhalb
            von BeyondBorderGroup, die Masterclasses, die Executive-Workshops und die China Learning
            Expeditions kommen direkt aus dieser Lehrpraxis.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow prose">
      <span class="eyebrow">Warum das für Kunden zählt</span>
      <h2 class="balance">Ein Operator, der die Praxis weiterhin selbst führt.</h2>
      <p>
        Die meisten Agenturgründer sind entweder Operatoren oder Vertriebler. Cyril ist ein Operator, der die
        Praxis weiterhin selbst führt. Er sitzt in den Strategiesitzungen der Agenturen der Gruppe. Er hat die
        Playbooks geschrieben, die die Teams jetzt ausführen. Wenn ein Kunde fragt „wurde das schon einmal
        gemacht?“, lautet die Antwort meistens „ja. Wir haben es für Apple gemacht. Oder Estée Lauder. Oder
        Heineken. Oder eine chinesische Marke, von der die meisten Leute noch nichts gehört haben.“
      </p>
      <p>
        Diese Kontinuität ist der Punkt. Die Gruppe sind nicht sechs unabhängige Anbieter, die ein Logo teilen.
        Es sind sechs Spezialteams, die eine These, ein Leadership und einen Operating-Standard teilen.
        Festgelegt von jemandem, der seit fünfundzwanzig Jahren Marken über die Grenze zwischen China und dem
        Westen baut, in beide Richtungen.
      </p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">Verbinden.</h2>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Termin mit Cyril buchen</a>
        <a class="btn btn--ghost-light" href="https://www.linkedin.com/in/cyril-d-68835729" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>
