---
import Layout from '../../../layouts/Layout.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'es' as const;
const route = 'agencies/hubstudio' as const;

type ServiceKey = 'produce' | 'platform' | 'direct';
const services: Array<{
  key: ServiceKey;
  title: string;
  intro: string;
  image: string;
  items: { name: string; body: string }[];
}> = [
  {
    key: 'produce',
    title: 'Producir',
    intro: 'Imágenes, vídeo y copy fieles a la marca. Cientos de piezas finalizadas al mes, generadas, rodadas o híbridas.',
    image: '/images/hubstudio-produce.webp',
    items: [
      { name: 'Producción de imagen', body: 'Visuales de marca a gran escala, desde 35 $ por brief hasta 405 $ por pieza finalizada. Varias versiones, retoque completo, tres rondas de cambios. Generadas, rodadas o híbridas.' },
      { name: 'Vídeo corto y largo', body: 'Desde 200 $ por guion. Preproducción, posproducción, locución, música, subtítulos. Rodajes reales, generados o híbridos.' },
      { name: 'Estudio de imagen real', body: 'Sesiones reales de foto y vídeo cuando el brief lo pide. Lo usan Mazda, Nescafé, Marriott, Bobbi Brown y otros.' },
      { name: '3D, CGI, motion', body: 'Animación 3D, CGI de producto, motion design, branding en vídeo, locución, text-to-speech.' },
    ],
  },
  {
    key: 'platform',
    title: 'Plataforma',
    intro: 'Su propio estudio de contenido sobre infraestructura GPU dedicada. Entrenado con su marca. Operado por su equipo.',
    image: '/images/hubstudio-platform.webp',
    items: [
      { name: 'Plataforma Hub4You', body: 'Una plataforma de contenido a medida, desplegada en sus servidores GPU dedicados, integrada con su DAM y su PIM. La opera su equipo. Nosotros formamos y damos soporte. Despliegue en semanas.' },
      { name: 'Modelos entrenados con su marca', body: 'LoRAs y fine-tunes a medida para cada cliente. Sus colores, su estilo, sus productos. Fijados y reproducibles.' },
      { name: 'Pipelines y herramientas', body: 'Flujos de producción montados sobre ComfyUI, Flux, Wan, Veo, Hunyuan y el modelo que apareció la semana pasada. Probados en campañas reales, no en demos.' },
    ],
  },
  {
    key: 'direct',
    title: 'Dirigir',
    intro: 'La capa de inteligencia creativa. Estrategia, transcreación, formación. La parte que no se puede automatizar.',
    image: '/images/hubstudio-direct.webp',
    items: [
      { name: 'Estrategia y guidelines', body: 'Estrategia de contenido, posicionamiento de marca, identidad visual, creatividad de campaña, política de uso de IA, flujos de aprobación.' },
      { name: 'Transcreación', body: 'Multimercado, multilingüe, nativa en cada cultura. Hecha por creativos que viven dentro de la cultura de destino.' },
      { name: 'Formación', body: 'Talleres prácticos para equipos internos sobre ComfyUI, Flux, Wan, Veo, MidJourney y Gemini.' },
    ],
  },
];

const visitUrl = 'https://hubstudio.ai';
const visitLabel = 'Visitar hubstudio.ai';
---

<Layout
  locale={locale}
  route={route}
  title="HubStudio: producción de contenido con IA a mitad de coste"
  description="Una productora con base en China que usa AIGC a gran escala para recortar el coste de contenido un 60 % y entregar cientos de piezas de marca al mes a clientes globales."
>
  <!-- ====================================================================== -->
  <!-- HERO                                                                   -->
  <!-- ====================================================================== -->
  <section class="hs-hero" data-hero>
    <div class="hs-hero__bg" aria-hidden="true">
      <img src="/images/hubstudio-shanghai-studio.webp" alt="" class="hs-hero__bg-img" data-parallax-bg onerror="this.style.display='none'" />
      <div class="hs-hero__bg-scrim"></div>
      <div class="hs-hero__bg-grain"></div>
      <div class="hs-hero__bg-grid"></div>
    </div>

    <div class="container hs-hero__main">
      <div class="hs-hero__content">
        <img src="/AgencyLogos/hubStudio%20(2).png" alt="HubStudio" class="hs-hero__logo" width="160" height="40" loading="eager" decoding="async" />

        <span class="hs-hero__eyebrow">
          <span class="hs-hero__eyebrow-dot"></span>
          Productora · Shanghái · AIGC a escala
        </span>

        <h1 class="hs-hero__title">
          <span class="hs-hero__line" data-anim="word">Una productora</span>
          <span class="hs-hero__line" data-anim="word">pensada para lo que</span>
          <span class="hs-hero__line" data-anim="word">
            el <em class="hs-hero__phrase">contenido</em> es hoy.
          </span>
        </h1>

        <p class="hs-hero__lead" data-anim="fade">Una marca global de electrodomésticos llegó el año pasado con un 22 por ciento de aprobación. Seis meses después, ese porcentaje rozaba el 78. La producción se multiplicó por siete. El coste cayó un 60 por ciento. Esa es, más o menos, la distancia entre la vieja forma de hacer contenido y la que se exige ahora.</p>

        <div class="hs-hero__cta-row" data-anim="fade">
          <a class="hs-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-magnet>
            <span class="hs-magnet__bg"></span>
            <span class="hs-magnet__label">{visitLabel}</span>
            <span class="hs-magnet__arrow" aria-hidden="true">→</span>
          </a>
          <a class="hs-hero__secondary" href={pathFor('contact', locale)} data-anim="fade">
            <span>Hablar con el equipo</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="hs-hero__preview" data-tilt>
        <div class="hs-hero__preview-frame">
          <a class="browser-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
            <div class="browser">
              <div class="browser__chrome">
                <span class="browser__dots">
                  <span class="browser__dot browser__dot--r"></span>
                  <span class="browser__dot browser__dot--y"></span>
                  <span class="browser__dot browser__dot--g"></span>
                </span>
                <span class="browser__url">hubstudio.ai</span>
              </div>
              <div class="browser__viewport">
                <img src="/images/hubstudio-home.png" alt="Página de inicio de hubstudio.ai" class="browser__shot" width="1440" height="900" loading="eager" decoding="async" onerror="this.style.display='none'" />
                <span class="browser__live">
                  <span class="browser__live-dot"></span>
                  En activo · {new Date().toLocaleDateString('es-ES', { month: 'short', year: 'numeric' })}
                </span>
                <span class="browser__visit" aria-hidden="true">
                  <span>Visitar el sitio</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                </span>
              </div>
            </div>
          </a>

          <div class="hs-hero__chip hs-hero__chip--stack">
            <span class="hs-hero__chip-label">Stack</span>
            <span>ComfyUI · Flux · Wan · Veo · Hunyuan</span>
          </div>
          <div class="hs-hero__chip hs-hero__chip--clients">
            <span class="hs-hero__chip-label">Confían en nosotros</span>
            <span>Mazda · Nescafé · Marriott · Bobbi Brown</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#track" class="hs-hero__scroll" aria-label="Bajar">
      <span>Bajar</span>
      <span class="hs-hero__scroll-line"></span>
    </a>
  </section>

  <!-- ====================================================================== -->
  <!-- TRACK RECORD                                                           -->
  <!-- ====================================================================== -->
  <section class="hs-track" id="track">
    <div class="container">
      <div class="hs-track__grid">
        <div class="hs-track__numeral" aria-hidden="true">
          <span class="hs-track__num" data-count="60">0</span>
          <span class="hs-track__num-suffix">%</span>
          <span class="hs-track__num-shadow">60%</span>
        </div>
        <div class="hs-track__copy">
          <span class="eyebrow">Trayectoria</span>
          <h2 class="hs-track__title balance">Coste por pieza finalizada, a la mitad. Producción multiplicada por siete.</h2>
          <p class="hs-track__lead">
            Bien usada, la generación con IA recorta a la mitad o más el coste de una pieza finalizada. El ahorro es real y se lo trasladamos al cliente. Las marcas necesitan cientos de activos al mes, a veces miles, en formatos que hace cinco años no existían. Los estudios tradicionales nunca se construyeron para esto. Nosotros sí.
          </p>
        </div>
      </div>

      <div class="hs-stats">
        <div class="hs-stat">
          <span class="hs-stat__num">22<span class="hs-stat__unit">%</span> <span class="hs-stat__arrow">→</span> 78<span class="hs-stat__unit">%</span></span>
          <span class="hs-stat__label">Tasa de aprobación a los seis meses</span>
        </div>
        <div class="hs-stat">
          <span class="hs-stat__num">7<span class="hs-stat__unit">×</span></span>
          <span class="hs-stat__label">Multiplicador de producción</span>
        </div>
        <div class="hs-stat">
          <span class="hs-stat__num">60<span class="hs-stat__unit">%</span></span>
          <span class="hs-stat__label">Reducción de coste, trasladada al cliente</span>
        </div>
        <div class="hs-stat">
          <span class="hs-stat__num">3<span class="hs-stat__unit">d</span></span>
          <span class="hs-stat__label">Plazos de entrega, el suelo desde el que partimos</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- SERVICES                                                               -->
  <!-- ====================================================================== -->
  <section class="hs-services" id="services">
    <div class="container">
      <header class="hs-services__header">
        <span class="eyebrow">Lo que hacemos</span>
        <h2 class="hs-services__title">
          Tres vías. <em>Un solo estudio.</em><br />
          De principio a fin.
        </h2>
        <p class="hs-services__lead">Somos una productora completa. Rodamos, dirigimos, retocamos, editamos. Y usamos la generación con IA a un nivel al que la mayoría de los estudios todavía no ha llegado. Esa es la parte de la que vale la pena hablar.</p>
      </header>

      <div class="hs-services__shell" data-tabs>
        <div class="hs-services__nav" role="tablist" aria-label="Vías de servicio">
          {services.map((s, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`hs-services__tab hs-services__tab--${s.key} ${i === 0 ? 'is-active' : ''}`}
              data-tab={s.key}
              id={`hs-tab-${s.key}`}
              aria-controls={`hs-panel-${s.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="hs-services__tab-pip" aria-hidden="true"></span>
              <span class="hs-services__tab-label">{s.title}</span>
              <span class="hs-services__tab-count">{s.items.length} {s.items.length === 1 ? 'servicio' : 'servicios'}</span>
            </button>
          ))}
          <span class="hs-services__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="hs-services__panels">
          {services.map((s, i) => (
            <div
              class={`hs-services__panel hs-services__panel--${s.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`hs-panel-${s.key}`}
              aria-labelledby={`hs-tab-${s.key}`}
              data-panel={s.key}
              hidden={i !== 0}
            >
              <div class="hs-services__panel-grid">
                <div class="hs-services__panel-image">
                  <div class="hs-services__panel-frame">
                    <img src={s.image} alt={`${s.title}, mirada editorial`} loading="lazy" decoding="async" onerror="this.style.display='none'" />
                    <div class={`hs-services__panel-tag hs-services__panel-tag--${s.key}`}>
                      <span>{s.title}</span>
                    </div>
                  </div>
                  <div class={`hs-services__panel-stamp hs-services__panel-stamp--${s.key}`} aria-hidden="true">
                    {s.key === 'produce' && '产'}
                    {s.key === 'platform' && '台'}
                    {s.key === 'direct' && '导'}
                  </div>
                </div>

                <div class="hs-services__panel-content">
                  <p class="hs-services__panel-intro">{s.intro}</p>
                  <ul class="hs-services__list">
                    {s.items.map((it) => (
                      <li class="hs-services__item">
                        <span class={`hs-services__item-pip hs-services__item-pip--${s.key}`} aria-hidden="true"></span>
                        <span class="hs-services__item-text">
                          <span class="hs-services__item-name">{it.name}.</span>
                          <span class="hs-services__item-body">{it.body}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- TWO WAYS TO WORK                                                       -->
  <!-- ====================================================================== -->
  <section class="hs-ways">
    <div class="container">
      <header class="hs-ways__header">
        <span class="eyebrow">Dos formas de trabajar con nosotros</span>
        <h2 class="hs-ways__title balance">Mande el brief. O lleve la plataforma.</h2>
      </header>
      <div class="hs-ways__grid">
        <article class="hs-way">
          <span class="hs-way__tag">Servicio</span>
          <h3 class="hs-way__title">Lo hacemos por usted.</h3>
          <p class="hs-way__body">
            Mande el brief, entregamos el contenido. Imágenes, vídeo, packs de eCommerce, adaptaciones de campaña, transcreación, sesiones completas de foto y vídeo cuando el brief lo pide. Cientos de piezas al mes, fieles a la marca, a tiempo.
          </p>
        </article>
        <article class="hs-way">
          <span class="hs-way__tag">Plataforma</span>
          <h3 class="hs-way__title">Le montamos la plataforma.</h3>
          <p class="hs-way__body">
            Hub4You es nuestra plataforma de contenido a medida, desplegada en sus servidores GPU dedicados, integrada con su DAM y su PIM. La opera su equipo, nosotros formamos y damos soporte. Despliegue en semanas.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- HOW WE OPERATE                                                         -->
  <!-- ====================================================================== -->
  <section class="hs-operate">
    <div class="hs-operate__bg" aria-hidden="true"></div>
    <div class="container hs-operate__container">
      <span class="eyebrow eyebrow--on-dark">En qué creemos</span>
      <h2 class="hs-operate__title">
        <span class="hs-operate__line" data-line>La inteligencia creativa es lo único que sigue importando.</span>
        <span class="hs-operate__line" data-line>La cultura no se brifa.</span>
        <span class="hs-operate__line" data-line>La velocidad es el nuevo oficio.</span>
      </h2>
      <div class="hs-operate__statement" data-line>
        <p>Hoy cualquiera genera una imagen aceptable. La diferencia entre aceptable y brillante está en las personas que dirigen el trabajo.</p>
        <p class="hs-operate__emphasis">Entregar en tres días antes parecía imposible. Hoy es el suelo desde el que partimos.</p>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- FINAL CTA                                                              -->
  <!-- ====================================================================== -->
  <section class="hs-cta">
    <div class="hs-cta__bg" aria-hidden="true">
      <img src="/images/hubstudio-shanghai-studio.webp" alt="" onerror="this.style.display='none'" />
      <div class="hs-cta__bg-scrim"></div>
    </div>
    <div class="container hs-cta__content">
      <span class="eyebrow eyebrow--on-dark">Cuando esté listo</span>
      <h2 class="hs-cta__title balance">La productora a la que las marcas se pasan<br />cuando la vieja forma deja de funcionar.</h2>
      <div class="hs-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Hablar con el equipo</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .hs-hero {
    position: relative;
    min-height: 88vh;
    padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    background: #100a0a;
  }

  .hs-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .hs-hero__bg-img {
    position: absolute;
    inset: -8% -4% -4% -4%;
    width: 108%;
    height: 112%;
    object-fit: cover;
    object-position: center 40%;
    will-change: transform;
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04);
    filter: saturate(0.85) contrast(1.05) brightness(0.72);
  }
  .hs-hero__bg-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(16, 10, 10, 0.86) 0%, rgba(16, 10, 10, 0.62) 38%, rgba(16, 10, 10, 0.30) 65%, rgba(16, 10, 10, 0.55) 100%),
      linear-gradient(180deg, rgba(16, 10, 10, 0.55) 0%, rgba(16, 10, 10, 0.05) 30%, rgba(16, 10, 10, 0.0) 60%, rgba(16, 10, 10, 0.85) 100%);
  }
  .hs-hero__bg-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1200px 600px at 20% 30%, rgba(255, 122, 60, 0.18), transparent 65%),
      radial-gradient(900px 500px at 90% 80%, rgba(220, 50, 80, 0.14), transparent 70%);
    mix-blend-mode: screen;
  }
  .hs-hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.6;
  }

  .hs-hero__main {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .hs-hero__content { min-width: 0; max-width: 38rem; }
  .hs-hero__logo {
    display: block;
    width: auto;
    height: 40px;
    filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.4));
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: hsFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.1s forwards;
  }

  .hs-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: hsFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.2s forwards;
  }
  .hs-hero__eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #ff7a3c;
    box-shadow: 0 0 0 0 rgba(255,122,60,0.5);
    animation: hsPulse 2.4s ease-in-out infinite;
  }

  .hs-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 600;
    color: #fff;
    margin: 0 0 var(--space-5);
    max-width: 16ch;
    text-wrap: balance;
  }
  .hs-hero__line {
    display: block;
    overflow: hidden;
  }
  .hs-hero__line[data-anim="word"] {
    transform: translateY(110%);
    opacity: 0;
    animation: hsWordIn 880ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
  }
  .hs-hero__line[data-anim="word"]:nth-child(1) { animation-delay: 0.30s; }
  .hs-hero__line[data-anim="word"]:nth-child(2) { animation-delay: 0.42s; }
  .hs-hero__line[data-anim="word"]:nth-child(3) { animation-delay: 0.54s; }
  @keyframes hsWordIn {
    from { transform: translateY(110%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .hs-hero__phrase {
    font-style: normal;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    position: relative;
    background-image: linear-gradient(120deg, #ffb56a 0%, #ff5a3c 60%, #ffb56a 100%);
  }

  .hs-hero__lead {
    max-width: 50ch;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    margin: 0 0 var(--space-5);
    opacity: 0;
    animation: hsFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.85s forwards;
  }

  .hs-hero__cta-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0;
    animation: hsFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 1s forwards;
  }

  .hs-magnet {
    --x: 0px; --y: 0px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px 16px 28px;
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    isolation: isolate;
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1);
    transform: translate(var(--x), var(--y));
  }
  .hs-magnet__bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, #ff5a3c 0%, #c8341d 100%);
    box-shadow: 0 16px 36px -10px rgba(255,90,60,0.55), inset 0 1px 0 rgba(255,255,255,0.2);
    z-index: -1;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .hs-magnet:hover .hs-magnet__bg { transform: scale(1.04); }
  .hs-magnet__arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .hs-magnet:hover .hs-magnet__arrow { transform: translateX(4px); }

  .hs-hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.92);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .hs-hero__secondary svg { transition: transform 220ms ease; }
  .hs-hero__secondary:hover { color: #ffb56a; }
  .hs-hero__secondary:hover svg { transform: translateX(3px); }

  /* Browser preview with parallax tilt */
  .hs-hero__preview {
    position: relative;
    perspective: 1600px;
    min-width: 0;
    opacity: 0;
    animation: hsFadeIn 900ms cubic-bezier(0.2,0.8,0.2,1) 0.5s forwards;
  }
  .hs-hero__preview-frame {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(var(--tilt-x, -3deg)) rotateX(var(--tilt-y, 2deg));
    transition: transform 600ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .browser-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 14px;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .browser-link:hover { transform: translateY(-2px); }
  .browser-link:focus-visible { outline: 2px solid #fff; outline-offset: 4px; }
  .browser-link:hover .browser__visit { opacity: 1; transform: translateY(0); }
  .browser {
    position: relative;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 40px 80px -28px rgba(0,0,0,0.55),
      0 12px 28px -8px rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.10);
    transform: translateZ(0);
  }
  .browser__visit {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(15,23,42,0.85);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2,0.8,0.2,1);
    pointer-events: none;
  }
  .browser__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
    border-bottom: 1px solid rgba(15,23,42,0.08);
  }
  .browser__dots { display: inline-flex; gap: 6px; }
  .browser__dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .browser__dot--r { background: #ff5f57; }
  .browser__dot--y { background: #febc2e; }
  .browser__dot--g { background: #28c840; }
  .browser__url {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--bbg-text-muted);
    background: rgba(15,23,42,0.04);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
    max-width: 320px;
    margin: 0 auto;
  }
  .browser__viewport {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #f7f9fb;
    overflow: hidden;
  }
  .browser__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .browser__live {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    background: rgba(16, 10, 10, 0.74);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .browser__live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #ff7a3c;
    box-shadow: 0 0 0 0 rgba(255,122,60,0.6);
    animation: hsPulse 2.4s ease-in-out infinite;
  }

  .hs-hero__chip {
    position: absolute;
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.92);
    color: var(--bbg-ink);
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 14px;
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    box-shadow: 0 24px 50px -18px rgba(0,0,0,0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translateZ(40px);
  }
  .hs-hero__chip-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c8341d;
  }
  .hs-hero__chip--stack {
    top: -20px; left: -28px;
    animation: hsFloatA 9s ease-in-out infinite;
  }
  .hs-hero__chip--clients {
    bottom: -24px; right: -20px;
    animation: hsFloatB 11s ease-in-out infinite;
  }
  @keyframes hsFloatA { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(-7px); } }
  @keyframes hsFloatB { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(8px); } }

  .hs-hero__scroll {
    position: absolute;
    bottom: clamp(1rem, 3vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: color 220ms ease;
  }
  .hs-hero__scroll:hover { color: #fff; }
  .hs-hero__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, rgba(255,255,255,0.7), rgba(255,255,255,0));
    position: relative;
    overflow: hidden;
  }
  .hs-hero__scroll-line::after {
    content: "";
    position: absolute;
    top: -36px;
    left: 0; right: 0;
    height: 36px;
    background: linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.95));
    animation: hsScrollLine 1.8s ease-in-out infinite;
  }
  @keyframes hsScrollLine { 0% { top: -36px; } 100% { top: 36px; } }

  @keyframes hsFadeIn { to { opacity: 1; } }
  @keyframes hsPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,122,60,0.55); }
    50% { box-shadow: 0 0 0 7px rgba(255,122,60,0); }
  }

  @media (max-width: 1023px) {
    .hs-hero__main { grid-template-columns: 1fr; gap: var(--space-7); }
    .hs-hero__title { max-width: none; }
    .hs-hero__chip--stack { top: -14px; left: 8px; }
    .hs-hero__chip--clients { bottom: -14px; right: 8px; }
  }
  @media (max-width: 639px) {
    .hs-hero__chip { font-size: 0.72rem; padding: 8px 10px; }
    .hs-hero__chip--stack { display: none; }
    .hs-hero__scroll { display: none; }
  }

  /* ===================================================================== */
  /* TRACK RECORD                                                           */
  /* ===================================================================== */
  .hs-track {
    padding: clamp(5rem, 10vh, 8rem) 0 clamp(4rem, 8vh, 6rem);
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-paper, #f8fafc) 100%);
    position: relative;
  }
  .hs-track__grid {
    display: grid;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (max-width: 1023px) { .hs-track__grid { grid-template-columns: 1fr; gap: var(--space-6); } }

  .hs-track__numeral {
    position: relative;
    line-height: 0.85;
    letter-spacing: -0.06em;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--bbg-ink);
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }
  .hs-track__num {
    position: relative;
    z-index: 2;
    display: inline-block;
    font-size: clamp(7rem, 18vw, 16rem);
    background: linear-gradient(180deg, var(--bbg-ink) 0%, #2a3550 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-variant-numeric: tabular-nums;
  }
  .hs-track__num-suffix {
    position: relative;
    z-index: 2;
    font-size: clamp(3rem, 7vw, 6rem);
    color: #c8341d;
    margin-left: 0.05em;
    letter-spacing: -0.04em;
  }
  .hs-track__num-shadow {
    position: absolute;
    top: 4px; left: 5px;
    font-size: clamp(7rem, 18vw, 16rem);
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,90,60,0.18);
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }
  .hs-track__copy { max-width: 56ch; }
  .hs-track__title { font-size: clamp(1.6rem, 2.4vw + 0.6rem, 2.4rem); line-height: 1.15; margin: 0 0 var(--space-4); }
  .hs-track__lead { font-size: var(--fs-lead); color: var(--bbg-text); }

  .hs-stats {
    margin-top: var(--space-7);
    padding-top: var(--space-6);
    border-top: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }
  @media (max-width: 1023px) { .hs-stats { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 639px) { .hs-stats { grid-template-columns: 1fr; } }
  .hs-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hs-stat__num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.6rem, 2.4vw + 0.4rem, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--bbg-ink);
    font-variant-numeric: tabular-nums;
  }
  .hs-stat__unit {
    color: #c8341d;
    font-size: 0.7em;
    margin-left: 0.05em;
  }
  .hs-stat__arrow {
    color: #c8341d;
    margin: 0 0.25em;
    font-weight: 500;
  }
  .hs-stat__label {
    font-size: 0.85rem;
    color: var(--bbg-text-muted, #6b7280);
    line-height: 1.4;
    max-width: 22ch;
  }

  /* ===================================================================== */
  /* SERVICES                                                               */
  /* ===================================================================== */
  .hs-services {
    padding: clamp(5rem, 10vh, 8rem) 0;
    background: var(--bbg-white, #ffffff);
    position: relative;
  }

  .hs-services__header {
    max-width: 60ch;
    margin: 0 0 var(--space-7);
  }
  .hs-services__title {
    font-size: clamp(2rem, 3.6vw + 0.5rem, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: var(--space-3) 0 var(--space-4);
  }
  .hs-services__title em {
    font-style: normal;
    background: linear-gradient(120deg, #ff7a3c, #c8341d 50%, #b8421a);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .hs-services__lead { color: var(--bbg-text); font-size: var(--fs-lead); max-width: 60ch; }

  .hs-services__shell {
    position: relative;
    background: var(--bbg-paper, #f8fafc);
    border-radius: 28px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    box-shadow: 0 60px 120px -60px rgba(15, 23, 42, 0.18);
  }

  .hs-services__nav {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    padding: 6px;
    background: var(--bbg-white, #ffffff);
    border: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    border-radius: 16px;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .hs-services__tab-indicator {
    position: absolute;
    top: 6px;
    left: 6px;
    width: calc((100% - 12px) / 3);
    height: calc(100% - 12px);
    background: linear-gradient(135deg, var(--bbg-ink) 0%, #2a2222 100%);
    border-radius: 12px;
    transition: transform 380ms cubic-bezier(0.2, 0.85, 0.2, 1);
    pointer-events: none;
    z-index: 0;
  }
  .hs-services__tab {
    position: relative;
    z-index: 1;
    background: transparent;
    border: 0;
    padding: 14px 16px;
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: var(--bbg-text-muted, #6b7280);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
    transition: color 320ms ease;
  }
  .hs-services__tab.is-active { color: #fff; }
  .hs-services__tab.is-active .hs-services__tab-count { color: rgba(255,255,255,0.6); }
  .hs-services__tab-pip {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    transition: background 320ms ease, transform 320ms ease;
  }
  .hs-services__tab--produce.is-active  .hs-services__tab-pip { background: #ff9b6f; }
  .hs-services__tab--platform.is-active .hs-services__tab-pip { background: #ff5a3c; }
  .hs-services__tab--direct.is-active   .hs-services__tab-pip { background: #ffb56a; }
  .hs-services__tab-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.005em;
    color: var(--bbg-ink);
    transition: color 320ms ease;
  }
  .hs-services__tab.is-active .hs-services__tab-label { color: #fff; }
  .hs-services__tab-count {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--bbg-text-muted, #6b7280);
    transition: color 320ms ease;
  }

  .hs-services__panels { position: relative; min-height: 480px; }
  .hs-services__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 380ms ease, transform 480ms cubic-bezier(0.2, 0.85, 0.2, 1);
    pointer-events: none;
  }
  .hs-services__panel.is-active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .hs-services__panel-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: stretch;
  }
  @media (max-width: 1023px) { .hs-services__panel-grid { grid-template-columns: 1fr; } }

  .hs-services__panel-image {
    position: relative;
    min-height: 420px;
  }
  .hs-services__panel-frame {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 420px;
    border-radius: 20px;
    overflow: hidden;
    background: var(--bbg-ink);
    box-shadow: 0 30px 60px -22px rgba(15,23,42,0.30);
  }
  .hs-services__panel-frame img {
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    display: block;
    transition: transform 1.2s cubic-bezier(0.2, 0.85, 0.2, 1);
  }
  .hs-services__panel.is-active .hs-services__panel-frame img { animation: hsKenburns 12s ease-in-out infinite alternate; }
  @keyframes hsKenburns {
    from { transform: scale(1.0); }
    to { transform: scale(1.06); }
  }
  .hs-services__panel-tag {
    position: absolute;
    bottom: 16px; left: 16px;
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(255,255,255,0.92);
    color: var(--bbg-ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 12px 24px -10px rgba(15,23,42,0.3);
  }
  .hs-services__panel-tag--produce  { color: #c8341d; }
  .hs-services__panel-tag--platform { color: #b8421a; }
  .hs-services__panel-tag--direct   { color: #b87a23; }

  .hs-services__panel-stamp {
    position: absolute;
    top: -36px;
    right: -12px;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: 'PingFang SC', 'Microsoft YaHei', serif;
    font-size: 3.2rem;
    font-weight: 700;
    color: #fff;
    box-shadow: 0 16px 36px -10px rgba(15,23,42,0.35);
    transform: rotate(-8deg);
    pointer-events: none;
    user-select: none;
  }
  .hs-services__panel-stamp--produce  { background: linear-gradient(135deg, #ff9b6f, #ff5a3c); }
  .hs-services__panel-stamp--platform { background: linear-gradient(135deg, #ff5a3c, #c8341d); }
  .hs-services__panel-stamp--direct   { background: linear-gradient(135deg, #ffcf6f, #d99a3a); }

  .hs-services__panel-content { display: flex; flex-direction: column; justify-content: center; min-width: 0; }
  .hs-services__panel-intro {
    font-size: 1.1rem;
    line-height: 1.45;
    color: var(--bbg-ink);
    margin: 0 0 var(--space-5);
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.005em;
    max-width: 38ch;
  }

  .hs-services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .hs-services__item {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 14px;
    align-items: start;
    opacity: 0;
    transform: translateY(8px);
  }
  .hs-services__panel.is-active .hs-services__item {
    animation: hsItemIn 520ms cubic-bezier(0.2, 0.85, 0.2, 1) forwards;
  }
  .hs-services__panel.is-active .hs-services__item:nth-child(1) { animation-delay: 0.10s; }
  .hs-services__panel.is-active .hs-services__item:nth-child(2) { animation-delay: 0.16s; }
  .hs-services__panel.is-active .hs-services__item:nth-child(3) { animation-delay: 0.22s; }
  .hs-services__panel.is-active .hs-services__item:nth-child(4) { animation-delay: 0.28s; }
  @keyframes hsItemIn { to { opacity: 1; transform: translateY(0); } }

  .hs-services__item-pip {
    width: 14px; height: 14px;
    border-radius: 50%;
    margin-top: 0.45em;
    flex-shrink: 0;
    background: currentColor;
    box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 12%, transparent);
  }
  .hs-services__item-pip--produce  { color: #ff7a3c; }
  .hs-services__item-pip--platform { color: #c8341d; }
  .hs-services__item-pip--direct   { color: #d99a3a; }
  .hs-services__item-text { display: block; line-height: 1.5; font-size: 0.98rem; }
  .hs-services__item-name { font-weight: 600; color: var(--bbg-ink); margin-right: 0.25rem; }
  .hs-services__item-body { color: var(--bbg-text); }

  /* ===================================================================== */
  /* TWO WAYS                                                               */
  /* ===================================================================== */
  .hs-ways {
    padding: clamp(5rem, 10vh, 8rem) 0;
    background: var(--bbg-paper, #f8fafc);
    position: relative;
  }
  .hs-ways__header {
    max-width: 60ch;
    margin: 0 0 var(--space-6);
  }
  .hs-ways__title {
    font-size: clamp(1.8rem, 3vw + 0.5rem, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: var(--space-3) 0 0;
  }
  .hs-ways__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (max-width: 767px) { .hs-ways__grid { grid-template-columns: 1fr; } }
  .hs-way {
    position: relative;
    background: #fff;
    border: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    border-radius: 22px;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    box-shadow: 0 28px 60px -36px rgba(15,23,42,0.25);
    transition: transform 320ms cubic-bezier(0.2, 0.85, 0.2, 1), box-shadow 320ms ease;
  }
  .hs-way:hover {
    transform: translateY(-4px);
    box-shadow: 0 36px 70px -32px rgba(15,23,42,0.30);
  }
  .hs-way::before {
    content: "";
    position: absolute;
    top: 0; left: clamp(1.75rem, 3vw, 2.5rem);
    width: 48px;
    height: 3px;
    border-radius: 0 0 4px 4px;
    background: linear-gradient(90deg, #ff7a3c, #c8341d);
  }
  .hs-way__tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c8341d;
    margin-bottom: var(--space-4);
  }
  .hs-way__title {
    font-size: clamp(1.4rem, 1.6vw + 0.5rem, 1.9rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-3);
    color: var(--bbg-ink);
  }
  .hs-way__body {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--bbg-text);
    margin: 0;
  }

  /* ===================================================================== */
  /* OPERATE                                                                */
  /* ===================================================================== */
  .hs-operate {
    position: relative;
    padding: clamp(6rem, 12vh, 9rem) 0;
    background: #100a0a;
    color: rgba(255,255,255,0.92);
    isolation: isolate;
    overflow: hidden;
  }
  .hs-operate__bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(900px 500px at 0% 100%, rgba(255,90,60,0.20), transparent 60%),
      radial-gradient(800px 500px at 100% 0%, rgba(217,154,58,0.16), transparent 60%);
    pointer-events: none;
    z-index: -1;
  }
  .hs-operate__container { position: relative; }
  .hs-operate__title {
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    font-size: clamp(2rem, 4vw + 0.5rem, 4.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: var(--space-4) 0 var(--space-6);
    color: #fff;
    max-width: 28ch;
    font-weight: 600;
  }
  .hs-operate__line {
    display: block;
    overflow: hidden;
    position: relative;
    transition: transform 880ms cubic-bezier(0.2, 0.9, 0.2, 1), opacity 600ms ease;
  }
  .hs-operate__line > * { display: inline-block; }
  .hs-operate__line:nth-child(2) { transition-delay: 0.10s; }
  .hs-operate__line:nth-child(3) { transition-delay: 0.20s; }

  .hs-operate__statement {
    max-width: 60ch;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.25rem);
    color: rgba(255,255,255,0.8);
    transition: transform 700ms cubic-bezier(0.2, 0.85, 0.2, 1), opacity 600ms ease;
    transition-delay: 0.40s;
  }
  .hs-operate__statement p { margin: 0 0 var(--space-3); }
  .hs-operate__emphasis {
    font-family: var(--font-display);
    font-weight: 600;
    color: #fff;
    font-size: 1.1em;
    letter-spacing: -0.01em;
  }

  /* ===================================================================== */
  /* FINAL CTA                                                              */
  /* ===================================================================== */
  .hs-cta {
    position: relative;
    padding: clamp(5rem, 10vh, 8rem) 0;
    color: #fff;
    isolation: isolate;
    overflow: hidden;
    background: #100a0a;
  }
  .hs-cta__bg { position: absolute; inset: 0; z-index: -1; }
  .hs-cta__bg img {
    width: 100%; height: 100%; object-fit: cover;
    filter: brightness(0.55) saturate(0.9);
    transform: scale(1.04);
  }
  .hs-cta__bg-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(16,10,10,0.65) 0%, rgba(16,10,10,0.55) 50%, rgba(16,10,10,0.85) 100%);
  }
  .hs-cta__content {
    position: relative;
    text-align: center;
    max-width: 780px;
    margin: 0 auto;
  }
  .hs-cta__title {
    font-size: clamp(2rem, 4vw + 0.5rem, 4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #fff;
    margin: var(--space-4) 0 var(--space-6);
    text-wrap: balance;
  }
  .hs-cta__actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  [data-anim="fade"] { opacity: 0; }
  .hs-track__numeral,
  .hs-track__copy,
  .hs-stats,
  .hs-services__header,
  .hs-services__shell,
  .hs-ways__header,
  .hs-way {
    transition: opacity 700ms cubic-bezier(0.2, 0.85, 0.2, 1), transform 800ms cubic-bezier(0.2, 0.85, 0.2, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .hs-hero__bg-img,
    .hs-hero__line[data-anim="word"],
    .hs-hero__lead,
    .hs-hero__cta-row,
    .hs-hero__logo,
    .hs-hero__eyebrow,
    .hs-hero__chip,
    .hs-services__panel.is-active .hs-services__panel-frame img,
    .hs-services__panel.is-active .hs-services__item,
    .hs-operate__line,
    .hs-operate__statement,
    .hs-track__numeral, .hs-track__copy, .hs-stats, .hs-services__header, .hs-services__shell, .hs-ways__header, .hs-way,
    [data-anim] {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  const init = () => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduced) {
      const revealTargets = document.querySelectorAll<HTMLElement>(
        '.hs-track__numeral, .hs-track__copy, .hs-stats, .hs-services__header, .hs-services__shell, .hs-ways__header, .hs-way'
      );
      revealTargets.forEach((el) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(24px)';
      });
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              el.style.opacity = '';
              el.style.transform = '';
              el.classList.add('is-revealed');
              io.unobserve(el);
            }
          });
        },
        { rootMargin: '0px 0px -5% 0px', threshold: 0.01 }
      );
      revealTargets.forEach((el) => io.observe(el));
    }

    const counter = document.querySelector<HTMLElement>('.hs-track__num[data-count]');
    if (counter) {
      const target = Number(counter.dataset.count || '0');
      if (reduced) {
        counter.textContent = String(target);
      } else {
        const cio = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const start = performance.now();
                const dur = 1600;
                const tick = (now: number) => {
                  const t = Math.min(1, (now - start) / dur);
                  const eased = 1 - Math.pow(1 - t, 3);
                  counter.textContent = String(Math.round(eased * target));
                  if (t < 1) requestAnimationFrame(tick);
                };
                requestAnimationFrame(tick);
                cio.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.4 }
        );
        cio.observe(counter);
      }
    }

    const tabsRoot = document.querySelector<HTMLElement>('[data-tabs]');
    if (tabsRoot) {
      const tabs = Array.from(tabsRoot.querySelectorAll<HTMLButtonElement>('.hs-services__tab'));
      const panels = Array.from(tabsRoot.querySelectorAll<HTMLElement>('.hs-services__panel'));
      const indicator = tabsRoot.querySelector<HTMLElement>('.hs-services__tab-indicator');

      const setIndicator = (idx: number) => {
        if (!indicator) return;
        indicator.style.transform = `translateX(${idx * 100}%)`;
        indicator.style.width = `calc((100% - 12px) / ${tabs.length})`;
      };

      const activate = (idx: number) => {
        tabs.forEach((t, i) => {
          const active = i === idx;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          t.tabIndex = active ? 0 : -1;
        });
        panels.forEach((p, i) => {
          const active = i === idx;
          p.classList.toggle('is-active', active);
          if (active) {
            p.removeAttribute('hidden');
          } else {
            p.setAttribute('hidden', '');
          }
        });
        setIndicator(idx);
      };

      setIndicator(tabs.findIndex((t) => t.classList.contains('is-active')) || 0);

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activate(i));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
            e.preventDefault();
            const dir = e.key === 'ArrowRight' ? 1 : -1;
            const next = (i + dir + tabs.length) % tabs.length;
            tabs[next].focus();
            activate(next);
          }
        });
      });
    }

    if (!reduced) {
      const hero = document.querySelector<HTMLElement>('[data-hero]');
      const tilt = document.querySelector<HTMLElement>('[data-tilt] .hs-hero__preview-frame');
      const bg = document.querySelector<HTMLElement>('[data-parallax-bg]');

      if (hero && tilt) {
        let raf = 0;
        let mx = 0, my = 0;
        let cx = 0, cy = 0;
        const onMove = (e: MouseEvent) => {
          const rect = hero.getBoundingClientRect();
          mx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
          my = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
          if (!raf) raf = requestAnimationFrame(loop);
        };
        const onLeave = () => { mx = 0; my = 0; if (!raf) raf = requestAnimationFrame(loop); };
        const loop = () => {
          cx += (mx - cx) * 0.08;
          cy += (my - cy) * 0.08;
          tilt.style.setProperty('--tilt-x', `${(-cx * 5).toFixed(2)}deg`);
          tilt.style.setProperty('--tilt-y', `${(cy * 4).toFixed(2)}deg`);
          if (Math.abs(mx - cx) > 0.001 || Math.abs(my - cy) > 0.001) {
            raf = requestAnimationFrame(loop);
          } else {
            raf = 0;
          }
        };
        hero.addEventListener('mousemove', onMove);
        hero.addEventListener('mouseleave', onLeave);
      }

      if (bg) {
        const onScroll = () => {
          const rect = bg.getBoundingClientRect();
          const offset = Math.max(-200, Math.min(200, rect.top * -0.18));
          (bg as HTMLElement).style.setProperty('--parallax-y', `${offset}px`);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    }

    if (!reduced) {
      const magnets = document.querySelectorAll<HTMLElement>('[data-magnet]');
      magnets.forEach((m) => {
        m.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = m.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          m.style.setProperty('--x', `${(x * 0.18).toFixed(1)}px`);
          m.style.setProperty('--y', `${(y * 0.18).toFixed(1)}px`);
        });
        m.addEventListener('mouseleave', () => {
          m.style.setProperty('--x', '0px');
          m.style.setProperty('--y', '0px');
        });
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
