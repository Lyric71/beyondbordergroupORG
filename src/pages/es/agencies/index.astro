---
import Layout from '../../../layouts/Layout.astro';
import AgencyLogo from '../../../components/AgencyLogo.astro';
import { pathFor } from '../../../i18n/ui';

const locale = 'es' as const;
const title = 'Siete agencias';
const description =
  'BeyondBorderGroup son siete agencias especialistas. Occidente hacia China, China hacia Occidente y transversales. Cada una se sostiene por sí sola. La mayoría de los clientes empieza por una y suma las demás según crece el proyecto.';

type Group = 'Occidente → China' | 'China → Occidente' | 'Transversal';

type AgencyRoute =
  | 'agencies/beyondbordergroup'
  | 'agencies/theredscroll'
  | 'agencies/chinawebfoundry'
  | 'agencies/beyondcompass'
  | 'agencies/beyondbridge'
  | 'agencies/hubstudio'
  | 'agencies/nuvora-studio';

interface Agency {
  slug: string;
  route: AgencyRoute;
  name: string;
  group: Group;
  category: string;
  tagline: string;
  lead: string;
  lanes: { name: string; body: string }[];
  signal?: string;
  visit: { url: string; label: string };
  based: string;
  accent: string;
}

const agencies: Agency[] = [
  {
    slug: 'beyondbordergroup',
    route: 'agencies/beyondbordergroup',
    name: 'BeyondBorderGroup',
    group: 'Occidente → China',
    category: 'Agencia integral en China',
    tagline: 'Entrar en China. Crecer en China. Entender China.',
    lead:
      'Quince años dentro del ecosistema de comercio chino. Lanzamientos en Tmall, vendavales en Douyin, expedientes ICP rehechos, y cada giro de algoritmo entre medias. Asesoramos, y ejecutamos lo que recomendamos. Sin plantillas. Sin presentaciones recicladas. El trabajo, y nada más.',
    lanes: [
      {
        name: 'Entrar',
        body: 'Consultoría de entrada al mercado, branding y localización, montaje de e-commerce transfronterizo en Tmall Global, JD Worldwide y Douyin, y distribución offline.',
      },
      {
        name: 'Crecer',
        body: 'Operaciones diarias de tienda, social commerce en Xiaohongshu, Douyin y WeChat, medios pagos, sitio chino dentro del Firewall, RR. PP., eventos y ferias.',
      },
      {
        name: 'Aprender',
        body: 'Masterclasses de medio día y de jornada completa, expediciones de aprendizaje de varios días a Shanghái y Shenzhen, e investigación de consumidor a demanda.',
      },
    ],
    signal: 'Tmall · JD · Douyin · RED · WeChat',
    visit: { url: 'https://beyondbordergroup.com', label: 'beyondbordergroup.com' },
    based: 'Shanghái. Hong Kong. París.',
    accent: '#269ada',
  },
  {
    slug: 'theredscroll',
    route: 'agencies/theredscroll',
    name: 'TheRedScroll',
    group: 'Occidente → China',
    category: 'Especialistas en redes sociales chinas',
    tagline: 'Publicamos en las plataformas chinas. Cada día. Desde el terreno.',
    lead:
      'China funciona en sus propias plataformas. WeChat, Douyin, RedNote, Weibo y otras catorce. Saberlo por una diapositiva no es lo mismo que abrir esas apps cada mañana, que es, francamente, lo que la mayoría de las agencias no hace.',
    lanes: [
      {
        name: 'Plan',
        body: 'Estrategia, análisis de competencia, calendarios editoriales y KPI atados a objetivos de negocio. Creación de cuentas, verificación, naming, integración con Tmall, JD y Douyin Shop.',
      },
      {
        name: 'Operar',
        body: 'WeChat, Douyin, RedNote y Weibo en el centro. Bilibili, Kuaishou, Zhihu y otras como complemento. Copy en chino nativo, medios pagos sin recargo sobre la inversión publicitaria, e influencers verificados.',
      },
      {
        name: 'Sostener',
        body: 'WeCom y CRM en WeChat, dominio privado, comunidad y flujos de atención al cliente. Masterclasses y consultoría estratégica en cada plataforma que operamos.',
      },
    ],
    signal: 'Alcance fijo. Precio fijo. Una sola cifra por paquete.',
    visit: { url: 'https://theredscroll.com', label: 'theredscroll.com' },
    based: 'Shanghái. Hong Kong.',
    accent: '#c8102e',
  },
  {
    slug: 'chinawebfoundry',
    route: 'agencies/chinawebfoundry',
    name: 'ChinaWebFoundry',
    group: 'Occidente → China',
    category: 'Infraestructura web para la internet china',
    tagline: 'Sitios pensados para la internet china, no remendados para ella.',
    lead:
      'Una Google Font se bloquea un martes cualquiera y la portada se desbarata para todos los que la abren en Shanghái. El equipo en Londres no se entera hasta que un cliente protesta. Construimos, alojamos y vigilamos los sitios desde dentro del Firewall para que esa conversación no tenga que ocurrir.',
    lanes: [
      {
        name: 'Planificar',
        body: 'Auditorías de China readiness desde navegadores reales en Pekín, Shanghái y Shenzhen. Migración con expediente ICP Bei’an, conmutación de DNS y entorno de staging en paralelo, comprobable antes del cambio.',
      },
      {
        name: 'Construir',
        body: 'UX y UI calibradas para lectores chinos. Pago con WeChat y Alipay, UnionPay, WooCommerce localizado para el continente, y reemplazos para cada llamada Google bloqueada en su stack.',
      },
      {
        name: 'Encontrar',
        body: 'Contenido nativo en chino, envío y seguimiento en Baidu Search Resource Platform y optimización para los buscadores generativos DeepSeek, Doubao, Kimi, Yuanbao y Baidu AI.',
      },
      {
        name: 'Operar',
        body: 'Hosting en China sobre Alibaba Cloud, Tencent Cloud y Huawei Cloud. Hosting puente en Hong Kong mientras se procesa el Bei’an. Mantenimiento y monitorización desde redes chinas.',
      },
    ],
    signal: 'Baidu concentró el 60,1 % de las búsquedas chinas en enero de 2025. Fuente: StatCounter.',
    visit: { url: 'https://chinawebfoundry.com', label: 'chinawebfoundry.com' },
    based: 'Shanghái. Hangzhou.',
    accent: '#d99a3a',
  },
  {
    slug: 'beyondcompass',
    route: 'agencies/beyondcompass',
    name: 'BeyondCompass',
    group: 'Occidente → China',
    category: 'Búsqueda y validación de partners',
    tagline: 'Encontrar el partner chino correcto, primero.',
    lead:
      'Un fichero privado de distribuidores, TP de Tmall, Douyin Partners e importadores con los que de verdad nos hemos sentado, validado y trabajado. El valor está en el contexto que rodea a los nombres, los veredictos y las presentaciones cálidas, no en el acceso a un CSV.',
    lanes: [
      {
        name: 'Selección',
        body: 'Tres a cinco nombres validados, instruidos a fondo, listos para reunión. Para marcas que ya saben cómo debe verse su distribución. De dos a tres semanas.',
      },
      {
        name: 'Mapa de mercado',
        body: 'Quince a veinte nombres mapeados por categoría, canal y huella, con una comparativa estructurada y una shortlist secuenciada formada por los nombres que sobreviven al análisis. De tres a seis semanas.',
      },
      {
        name: 'Sustitución',
        body: 'Para marcas que ya firmaron con el partner equivocado. La misma validación, restricciones más ajustadas, acompañamiento en la salida del contrato, discreción por defecto.',
      },
    ],
    signal: 'Entregable escrito, sesión de trabajo, presentaciones cálidas, veredictos honestos.',
    visit: { url: 'https://beyondcompass.beyondbordergroup.com', label: 'beyondcompass.beyondbordergroup.com' },
    based: 'Shanghái. Veinte años validando en el terreno.',
    accent: '#1e7db0',
  },
  {
    slug: 'beyondbridge',
    route: 'agencies/beyondbridge',
    name: 'BeyondBridge',
    group: 'China → Occidente',
    category: 'Pipeline exterior para empresas chinas',
    tagline: 'Hacemos crecer a las empresas chinas fuera.',
    lead:
      'La mayoría de las empresas chinas que salen al exterior pierden dos años antes de admitir que el manual ya no funciona. Cerramos la distancia entre un buen producto y un comprador con un solo stack y un solo pipeline.',
    lanes: [
      {
        name: 'Construir',
        body: 'Consultoría sénior sobre las decisiones grandes. Estrategia de marca diseñada para los mercados a los que entran, no heredada de la marca china. Un sitio que carga rápido en Hamburgo y en Houston, con UX pensada para el ojo occidental.',
      },
      {
        name: 'Demanda',
        body: 'LinkedIn para compradores B2B. SEO y GEO para aparecer en Google y ser citado por ChatGPT, Perplexity y Claude. Google Ads que traen leads cualificados mientras el SEO compone.',
      },
      {
        name: 'Cerrar',
        body: 'Comerciales nativos en Francia, Alemania, Italia, Reino Unido, Estados Unidos, Australia y América Latina. Ellos toman la primera llamada. Cuando el negocio merece un avión, van a estrechar la mano del comprador.',
      },
    ],
    signal: 'París · Múnich · Milán · Londres · Nueva York · Sídney · São Paulo',
    visit: { url: 'https://beyondbridge.com', label: 'beyondbridge.com' },
    based: 'Sede en China. Comerciales en siete mercados.',
    accent: '#22c55e',
  },
  {
    slug: 'hubstudio',
    route: 'agencies/hubstudio',
    name: 'HubStudio',
    group: 'Transversal',
    category: 'Productora, AIGC a escala',
    tagline: 'Una productora pensada para lo que el contenido se ha vuelto.',
    lead:
      'Una marca global de electrodomésticos llegó el año pasado con una tasa de aprobación del 22 por ciento. Seis meses después, esa tasa alcanzaba el 78. La producción se multiplicó por siete. El coste cayó un 60 por ciento. Esa es, más o menos, la distancia entre la vieja forma de hacer contenido y cómo toca trabajarlo ahora.',
    lanes: [
      {
        name: 'Producir',
        body: 'Visuales on-brand desde 35 $ por brief hasta 405 $ por activo terminado. Vídeo corto y largo desde 200 $ por guion. Estudio de rodaje en Shanghái. 3D, CGI y motion. Generado, rodado o híbrido.',
      },
      {
        name: 'Plataforma',
        body: 'Hub4You, su propio estudio de contenido sobre servidores GPU dedicados, integrado con su DAM y su PIM. Modelos entrenados para la marca, LoRAs a medida, y pipelines construidos sobre ComfyUI, Flux, Wan, Veo, Hunyuan.',
      },
      {
        name: 'Dirigir',
        body: 'Estrategia de contenido, identidad de marca e identidad visual, transcreación a cargo de creativos que viven dentro de la cultura objetivo, y formación práctica a equipos internos.',
      },
    ],
    signal: 'Mazda, Nescafé, Marriott, Bobbi Brown y otros confían en nosotros.',
    visit: { url: 'https://hubstudio.ai', label: 'hubstudio.ai' },
    based: 'Estudio en Shanghái. Entrega global.',
    accent: '#ff7a8a',
  },
  {
    slug: 'nuvora-studio',
    route: 'agencies/nuvora-studio',
    name: 'Nuvora Studio',
    group: 'Transversal',
    category: 'B2B exclusivamente en LinkedIn',
    tagline: 'Sus compradores la consultan. Sus candidatos la consultan. Sus inversores la consultan.',
    lead:
      'Con más de mil millones de miembros, LinkedIn es el registro profesional del mundo. Hacemos crecer su presencia ahí. Cada día. La estrategia primero, el lock-in nunca.',
    lanes: [
      {
        name: 'Construir',
        body: 'Contenido en LinkedIn pensado, redactado y publicado para generar leads. Personal branding para fundadores, directores generales y altos cargos. Employee advocacy que convierte al equipo en motor de contenido.',
      },
      {
        name: 'Convertir',
        body: 'Publicidad en LinkedIn atada al ingreso, no a las métricas de vanidad. Segmentación, creatividad y reportes que enrutan los leads cualificados al pipeline. Ningún presupuesto quemado en la audiencia equivocada.',
      },
      {
        name: 'Aprender',
        body: 'Formación práctica y talleres sobre algoritmo, perfil y estrategia de contenido. Auditoría completa de la presencia actual en LinkedIn y la hoja de ruta para hacerla crecer.',
      },
    ],
    signal: 'Empresas B2B en cualquier lugar del mundo.',
    visit: { url: 'https://nuvora.studio', label: 'nuvora.studio' },
    based: 'Global.',
    accent: '#7c3aed',
  },
];

const groups: { id: Group; label: string; intro: string }[] = [
  {
    id: 'Occidente → China',
    label: 'Occidente → China',
    intro: 'Para marcas que entran o escalan en China.',
  },
  {
    id: 'China → Occidente',
    label: 'China → Occidente',
    intro: 'Para empresas chinas que salen al exterior.',
  },
  {
    id: 'Transversal',
    label: 'Transversal',
    intro: 'Para cualquier empresa, en cualquier sitio. Producción de contenido y LinkedIn.',
  },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <!-- ===================================================================== -->
  <!-- HERO                                                                  -->
  <!-- ===================================================================== -->
  <section class="ag-hero">
    <div class="ag-hero__bg" aria-hidden="true"></div>
    <div class="container ag-hero__container">
      <span class="eyebrow eyebrow--on-dark">El grupo</span>
      <h1 class="ag-hero__title balance">
        Siete agencias especialistas.<br />
        <em>Un ecosistema.</em>
      </h1>
      <p class="ag-hero__lead">
        Cada agencia se sostiene por sí sola. Su propia marca, sus tarifas, sus entregables. Coge la que
        encaja con su asunto. La mayoría de los clientes empieza por una y suma las demás según crece el
        proyecto.
      </p>

      <ul class="ag-hero__logos" aria-label="Logos de las agencias">
        {agencies.map((a) => (
          <li>
            <a href={`#${a.slug}`} aria-label={`Ir a ${a.name}`}>
              <AgencyLogo slug={a.slug} name={a.name} class="ag-hero__logo" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- INDEX BY GROUP                                                        -->
  <!-- ===================================================================== -->
  <section class="section section--alt">
    <div class="container">
      <div class="ag-index">
        {groups.map((g) => (
          <div class="ag-index__col">
            <span class="eyebrow">{g.label}</span>
            <p class="ag-index__intro">{g.intro}</p>
            <ul class="ag-index__list">
              {agencies
                .filter((a) => a.group === g.id)
                .map((a) => (
                  <li>
                    <a href={`#${a.slug}`} class="ag-index__link">
                      <span class="ag-index__name">{a.name}</span>
                      <span class="ag-index__cat">{a.category}</span>
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================================== -->
  <!-- AGENCY SECTIONS                                                       -->
  <!-- ===================================================================== -->
  {agencies.map((a, i) => (
    <section
      id={a.slug}
      class={`ag-feature ${i % 2 === 1 ? 'ag-feature--alt' : ''}`}
      style={`--accent: ${a.accent};`}
    >
      <div class="container">
        <header class="ag-feature__head">
          <div class="ag-feature__head-left">
            <AgencyLogo slug={a.slug} name={a.name} class="ag-feature__logo" />
            <span class="ag-feature__group">{a.group} · {a.category}</span>
          </div>
          <a class="ag-feature__visit" href={a.visit.url} target="_blank" rel="noreferrer">
            {a.visit.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17l10-10M7 7h10v10"/></svg>
          </a>
        </header>

        <div class="ag-feature__pitch">
          <h2 class="ag-feature__tagline">{a.tagline}</h2>
          <p class="ag-feature__lead">{a.lead}</p>
        </div>

        <ol class={`ag-feature__lanes ag-feature__lanes--${a.lanes.length}`}>
          {a.lanes.map((lane) => (
            <li class="ag-feature__lane">
              <h3 class="ag-feature__lane-title">{lane.name}</h3>
              <p class="ag-feature__lane-body">{lane.body}</p>
            </li>
          ))}
        </ol>

        <footer class="ag-feature__foot">
          <div class="ag-feature__foot-meta">
            <span><strong>Sede.</strong> {a.based}</span>
            {a.signal && <span class="ag-feature__signal">{a.signal}</span>}
          </div>
          <div class="ag-feature__foot-cta">
            <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>Abrir {a.name}</a>
          </div>
        </footer>
      </div>
    </section>
  ))}

  <!-- ===================================================================== -->
  <!-- HOW THEY FIT TOGETHER                                                 -->
  <!-- ===================================================================== -->
  <section class="ag-stacks">
    <div class="ag-stacks__bg" aria-hidden="true"></div>
    <div class="container ag-stacks__container">
      <header class="ag-stacks__head">
        <span class="eyebrow eyebrow--on-dark">Cómo encajan</span>
        <h2 class="ag-stacks__title balance">
          Un solo proyecto.<br />
          <em>Tantas agencias como el trabajo requiera.</em>
        </h2>
        <p class="ag-stacks__lead">
          No tiene que adivinar el orden. Abra la agencia que corresponde a su momento. Le diremos cuándo
          toca traer otra y cuándo no hace falta.
        </p>
      </header>

      <div class="ag-stacks__grid">
        {[
          {
            scenario: 'Una marca francesa de cosmética. Entrando en China.',
            steps: [
              { slug: 'beyondcompass', name: 'BeyondCompass', role: 'Elegir al distribuidor adecuado.' },
              { slug: 'chinawebfoundry', name: 'ChinaWebFoundry', role: 'Construir el sitio China, ICP tramitado.' },
              { slug: 'beyondbordergroup', name: 'BeyondBorderGroup', role: 'Operar Tmall, llevar los medios.' },
              { slug: 'theredscroll', name: 'TheRedScroll', role: 'WeChat, Douyin, RedNote, a diario.' },
            ],
          },
          {
            scenario: 'Una empresa china de robótica. Saliendo al exterior.',
            steps: [
              { slug: 'beyondbridge', name: 'BeyondBridge', role: 'Marca, sitio, demanda, comerciales en EE. UU. y Alemania.' },
              { slug: 'hubstudio', name: 'HubStudio', role: 'Producción de contenido a escala, en marca.' },
              { slug: 'nuvora-studio', name: 'Nuvora Studio', role: 'LinkedIn del fundador, cada día.' },
            ],
          },
        ].map((stack) => (
          <article class="ag-stack">
            <h3 class="ag-stack__scenario">{stack.scenario}</h3>
            <ol class="ag-stack__steps">
              {stack.steps.map((step) => (
                <li class="ag-stack__step">
                  <a class="ag-stack__step-link" href={`#${step.slug}`}>
                    <span class="ag-stack__step-logo">
                      <AgencyLogo slug={step.slug} name={step.name} class="ag-stack__logo" />
                    </span>
                    <span class="ag-stack__step-text">
                      <span class="ag-stack__step-name">{step.name}</span>
                      <span class="ag-stack__step-role">{step.role}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </article>
        ))}
      </div>

      <div class="ag-stacks__cta">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Hablar con nosotros</a>
        <a class="btn btn--ghost-light" href={pathFor('how-we-work-together', locale)}>Cómo trabajamos juntos</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .ag-hero {
    position: relative;
    color: #fff;
    background: var(--bbg-ink);
    padding: clamp(4rem, 9vh, 7rem) 0 clamp(3rem, 7vh, 5rem);
    overflow: hidden;
    isolation: isolate;
  }
  .ag-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(900px 500px at 12% 18%, rgba(38,154,218,0.22), transparent 65%),
      radial-gradient(800px 500px at 88% 82%, rgba(200,16,46,0.16), transparent 70%),
      linear-gradient(180deg, #0c1220 0%, #1a1a1a 100%);
  }
  .ag-hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.6;
  }
  .ag-hero__container { max-width: 920px; }
  .ag-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: var(--space-3) 0 var(--space-5);
    font-weight: 600;
  }
  .ag-hero__title em {
    font-style: normal;
    background: linear-gradient(120deg, #59c2ee, #ff7a8a 50%, #ffcf6f);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .ag-hero__lead {
    font-size: clamp(1.05rem, 0.5vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    max-width: 60ch;
    margin: 0 0 var(--space-7);
  }
  .ag-hero__logos {
    list-style: none;
    margin: 0;
    padding: var(--space-5) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-3);
    align-items: stretch;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  @media (min-width: 1024px) {
    .ag-hero__logos { grid-template-columns: repeat(7, minmax(0, 1fr)); }
  }
  .ag-hero__logos a {
    display: grid;
    place-items: center;
    height: 72px;
    padding: var(--space-3) var(--space-4);
    background: #fff;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.18);
    transition: transform 220ms cubic-bezier(0.2,0.85,0.2,1), box-shadow 220ms ease;
    box-shadow: 0 10px 30px -16px rgba(0,0,0,0.45);
  }
  .ag-hero__logos a:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -18px rgba(0,0,0,0.55);
  }
  .ag-hero__logos :global(.ag-hero__logo) {
    max-height: 36px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  /* ===================================================================== */
  /* INDEX                                                                  */
  /* ===================================================================== */
  .ag-index {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  @media (min-width: 768px) {
    .ag-index { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .ag-index__intro {
    margin: var(--space-3) 0 var(--space-4);
    color: var(--bbg-text);
    font-size: 1.05rem;
  }
  .ag-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--bbg-border);
  }
  .ag-index__list li { border-bottom: 1px solid var(--bbg-border); }
  .ag-index__link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    color: var(--bbg-ink);
    text-decoration: none;
    transition: color 180ms ease;
  }
