---
import Layout from '../../layouts/Layout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'es' as const;
const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';
const title = 'China y Occidente, en los dos sentidos';
const description = 'Siete agencias especializadas que tienden el puente entre China y Occidente, en los dos sentidos. Marca, canales, web, sourcing, contenido y ventas. Un mismo ecosistema, una columna vertebral compartida.';

const agencies = [
  { n: '01', name: 'BeyondBorderGroup', tagline: 'Implantación en China de extremo a extremo. De la marca al eCommerce.', route: 'agencies/beyondbordergroup' as const },
  { n: '02', name: 'TheRedScroll', tagline: 'Redes sociales chinas. WeChat, Douyin, RED, Weibo.', route: 'agencies/theredscroll' as const },
  { n: '03', name: 'ChinaWebFoundry', tagline: 'Webs hechas para la red china. Baidu, ICP, IA locales.', route: 'agencies/chinawebfoundry' as const },
  { n: '04', name: 'BeyondCompass', tagline: 'Una base privada de distribuidores, TP de Tmall y Douyin Partners contrastados.', route: 'agencies/beyondcompass' as const },
  { n: '05', name: 'BeyondBridge', tagline: 'Internacionalización llave en mano para marcas chinas.', route: 'agencies/beyondbridge' as const },
  { n: '06', name: 'HubStudio', tagline: 'Imagen, vídeo y contenido AIGC. Producción a gran escala.', route: 'agencies/hubstudio' as const },
  { n: '07', name: 'Nuvora Studio', tagline: 'B2B, exclusivamente en LinkedIn. Estrategia, contenido, medios.', route: 'agencies/nuvora-studio' as const },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <div class="container">
      <div class="hero-statement__grid">
        <div>
          <span class="eyebrow">Ecosistema</span>
          <h1 class="hero-statement__title balance">Construir marcas entre China y Occidente. Y hacerlo en los dos sentidos.</h1>
          <p class="hero-statement__lead">
            Siete agencias especializadas y una sola convicción. La distancia entre China y Occidente no se
            reduce a un asunto de traducción: es un asunto de marca, de canales, de infraestructura y de
            venta. Y opera en ambas direcciones.
          </p>
          <div class="btn-row">
            <a class="btn btn--primary" href={pathFor('agencies', locale)}>Encontrar la agencia adecuada</a>
            <a class="btn btn--ghost" href={pathFor('contact', locale)}>Hablar con nosotros</a>
          </div>
          <p class="hero-statement__cite">Shanghái · Hong Kong · París. Representantes comerciales en Estados Unidos, Reino Unido, Alemania y Francia.</p>
        </div>
        <div class="hero-statement__visual">
          <ImagePlaceholder ratio="3x4" label="Retrato editorial. Operador transfronterizo en plena tarea." />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Dos flujos. Una página.</span>
        <h2 class="balance">Las dos direcciones están ahora en una sola página.</h2>
        <p class="lead">
          La misma columna vertebral de agencias detrás de los dos sentidos. Seis puntos de entrada típicos
          a cada lado. Elija su orilla, o recorra el puente entero de cabo a rabo.
        </p>
      </header>

      <div class="bridge-panel">
        <span class="bridge-panel__spine" aria-hidden="true">
          <span class="bridge-panel__spine-line"></span>
          <span class="bridge-panel__spine-mark">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 16h22" />
              <path d="M22 11l5 5-5 5" />
              <path d="M10 21l-5-5 5-5" />
            </svg>
          </span>
        </span>

        <a class="bridge-panel__side bridge-panel__side--inbound" href={`${pathFor('two-flows', locale)}#inbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">→</span>
            De Occidente hacia China · Entrada
          </span>
          <h3 class="bridge-panel__title">Llevar una marca occidental al mercado chino.</h3>
          <p class="bridge-panel__body">
            Marca, WeChat, RedNote, Douyin, Tmall, JD, Baidu, KOL, distribución. De una landing page sencilla
            al stack completo.
          </p>
          <span class="bridge-panel__by">BeyondBorderGroup · TheRedScroll · ChinaWebFoundry · BeyondCompass · HubStudio</span>
          <span class="bridge-panel__cta">
            Ir al flujo de entrada
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>

        <a class="bridge-panel__side bridge-panel__side--outbound" href={`${pathFor('two-flows', locale)}#outbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">←</span>
            De China hacia Occidente · Salida
          </span>
          <h3 class="bridge-panel__title">Sacar una marca china al exterior.</h3>
          <p class="bridge-panel__body">
            Una marca pensada para compradores occidentales, una presencia real en LinkedIn, una web legible
            para ojos occidentales, SEO, GEO, Google Ads y comerciales con nombre en la zona horaria correcta.
          </p>
          <span class="bridge-panel__by">BeyondBridge · Nuvora Studio</span>
          <span class="bridge-panel__cta">
            Ir al flujo de salida
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>
      </div>

      <div class="btn-row" style="margin-top: var(--space-6); justify-content: center;">
        <a class="btn btn--primary" href={pathFor('two-flows', locale)}>Abrir la página Dos flujos</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">El planteamiento</span>
        <h2 class="balance">Siete especialistas, un mismo ecosistema.</h2>
        <p class="lead">
          Cada agencia es autónoma. Usted toma la que le hace falta. La mayoría de los clientes empiezan con
          una y suman las demás conforme avanza el proyecto.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <span class="card__index">{a.n}</span>
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Abrir</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">La arquitectura</span>
        <h2 class="balance">Una matriz 2x2 con un cimiento debajo.</h2>
        <p class="lead">
          Dos columnas por dirección. Dos capas horizontales que dan servicio a las dos. Cada agencia ocupa
          una casilla y se asoma a las demás cuando el proyecto lo pide.
        </p>
      </header>
      <div style="overflow-x: auto;">
        <table class="matrix">
          <thead>
            <tr>
              <th></th>
              <th>De Occidente hacia China</th>
              <th>De China hacia Occidente</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Cobertura integral</th>
              <td><strong>BeyondBorderGroup</strong></td>
              <td><strong>BeyondBridge</strong></td>
            </tr>
            <tr>
              <th>Especialista de canal</th>
              <td>TheRedScroll</td>
              <td>Nuvora Studio</td>
            </tr>
            <tr>
              <th>Infraestructura web</th>
              <td>ChinaWebFoundry</td>
              <td>Módulo web de BeyondBridge</td>
            </tr>
            <tr>
              <th>Sourcing de partners</th>
              <td>BeyondCompass</td>
              <td class="muted">-</td>
            </tr>
            <tr>
              <th>Producción</th>
              <td colspan="2" style="text-align:center; background: var(--bbg-blue-light); color: var(--bbg-ink); font-weight: 600;">HubStudio cruza los dos lados</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>Cómo nos coordinamos</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Por qué un grupo</span>
        <h2 class="balance">Especialistas, no compartimentos.</h2>
      </header>
      <div class="grid-3">
        <div class="prose">
          <h3>Una sola tesis, aplicada en espejo.</h3>
          <p>
            Tanto si es una marca de lujo francesa que aterriza en China como un grupo industrial chino que
            aterriza en Alemania, el trabajo tiene la misma forma. Reconstruir la marca para el público de
            destino. Levantar los canales correctos. Levantar la infraestructura correcta. Producir el
            contenido que toca. Poner a un equipo al teléfono, en la zona horaria que toca.
          </p>
        </div>
        <div class="prose">
          <h3>Especialistas, nunca un megapaquete.</h3>
          <p>
            Cada agencia tiene su marca, sus tarifas, sus entregables y su equipo. Un cliente que solo
            necesita una web china no paga por un equipo de medios. Un cliente que solo necesita LinkedIn no
            paga por una red de KOL chinos.
          </p>
        </div>
        <div class="prose">
          <h3>Un mismo motor de producción.</h3>
          <p>
            Todas las agencias del grupo se apoyan en la capa AIGC de HubStudio. Ese es el motivo por el que
            el coste por activo se sostiene, y la razón por la que una marca china puede publicar fuera al
            mismo ritmo al que una marca occidental publica en China.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Quién está al mando</span>
          <h2 class="balance">Un operador. Dos décadas a un lado y a otro.</h2>
          <p class="lead">
            El grupo lo funda y dirige Cyril Drouin. Veinticinco años en digital, eCommerce y trabajo de
            marca, repartidos entre Europa y el norte de Asia. Antiguo Chief Digital and eCommerce Officer
            de Publicis North Asia. Fundador de HubStudio y Nuvora Studio.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Conectar en LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin en LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, fundador de BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Cuéntenos en qué dirección camina.</h2>
      <p class="lead" style="margin-inline: auto;">
        Treinta minutos al teléfono. Le diremos por qué agencia conviene empezar, o si lo sensato es activar
        varias en paralelo.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Reservar una llamada</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.agency-card-logo) {
    height: 48px;
    width: auto;
    max-width: 180px;
    margin-bottom: var(--space-3);
  }
</style>
