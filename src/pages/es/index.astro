---
import Layout from '../../layouts/Layout.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'es' as const;
const title = 'China y Occidente, en los dos sentidos';
const description = 'Siete agencias especializadas que tienden el puente entre China y Occidente, en los dos sentidos. Marca, canales, web, sourcing de partners, contenido y ventas. Un ecosistema, una columna vertebral compartida.';

const linkedinUrl = 'https://www.linkedin.com/in/cyril-d-68835729/';

const agencies = [
  {
    name: 'BeyondBorderGroup',
    tagline: 'Implantación integral en China. De la marca al eCommerce.',
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    tagline: 'Redes sociales chinas. WeChat, Douyin, RedNote, Weibo.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    tagline: 'Webs pensadas para la red china. Baidu, ICP, motores de IA locales.',
    route: 'agencies/chinawebfoundry' as const,
  },
  {
    name: 'BeyondCompass',
    tagline: 'Una base privada de distribuidores chinos, TP de Tmall y Douyin Partners, todos contrastados.',
    route: 'agencies/beyondcompass' as const,
  },
  {
    name: 'BeyondBridge',
    tagline: 'La cadena completa para que una marca china salga al exterior.',
    route: 'agencies/beyondbridge' as const,
  },
  {
    name: 'HubStudio',
    tagline: 'Imagen, vídeo y contenido a gran escala.',
    route: 'agencies/hubstudio' as const,
  },
  {
    name: 'Nuvora Studio',
    tagline: 'B2B, exclusivamente en LinkedIn. Estrategia, contenido, medios.',
    route: 'agencies/nuvora-studio' as const,
  },
];
---

<Layout locale={locale} route="home" title={title} description={description}>
  <section class="hero-statement">
    <video
      class="hero-statement__video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/Video/greatWall%20AI%20video.mp4" type="video/mp4" />
    </video>
    <div class="hero-statement__scrim" aria-hidden="true"></div>
    <div class="hero-statement__rail">
      <aside class="rail" aria-label="Las siete agencias del grupo">
        <header class="rail__head">
          <span class="rail__head-tag">Ecosistema</span>
          <span class="rail__head-count">Siete especialistas</span>
        </header>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Agencias líder</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 0;">
              <a class="rail__link" href={pathFor('agencies/beyondbordergroup', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BBG%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBorderGroup</span>
                  <span class="rail__tagline">Cobertura integral hacia China</span>
                </span>
                <span class="rail__stripe rail__stripe--w" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 1;">
              <a class="rail__link" href={pathFor('agencies/beyondbridge', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondBridge-%20Logo-EN-4K-Transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondBridge</span>
                  <span class="rail__tagline">Cobertura integral hacia Occidente</span>
                </span>
                <span class="rail__stripe rail__stripe--e" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Especialistas, los dos sentidos</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 2;">
              <a class="rail__link" href={pathFor('agencies/theredscroll', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/TheredScroll%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">TheRedScroll</span>
                  <span class="rail__tagline">Redes sociales chinas</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 3;">
              <a class="rail__link" href={pathFor('agencies/chinawebfoundry', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Logo-ChinaWebFoundry-transparent.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">ChinaWebFoundry</span>
                  <span class="rail__tagline">Pensada para la red china</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 4;">
              <a class="rail__link" href={pathFor('agencies/beyondcompass', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">BeyondCompass</span>
                  <span class="rail__tagline">Partners chinos contrastados</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
            <li class="rail__row" style="--row-i: 5;">
              <a class="rail__link" href={pathFor('agencies/nuvora-studio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/Nuvora%20PNG.png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">Nuvora Studio</span>
                  <span class="rail__tagline">Especialistas LinkedIn B2B</span>
                </span>
                <span class="rail__stripe rail__stripe--both" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>

        <div class="rail__chapter">
          <div class="rail__chapter-head">
            <span class="rail__chapter-label">Producción</span>
            <span class="rail__chapter-rule" aria-hidden="true"></span>
          </div>
          <ol class="rail__list">
            <li class="rail__row" style="--row-i: 6;">
              <a class="rail__link" href={pathFor('agencies/hubstudio', locale)}>
                <span class="rail__logo"><img src="/AgencyLogos/hubStudio%20(2).png" alt="" /></span>
                <span class="rail__body">
                  <span class="rail__name">HubStudio</span>
                  <span class="rail__tagline">Atraviesa los dos sentidos</span>
                </span>
                <span class="rail__stripe rail__stripe--c" aria-hidden="true"></span>
              </a>
            </li>
          </ol>
        </div>
      </aside>
    </div>
    <div class="container hero-statement__container">
      <div class="hero-statement__content">
        <span class="eyebrow">Ecosistema</span>
        <h1 class="hero-statement__title balance">Construimos y hacemos crecer marcas, productos y servicios entre China y Occidente. En los dos sentidos.</h1>
        <p class="hero-statement__lead">
          Seis agencias especializadas. Una sola tesis. La distancia entre China y Occidente no es un asunto
          de traducción. Es un asunto de marca, de canales, de infraestructura y de venta. Y opera en las dos
          direcciones.
        </p>
        <div class="btn-row">
          <a class="btn btn--primary" href={pathFor('agencies', locale)}>Encontrar la agencia adecuada</a>
          <a class="btn btn--ghost" href={pathFor('contact', locale)}>Hablar con nosotros</a>
        </div>
        <p class="hero-statement__cite">Shanghái. Hong Kong. París. Representantes en plaza en Estados Unidos, Reino Unido, Alemania y Francia.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Dos flujos. Una página.</span>
        <h2 class="balance">Las dos direcciones, en una sola página.</h2>
        <p class="lead">
          La misma columna vertebral de agencias detrás de los dos sentidos. Seis puntos de entrada típicos a
          cada lado. Elija su orilla, o recorra el puente entero de cabo a rabo.
        </p>
      </header>

      <div class="bridge-panel">
        <span class="bridge-panel__spine" aria-hidden="true">
          <span class="bridge-panel__spine-line"></span>
          <span class="bridge-panel__spine-mark">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 16h22" />
              <path d="M22 11l5 5-5 5" />
              <path d="M10 21l-5-5 5-5" />
            </svg>
          </span>
        </span>

        <a class="bridge-panel__side bridge-panel__side--inbound" href={`${pathFor('two-flows', locale)}#inbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">→</span>
            De Occidente hacia China · Entrada
          </span>
          <h3 class="bridge-panel__title">Llevar una marca occidental al mercado chino.</h3>
          <p class="bridge-panel__body">
            Marca, WeChat, RedNote, Douyin, Tmall, JD, Baidu, KOL, distribución. De una landing page sencilla
            al stack completo.
          </p>
          <span class="bridge-panel__by">BeyondBorderGroup · TheRedScroll · ChinaWebFoundry · BeyondCompass · HubStudio</span>
          <span class="bridge-panel__cta">
            Ir al flujo de entrada
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>

        <a class="bridge-panel__side bridge-panel__side--outbound" href={`${pathFor('two-flows', locale)}#outbound`}>
          <span class="bridge-panel__direction">
            <span class="bridge-panel__arrow" aria-hidden="true">←</span>
            De China hacia Occidente · Salida
          </span>
          <h3 class="bridge-panel__title">Sacar una marca china al exterior.</h3>
          <p class="bridge-panel__body">
            Una marca pensada para el comprador occidental, una presencia real en LinkedIn, una web legible para
            ojos occidentales, SEO, GEO, Google Ads y comerciales con nombre en la zona horaria correcta.
          </p>
          <span class="bridge-panel__by">BeyondBridge · Nuvora Studio</span>
          <span class="bridge-panel__cta">
            Ir al flujo de salida
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </span>
        </a>
      </div>

      <div class="btn-row" style="margin-top: var(--space-6); justify-content: center;">
        <a class="btn btn--primary" href={pathFor('two-flows', locale)}>Abrir la página Dos flujos</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">El stack</span>
        <h2 class="balance">Siete especialistas. Un mismo ecosistema.</h2>
        <p class="lead">
          Cada agencia es autónoma. Coja la que necesita. La mayoría de los clientes empiezan con una y van
          sumando otras a medida que el proyecto crece.
        </p>
      </header>
      <div class="grid-3">
        {agencies.map((a) => (
          <a class="card" href={pathFor(a.route, locale)}>
            <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            <h3 class="card__title">{a.name}</h3>
            <p>{a.tagline}</p>
            <span class="btn btn--ghost" style="margin-top: auto;">Abrir</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">La lógica</span>
        <h2 class="balance">Dos líderes. Cinco especialistas. Un solo motor.</h2>
        <p class="lead">
          Dos agencias líder, una por dirección. Cinco especialistas que enchufan en cualquiera de las dos.
          Un motor de producción que cruza ambos sentidos.
        </p>
      </header>
      <div class="matrix-grid" role="table" aria-label="Agencias por dirección y capa">
        <div class="matrix-grid__head" role="row">
          <div class="matrix-grid__corner" aria-hidden="true"></div>
          <div class="matrix-grid__direction matrix-grid__direction--west" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">→</span>
            <span class="matrix-grid__direction-label">De Occidente hacia China</span>
          </div>
          <div class="matrix-grid__direction matrix-grid__direction--east" role="columnheader">
            <span class="matrix-grid__arrow" aria-hidden="true">←</span>
            <span class="matrix-grid__direction-label">De China hacia Occidente</span>
          </div>
        </div>

        <div class="matrix-grid__row" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Cobertura integral</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Agencia líder</span>
            <span class="matrix-cell__name">BeyondBorderGroup</span>
          </div>
          <div class="matrix-cell matrix-cell--lead" role="cell">
            <span class="matrix-cell__tag">Agencia líder</span>
            <span class="matrix-cell__name">BeyondBridge</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Redes sociales</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Los dos sentidos</span>
            <span class="matrix-cell__name">TheRedScroll</span>
            <span class="matrix-cell__note">WeChat, Douyin, RedNote, Weibo. Para clientes occidentales o chinos.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">LinkedIn B2B</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Los dos sentidos</span>
            <span class="matrix-cell__name">Nuvora Studio</span>
            <span class="matrix-cell__note">Solo LinkedIn. Para clientes occidentales o chinos.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Infraestructura web</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Los dos sentidos</span>
            <span class="matrix-cell__name">ChinaWebFoundry</span>
            <span class="matrix-cell__note">Lista para Baidu, ICP, motores de IA chinos. Para clientes occidentales o chinos.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--both" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Sourcing de partners</span>
          </div>
          <div class="matrix-cell matrix-cell--both" role="cell">
            <span class="matrix-cell__tag">Los dos sentidos</span>
            <span class="matrix-cell__name">BeyondCompass</span>
            <span class="matrix-cell__note">Distribuidores chinos, TP de Tmall y Douyin Partners, todos contrastados.</span>
          </div>
        </div>

        <div class="matrix-grid__row matrix-grid__row--span" role="row">
          <div class="matrix-grid__layer" role="rowheader">
            <span class="matrix-grid__layer-name">Producción</span>
          </div>
          <div class="matrix-cell matrix-cell--span" role="cell">
            <span class="matrix-cell__bridge" aria-hidden="true">
              <span class="matrix-cell__bridge-dot"></span>
              <span class="matrix-cell__bridge-line"></span>
              <span class="matrix-cell__bridge-dot"></span>
            </span>
            <span class="matrix-cell__name">HubStudio</span>
            <span class="matrix-cell__note">Motor de producción de contenido. Cruza las dos direcciones.</span>
          </div>
        </div>
      </div>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn--ghost" href={pathFor('how-we-work-together', locale)}>Cómo nos coordinamos</a>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split split--text-first">
        <div>
          <span class="eyebrow eyebrow--on-dark">Quién está al mando</span>
          <h2 class="balance">Un operador. Dos décadas a un lado y a otro.</h2>
          <p class="lead">
            El grupo lo funda y dirige Cyril Drouin. Veinticinco años en digital, eCommerce y trabajo de marca,
            repartidos entre Europa y el norte de Asia. Antiguo Chief Digital and eCommerce Officer de Publicis
            North Asia.
          </p>
          <a class="btn btn--ghost-light" href={linkedinUrl} target="_blank" rel="noreferrer">Conectar en LinkedIn</a>
        </div>
        <div>
          <a class="founder-portrait" href={linkedinUrl} target="_blank" rel="noreferrer" aria-label="Cyril Drouin en LinkedIn">
            <img
              src="/Team/CyrilDrouin.jpg"
              alt="Cyril Drouin, fundador de BeyondBorderGroup."
              width="1905"
              height="2560"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container container--narrow center">
      <h2 class="balance">Cuéntenos en qué dirección camina.</h2>
      <p class="lead" style="margin-inline: auto;">
        Treinta minutos al teléfono. Le diremos qué agencia conviene como punto de partida, o si lo sensato es
        activar varias en paralelo.
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: var(--space-5);">
        <a class="btn btn--primary" href={pathFor('contact', locale)}>Reservar una llamada</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- The Stack: consistent logo sizing ---------- */
  .card :global(.agency-card-logo) {
    width: 100%;
    height: 56px;
    max-height: 56px;
    object-fit: contain;
    object-position: left center;
    margin-bottom: var(--space-3);
    background: transparent;
    display: block;
    filter: none;
  }

  /* ---------- Modern matrix grid ---------- */
  .matrix-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  .matrix-grid__head,
  .matrix-grid__row {
    display: grid;
    grid-template-columns: minmax(160px, 200px) 1fr 1fr;
    gap: var(--space-4);
    align-items: stretch;
  }
  .matrix-grid__direction {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--fs-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bbg-ink);
    position: relative;
  }
  .matrix-grid__direction::after {
    content: '';
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: 0;
    height: 2px;
    border-radius: 2px;
  }
  .matrix-grid__direction--west::after { background: linear-gradient(90deg, var(--bbg-blue), transparent); }
  .matrix-grid__direction--east::after { background: linear-gradient(90deg, transparent, #c8102e); }
  .matrix-grid__direction--east { justify-content: flex-end; flex-direction: row-reverse; }
  .matrix-grid__arrow {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--bbg-blue);
  }
  .matrix-grid__direction--east .matrix-grid__arrow { color: #c8102e; }
  .matrix-grid__layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) 0;
    align-self: center;
  }
  .matrix-grid__layer-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--bbg-text-muted);
  }
  .matrix-grid__layer-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 12px;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .matrix-cell:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(15, 23, 42, 0.18);
    border-color: var(--bbg-border-strong);
  }
  .matrix-cell--lead {
    background: linear-gradient(180deg, #ffffff 0%, var(--bbg-surface) 100%);
    border-color: rgba(38, 154, 218, 0.25);
  }
  .matrix-cell--lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue), #c8102e);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both {
    grid-column: 2 / -1;
    background: linear-gradient(90deg, rgba(38, 154, 218, 0.06) 0%, rgba(255, 255, 255, 0.5) 50%, rgba(200, 16, 46, 0.06) 100%);
    border-color: rgba(15, 23, 42, 0.10);
    padding: var(--space-3) var(--space-5);
  }
  .matrix-grid__row--both .matrix-cell--both::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: linear-gradient(180deg, var(--bbg-blue) 0%, #c8102e 100%);
    border-radius: 0 3px 3px 0;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__tag {
    color: transparent;
    background: linear-gradient(90deg, var(--bbg-blue), #c8102e);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .matrix-grid__row--both .matrix-cell--both .matrix-cell__note {
    color: var(--bbg-text-muted);
    font-size: var(--fs-small);
  }
  .matrix-cell__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .matrix-cell__name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .matrix-cell--empty {
    background: transparent;
    border: 1px dashed var(--bbg-border);
    align-items: center;
    justify-content: center;
  }
  .matrix-cell--empty:hover { transform: none; box-shadow: none; }
