---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'en' as const;
const route = 'agencies/theredscroll' as const;

const platforms = ['WeChat', 'Douyin', 'RedNote', 'Weibo', '+14 more'];

const services = [
  {
    key: 'plan',
    title: 'Plan',
    items: [
      { name: 'Strategy, Campaigns and Analytics', body: 'Market and competitor research, platform selection, content calendar, KPIs tied to business goals, dashboards, and social listening.' },
      { name: 'China Market Entry', body: 'Account setup, verification, e-commerce integration with Tmall, JD and Douyin Shop, Chinese naming and platform-ready asset packs.' },
    ],
  },
  {
    key: 'run',
    title: 'Run',
    items: [
      { name: 'Platform Coverage', body: 'WeChat, Douyin, RedNote and Weibo at the core. Bilibili, Kuaishou, Zhihu, Toutiao and others as transparent add-ons.' },
      { name: 'Content Production', body: 'Human-led strategy. AIGC images and video via HubStudio.ai. Real shoots in China. Native Chinese copy review.' },
      { name: 'Advertising Planning and Buying', body: 'Paid media across WeChat, Douyin, RedNote, Weibo and Baidu. Weekly and monthly reports on CPM, CPC, CPA and ROAS. No markups on ad spend.' },
      { name: 'Influencer Marketing', body: 'Verified engagement data, fake follower detection, niche matching. Briefs, co-creation, posting, live commerce and ROI reports.' },
    ],
  },
  {
    key: 'sustain',
    title: 'Sustain',
    items: [
      { name: 'CRM and Private Domain', body: 'WeCom setup, WeChat CRM, community management, customer service flows and loyalty programs.' },
      { name: 'Training and Consulting', body: 'Masterclasses on WeChat, Douyin, RedNote and Weibo. Workshops on content, influencers and paid media. Strategic consulting.' },
    ],
  },
];

const visitUrl = 'https://theredscroll.com';
const visitLabel = 'Visit theredscroll.com';
---

<Layout
  locale={locale}
  route={route}
  title="China Social Media Agency. Fixed Scope. Fixed Price."
  description="We grow social networks in China for international brands. Fixed scope. Fixed price. Team on the ground in Shanghai and Hong Kong. Book a call."
>
  <section class="trs-hero">
    <div class="trs-hero__bg" aria-hidden="true">
      <span class="trs-hero__blob trs-hero__blob--a"></span>
      <span class="trs-hero__blob trs-hero__blob--b"></span>
      <span class="trs-hero__blob trs-hero__blob--c"></span>
      <span class="trs-hero__grid-lines"></span>
    </div>

    <div class="container trs-hero__container">
      <div class="trs-hero__grid">
        <div class="trs-hero__content">
          <img src="/AgencyLogos/TheredScroll%20PNG.png" alt="TheRedScroll logo" class="trs-hero__logo" width="180" height="40" loading="eager" decoding="async" />
          <span class="eyebrow eyebrow--rule">China social media · Fixed scope · Fixed price</span>
          <h1 class="trs-hero__title">
            We post on
            <span class="trs-hero__phrase trs-hero__phrase--platforms">China's platforms</span>.
            <span class="trs-hero__phrase trs-hero__phrase--daily">Every day</span>.
            <span class="trs-hero__phrase trs-hero__phrase--ground">From the ground</span>.
          </h1>
          <p class="trs-hero__lead">China runs on its own platforms. WeChat, Douyin, RedNote, Weibo, and fourteen others. Knowing this from a slide deck is not the same as opening these apps every morning, which is, frankly, what most agencies don't do.</p>
          <div class="trs-hero__actions">
            <a class="btn btn--primary trs-hero__cta" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
          </div>
          <div class="trs-hero__clients">
            <span class="trs-hero__clients-label">Active on</span>
            <ul class="trs-hero__clients-list">
              {platforms.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </div>

        <div class="trs-hero__media">
          <a class="browser-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
            <div class="browser">
              <div class="browser__chrome">
                <span class="browser__dots">
                  <span class="browser__dot browser__dot--r"></span>
                  <span class="browser__dot browser__dot--y"></span>
                  <span class="browser__dot browser__dot--g"></span>
                </span>
                <span class="browser__url">theredscroll.com</span>
              </div>
              <div class="browser__viewport">
                <img src="/images/theredscroll-home.webp" alt="theredscroll.com homepage" class="browser__shot" width="1408" height="832" loading="eager" decoding="async" />
                <span class="browser__visit" aria-hidden="true">
                  <span>Visit site</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                </span>
              </div>
            </div>
          </a>

          <div class="trs-hero__chip trs-hero__chip--cities">
            <span class="trs-hero__chip-dot"></span>
            Shanghai · Hong Kong · Native team
          </div>
          <div class="trs-hero__chip trs-hero__chip--ai">
            HubStudio.ai · AIGC content at scale
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="eyebrow">How we work</span>
      <p class="lead">Every post, video, campaign and report is defined upfront in a written scope of work. One number per package. No hidden fees, no scope creep. Our team works from Shanghai and Hong Kong, with native speakers, real platform access, and direct lines to Chinese influencers. We built HubStudio.ai to produce visuals, video and copy at a fraction of the old cost. Strategy stays human.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What we do</span>
        <h2 class="balance">Three lanes. Eight pillars. End to end.</h2>
      </header>
      <div class="services">
        {services.map((s) => (
          <article class={`service-card service-card--${s.key}`}>
            <header class="service-card__head">
              <span class={`service-card__pip service-card__pip--${s.key}`} aria-hidden="true"></span>
              <h3 class="service-card__title">{s.title}</h3>
            </header>
            <ul class="service-card__list">
              {s.items.map((it) => (
                <li class="service-card__item">
                  <span class="service-card__name">{it.name}.</span>
                  <span class="service-card__body">{it.body}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="eyebrow">How we package it</span>
      <p class="lead">Three tiers, all priced upfront. Discovery is for brands testing China, three months on one platform. Growth is for brands scaling in China, six months across two or three platforms. Premium is for brands going all-in, twelve months across four or more platforms. Every tier ships with a written scope of work and a fixed price.</p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container container--narrow center">
      <h2 class="balance">More followers. More engagement. More leads. More conversions.</h2>
      <div class="btn-row" style="justify-content: center;">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Talk to us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ----- Hero (mirrors BBG) ------------------------------------------------ */
  .trs-hero {
    position: relative;
    padding: clamp(5rem, 10vh, 7.5rem) 0 clamp(3rem, 6vh, 5rem);
    background: linear-gradient(180deg, #ffffff 0%, #fdf5f2 100%);
    overflow: hidden;
    isolation: isolate;
  }
  .trs-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .trs-hero__blob {
    position: absolute;
    display: block;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.55;
    will-change: transform;
  }
  .trs-hero__blob--a {
    width: 520px; height: 520px;
    top: -180px; left: -120px;
    background: radial-gradient(circle, rgba(200,16,46,0.45), transparent 65%);
    animation: trsFloatA 18s ease-in-out infinite;
  }
  .trs-hero__blob--b {
    width: 460px; height: 460px;
    top: 30%; right: -180px;
    background: radial-gradient(circle, rgba(217,154,58,0.38), transparent 65%);
    animation: trsFloatB 22s ease-in-out infinite;
  }
  .trs-hero__blob--c {
    width: 380px; height: 380px;
    bottom: -160px; left: 35%;
    background: radial-gradient(circle, rgba(45,106,79,0.30), transparent 65%);
    animation: trsFloatC 26s ease-in-out infinite;
  }
  @keyframes trsFloatA { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,30px)} }
  @keyframes trsFloatB { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-30px,40px)} }
  @keyframes trsFloatC { 0%,100%{transform:translate(0,0)} 50%{transform:translate(20px,-40px)} }

  .trs-hero__grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(15,23,42,0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(15,23,42,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, #000 30%, transparent 75%);
  }

  .trs-hero__container { position: relative; z-index: 1; }
  .trs-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .trs-hero__content { min-width: 0; }
  .trs-hero__logo {
    display: block;
    width: auto;
    height: 40px;
    object-fit: contain;
    margin-bottom: var(--space-3);
  }

  .trs-hero__title {
    font-size: clamp(2.4rem, 4.4vw + 0.6rem, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--bbg-ink);
    margin: var(--space-4) 0 var(--space-5);
    max-width: 18ch;
  }
  .trs-hero__phrase {
    position: relative;
    white-space: nowrap;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .trs-hero__phrase--platforms { background-image: linear-gradient(120deg, #c8102e 0%, #ff5e75 100%); }
  .trs-hero__phrase--daily     { background-image: linear-gradient(120deg, #d99a3a 0%, #ffcf6f 100%); }
  .trs-hero__phrase--ground    { background-image: linear-gradient(120deg, #2d6a4f 0%, #52b788 100%); }
  .trs-hero__phrase::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -0.08em;
    height: 0.18em;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.18;
    transform: scaleX(0.65);
    transform-origin: left;
    transition: transform 480ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .trs-hero__phrase--platforms::after { background: #c8102e; }
  .trs-hero__phrase--daily::after     { background: #d99a3a; }
  .trs-hero__phrase--ground::after    { background: #2d6a4f; }
  .trs-hero:hover .trs-hero__phrase::after { transform: scaleX(1); }

  .trs-hero__lead {
    max-width: 52ch;
    font-size: var(--fs-lead);
    color: var(--bbg-text);
    margin-bottom: var(--space-5);
  }

  .trs-hero__actions { margin-bottom: var(--space-6); }
  .trs-hero__cta {
    box-shadow: 0 12px 28px -14px rgba(200,16,46,0.55);
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1), box-shadow 220ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .trs-hero__cta:hover { transform: translateY(-2px); box-shadow: 0 18px 36px -14px rgba(200,16,46,0.65); }

  .trs-hero__clients {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(15,23,42,0.08);
  }
  .trs-hero__clients-label {
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bbg-text-muted);
  }
  .trs-hero__clients-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
  }
  .trs-hero__clients-list li {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--bbg-ink);
    letter-spacing: -0.005em;
    position: relative;
  }
  .trs-hero__clients-list li + li::before {
    content: "";
    position: absolute;
    left: calc(var(--space-5) * -0.5);
    top: 50%;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #c8102e;
    transform: translate(-50%, -50%);
    opacity: 0.6;
  }

  /* ----- Browser mockup ---------------------------------------------------- */
  .trs-hero__media { position: relative; min-width: 0; perspective: 1600px; }
  .browser-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 14px;
  }
  .browser-link:focus-visible { outline: 2px solid #c8102e; outline-offset: 4px; }
  .browser-link:hover .browser__visit { opacity: 1; transform: translateY(0); }
  .browser-link:hover .browser { transform: rotate(0deg) translateY(-2px); }
  .browser__visit {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(15,23,42,0.85);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2,0.8,0.2,1);
    pointer-events: none;
    z-index: 2;
  }
  .browser {
    position: relative;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 28px 60px -22px rgba(15,23,42,0.30),
      0 6px 18px -6px rgba(15,23,42,0.16);
    border: 1px solid rgba(15,23,42,0.08);
    transform: rotate(-1.2deg) translateZ(0);
    transition: transform 480ms cubic-bezier(0.2,0.8,0.2,1), box-shadow 480ms cubic-bezier(0.2,0.8,0.2,1);
    animation: trsBrowserIn 720ms cubic-bezier(0.2,0.8,0.2,1) 0.1s backwards;
  }
  @keyframes trsBrowserIn {
    from { opacity: 0; transform: rotate(-1.2deg) translateY(24px); }
    to { opacity: 1; transform: rotate(-1.2deg) translateY(0); }
  }
  .trs-hero__media:hover .browser {
    transform: rotate(0deg) translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 36px 70px -22px rgba(15,23,42,0.34),
      0 8px 22px -6px rgba(15,23,42,0.18);
  }
  .browser__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
    border-bottom: 1px solid rgba(15,23,42,0.08);
  }
  .browser__dots { display: inline-flex; gap: 6px; }
  .browser__dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .browser__dot--r { background: #ff5f57; }
  .browser__dot--y { background: #febc2e; }
  .browser__dot--g { background: #28c840; }
  .browser__url {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--bbg-text-muted);
    background: rgba(15,23,42,0.04);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
    max-width: 360px;
    margin: 0 auto;
  }
  .browser__viewport {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #f7f9fb;
    overflow: hidden;
  }
  .browser__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Floating chips */
  .trs-hero__chip {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(15,23,42,0.08);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--bbg-ink);
    letter-spacing: 0.01em;
    box-shadow: 0 12px 28px -14px rgba(15,23,42,0.25);
    white-space: nowrap;
  }
  .trs-hero__chip--cities {
    top: -18px; left: -10px;
    animation: trsChipIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.35s backwards, trsChipBobA 7s ease-in-out 1s infinite;
  }
  .trs-hero__chip--ai {
    bottom: -18px; right: -10px;
    animation: trsChipIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.5s backwards, trsChipBobB 8s ease-in-out 1.5s infinite;
  }
  .trs-hero__chip-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34,197,94,0.5);
    animation: trsChipPulse 2.4s ease-in-out infinite;
  }
  @keyframes trsChipIn {
    from { opacity: 0; transform: translateY(8px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes trsChipBobA { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @keyframes trsChipBobB { 0%,100% { transform: translateY(0); } 50% { transform: translateY(6px); } }
  @keyframes trsChipPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
  }

  @media (max-width: 980px) {
    .trs-hero__grid { grid-template-columns: 1fr; gap: var(--space-7); }
    .trs-hero__title { max-width: none; }
    .trs-hero__chip--cities { left: 8px; top: -14px; }
    .trs-hero__chip--ai { right: 8px; bottom: -14px; }
  }
  @media (max-width: 640px) {
    .trs-hero__chip { font-size: 0.7rem; padding: 6px 10px; }
    .trs-hero__chip--cities { display: none; }
  }

  /* ----- Services ---------------------------------------------------------- */
  .services {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 1024px) { .services { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 720px) { .services { grid-template-columns: 1fr; } }

  .service-card {
    position: relative;
    background: #ffffff;
    border: 1px solid var(--bbg-border, rgba(15,23,42,0.08));
    border-radius: 18px;
    padding: var(--space-5) var(--space-5) var(--space-6);
    overflow: hidden;
    transition:
      transform 280ms cubic-bezier(0.2,0.8,0.2,1),
      box-shadow 280ms cubic-bezier(0.2,0.8,0.2,1),
      border-color 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .service-card::before {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, currentColor, transparent);
    opacity: 0.6;
  }
  .service-card--plan    { color: #2d6a4f; }
  .service-card--run     { color: #c8102e; }
  .service-card--sustain { color: #d99a3a; }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: currentColor;
    box-shadow: 0 22px 44px -22px rgba(15,23,42,0.22);
  }
  .service-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--space-4);
  }
  .service-card__pip {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 14%, transparent);
  }
  .service-card__title {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--bbg-ink);
    margin: 0;
  }
  .service-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
  }
  .service-card__item {
    display: block;
    color: var(--bbg-text);
    font-size: 0.95rem;
    line-height: 1.55;
    padding-left: 18px;
    position: relative;
  }
  .service-card__item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 1px;
    background: currentColor;
    opacity: 0.7;
  }
  .service-card__name {
    font-weight: 600;
    color: var(--bbg-ink);
    margin-right: 0.25rem;
  }
  .service-card__body { color: var(--bbg-text); }

  @media (prefers-reduced-motion: reduce) {
    .trs-hero__blob, .trs-hero__chip, .trs-hero__chip-dot, .browser, .service-card {
      animation: none !important;
      transition: none !important;
    }
    .browser { transform: none; }
  }
</style>
