    .bc-hero__logo,
    .bc-hero__eyebrow,
    .bc-hero__chip,
    .bc-shapes__panel.is-active .bc-shapes__item,
    .bc-manifesto__line,
    .bc-manifesto__statement,
    .bc-track__numeral, .bc-track__copy,
    .bc-shapes__header, .bc-shapes__shell,
    .bc-included__header, .bc-included__card,
    .bc-bounds__header, .bc-bounds__card,
    [data-anim] {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
