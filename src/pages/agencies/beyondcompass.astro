---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'en' as const;
const route = 'agencies/beyondcompass' as const;

type ShapeKey = 'shortlist' | 'map' | 'replace';
const shapes: Array<{
  key: ShapeKey;
  title: string;
  meta: string;
  intro: string;
  image: string;
  imageLabel: string;
  items: { name: string; body: string }[];
}> = [
  {
    key: 'shortlist',
    title: 'Shortlist',
    meta: '2 to 3 weeks',
    intro: 'Three to five vetted names, briefed in depth, ready to meet. For brands that already know what their distribution should look like.',
    image: '/images/beyondcompass-shortlist.svg',
    imageLabel: 'Editorial. Shortlist dossier with one name surfaced.',
    items: [
      { name: 'Curated names', body: 'Three to five partners that match your category, your stage, and your channel mix.' },
      { name: 'In-depth briefs', body: 'Footprint, brands they have worked with, commercial terms, our view on each.' },
      { name: 'Working session', body: 'Senior people walking through every name. Why this one, why not that one, where we would push in negotiation.' },
      { name: 'Warm introductions', body: 'You walk in with a relationship behind you. You tend to get the senior team, not the pitch team.' },
    ],
  },
  {
    key: 'map',
    title: 'Market map',
    meta: '3 to 6 weeks',
    intro: 'Fifteen to twenty names, structured for comparison. For brands still working out what their distribution should look like. Followed by a focused shortlist when you are ready.',
    image: '/images/beyondcompass-map.svg',
    imageLabel: 'Editorial. Market map laid out across a long table.',
    items: [
      { name: 'Longlist coverage', body: 'Fifteen to twenty names, mapped by category, channel, and footprint.' },
      { name: 'Structured comparison', body: 'Same categories on every row, so you can compare options on the same axes.' },
      { name: 'Channel logic', body: 'Cross-border versus domestic, Tmall TP versus distributor, B2B versus DTC. We say which fits.' },
      { name: 'Sequenced shortlist', body: 'The most common shape for first-time China entries. Map first, then a focused shortlist drawn from the names that survived it.' },
    ],
  },
  {
    key: 'replace',
    title: 'Replacement',
    meta: 'Contract-dependent',
    intro: 'For brands that already signed with the wrong partner. The shortlist work is the same. The constraints are tighter and there is usually a contract to unwind.',
    image: '/images/beyondcompass-replacement.svg',
    imageLabel: 'Editorial. Replacement work, contract review, Shanghai.',
    items: [
      { name: 'Replacement shortlist', body: 'Same vetting, same warm introductions, but built around an active operation.' },
      { name: 'Transition planning', body: 'How to move inventory, channels, and content without losing the launch window.' },
      { name: 'Contract unwind support', body: 'We help on the resourcing side. Finding a replacement, comparing options, running the transition.' },
      { name: 'Discreet by default', body: 'No public noise. We have done this enough times to know when to keep quiet.' },
    ],
  },
];

type IconKey = 'doc' | 'session' | 'intro' | 'verdict';
const included: Array<{ icon: IconKey; title: string; body: string }> = [
  {
    icon: 'doc',
    title: 'A written deliverable',
    body: 'Real categories, channels, footprint, commercial terms, the brands they have worked with, and our view on each name.',
  },
  {
    icon: 'session',
    title: 'A working session',
    body: 'Senior people walking through every name. Why this one, why not that one, where we would push in negotiation.',
  },
  {
    icon: 'intro',
    title: 'Warm introductions',
    body: 'Almost every name in BeyondCompass is someone our team has met, briefed, or worked with on a real project. You walk in with a relationship behind you.',
  },
  {
    icon: 'verdict',
    title: 'Honest assessments',
    body: 'Who we would recommend without thinking twice, who we would warn you off, and who only fits a very specific kind of brand.',
  },
];

const boundaries: Array<{ title: string; body: string }> = [
  {
    title: 'We do not sell access to the database',
    body: 'No login, no seat license. The value is the context around the rows, and that does not export to a CSV.',
  },
  {
    title: 'We do not run the partnership once it is signed',
    body: 'BeyondBorderGroup does that work separately, when you want it.',
  },
  {
    title: 'We do not promise outcomes two years out',
    body: 'What we can do is make sure the names on your list deserve to be there.',
  },
];

const visitUrl = 'https://beyondcompass.beyondbordergroup.com';
const visitLabel = 'Visit BeyondCompass';
---

<Layout
  locale={locale}
  route={route}
  title="BeyondCompass. Find the right China partner first."
  description="A private database of distributors, Tmall TPs, Douyin Partners and importers we have actually met, vetted, and worked with. Shortlist, market map, or replacement, sourced from twenty years on the ground."
>
  <!-- ====================================================================== -->
  <!-- HERO: cinematic dark + curated shortlist preview                       -->
  <!-- ====================================================================== -->
  <section class="bc-hero" data-hero>
    <div class="bc-hero__bg" aria-hidden="true">
      <img src="/images/bbg-shanghai-twilight.webp" alt="" class="bc-hero__bg-img" data-parallax-bg onerror="this.style.display='none'" />
      <div class="bc-hero__bg-scrim"></div>
      <div class="bc-hero__bg-glow"></div>
      <div class="bc-hero__bg-grid"></div>
    </div>

    <div class="container bc-hero__main">
      <div class="bc-hero__content">
        <img src="/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.png" alt="BeyondCompass" class="bc-hero__logo" width="200" height="48" loading="eager" decoding="async" />

        <span class="bc-hero__eyebrow">
          <span class="bc-hero__eyebrow-dot"></span>
          Twenty years on the ground · Distributors · Tmall TPs · Douyin Partners
        </span>

        <h1 class="bc-hero__title">
          <span class="bc-hero__line" data-anim="word">A contact list</span>
          <span class="bc-hero__line" data-anim="word">tells you who <em class="bc-hero__phrase bc-hero__phrase--exists">exists</em>.</span>
          <span class="bc-hero__line" data-anim="word">We tell you</span>
          <span class="bc-hero__line" data-anim="word">who <em class="bc-hero__phrase bc-hero__phrase--fits">fits</em>.</span>
        </h1>

        <p class="bc-hero__lead" data-anim="fade">
          We did the sourcing already. You do not have to start where most brands do.
        </p>

        <div class="bc-hero__cta-row" data-anim="fade">
          <a class="bc-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-magnet>
            <span class="bc-magnet__bg"></span>
            <span class="bc-magnet__label">{visitLabel}</span>
            <span class="bc-magnet__arrow" aria-hidden="true">→</span>
          </a>
          <a class="bc-hero__secondary" href={pathFor('contact', locale)} data-anim="fade">
            <span>Talk to us</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="bc-hero__preview" data-tilt>
        <div class="bc-hero__preview-frame">
          <a class="bc-mock-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
          <div class="bc-mock">
            <div class="bc-mock__chrome">
              <span class="bc-mock__dots">
                <span class="bc-mock__dot bc-mock__dot--r"></span>
                <span class="bc-mock__dot bc-mock__dot--y"></span>
                <span class="bc-mock__dot bc-mock__dot--g"></span>
              </span>
              <span class="bc-mock__url">beyondcompass.beyondbordergroup.com</span>
              <span class="bc-mock__visit" aria-hidden="true">
                <span>Visit site</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
              </span>
            </div>

            <div class="bc-mock__viewport">
              <div class="bc-mock__head">
                <span class="bc-mock__head-eyebrow">Shortlist · Beauty · Cross-border</span>
                <span class="bc-mock__head-meta">3 of 4 names shown</span>
              </div>

              <ul class="bc-mock__list" aria-hidden="true">
                <li class="bc-mock__row">
                  <div class="bc-mock__row-left">
                    <span class="bc-mock__name"><span class="bc-mock__redact bc-mock__redact--lg"></span></span>
                    <span class="bc-mock__tag bc-mock__tag--tmall">Tmall TP</span>
                  </div>
                  <div class="bc-mock__row-right">
                    <span class="bc-mock__meta">Shanghai · Beauty</span>
                    <span class="bc-mock__brands">
                      <span class="bc-mock__redact"></span>
                      <span class="bc-mock__redact bc-mock__redact--md"></span>
                      <span class="bc-mock__redact"></span>
                    </span>
                  </div>
                </li>
                <li class="bc-mock__row">
                  <div class="bc-mock__row-left">
                    <span class="bc-mock__name"><span class="bc-mock__redact bc-mock__redact--md"></span></span>
                    <span class="bc-mock__tag bc-mock__tag--dist">Distributor</span>
                  </div>
                  <div class="bc-mock__row-right">
                    <span class="bc-mock__meta">Hong Kong · Lifestyle</span>
                    <span class="bc-mock__brands">
                      <span class="bc-mock__redact"></span>
                      <span class="bc-mock__redact"></span>
                    </span>
                  </div>
                </li>
                <li class="bc-mock__row">
                  <div class="bc-mock__row-left">
                    <span class="bc-mock__name"><span class="bc-mock__redact bc-mock__redact--lg"></span></span>
                    <span class="bc-mock__tag bc-mock__tag--douyin">Douyin Partner</span>
                  </div>
                  <div class="bc-mock__row-right">
                    <span class="bc-mock__meta">Shenzhen · Wellness</span>
                    <span class="bc-mock__brands">
                      <span class="bc-mock__redact bc-mock__redact--md"></span>
                      <span class="bc-mock__redact"></span>
                      <span class="bc-mock__redact"></span>
                    </span>
                  </div>
                </li>
              </ul>

              <div class="bc-mock__foot">
                <span class="bc-mock__foot-dot"></span>
                Names redacted. Released after the brief.
              </div>
            </div>
          </div>
          </a>

          <div class="bc-hero__chip bc-hero__chip--coverage">
            <span class="bc-hero__chip-label">Coverage</span>
            <span>Tmall TP · Distributor · Douyin · Importer</span>
          </div>
          <div class="bc-hero__chip bc-hero__chip--cats">
            <span class="bc-hero__chip-label">Categories</span>
            <span>Beauty · F&B · Fashion · Wellness · Pet</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#track" class="bc-hero__scroll" aria-label="Scroll">
      <span>Scroll</span>
      <span class="bc-hero__scroll-line"></span>
    </a>
  </section>

  <!-- ====================================================================== -->
  <!-- TRACK RECORD: editorial numeral, twenty years of meetings              -->
  <!-- ====================================================================== -->
  <section class="bc-track" id="track">
    <div class="container">
      <div class="bc-track__grid">
        <div class="bc-track__numeral" aria-hidden="true">
          <span class="bc-track__num" data-count="20">0</span>
          <span class="bc-track__num-shadow">20</span>
        </div>
        <div class="bc-track__copy">
          <span class="eyebrow">Sourcing depth</span>
          <h2 class="bc-track__title balance">Twenty years of meetings, vetted into one private database.</h2>
          <p class="bc-track__lead">
            A directory cannot protect you from a wrong-partner mistake. A database built one meeting at a time can. Almost every name in BeyondCompass is someone our team has met, briefed, or worked with on a real brand project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- WHAT WE DO: tabbed editorial panels, three shapes                      -->
  <!-- ====================================================================== -->
  <section class="bc-shapes" id="shapes">
    <div class="container">
      <header class="bc-shapes__header">
        <span class="eyebrow">What we do</span>
        <h2 class="bc-shapes__title">
          Partner sourcing, <em>in three shapes.</em>
        </h2>
        <p class="bc-shapes__lead">
          We use BeyondCompass to draw you a list of distribution and channel partners worth talking to, validated against what we have seen recently and what we know about your category.
        </p>
      </header>

      <div class="bc-shapes__shell" data-tabs>
        <div class="bc-shapes__nav" role="tablist" aria-label="Sourcing shapes">
          {shapes.map((s, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`bc-shapes__tab bc-shapes__tab--${s.key} ${i === 0 ? 'is-active' : ''}`}
              data-tab={s.key}
              id={`bc-tab-${s.key}`}
              aria-controls={`bc-panel-${s.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="bc-shapes__tab-pip" aria-hidden="true"></span>
              <span class="bc-shapes__tab-text">
                <span class="bc-shapes__tab-label">{s.title}</span>
                <span class="bc-shapes__tab-count">{s.meta}</span>
              </span>
            </button>
          ))}
          <span class="bc-shapes__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="bc-shapes__panels">
          {shapes.map((s, i) => (
            <div
              class={`bc-shapes__panel bc-shapes__panel--${s.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`bc-panel-${s.key}`}
              aria-labelledby={`bc-tab-${s.key}`}
              data-panel={s.key}
              hidden={i !== 0}
            >
              <div class="bc-shapes__panel-grid">
                <div class="bc-shapes__panel-image">
                  <div class={`bc-shapes__panel-frame bc-shapes__panel-frame--${s.key}`}>
                    <img src={s.image} alt={s.imageLabel} class="bc-shapes__panel-img" loading="lazy" decoding="async" />
                    <div class={`bc-shapes__panel-tag bc-shapes__panel-tag--${s.key}`}>
                      <span>{s.title}</span>
                    </div>
                  </div>
                </div>

                <div class="bc-shapes__panel-content">
                  <p class="bc-shapes__panel-intro">{s.intro}</p>
                  <ul class="bc-shapes__list">
                    {s.items.map((it) => (
                      <li class="bc-shapes__item">
                        <span class={`bc-shapes__item-pip bc-shapes__item-pip--${s.key}`} aria-hidden="true"></span>
                        <span class="bc-shapes__item-text">
                          <span class="bc-shapes__item-name">{it.name}.</span>
                          <span class="bc-shapes__item-body">{it.body}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- INCLUDED, EVERY TIME                                                    -->
  <!-- ====================================================================== -->
  <section class="bc-included">
    <div class="container">
      <header class="bc-included__header">
        <span class="eyebrow">Included, every time</span>
        <h2 class="bc-included__title balance">
          A list is not worth much if you do not trust the thinking behind it.
        </h2>
      </header>

      <div class="bc-included__grid">
        {included.map((it) => (
          <article class={`bc-included__card bc-included__card--${it.icon}`}>
            <span class="bc-included__icon" aria-hidden="true">
              {it.icon === 'doc' && (
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
                  <path d="M7 4.5h10l4 4v15A1.5 1.5 0 0 1 19.5 25h-12A1.5 1.5 0 0 1 6 23.5V6A1.5 1.5 0 0 1 7.5 4.5Z" stroke="currentColor"/>
                  <path d="M17 4.5v4h4" stroke="currentColor"/>
                  <path d="M9.5 13h9M9.5 16.5h9M9.5 20h6" stroke="currentColor"/>
                </svg>
              )}
              {it.icon === 'session' && (
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
                  <circle cx="10" cy="10" r="3.2" stroke="currentColor"/>
                  <circle cx="19" cy="11.5" r="2.6" stroke="currentColor"/>
                  <path d="M4 22c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor"/>
                  <path d="M16.5 22c0-2.7 2-5 4.5-5 1.5 0 2.8.8 3.5 2" stroke="currentColor"/>
                </svg>
              )}
              {it.icon === 'intro' && (
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
                  <path d="M3.5 14.5l5-3 4 2.5 6-3.5 6 4" stroke="currentColor"/>
                  <circle cx="3.5" cy="14.5" r="1.7" stroke="currentColor" fill="currentColor"/>
                  <circle cx="8.5" cy="11.5" r="1.7" stroke="currentColor"/>
                  <circle cx="12.5" cy="14" r="1.7" stroke="currentColor"/>
                  <circle cx="18.5" cy="10.5" r="1.7" stroke="currentColor"/>
                  <circle cx="24.5" cy="14.5" r="1.7" stroke="currentColor" fill="currentColor"/>
                </svg>
              )}
              {it.icon === 'verdict' && (
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6">
                  <path d="M14 4.5L23 8v6.5c0 4.7-3.6 8.6-9 9.5-5.4-.9-9-4.8-9-9.5V8l9-3.5Z" stroke="currentColor"/>
                  <path d="M10 14.5l3 3 5.5-6" stroke="currentColor"/>
                </svg>
              )}
            </span>
            <div class="bc-included__copy">
              <h3 class="bc-included__card-title">{it.title}</h3>
              <p class="bc-included__card-body">{it.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- MANIFESTO: dark editorial, three-line statement                         -->
  <!-- ====================================================================== -->
  <section class="bc-manifesto">
    <div class="bc-manifesto__bg" aria-hidden="true"></div>
    <div class="container bc-manifesto__container">
      <span class="eyebrow eyebrow--on-dark">Manifesto</span>
      <h2 class="bc-manifesto__title">
        <span class="bc-manifesto__line" data-line>China rewards brands that pick the right partner first.</span>
        <span class="bc-manifesto__line" data-line>It punishes the ones that do not.</span>
        <span class="bc-manifesto__line" data-line>The punishment is rarely loud.</span>
      </h2>
      <div class="bc-manifesto__statement" data-line>
        <p>Inventory sits in a warehouse for eighteen months. A flagship store gets run by a team that has never moved your category. Two years of your China entry, gone.</p>
        <p class="bc-manifesto__emphasis">A database built one meeting at a time, over twenty years, can protect you from that.</p>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- BOUNDARIES: what we do not do                                          -->
  <!-- ====================================================================== -->
  <section class="bc-bounds">
    <div class="bc-bounds__bg" aria-hidden="true">
      <span class="bc-bounds__rail">Out of scope · Out of scope · Out of scope · Out of scope</span>
    </div>
    <div class="container">
      <header class="bc-bounds__header">
        <span class="eyebrow">What this is not</span>
        <h2 class="bc-bounds__title">
          Three things <em>this is not.</em>
        </h2>
        <p class="bc-bounds__lead">
          The lines we keep clean. So you know what you are paying for, and what you are not.
        </p>
      </header>

      <div class="bc-bounds__grid">
        {boundaries.map((b, i) => (
          <article class={`bc-bounds__card bc-bounds__card--${i}`}>
            <span class="bc-bounds__strike" aria-hidden="true"></span>
            <span class="bc-bounds__icon" aria-hidden="true">
              <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="28" cy="28" r="25" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 4" />
                <path d="M19 19 L37 37 M37 19 L19 37" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
              </svg>
            </span>
            <span class="bc-bounds__tag">Not in scope</span>
            <h3 class="bc-bounds__card-title">{b.title}.</h3>
            <p class="bc-bounds__card-body">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- FINAL CTA                                                              -->
  <!-- ====================================================================== -->
  <section class="bc-cta">
    <div class="bc-cta__bg" aria-hidden="true">
      <img src="/images/bbg-shanghai-twilight.webp" alt="" onerror="this.style.display='none'" />
      <div class="bc-cta__bg-scrim"></div>
    </div>
    <div class="container bc-cta__content">
      <span class="eyebrow eyebrow--on-dark">Ready when you are</span>
      <h2 class="bc-cta__title balance">
        Find the right China partner first.<br />Before the wrong one finds you.
      </h2>
      <div class="bc-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Talk to us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* BeyondCompass color tokens                                            */
  /* ===================================================================== */
  .bc-hero,
  .bc-shapes,
  .bc-included,
  .bc-manifesto,
  .bc-bounds,
  .bc-cta,
  .bc-track {
    --bc-ink: #0c1220;
    --bc-teal: #14b8a6;
    --bc-teal-strong: #0d9488;
    --bc-gold: #d99a3a;
    --bc-gold-strong: #b8782b;
    --bc-rose: #f43f5e;
    --bc-rose-strong: #d1234a;
    --bc-paper: #f7f6f1;
    --bc-paper-2: #efece4;
  }

  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .bc-hero {
    position: relative;
    min-height: 88vh;
    padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    background: var(--bc-ink);
  }

  .bc-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .bc-hero__bg-img {
    position: absolute;
    inset: -8% -4% -4% -4%;
    width: 108%;
    height: 112%;
    object-fit: cover;
    object-position: center 35%;
    will-change: transform;
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04);
    filter: saturate(0.7) contrast(1.1) brightness(0.62) hue-rotate(-12deg);
  }
  .bc-hero__bg-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(8, 12, 24, 0.92) 0%, rgba(8, 12, 24, 0.7) 38%, rgba(8, 12, 24, 0.34) 65%, rgba(8, 12, 24, 0.65) 100%),
      linear-gradient(180deg, rgba(8, 12, 24, 0.55) 0%, rgba(8, 12, 24, 0.05) 30%, rgba(8, 12, 24, 0.0) 60%, rgba(8, 12, 24, 0.85) 100%);
  }
  .bc-hero__bg-glow {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(900px 500px at 14% 28%, rgba(20,184,166,0.20), transparent 65%),
      radial-gradient(800px 480px at 88% 78%, rgba(217,154,58,0.18), transparent 70%);
    mix-blend-mode: screen;
  }
  .bc-hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.045) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.045) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.65;
  }

  .bc-hero__main {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .bc-hero__content { min-width: 0; max-width: 36rem; }
  .bc-hero__logo {
    display: block;
    width: auto;
    height: 40px;
    filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.4));
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: bcFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.1s forwards;
  }

  .bc-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: bcFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.2s forwards;
  }
  .bc-hero__eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--bc-teal);
    box-shadow: 0 0 0 0 rgba(20,184,166,0.55);
    animation: bcPulse 2.4s ease-in-out infinite;
  }

  .bc-hero__title {
    font-size: clamp(2.1rem, 3.4vw + 0.5rem, 3.6rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: #fff;
    margin: 0 0 var(--space-5);
    max-width: 24ch;
  }
  .bc-hero__line {
    display: block;
    overflow: hidden;
  }
  .bc-hero__line[data-anim="word"] {
    transform: translateY(110%);
    opacity: 0;
    animation: bcWordIn 880ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
  }
  .bc-hero__line[data-anim="word"]:nth-child(1) { animation-delay: 0.30s; }
  .bc-hero__line[data-anim="word"]:nth-child(2) { animation-delay: 0.42s; }
  .bc-hero__line[data-anim="word"]:nth-child(3) { animation-delay: 0.58s; }
  .bc-hero__line[data-anim="word"]:nth-child(4) { animation-delay: 0.70s; }
  @keyframes bcWordIn {
    from { transform: translateY(110%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .bc-hero__phrase {
    font-style: normal;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    position: relative;
  }
  .bc-hero__phrase--exists {
    background-image: linear-gradient(120deg, #6b7280 0%, #9ca3af 60%, #6b7280 100%);
  }
  .bc-hero__phrase--fits {
    background-image: linear-gradient(120deg, #2dd4bf 0%, #0d9488 60%, #ffd07a 100%);
  }

  .bc-hero__lead {
    max-width: 44ch;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    margin: 0 0 var(--space-5);
    opacity: 0;
    animation: bcFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.95s forwards;
  }

  .bc-hero__cta-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0;
    animation: bcFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 1.1s forwards;
  }

  .bc-magnet {
    --x: 0px; --y: 0px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px 16px 28px;
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    isolation: isolate;
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1);
    transform: translate(var(--x), var(--y));
  }
  .bc-magnet__bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, var(--bc-teal) 0%, var(--bc-teal-strong) 100%);
    box-shadow: 0 16px 36px -10px rgba(20,184,166,0.55), inset 0 1px 0 rgba(255,255,255,0.2);
    z-index: -1;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bc-magnet:hover .bc-magnet__bg { transform: scale(1.04); }
  .bc-magnet__arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bc-magnet:hover .bc-magnet__arrow { transform: translateX(4px); }

  .bc-hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.92);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .bc-hero__secondary svg { transition: transform 220ms ease; }
  .bc-hero__secondary:hover { color: #5eead4; }
  .bc-hero__secondary:hover svg { transform: translateX(3px); }

  /* Hero preview: BeyondCompass shortlist mockup (CSS-only) */
  .bc-hero__preview {
    position: relative;
    perspective: 1600px;
    min-width: 0;
    opacity: 0;
    animation: bcFadeIn 900ms cubic-bezier(0.2,0.8,0.2,1) 0.55s forwards;
  }
  .bc-hero__preview-frame {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(var(--tilt-x, -3deg)) rotateX(var(--tilt-y, 2deg));
    transition: transform 600ms cubic-bezier(0.2,0.8,0.2,1);
  }

  .bc-mock-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 14px;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .bc-mock-link:hover { transform: translateY(-2px); }
  .bc-mock-link:focus-visible { outline: 2px solid #fff; outline-offset: 4px; }
  .bc-mock-link:hover .bc-mock__visit { opacity: 1; transform: translateY(0); }
  .bc-mock__visit {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(15,23,42,0.85);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    opacity: 0;
    transform: translateY(-2px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2,0.8,0.2,1);
    pointer-events: none;
  }
  .bc-mock {
    position: relative;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 40px 80px -28px rgba(0,0,0,0.55),
      0 12px 28px -8px rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.10);
    transform: translateZ(0);
  }
  .bc-mock__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
    border-bottom: 1px solid rgba(15,23,42,0.08);
  }
  .bc-mock__dots { display: inline-flex; gap: 6px; }
  .bc-mock__dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .bc-mock__dot--r { background: #ff5f57; }
  .bc-mock__dot--y { background: #febc2e; }
  .bc-mock__dot--g { background: #28c840; }
  .bc-mock__url {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--bbg-text-muted);
    background: rgba(15,23,42,0.04);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
    max-width: 360px;
    margin: 0 auto;
  }
  .bc-mock__viewport {
    position: relative;
    aspect-ratio: 16 / 11;
    background: linear-gradient(180deg, #ffffff 0%, #fbfaf6 100%);
    padding: 18px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bc-mock__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .bc-mock__head-eyebrow {
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bc-teal-strong);
  }
  .bc-mock__head-meta {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--bbg-text-muted);
    letter-spacing: 0.04em;
  }
  .bc-mock__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .bc-mock__row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    background: rgba(15,23,42,0.025);
    border: 1px solid rgba(15,23,42,0.06);
    align-items: center;
  }
  .bc-mock__row-left { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .bc-mock__row-right { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .bc-mock__name {
    display: inline-flex;
    align-items: center;
    flex: 1;
    min-width: 0;
  }
  .bc-mock__redact {
    display: inline-block;
    height: 10px;
    width: 60px;
    border-radius: 3px;
    background: linear-gradient(90deg, rgba(15,23,42,0.10), rgba(15,23,42,0.18));
  }
  .bc-mock__redact--md { width: 80px; }
  .bc-mock__redact--lg { width: 110px; }
  .bc-mock__brands {
    display: inline-flex;
    gap: 6px;
    align-items: center;
  }
  .bc-mock__brands .bc-mock__redact {
    height: 8px;
    background: linear-gradient(90deg, rgba(20,184,166,0.18), rgba(20,184,166,0.32));
  }
  .bc-mock__tag {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 999px;
    color: #fff;
  }
  .bc-mock__tag--tmall  { background: linear-gradient(120deg, #d99a3a, #b8782b); }
  .bc-mock__tag--dist   { background: linear-gradient(120deg, #14b8a6, #0d9488); }
  .bc-mock__tag--douyin { background: linear-gradient(120deg, #f43f5e, #d1234a); }
  .bc-mock__meta {
    font-family: var(--font-display);
    font-size: 0.7rem;
    color: var(--bbg-text);
    letter-spacing: 0.01em;
  }
  .bc-mock__foot {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 0.68rem;
    color: var(--bbg-text-muted);
    letter-spacing: 0.04em;
    border-top: 1px dashed rgba(15,23,42,0.10);
    padding-top: 10px;
  }
  .bc-mock__foot-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--bc-teal);
    box-shadow: 0 0 0 0 rgba(20,184,166,0.5);
    animation: bcPulse 2.4s ease-in-out infinite;
  }

  .bc-hero__chip {
    position: absolute;
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.92);
    color: var(--bbg-ink);
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 14px;
    font-family: var(--font-display);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    box-shadow: 0 24px 50px -18px rgba(0,0,0,0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translateZ(40px);
  }
  .bc-hero__chip-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bc-teal-strong);
  }
  .bc-hero__chip--coverage {
    top: -22px; left: -28px;
    animation: bcFloatA 9s ease-in-out infinite;
  }
  .bc-hero__chip--cats {
    bottom: -24px; right: -20px;
    animation: bcFloatB 11s ease-in-out infinite;
  }
  @keyframes bcFloatA { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(-7px); } }
  @keyframes bcFloatB { 0%,100% { transform: translateZ(40px) translateY(0); } 50% { transform: translateZ(40px) translateY(8px); } }

  /* Scroll hint */
  .bc-hero__scroll {
    position: absolute;
    bottom: clamp(1rem, 3vh, 2rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: color 220ms ease;
  }
  .bc-hero__scroll:hover { color: #fff; }
  .bc-hero__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, rgba(255,255,255,0.7), rgba(255,255,255,0));
    position: relative;
    overflow: hidden;
  }
  .bc-hero__scroll-line::after {
    content: "";
    position: absolute;
    top: -36px;
    left: 0; right: 0;
    height: 36px;
    background: linear-gradient(180deg, rgba(255,255,255,0), rgba(255,255,255,0.95));
    animation: bcScrollLine 1.8s ease-in-out infinite;
  }
  @keyframes bcScrollLine { 0% { top: -36px; } 100% { top: 36px; } }

  @keyframes bcFadeIn { to { opacity: 1; } }
  @keyframes bcPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(20,184,166,0.55); }
    50% { box-shadow: 0 0 0 7px rgba(20,184,166,0); }
  }

  @media (max-width: 1023px) {
    .bc-hero__main { grid-template-columns: 1fr; gap: var(--space-7); }
    .bc-hero__title { max-width: none; }
    .bc-hero__chip--coverage { top: -14px; left: 8px; }
    .bc-hero__chip--cats { bottom: -14px; right: 8px; }
  }
  @media (max-width: 639px) {
    .bc-hero__chip { font-size: 0.72rem; padding: 8px 10px; }
    .bc-hero__chip--coverage { display: none; }
    .bc-hero__scroll { display: none; }
  }

  /* ===================================================================== */
  /* TRACK RECORD                                                           */
  /* ===================================================================== */
  .bc-track {
    padding: clamp(5rem, 10vh, 8rem) 0 clamp(4rem, 8vh, 6rem);
    background: linear-gradient(180deg, var(--bbg-white) 0%, var(--bc-paper) 100%);
    position: relative;
  }
  .bc-track__grid {
    display: grid;
    grid-template-columns: minmax(0, auto) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (max-width: 1023px) { .bc-track__grid { grid-template-columns: 1fr; gap: var(--space-6); } }

  .bc-track__numeral {
    position: relative;
    line-height: 0.85;
    letter-spacing: -0.06em;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--bbg-ink);
  }
  .bc-track__num {
    position: relative;
    z-index: 2;
    display: inline-block;
    font-size: clamp(7rem, 18vw, 16rem);
    background: linear-gradient(180deg, var(--bbg-ink) 0%, #2a2f3f 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-variant-numeric: tabular-nums;
  }
  .bc-track__num-shadow {
    position: absolute;
    top: 4px; left: 5px;
    font-size: clamp(7rem, 18vw, 16rem);
    color: transparent;
    -webkit-text-stroke: 1px rgba(20,184,166,0.22);
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }
  .bc-track__copy { max-width: 56ch; }
  .bc-track__title { font-size: clamp(1.6rem, 2.4vw + 0.6rem, 2.4rem); line-height: 1.15; margin: 0 0 var(--space-4); }
  .bc-track__lead { font-size: var(--fs-lead); color: var(--bbg-text); }

  /* ===================================================================== */
  /* SHAPES (services tabs)                                                 */
  /* ===================================================================== */
  .bc-shapes {
    padding: clamp(5rem, 10vh, 8rem) 0 clamp(4rem, 8vh, 6rem);
    background: var(--bbg-white);
    position: relative;
  }

  .bc-shapes__header { max-width: 60ch; margin: 0 0 var(--space-7); }
  .bc-shapes__title {
    font-size: clamp(2rem, 3.6vw + 0.5rem, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: var(--space-3) 0 var(--space-4);
  }
  .bc-shapes__title em {
    font-style: normal;
    background: linear-gradient(120deg, var(--bc-teal-strong), var(--bc-gold) 60%, var(--bc-rose));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .bc-shapes__lead { color: var(--bbg-text); font-size: var(--fs-lead); max-width: 64ch; }

  .bc-shapes__shell {
    position: relative;
    background: var(--bc-paper);
    border-radius: 28px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid var(--bbg-border);
    box-shadow: 0 60px 120px -60px rgba(15, 23, 42, 0.18);
  }

  .bc-shapes__nav {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    padding: 6px;
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 16px;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  .bc-shapes__tab-indicator {
    position: absolute;
    top: 6px;
    left: 6px;
    width: calc((100% - 12px) / 3);
    height: calc(100% - 12px);
    background: linear-gradient(135deg, var(--bbg-ink) 0%, #2a2f3f 100%);
    border-radius: 12px;
    transition: transform 380ms cubic-bezier(0.2, 0.85, 0.2, 1);
    pointer-events: none;
    z-index: 0;
  }
  .bc-shapes__tab {
    position: relative;
    z-index: 1;
    background: transparent;
    border: 0;
    padding: 14px 18px;
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    font: inherit;
    color: var(--bbg-text-muted);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    transition: color 320ms ease;
    min-width: 0;
  }
  .bc-shapes__tab.is-active { color: #fff; }
  .bc-shapes__tab.is-active .bc-shapes__tab-count { color: rgba(255,255,255,0.6); }
  .bc-shapes__tab-pip {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    transition: background 320ms ease, transform 320ms ease;
  }
  .bc-shapes__tab--shortlist.is-active .bc-shapes__tab-pip { background: var(--bc-gold); }
  .bc-shapes__tab--map.is-active       .bc-shapes__tab-pip { background: var(--bc-teal); }
  .bc-shapes__tab--replace.is-active   .bc-shapes__tab-pip { background: var(--bc-rose); }
  .bc-shapes__tab-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .bc-shapes__tab-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    letter-spacing: -0.005em;
    color: var(--bbg-ink);
    transition: color 320ms ease;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bc-shapes__tab.is-active .bc-shapes__tab-label { color: #fff; }
  .bc-shapes__tab-count {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--bbg-text-muted);
    transition: color 320ms ease;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @media (max-width: 767px) {
    .bc-shapes__nav { grid-template-columns: 1fr; }
    .bc-shapes__tab-indicator { display: none; }
    .bc-shapes__tab { background: rgba(15,23,42,0.04); }
    .bc-shapes__tab.is-active { background: var(--bbg-ink); }
  }

  .bc-shapes__panels { position: relative; min-height: 480px; }
  .bc-shapes__panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 380ms ease, transform 480ms cubic-bezier(0.2, 0.85, 0.2, 1);
    pointer-events: none;
  }
