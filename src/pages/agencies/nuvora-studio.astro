---
import Layout from '../../layouts/Layout.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'en' as const;
const route = 'agencies/nuvora-studio' as const;

type ServiceKey = 'build' | 'convert' | 'learn';
const services: Array<{
  key: ServiceKey;
  title: string;
  intro: string;
  image: string;
  items: { name: string; body: string }[];
}> = [
  {
    key: 'build',
    title: 'Build',
    intro: 'Show up where buyers, hires, and investors are looking. Every day.',
    image: '/images/nuvora-build.webp',
    items: [
      { name: 'LinkedIn Content', body: 'Planned, written, and published to get your company seen by buyers. Built to drive leads, not just likes.' },
      { name: 'Executive Personal Branding', body: 'LinkedIn presence built for founders, CEOs, and senior leaders. Ghostwriting that sounds like you and earns trust at scale.' },
      { name: 'Employee Advocacy', body: 'Your team, turned into a content engine. Trained, equipped, and posting consistently. Reach multiplied.' },
    ],
  },
  {
    key: 'convert',
    title: 'Convert',
    intro: 'Reach the right decision makers and convert attention into pipeline.',
    image: '/images/nuvora-grow.webp',
    items: [
      { name: 'LinkedIn Advertising', body: 'Ad campaigns that bring qualified leads into your pipeline. Targeting, creative, and reporting tied to revenue. No budget burned on the wrong audience.' },
    ],
  },
  {
    key: 'learn',
    title: 'Learn',
    intro: 'Build the muscle in-house. Strategy first, lock-in never.',
    image: '/images/nuvora-learn.webp',
    items: [
      { name: 'Training and Workshops', body: 'Hands-on sessions for in-house teams. Algorithm, profile, content strategy. Practical from day one.' },
      { name: 'Consulting', body: 'A full audit of your current LinkedIn presence and the roadmap to grow it. Strategy first. Execution second.' },
    ],
  },
];

const visitUrl = 'https://nuvora.studio';
const visitLabel = 'Visit nuvora.studio';
---

<Layout
  locale={locale}
  route={route}
  title="Nuvora Studio: Get More Leads on LinkedIn"
  description="Nuvora Studio grows LinkedIn presence for B2B companies. Content, ads, executive branding, and more. Get qualified leads from decision makers."
>
  <!-- ====================================================================== -->
  <!-- HERO                                                                   -->
  <!-- ====================================================================== -->
  <section class="nv-hero" data-hero>
    <div class="nv-hero__bg" aria-hidden="true">
      <img src="/images/nuvora-hero-bg.webp" alt="" class="nv-hero__bg-img" data-parallax-bg onerror="this.style.display='none'" />
      <div class="nv-hero__bg-scrim"></div>
      <div class="nv-hero__bg-grain"></div>
      <div class="nv-hero__bg-grid"></div>
    </div>

    <div class="container nv-hero__main">
      <div class="nv-hero__content">
        <img src="/AgencyLogos/Nuvora%20PNG.png" alt="Nuvora Studio" class="nv-hero__logo" width="160" height="40" loading="eager" decoding="async" />

        <span class="nv-hero__eyebrow">
          <span class="nv-hero__eyebrow-dot"></span>
          LinkedIn-only · B2B · Lead generation
        </span>

        <h1 class="nv-hero__title">
          <span class="nv-hero__line" data-anim="word">Your <em class="nv-hero__phrase nv-hero__phrase--buyers">buyers</em> check it.</span>
          <span class="nv-hero__line" data-anim="word">Your <em class="nv-hero__phrase nv-hero__phrase--hires">hires</em> check it.</span>
          <span class="nv-hero__line" data-anim="word">Your <em class="nv-hero__phrase nv-hero__phrase--investors">investors</em> check it.</span>
        </h1>

        <p class="nv-hero__lead" data-anim="fade">With over one billion members, LinkedIn is the world's professional record. We grow your presence on it. Every day.</p>

        <div class="nv-hero__cta-row" data-anim="fade">
          <a class="nv-magnet" href={visitUrl} target="_blank" rel="noreferrer" data-magnet>
            <span class="nv-magnet__bg"></span>
            <span class="nv-magnet__label">{visitLabel}</span>
            <span class="nv-magnet__arrow" aria-hidden="true">→</span>
          </a>
          <a class="nv-hero__secondary" href={pathFor('contact', locale)} data-anim="fade">
            <span>Talk to us</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="nv-hero__preview" data-tilt>
        <div class="nv-hero__preview-frame">
          <a class="browser-link" href={visitUrl} target="_blank" rel="noreferrer" aria-label={visitLabel}>
            <div class="browser">
              <div class="browser__chrome">
                <span class="browser__dots">
                  <span class="browser__dot browser__dot--r"></span>
                  <span class="browser__dot browser__dot--y"></span>
                  <span class="browser__dot browser__dot--g"></span>
                </span>
                <span class="browser__url">nuvora.studio</span>
              </div>
              <div class="browser__viewport">
                <img src="/images/nuvora-studio-home.webp" alt="nuvora.studio homepage" class="browser__shot" width="1600" height="1000" loading="eager" decoding="async" />
                <span class="browser__live">
                  <span class="browser__live-dot"></span>
                  Live · {new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </span>
                <span class="browser__visit" aria-hidden="true">
                  <span>Visit site</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l10-10M7 7h10v10"/></svg>
                </span>
              </div>
            </div>
          </a>

          <div class="nv-hero__chip nv-hero__chip--scope">
            <span class="nv-hero__chip-label">Scope</span>
            <span>Content · Ads · Branding · Advocacy</span>
          </div>
          <div class="nv-hero__chip nv-hero__chip--audience">
            <span class="nv-hero__chip-label">Built for</span>
            <span>Founders · CEOs · Marketing leaders</span>
          </div>
        </div>
      </div>
    </div>

    <a href="#track" class="nv-hero__scroll" aria-label="Scroll">
      <span>Scroll</span>
      <span class="nv-hero__scroll-line"></span>
    </a>
  </section>

  <!-- ====================================================================== -->
  <!-- TRACK RECORD                                                           -->
  <!-- ====================================================================== -->
  <section class="nv-track" id="track">
    <div class="container">
      <div class="nv-track__grid">
        <div class="nv-track__numeral" aria-hidden="true">
          <span class="nv-track__num" data-count="1">0</span>
          <span class="nv-track__num-suffix">B+</span>
          <span class="nv-track__num-shadow">1B+</span>
        </div>
        <div class="nv-track__copy">
          <span class="eyebrow">The platform</span>
          <h2 class="nv-track__title balance">One billion members. One platform that decides who gets the meeting.</h2>
          <p class="nv-track__lead">
            Empty company pages. Silent executives. Posts that read like press releases. Ad budgets spent on the wrong audience. That's lost pipeline, every week of it. We change that.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- SERVICES                                                               -->
  <!-- ====================================================================== -->
  <section class="nv-services" id="services">
    <div class="container">
      <header class="nv-services__header">
        <span class="eyebrow">What we do</span>
        <h2 class="nv-services__title">
          Three lanes. <em>One platform.</em><br />
          End to end.
        </h2>
        <p class="nv-services__lead">From the first ghost-written post to a fully running paid pipeline. Pick the lane that fits your moment, or run all three.</p>
      </header>

      <div class="nv-services__shell" data-tabs>
        <div class="nv-services__nav" role="tablist" aria-label="Service lanes">
          {services.map((s, i) => (
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              class={`nv-services__tab nv-services__tab--${s.key} ${i === 0 ? 'is-active' : ''}`}
              data-tab={s.key}
              id={`nv-tab-${s.key}`}
              aria-controls={`nv-panel-${s.key}`}
              tabindex={i === 0 ? 0 : -1}
            >
              <span class="nv-services__tab-pip" aria-hidden="true"></span>
              <span class="nv-services__tab-label">{s.title}</span>
              <span class="nv-services__tab-count">{s.items.length} {s.items.length === 1 ? 'service' : 'services'}</span>
            </button>
          ))}
          <span class="nv-services__tab-indicator" aria-hidden="true"></span>
        </div>

        <div class="nv-services__panels">
          {services.map((s, i) => (
            <div
              class={`nv-services__panel nv-services__panel--${s.key} ${i === 0 ? 'is-active' : ''}`}
              role="tabpanel"
              id={`nv-panel-${s.key}`}
              aria-labelledby={`nv-tab-${s.key}`}
              data-panel={s.key}
              hidden={i !== 0}
            >
              <div class="nv-services__panel-grid">
                <div class="nv-services__panel-image">
                  <div class="nv-services__panel-frame">
                    <img src={s.image} alt={`${s.title} editorial`} loading="lazy" decoding="async" />
                    <div class={`nv-services__panel-tag nv-services__panel-tag--${s.key}`}>
                      <span>{s.title}</span>
                    </div>
                  </div>
                </div>

                <div class="nv-services__panel-content">
                  <p class="nv-services__panel-intro">{s.intro}</p>
                  <ul class="nv-services__list">
                    {s.items.map((it) => (
                      <li class="nv-services__item">
                        <span class={`nv-services__item-pip nv-services__item-pip--${s.key}`} aria-hidden="true"></span>
                        <span class="nv-services__item-text">
                          <span class="nv-services__item-name">{it.name}.</span>
                          <span class="nv-services__item-body">{it.body}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- HOW WE OPERATE                                                         -->
  <!-- ====================================================================== -->
  <section class="nv-operate">
    <div class="nv-operate__bg" aria-hidden="true"></div>
    <div class="container nv-operate__container">
      <span class="eyebrow eyebrow--on-dark">How we operate</span>
      <h2 class="nv-operate__title">
        <span class="nv-operate__line" data-line>LinkedIn is not a side channel.</span>
        <span class="nv-operate__line" data-line>Specialists beat generalists.</span>
        <span class="nv-operate__line" data-line>Activity is not the goal.</span>
      </h2>
      <div class="nv-operate__statement" data-line>
        <p>Content earns attention. Ads convert it.</p>
        <p class="nv-operate__emphasis">Qualified leads compound. Month after month.</p>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- FINAL CTA                                                              -->
  <!-- ====================================================================== -->
  <section class="nv-cta">
    <div class="nv-cta__bg" aria-hidden="true">
      <img src="/images/nuvora-hero-bg.webp" alt="" onerror="this.style.display='none'" />
      <div class="nv-cta__bg-scrim"></div>
    </div>
    <div class="container nv-cta__content">
      <span class="eyebrow eyebrow--on-dark">Ready when you are</span>
      <h2 class="nv-cta__title balance">More leads on LinkedIn.<br />From decision makers in your market.</h2>
      <div class="nv-cta__actions">
        <a class="btn btn--primary" href={visitUrl} target="_blank" rel="noreferrer">{visitLabel}</a>
        <a class="btn btn--ghost-light" href={pathFor('contact', locale)}>Talk to us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===================================================================== */
  /* HERO                                                                   */
  /* ===================================================================== */
  .nv-hero {
    position: relative;
    min-height: 88vh;
    padding: clamp(2.5rem, 5vh, 4rem) 0 clamp(3rem, 6vh, 5rem);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    background: #0a1428;
  }

  .nv-hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .nv-hero__bg-img {
    position: absolute;
    inset: -8% -4% -4% -4%;
    width: 108%;
    height: 112%;
    object-fit: cover;
    object-position: center 40%;
    will-change: transform;
    transform: translate3d(0, var(--parallax-y, 0), 0) scale(1.04);
    filter: saturate(0.85) contrast(1.05) brightness(0.78);
  }
  .nv-hero__bg-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(8, 14, 32, 0.86) 0%, rgba(8, 14, 32, 0.62) 38%, rgba(8, 14, 32, 0.30) 65%, rgba(8, 14, 32, 0.55) 100%),
      linear-gradient(180deg, rgba(8, 14, 32, 0.55) 0%, rgba(8, 14, 32, 0.05) 30%, rgba(8, 14, 32, 0.0) 60%, rgba(8, 14, 32, 0.85) 100%);
  }
  .nv-hero__bg-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1200px 600px at 20% 30%, rgba(89, 194, 238, 0.22), transparent 65%),
      radial-gradient(900px 500px at 90% 80%, rgba(10, 102, 194, 0.18), transparent 70%);
    mix-blend-mode: screen;
  }
  .nv-hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 30%, transparent 80%);
    opacity: 0.7;
  }

  .nv-hero__main {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .nv-hero__content { min-width: 0; max-width: 36rem; }
  .nv-hero__logo {
    display: block;
    width: auto;
    height: 36px;
    filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.4));
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: nvFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.1s forwards;
  }

  .nv-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: nvFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.2s forwards;
  }
  .nv-hero__eyebrow-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34,197,94,0.5);
    animation: nvPulse 2.4s ease-in-out infinite;
  }

  .nv-hero__title {
    font-size: clamp(2.5rem, 5vw + 0.5rem, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 600;
    color: #fff;
    margin: 0 0 var(--space-5);
    max-width: 16ch;
    text-wrap: balance;
  }
  .nv-hero__line {
    display: block;
    overflow: hidden;
  }
  .nv-hero__line[data-anim="word"] {
    transform: translateY(110%);
    opacity: 0;
    animation: nvWordIn 880ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
  }
  .nv-hero__line[data-anim="word"]:nth-child(1) { animation-delay: 0.30s; }
  .nv-hero__line[data-anim="word"]:nth-child(2) { animation-delay: 0.42s; }
  .nv-hero__line[data-anim="word"]:nth-child(3) { animation-delay: 0.54s; }
  @keyframes nvWordIn {
    from { transform: translateY(110%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .nv-hero__phrase {
    font-style: normal;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    position: relative;
  }
  .nv-hero__phrase--buyers    { background-image: linear-gradient(120deg, #59c2ee 0%, #269ada 60%, #59c2ee 100%); }
  .nv-hero__phrase--hires     { background-image: linear-gradient(120deg, #5ec8d8 0%, #0a66c2 60%, #5ec8d8 100%); }
  .nv-hero__phrase--investors { background-image: linear-gradient(120deg, #8ddff0 0%, #064a8c 60%, #8ddff0 100%); }

  .nv-hero__lead {
    max-width: 44ch;
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.2rem);
    color: rgba(255,255,255,0.82);
    margin: 0 0 var(--space-5);
    opacity: 0;
    animation: nvFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 0.85s forwards;
  }

  .nv-hero__cta-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0;
    animation: nvFadeIn 700ms cubic-bezier(0.2,0.8,0.2,1) 1s forwards;
  }

  .nv-magnet {
    --x: 0px; --y: 0px;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 16px 26px 16px 28px;
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    isolation: isolate;
    transition: transform 220ms cubic-bezier(0.2,0.8,0.2,1);
    transform: translate(var(--x), var(--y));
  }
  .nv-magnet__bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, #0a66c2 0%, #064a8c 100%);
    box-shadow: 0 16px 36px -10px rgba(10,102,194,0.55), inset 0 1px 0 rgba(255,255,255,0.2);
    z-index: -1;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .nv-magnet:hover .nv-magnet__bg { transform: scale(1.04); }
  .nv-magnet__arrow {
    display: inline-block;
    transform: translateX(0);
    transition: transform 280ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .nv-magnet:hover .nv-magnet__arrow { transform: translateX(4px); }

  .nv-hero__secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.92);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .nv-hero__secondary svg { transition: transform 220ms ease; }
  .nv-hero__secondary:hover { color: #59c2ee; }
  .nv-hero__secondary:hover svg { transform: translateX(3px); }

  /* Browser preview with parallax tilt */
  .nv-hero__preview {
    position: relative;
    perspective: 1600px;
    min-width: 0;
    opacity: 0;
    animation: nvFadeIn 900ms cubic-bezier(0.2,0.8,0.2,1) 0.5s forwards;
  }
  .nv-hero__preview-frame {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(var(--tilt-x, -3deg)) rotateX(var(--tilt-y, 2deg));
    transition: transform 600ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .browser-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 14px;
    transition: transform 320ms cubic-bezier(0.2,0.8,0.2,1);
  }
  .browser-link:hover { transform: translateY(-2px); }
  .browser-link:focus-visible { outline: 2px solid #fff; outline-offset: 4px; }
  .browser-link:hover .browser__visit { opacity: 1; transform: translateY(0); }
  .browser {
    position: relative;
    background: #ffffff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 40px 80px -28px rgba(0,0,0,0.55),
      0 12px 28px -8px rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.10);
    transform: translateZ(0);
  }
  .browser__visit {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(15,23,42,0.85);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 240ms ease, transform 240ms cubic-bezier(0.2,0.8,0.2,1);
    pointer-events: none;
  }
  .browser__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 10px 14px;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f6 100%);
    border-bottom: 1px solid rgba(15,23,42,0.08);
  }
  .browser__dots { display: inline-flex; gap: 6px; }
  .browser__dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .browser__dot--r { background: #ff5f57; }
  .browser__dot--y { background: #febc2e; }
  .browser__dot--g { background: #28c840; }
  .browser__url {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--bbg-text-muted);
    background: rgba(15,23,42,0.04);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
    max-width: 320px;
    margin: 0 auto;
  }
  .browser__viewport {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #f7f9fb;
    overflow: hidden;
  }
  .browser__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .browser__live {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    background: rgba(8, 14, 32, 0.74);
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .browser__live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #22c55e;
