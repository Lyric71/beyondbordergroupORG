---
import Layout from '../../layouts/Layout.astro';
import AgencyLogo from '../../components/AgencyLogo.astro';
import { pathFor } from '../../i18n/ui';

const locale = 'en' as const;
const title = 'Seven agencies';
const description = 'BeyondBorderGroup is seven specialist agencies. Pick the one you need. Each one stands alone. Most clients start with one and add others as projects grow.';

const agencies = [
  {
    slug: 'beyondbordergroup',
    route: 'agencies/beyondbordergroup' as const,
    name: 'BeyondBorderGroup',
    badge: 'West to China · Full-service',
    body: 'Enter China, grow in China, learn China. Fifteen years on the ground running market entry, eCommerce, social commerce, media, PR, and masterclasses. We consult, and we run what we recommend.',
    fit: 'Brands who need one accountable team to enter or scale in China.',
    based: 'Shanghai. Hong Kong. Paris.',
  },
  {
    slug: 'theredscroll',
    route: 'agencies/theredscroll' as const,
    name: 'TheRedScroll',
    badge: 'West to China · Channel specialist',
    body: "Chinese social media run by people who open these apps every morning. WeChat, Douyin, RedNote, Weibo, and fourteen others. Strategy, content, paid, and influencers in one written scope, one number per package.",
    fit: 'International brands who need Chinese social run properly, with no scope creep.',
    based: 'Shanghai. Hong Kong.',
  },
  {
    slug: 'chinawebfoundry',
    route: 'agencies/chinawebfoundry' as const,
    name: 'ChinaWebFoundry',
    badge: 'West to China · Web infrastructure',
    body: "Websites built for the Chinese internet, not retrofitted to it. ICP filing, China hosting, Baidu and DeepSeek visibility, WeChat and Alipay checkout. Plan, build, find, run.",
    fit: 'Brands whose site needs to actually load, rank, and convert inside the Firewall.',
    based: 'Shanghai. Hangzhou.',
  },
  {
    slug: 'beyondcompass',
    route: 'agencies/beyondcompass' as const,
    name: 'BeyondCompass',
    badge: 'West to China · Partner sourcing',
    body: 'A private file of distributors, Tmall TPs, Douyin Partners, and importers we have actually met, vetted, and worked with. Shortlist, market map, or replacement, with warm introductions and an honest verdict on every name.',
    fit: 'Brands choosing a China partner for the first time, or unwinding the wrong one.',
    based: 'Shanghai. Twenty years of on-ground vetting.',
  },
  {
    slug: 'beyondbridge',
    route: 'agencies/beyondbridge' as const,
    name: 'BeyondBridge',
    badge: 'China to West · Full pipeline',
    body: 'The full overseas pipeline for Chinese companies. Brand, website, LinkedIn, SEO and GEO, Google Ads, and native sales reps in seven countries. One stack, one pipeline, real people taking the call.',
    fit: 'Chinese companies tired of trade-show booths that close nothing.',
    based: 'China HQ. Reps in Paris, Munich, Milan, London, New York, Sydney, São Paulo.',
  },
  {
    slug: 'hubstudio',
    route: 'agencies/hubstudio' as const,
    name: 'HubStudio',
    badge: 'Horizontal · Content production',
    body: 'A production house built for what content has become. Image, video, 3D, plus a brand-trained platform on dedicated GPUs. Hundreds of on-brand assets a month. Real shoots when the brief calls for it.',
    fit: 'Brands, retailers, and agencies that need content at scale without losing the brand.',
    based: 'Shanghai studio. Global delivery.',
  },
  {
    slug: 'nuvora-studio',
    route: 'agencies/nuvora-studio' as const,
    name: 'Nuvora Studio',
    badge: 'Horizontal · LinkedIn-only B2B',
    body: 'LinkedIn only, every day. Content, ads, executive personal branding, employee advocacy. Built to drive leads, not just likes.',
    fit: 'B2B companies whose buyers, hires, and investors all check LinkedIn.',
    based: 'Global.',
  },
];
---

<Layout locale={locale} route="agencies" title={title} description={description}>
  <section class="hero-editorial">
    <div class="container">
      <span class="eyebrow eyebrow--rule">Agencies</span>
      <h1 class="hero-editorial__title balance">Seven specialist agencies. One ecosystem.</h1>
      <p class="hero-editorial__lead">
        Each agency stands alone. Its own brand, its own pricing, its own deliverables. Pick the one that
        matches what you need. Most clients start with one, and pull in others as the project expands.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="grid-2">
        {agencies.map((a) => (
          <article class="card" style="gap: var(--space-4);">
            <div style="display: flex; gap: var(--space-4); align-items: flex-start;">
              <AgencyLogo slug={a.slug} name={a.name} class="card__logo" />
            </div>
            <div class="card__meta">
              <span class="card__tag">{a.badge}</span>
            </div>
            <h2 class="card__title" style="font-size: var(--fs-h3);">{a.name}</h2>
            <p>{a.body}</p>
            <p class="muted"><strong>For:</strong> {a.fit}</p>
            <p class="muted"><strong>Based:</strong> {a.based}</p>
            <div class="btn-row" style="margin-top: var(--space-3);">
              <a class="btn btn--primary btn--sm" href={pathFor(a.route, locale)}>Open agency page</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .card :global(.card__logo) {
    height: 64px;
    width: auto;
    max-width: 200px;
  }
</style>
