---
import Layout from '../layouts/Layout.astro';
import AgencyLogo from '../components/AgencyLogo.astro';
import { pathFor } from '../i18n/ui';

const locale = 'en' as const;
const title = 'Two flows';
const description = 'One bridge, two directions. The full inbound stack to enter or scale in China, and the full outbound pipeline for Chinese brands going overseas.';

const inboundReq = [
  {
    icon: 'badge',
    h: 'Brand that reads as quality to a Chinese audience',
    body: 'Trust signals up front. Certifications, partner logos, third-party validation. What looks cluttered in the West reads as serious in China.',
    pill: 'Density signals quality',
  },
  {
    icon: 'channels',
    h: 'Channels Chinese consumers actually use',
    body: 'WeChat for trust. RedNote for the shortlist. Douyin for discovery. Weibo for reach. Each one needs its own format and its own team.',
    pill: 'Four stacks, not one',
  },
  {
    icon: 'server',
    h: 'Web infrastructure built behind the Firewall',
    body: 'ICP-licensed hosting on Aliyun, Tencent or Huawei. A site Baidu can index. Mobile-first by force, not by trend.',
    pill: '95%+ mobile traffic',
  },
  {
    icon: 'search',
    h: 'Search visibility in the engines Chinese buyers use',
    body: 'Baidu still owns over half the search market. Google sits under three percent. Under-35s are skipping search entirely for AI: DeepSeek, Doubao, Kimi, Yuanbao.',
    pill: 'Baidu > 50% · Google < 3%',
  },
  {
    icon: 'cart',
    h: 'Commerce where the buying actually happens',
    body: 'Tmall, JD, Douyin Shop, RED, plus social commerce on WeChat. eCommerce and social are the same surface, not separate funnels.',
    pill: 'Social = commerce',
  },
];

const inboundAgencies = [
  {
    name: 'BeyondBorderGroup',
    role: 'The full-service operator',
    body: 'Twenty years on the ground. Branding, eCommerce, distribution. One accountable team.',
    route: 'agencies/beyondbordergroup' as const,
  },
  {
    name: 'TheRedScroll',
    role: 'The social media specialist',
    body: 'WeChat, Douyin, RedNote, Weibo, plus 14 more. Fixed scope, fixed price, two-week onboarding.',
    route: 'agencies/theredscroll' as const,
  },
  {
    name: 'ChinaWebFoundry',
    role: 'The web infrastructure specialist',
    body: 'ICP-licensed hosting, Baidu SEO, mobile-first UX, GEO for Chinese AI engines.',
    route: 'agencies/chinawebfoundry' as const,
  },
  {
    name: 'BeyondCompass',
    role: 'The distributor and TP database',
    body: 'A private database of vetted China distributors, Tmall TPs, and Douyin partners.',
    route: 'agencies/beyondcompass' as const,
  },
  {
    name: 'HubStudio',
    role: 'The AIGC content engine for China',
    body: 'AIGC production for Chinese audiences at the volume RedNote, Douyin and WeChat demand.',
    route: 'agencies/hubstudio' as const,
  },
];

const outboundReq = [
  {
    icon: 'badge',
    h: 'A brand Western buyers recognise',
    body: 'Not translated from China. Names that work, claims that do not read off, a visual identity that lands in Frankfurt and Chicago without an asterisk.',
    pill: 'Built, not translated',
  },
  {
    icon: 'channels',
    h: 'Presence on LinkedIn',
    body: 'Western B2B opens LinkedIn before the call. Empty page, no call. Buyers trust companies more when executives post.',
    pill: '82% trust execs who post',
  },
  {
    icon: 'monitor',
    h: 'A website built for Western eyes',
    body: 'Clean. Spacious. One action per page. Hosted outside China. Fast: three seconds costs you over half your visitors.',
    pill: '3s load = -50% visitors',
  },
  {
    icon: 'search',
    h: 'Search visibility in Western engines',
    body: 'Google rankings, plus citations in ChatGPT, Perplexity and Gemini. Competitors already own the answers.',
    pill: 'Google + ChatGPT + AI',
  },
  {
    icon: 'megaphone',
    h: 'Page-one search ads',
    body: 'Google Ads while SEO compounds. Western landing pages, not translated ones. Right keywords, right geography.',
    pill: 'Page one, day one',
  },
  {
    icon: 'globe',
    h: 'Sales reps in the right time zone',
    body: 'A buyer in Germany writes at 10am Berlin. Shenzhen is asleep. By morning, three competitors already replied.',
    pill: 'First reply wins',
  },
];

---

<Layout locale={locale} route="two-flows" title={title} description={description}>
  <section class="page-hero">
    <div class="page-hero__bg" aria-hidden="true">
      <svg viewBox="0 0 1600 760" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
        <defs>
          <linearGradient id="page-cable" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#269ada" stop-opacity="0.95" />
            <stop offset="50%" stop-color="#f4f1e6" stop-opacity="0.9" />
            <stop offset="100%" stop-color="#c8102e" stop-opacity="0.95" />
          </linearGradient>
          <radialGradient id="page-glow-w" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#269ada" stop-opacity="0.30" />
            <stop offset="100%" stop-color="#269ada" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="page-glow-e" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#c8102e" stop-opacity="0.28" />
            <stop offset="100%" stop-color="#c8102e" stop-opacity="0" />
          </radialGradient>
        </defs>

        <ellipse cx="280" cy="500" rx="560" ry="220" fill="url(#page-glow-w)" />
        <ellipse cx="1320" cy="500" rx="560" ry="220" fill="url(#page-glow-e)" />

        <line x1="0" y1="500" x2="1600" y2="500" stroke="rgba(255,255,255,0.06)" stroke-width="1" />
        <line x1="0" y1="518" x2="1600" y2="518" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="0" y1="538" x2="1600" y2="538" stroke="rgba(255,255,255,0.025)" stroke-width="1" />

        <path class="page-hero__cable" d="M 220 500 Q 800 110 1380 500" fill="none" stroke="url(#page-cable)" stroke-width="2" stroke-linecap="round" />

        <g stroke="rgba(255,255,255,0.18)" stroke-width="1">
          <line x1="320" y1="500" x2="320" y2="396" />
          <line x1="440" y1="500" x2="440" y2="320" />
          <line x1="560" y1="500" x2="560" y2="262" />
          <line x1="680" y1="500" x2="680" y2="222" />
          <line x1="800" y1="500" x2="800" y2="208" />
          <line x1="920" y1="500" x2="920" y2="222" />
          <line x1="1040" y1="500" x2="1040" y2="262" />
          <line x1="1160" y1="500" x2="1160" y2="320" />
          <line x1="1280" y1="500" x2="1280" y2="396" />
        </g>

        <g>
          <line x1="220" y1="240" x2="220" y2="500" stroke="rgba(38,154,218,0.55)" stroke-width="2" />
          <line x1="1380" y1="240" x2="1380" y2="500" stroke="rgba(200,16,46,0.55)" stroke-width="2" />
          <circle class="page-hero__dot page-hero__dot--w" cx="220" cy="500" r="5" fill="#269ada" />
          <circle class="page-hero__dot page-hero__dot--e" cx="1380" cy="500" r="5" fill="#c8102e" />
        </g>

        <text x="220" y="555" text-anchor="middle" fill="rgba(38,154,218,0.85)" font-family="Inter, sans-serif" font-size="12" letter-spacing="3">WEST</text>
        <text x="1380" y="555" text-anchor="middle" fill="rgba(200,16,46,0.85)" font-family="Inter, sans-serif" font-size="12" letter-spacing="3">CHINA</text>
      </svg>
    </div>
    <div class="page-hero__scrim" aria-hidden="true"></div>
    <div class="container page-hero__content">
      <span class="eyebrow eyebrow--on-dark eyebrow--rule">Two directions</span>
      <h1 class="page-hero__title balance">
        One bridge. <span class="page-hero__accent">Two flows.</span>
      </h1>
      <p class="page-hero__lead">
        Whichever way you are going, we have already done the work on both sides. Pick the side of the bridge you are coming from.
      </p>
      <div class="page-hero__jumps">
        <a class="page-hero__jump" href="#inbound">
          <span class="page-hero__jump-name">Inbound</span>
          <span class="page-hero__jump-meta">West to China</span>
        </a>
        <a class="page-hero__jump page-hero__jump--alt" href="#outbound">
          <span class="page-hero__jump-name">Outbound</span>
          <span class="page-hero__jump-meta">China to the West</span>
        </a>
      </div>
    </div>
  </section>

  <section id="inbound" class="entry-hero entry-hero--inbound">
    <div class="entry-hero__bg" aria-hidden="true">
      <svg viewBox="0 0 1600 720" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
        <defs>
          <radialGradient id="entry-glow-w" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#269ada" stop-opacity="0.34" />
            <stop offset="100%" stop-color="#269ada" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="entry-glow-e" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#c8102e" stop-opacity="0.32" />
            <stop offset="100%" stop-color="#c8102e" stop-opacity="0" />
          </radialGradient>
          <pattern id="entry-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="1.5" cy="1.5" r="1.5" fill="rgba(255,255,255,0.10)" />
          </pattern>
          <linearGradient id="entry-stream" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#269ada" stop-opacity="0" />
            <stop offset="50%" stop-color="#269ada" stop-opacity="0.85" />
            <stop offset="100%" stop-color="#c8102e" stop-opacity="0" />
          </linearGradient>
        </defs>

        <ellipse cx="220" cy="380" rx="540" ry="240" fill="url(#entry-glow-w)" />
        <ellipse cx="1380" cy="380" rx="540" ry="240" fill="url(#entry-glow-e)" />

        <rect x="0" y="0" width="1600" height="720" fill="url(#entry-grid)" />

        <g class="entry-hero__nodes" stroke="rgba(255,255,255,0.18)" fill="none" stroke-width="1">
          <circle cx="900" cy="180" r="3" fill="rgba(38,154,218,0.9)" stroke="none" />
          <circle cx="1080" cy="260" r="3" fill="rgba(255,255,255,0.6)" stroke="none" />
          <circle cx="1240" cy="200" r="3" fill="rgba(200,16,46,0.9)" stroke="none" />
          <circle cx="1140" cy="380" r="3" fill="rgba(255,255,255,0.6)" stroke="none" />
          <circle cx="980" cy="340" r="3" fill="rgba(38,154,218,0.7)" stroke="none" />
          <circle cx="1320" cy="320" r="3" fill="rgba(255,255,255,0.5)" stroke="none" />
          <line x1="900" y1="180" x2="1080" y2="260" />
          <line x1="1080" y1="260" x2="1240" y2="200" />
          <line x1="1080" y1="260" x2="1140" y2="380" />
          <line x1="980" y1="340" x2="1140" y2="380" />
          <line x1="1140" y1="380" x2="1320" y2="320" />
        </g>

        <path class="entry-hero__stream" d="M 80 420 Q 800 280 1520 420" fill="none" stroke="url(#entry-stream)" stroke-width="2" stroke-linecap="round" />
      </svg>
    </div>
    <div class="entry-hero__scrim" aria-hidden="true"></div>
    <div class="container entry-hero__content">
      <span class="eyebrow eyebrow--on-dark eyebrow--rule">Flow 1 · Inbound · West to China</span>
      <h2 class="entry-hero__title balance">
        You have a brand. China has 1.1 billion internet users. Closing that gap is not a translation job.
      </h2>
      <p class="entry-hero__lead">
        The Chinese internet runs on its own stack. Different platforms, different search engines, different
        infrastructure, different content density, different buyer signals. We have been working inside it for
        twenty years.
      </p>
      <div class="entry-hero__chips">
        <span class="entry-hero__chip">WeChat</span>
        <span class="entry-hero__chip">RedNote</span>
        <span class="entry-hero__chip">Douyin</span>
        <span class="entry-hero__chip">Weibo</span>
        <span class="entry-hero__chip">Tmall</span>
        <span class="entry-hero__chip">JD</span>
        <span class="entry-hero__chip">Baidu</span>
        <span class="entry-hero__chip">DeepSeek</span>
      </div>
    </div>
  </section>

  <section class="section req-section">
    <div class="req-section__bg" aria-hidden="true">
      <span class="req-section__blob req-section__blob--w"></span>
      <span class="req-section__blob req-section__blob--e"></span>
    </div>
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What it actually takes</span>
        <h2 class="balance">Five surfaces. One Chinese internet.</h2>
        <p class="lead">A landing in China is five different jobs running at once. Each surface has its own logic, its own tempo, and its own tax for getting it wrong.</p>
      </header>

      <ol class="req-grid" role="list">
        {inboundReq.map((r, i) => (
          <li class="req-card" style={`--i: ${i};`}>
            <div class="req-card__inner">
              <span class="req-card__icon" aria-hidden="true">
                {r.icon === 'badge' && (
                  <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4l3 5 6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1 3-5z" />
                  </svg>
                )}
                {r.icon === 'channels' && (
                  <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="6" width="10" height="10" rx="2" />
                    <rect x="18" y="6" width="10" height="10" rx="2" />
                    <rect x="4" y="18" width="10" height="10" rx="2" />
                    <rect x="18" y="18" width="10" height="10" rx="2" />
                  </svg>
                )}
                {r.icon === 'server' && (
                  <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="5" y="6" width="22" height="8" rx="2" />
                    <rect x="5" y="18" width="22" height="8" rx="2" />
                    <circle cx="9" cy="10" r="0.8" fill="currentColor" />
                    <circle cx="9" cy="22" r="0.8" fill="currentColor" />
                    <line x1="13" y1="10" x2="22" y2="10" />
                    <line x1="13" y1="22" x2="22" y2="22" />
                  </svg>
                )}
                {r.icon === 'search' && (
                  <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="14" cy="14" r="8" />
                    <line x1="20" y1="20" x2="27" y2="27" />
                    <path d="M10 14 L13 17 L18 12" />
                  </svg>
                )}
                {r.icon === 'cart' && (
                  <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 7h3l3 14h12l3-10H10" />
                    <circle cx="13" cy="26" r="1.6" />
                    <circle cx="23" cy="26" r="1.6" />
                  </svg>
                )}
              </span>
              <h3 class="req-card__title">{r.h}</h3>
              <p class="req-card__body">{r.body}</p>
              <span class="req-card__pill">{r.pill}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section section--alt agency-section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Five specialists. One flow.</span>
        <h2 class="balance">Pick the whole stack, or pick the piece.</h2>
        <p class="lead">Five independent teams cover the inbound stack end to end. Hire one. Hire two. Hire all five. They share a spine.</p>
      </header>
      <div class="agency-rail" data-stagger>
        {inboundAgencies.map((a, i) => (
          <a class="agency-tile" href={pathFor(a.route, locale)} style={`--i: ${i};`}>
            <span class="agency-tile__logo">
              <AgencyLogo route={a.route} name={a.name} class="agency-card-logo" />
            </span>
            <span class="agency-tile__role">{a.role}</span>
            <h3 class="agency-tile__name">{a.name}</h3>
            <p class="agency-tile__body">{a.body}</p>
            <span class="agency-tile__cta">Visit
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section openings-section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">How clients usually start</span>
        <h2 class="balance">Six typical openings.</h2>
        <p class="lead">Most projects start as one sentence. Pick the one closest to yours.</p>
      </header>
      <div class="openings" data-stagger>
        <a class="opening" href={pathFor('agencies/chinawebfoundry', locale)} style="--i: 0;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">I just need a Chinese website that actually works.</p>
          <div class="opening__answer">
            <span class="opening__by">ChinaWebFoundry</span>
            <span class="opening__line">Six-week migration. ICP filed. Baidu-indexable.</span>
          </div>
        </a>
        <a class="opening" href={pathFor('agencies/theredscroll', locale)} style="--i: 1;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">I need to be on RedNote and Douyin in 90 days.</p>
          <div class="opening__answer">
            <span class="opening__by">TheRedScroll</span>
            <span class="opening__line">Two-week onboarding. First content live in a fortnight.</span>
          </div>
        </a>
        <a class="opening" href={pathFor('agencies/beyondbordergroup', locale)} style="--i: 2;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">I need everything: brand, channels, eCommerce, KOLs.</p>
          <div class="opening__answer">
            <span class="opening__by">BeyondBorderGroup</span>
            <span class="opening__line">Full-service entry. Twenty-year playbook.</span>
          </div>
        </a>
        <a class="opening" href={pathFor('agencies/beyondcompass', locale)} style="--i: 3;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">We need a distributor in China asap.</p>
          <div class="opening__answer">
            <span class="opening__by">BeyondCompass</span>
            <span class="opening__line">A vetted shortlist of distributors and TPs in days, not months.</span>
          </div>
        </a>
        <a class="opening" href={pathFor('agencies/hubstudio', locale)} style="--i: 4;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">Our content does not resonate with Chinese audiences.</p>
          <div class="opening__answer">
            <span class="opening__by">HubStudio</span>
            <span class="opening__line">AIGC content rebuilt for Chinese readers, at the volume the channels demand.</span>
          </div>
        </a>
        <a class="opening opening--cta" href={pathFor('contact', locale)} style="--i: 5;">
          <span class="opening__quote-mark" aria-hidden="true">&#8220;</span>
          <p class="opening__quote">I am not sure where to start.</p>
          <div class="opening__answer">
            <span class="opening__by">Book a call</span>
            <span class="opening__line">Thirty minutes. We tell you which agency, and what 90 days look like.</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section id="outbound" class="entry-hero entry-hero--outbound">
    <div class="entry-hero__bg" aria-hidden="true">
      <svg viewBox="0 0 1600 720" preserveAspectRatio="xMidYMid slice" role="img" aria-hidden="true">
        <defs>
          <radialGradient id="out-glow-e" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#c8102e" stop-opacity="0.34" />
            <stop offset="100%" stop-color="#c8102e" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="out-glow-w" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#269ada" stop-opacity="0.32" />
            <stop offset="100%" stop-color="#269ada" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="out-stream" x1="1" x2="0" y1="0" y2="0">
            <stop offset="0%" stop-color="#c8102e" stop-opacity="0" />
            <stop offset="50%" stop-color="#f4f1e6" stop-opacity="0.85" />
            <stop offset="100%" stop-color="#269ada" stop-opacity="0" />
          </linearGradient>
        </defs>

        <ellipse cx="1380" cy="380" rx="540" ry="240" fill="url(#out-glow-e)" />
        <ellipse cx="220" cy="380" rx="540" ry="240" fill="url(#out-glow-w)" />

        <g class="entry-hero__lines" stroke="rgba(255,255,255,0.06)" stroke-width="1">
          <line x1="0" y1="180" x2="1600" y2="180" />
          <line x1="0" y1="260" x2="1600" y2="260" />
          <line x1="0" y1="340" x2="1600" y2="340" />
          <line x1="0" y1="420" x2="1600" y2="420" />
          <line x1="0" y1="500" x2="1600" y2="500" />
        </g>

        <g class="entry-hero__nodes" fill="none">
          <circle cx="180" cy="220" r="3" fill="rgba(38,154,218,0.9)" />
          <circle cx="320" cy="280" r="3" fill="rgba(255,255,255,0.65)" />
          <circle cx="460" cy="220" r="3" fill="rgba(255,255,255,0.55)" />
          <circle cx="600" cy="320" r="3" fill="rgba(38,154,218,0.7)" />
        </g>

        <path class="entry-hero__stream" d="M 1520 420 Q 800 280 80 420" fill="none" stroke="url(#out-stream)" stroke-width="2" stroke-linecap="round" />
      </svg>
    </div>
    <div class="entry-hero__scrim" aria-hidden="true"></div>
    <div class="container entry-hero__content">
      <span class="eyebrow eyebrow--on-dark eyebrow--rule">Flow 2 · Outbound · China to the West</span>
      <h2 class="entry-hero__title balance">
        Great product. Great price. Great factory. No pipeline overseas.
      </h2>
      <p class="entry-hero__lead">
        Every Chinese B2B and services company going overseas hits the same wall. The brand was built for
        Chinese buyers. The website reads as cluttered to Western eyes. The LinkedIn page is empty. And nobody
        is answering the inquiry from Berlin at 10am local time. B2B and services are where we focus, and we
        have been building the other side of that bridge for twenty years.
      </p>
      <div class="entry-hero__chips">
        <span class="entry-hero__chip">LinkedIn</span>
        <span class="entry-hero__chip">Google</span>
        <span class="entry-hero__chip">ChatGPT</span>
        <span class="entry-hero__chip">Perplexity</span>
        <span class="entry-hero__chip">Gemini</span>
        <span class="entry-hero__chip">US</span>
        <span class="entry-hero__chip">UK</span>
        <span class="entry-hero__chip">DE</span>
        <span class="entry-hero__chip">FR</span>
      </div>
    </div>
  </section>

