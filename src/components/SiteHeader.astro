---
import { type Locale, pathFor, t, localeNames } from '../i18n/ui';
import AgencyLogo from './AgencyLogo.astro';
import LocaleFlag from './LocaleFlag.astro';

const langs: Locale[] = ['en', 'fr', 'es', 'de', 'zh'];

interface Props {
  locale: Locale;
  current?: string;
}

const { locale, current } = Astro.props;
const ui = t(locale);

const ourWay = [
  { route: 'bridge' as const, label: ui.nav.bridge, desc: ui.nav.bridgeItemDesc, mod: 'bridge' as const },
  { route: 'two-flows' as const, label: ui.nav.flowsLabel, desc: ui.nav.flowsItemDesc, mod: 'flows' as const },
  { route: 'how-we-work-together' as const, label: ui.nav.howWeWork, desc: ui.nav.howWeWorkItemDesc, mod: 'method' as const },
];

const agencies = [
  { route: 'agencies/beyondbordergroup' as const, title: 'BeyondBorderGroup', desc: ui.nav.agencyDescs.beyondbordergroup },
  { route: 'agencies/theredscroll' as const, title: 'TheRedScroll', desc: ui.nav.agencyDescs.theredscroll },
  { route: 'agencies/chinawebfoundry' as const, title: 'ChinaWebFoundry', desc: ui.nav.agencyDescs.chinawebfoundry },
  { route: 'agencies/beyondcompass' as const, title: 'BeyondCompass', desc: ui.nav.agencyDescs.beyondcompass },
  { route: 'agencies/beyondbridge' as const, title: 'BeyondBridge', desc: ui.nav.agencyDescs.beyondbridge },
  { route: 'agencies/hubstudio' as const, title: 'HubStudio', desc: ui.nav.agencyDescs.hubstudio },
  { route: 'agencies/nuvora-studio' as const, title: 'Nuvora Studio', desc: ui.nav.agencyDescs.nuvoraStudio },
];

const ourWayDesc = ui.nav.ourWayDesc;
const agenciesDesc = ui.nav.agenciesDesc;

const ourWayRoutes: string[] = ['bridge', 'two-flows', 'entering-china', 'going-overseas', 'how-we-work-together'];
const isOurWayActive = !!current && ourWayRoutes.includes(current);
const isAgenciesActive = !!current && (current === 'agencies' || current.startsWith('agencies/'));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={pathFor('home', locale)} class="brand" aria-label="BeyondBorderGroup">
      <img
        src="/Logo Beyond SVG Export - Horizonthal.svg"
        alt="BeyondBorderGroup"
        class="brand__logo"
        width="1448"
        height="563"
      />
    </a>

    <nav class="nav-primary" aria-label="Primary">
      <ul class="nav-primary__list">
        <li class="nav-item nav-item--mega">
          <a class="nav-primary__link" href={pathFor('bridge', locale)} aria-haspopup="true" aria-current={isOurWayActive ? 'page' : undefined}>
            {ui.nav.ourWay}
            <svg class="nav-chev" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 4.5l3 3 3-3" />
            </svg>
          </a>
          <div class="mega" role="menu" aria-label={ui.nav.ourWay}>
            <div class="container mega__grid">
              <div class="mega__lead">
                <div class="mega__lead-text">
                  <h3>{ui.nav.ourWay}</h3>
                  <p>{ourWayDesc}</p>
                </div>
                <span class="mega__lead-meta"><span class="dot" aria-hidden="true"></span>{ui.nav.ourWayMeta}</span>
              </div>
              <div class="mega__items">
                {ourWay.map((f, i) => (
                  <a class={`mega-item mega-item--with-icon mega-item--${f.mod}`} href={pathFor(f.route, locale)} style={`--i: ${i}`}>
                    <span class="mega-item__icon" aria-hidden="true">
                      {f.route === 'bridge' && (
                        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M3 23h26" />
                          <path d="M6 23v-6" />
                          <path d="M26 23v-6" />
                          <path d="M6 17c4 0 5.5-3 10-3s6 3 10 3" />
                          <path d="M11 23v-3" />
                          <path d="M16 23v-4" />
                          <path d="M21 23v-3" />
                        </svg>
                      )}
                      {f.route === 'two-flows' && (
                        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 12h22" />
                          <path d="M19 6l7 6-7 6" />
                          <path d="M28 20H6" />
                          <path d="M13 14l-7 6 7 6" />
                        </svg>
                      )}
                      {f.route === 'how-we-work-together' && (
                        <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="13" cy="16" r="6" />
                          <circle cx="19" cy="16" r="6" />
                        </svg>
                      )}
                    </span>
                    <span class="mega-item__title">{f.label}</span>
                    <span class="mega-item__desc">{f.desc}</span>
                    <svg class="mega-item__arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M3 8h10" />
                      <path d="M9 4l4 4-4 4" />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item nav-item--mega">
          <a class="nav-primary__link" href={pathFor('agencies', locale)} aria-haspopup="true" aria-current={isAgenciesActive ? 'page' : undefined}>
            {ui.nav.agencies}
            <svg class="nav-chev" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 4.5l3 3 3-3" />
            </svg>
          </a>
          <div class="mega" role="menu" aria-label={ui.nav.agencies}>
            <div class="container mega__grid">
              <div class="mega__lead">
                <div class="mega__lead-text">
                  <h3>{ui.nav.agencies}</h3>
                  <p>{agenciesDesc}</p>
                </div>
                <span class="mega__lead-meta"><span class="dot" aria-hidden="true"></span>{ui.nav.specialistStudios(agencies.length)}</span>
              </div>
              <div class="mega__items mega__items--agencies">
                {agencies.map((a, i) => (
                  <a class="mega-item mega-item--with-logo" href={pathFor(a.route, locale)} style={`--i: ${i}`}>
                    <span class="mega-item__logo">
                      <AgencyLogo route={a.route} name={a.title} />
                    </span>
                    <span class="mega-item__desc">{a.desc}</span>
                    <svg class="mega-item__arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M3 8h10" />
                      <path d="M9 4l4 4-4 4" />
                    </svg>
                  </a>
                ))}
              </div>
              <div class="mega__footer">
                <span>{ui.nav.agenciesStandAlone}</span>
                <a class="mega__footer-link" href={pathFor('agencies', locale)}>
                  {ui.nav.viewAllAgencies}
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 8h10" />
                    <path d="M9 4l4 4-4 4" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </li>
      </ul>
    </nav>

    <div class="nav-right">
      <span class="lang-switch" aria-label="Language">
        {langs.map((l) => (
          <a
            href={pathFor((current as any) ?? 'home', l)}
            aria-current={locale === l}
            aria-label={localeNames[l]}
            title={localeNames[l]}
          >
            <LocaleFlag locale={l} />
          </a>
        ))}
      </span>
      <a href={pathFor('contact', locale)} class="btn btn--primary btn--sm nav-right__cta">{ui.nav.contact}</a>
      <button
        type="button"
        class="nav-toggle"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <div class="site-header__progress" aria-hidden="true"></div>
</header>

<nav id="mobile-menu" class="nav-mobile" aria-label="Mobile" hidden>
    <div class="container nav-mobile__inner">
      <ul class="nav-mobile__list">
        <li class="nav-mobile__section" style="--i: 0">
          <span class="nav-mobile__group">{ui.nav.ourWay}</span>
          <ul class="nav-mobile__sublist">
            {ourWay.map((f) => (
              <li><a class="nav-mobile__link" href={pathFor(f.route, locale)}>{f.label}</a></li>
            ))}
          </ul>
        </li>

        <li class="nav-mobile__section" style="--i: 1">
          <span class="nav-mobile__group">{ui.nav.agencies}</span>
          <ul class="nav-mobile__sublist">
            <li><a class="nav-mobile__link" href={pathFor('agencies', locale)}>{ui.nav.agencies}</a></li>
            {agencies.map((a) => (
              <li>
                <a class="nav-mobile__link nav-mobile__link--with-logo" href={pathFor(a.route, locale)}>
                  <span class="nav-mobile__logo"><AgencyLogo route={a.route} name={a.title} /></span>
                  <span>{a.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </li>

        <li style="--i: 2">
          <a class="nav-mobile__link nav-mobile__link--cta btn btn--primary" href={pathFor('contact', locale)}>{ui.nav.contact}</a>
        </li>
      </ul>

      <span class="lang-switch nav-mobile__lang" aria-label="Language">
        {langs.map((l) => (
          <a
            href={pathFor((current as any) ?? 'home', l)}
            aria-current={locale === l}
            aria-label={localeNames[l]}
            title={localeNames[l]}
          >
            <LocaleFlag locale={l} />
          </a>
        ))}
      </span>
    </div>
  </nav>

<div class="site-overlay" aria-hidden="true"></div>

<script>
  const headerEl = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('mobile-menu');

  // Header scroll state — glass intensity, compact mode, scroll-progress var
  if (headerEl) {
    let ticking = false;
    const updateScroll = () => {
      const y = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(1, Math.max(0, y / docHeight)) : 0;
      headerEl.classList.toggle('is-scrolled', y > 8);
      headerEl.style.setProperty('--scroll-progress', String(progress));
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(updateScroll);
          ticking = true;
        }
      },
      { passive: true }
    );
    updateScroll();
  }

  // Cursor spotlight on every mega card
  document.querySelectorAll<HTMLElement>('.mega-item').forEach((card) => {
    card.addEventListener('mousemove', (event) => {
      const rect = card.getBoundingClientRect();
      const mx = ((event.clientX - rect.left) / rect.width) * 100;
      const my = ((event.clientY - rect.top) / rect.height) * 100;
      card.style.setProperty('--mx', `${mx}%`);
      card.style.setProperty('--my', `${my}%`);
    });
  });

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.classList.toggle('is-open', open);
      menu.toggleAttribute('hidden', !open);
      document.body.classList.toggle('nav-open', open);
    };

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    // Close on link tap inside the drawer
    menu.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      if (target?.closest('a')) setOpen(false);
    });

    // Close on Escape
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // Close if window resizes back to desktop
    const mq = window.matchMedia('(min-width: 1025px)');
    mq.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
