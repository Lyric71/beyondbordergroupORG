---
import { type Locale, pathFor, t, localeShort } from '../i18n/ui';

interface Props {
  locale: Locale;
  current?: string;
}

const { locale, current } = Astro.props;
const ui = t(locale);

const flows = [
  { route: 'entering-china' as const, label: ui.nav.enteringChina, desc: 'West to China. Brand, channels, web, eCommerce.' },
  { route: 'going-overseas' as const, label: ui.nav.goingOverseas, desc: 'China to the West. Brand, LinkedIn, sales pipeline.' },
];

const agencies = [
  { route: 'agencies/beyondbordergroup' as const, title: 'BeyondBorderGroup', desc: 'Full-service China entry.' },
  { route: 'agencies/theredscroll' as const, title: 'TheRedScroll', desc: 'Chinese social media specialist.' },
  { route: 'agencies/chinawebfoundry' as const, title: 'ChinaWebFoundry', desc: 'Websites built for China.' },
  { route: 'agencies/beyondcompass' as const, title: 'BeyondCompass', desc: 'Vetted China distributors and TPs.' },
  { route: 'agencies/beyondbridge' as const, title: 'BeyondBridge', desc: 'Chinese brands, Western pipeline.' },
  { route: 'agencies/hubstudio' as const, title: 'HubStudio', desc: 'AIGC content production.' },
  { route: 'agencies/nuvora-studio' as const, title: 'Nuvora Studio', desc: 'LinkedIn-only B2B.' },
];

const flowsDesc = ui.nav.flowsDesc;
const agenciesDesc = ui.nav.agenciesDesc;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={pathFor('home', locale)} class="brand" aria-label="BeyondBorderGroup">
      <img
        src="/Logo Beyond SVG Export - Horizonthal.svg"
        alt="BeyondBorderGroup"
        class="brand__logo"
        width="1448"
        height="563"
      />
    </a>

    <nav class="nav-primary" aria-label="Primary">
      <ul class="nav-primary__list">
        <li class="nav-item">
          <a class="nav-primary__link" href={pathFor('bridge', locale)}>{ui.nav.bridge}</a>
        </li>

        <li class="nav-item nav-item--mega">
          <a class="nav-primary__link" href={pathFor('entering-china', locale)} aria-haspopup="true">
            {ui.nav.flowsLabel}
          </a>
          <div class="mega" role="menu" aria-label={ui.nav.flowsLabel}>
            <div class="container mega__grid">
              <div class="mega__lead">
                <h3>{ui.nav.flowsLabel}</h3>
                <p>{flowsDesc}</p>
              </div>
              <div class="mega__items">
                {flows.map((f) => (
                  <a class="mega-item" href={pathFor(f.route, locale)}>
                    <span class="mega-item__title">{f.label}</span>
                    <span class="mega-item__desc">{f.desc}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item nav-item--mega">
          <a class="nav-primary__link" href={pathFor('agencies', locale)} aria-haspopup="true">
            {ui.nav.agencies}
          </a>
          <div class="mega" role="menu" aria-label={ui.nav.agencies}>
            <div class="container mega__grid">
              <div class="mega__lead">
                <h3>{ui.nav.agencies}</h3>
                <p>{agenciesDesc}</p>
              </div>
              <div class="mega__items">
                {agencies.map((a) => (
                  <a class="mega-item" href={pathFor(a.route, locale)}>
                    <span class="mega-item__title">{a.title}</span>
                    <span class="mega-item__desc">{a.desc}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <li class="nav-item">
          <a class="nav-primary__link" href={pathFor('how-we-work-together', locale)}>{ui.nav.howWeWork}</a>
        </li>
      </ul>
    </nav>

    <div class="nav-right">
      <span class="lang-switch" aria-label="Language">
        <a href={pathFor((current as any) ?? 'home', 'en')} aria-current={locale === 'en'}>{localeShort.en}</a>
        <a href={pathFor((current as any) ?? 'home', 'fr')} aria-current={locale === 'fr'}>{localeShort.fr}</a>
        <a href={pathFor((current as any) ?? 'home', 'es')} aria-current={locale === 'es'}>{localeShort.es}</a>
        <a href={pathFor((current as any) ?? 'home', 'de')} aria-current={locale === 'de'}>{localeShort.de}</a>
        <a href={pathFor((current as any) ?? 'home', 'zh')} aria-current={locale === 'zh'}>{localeShort.zh}</a>
      </span>
      <a href={pathFor('contact', locale)} class="btn btn--primary btn--sm nav-right__cta">{ui.nav.contact}</a>
      <button
        type="button"
        class="nav-toggle"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="nav-mobile" aria-label="Mobile" hidden>
    <div class="container nav-mobile__inner">
      <ul class="nav-mobile__list">
        <li>
          <a class="nav-mobile__link" href={pathFor('bridge', locale)}>{ui.nav.bridge}</a>
        </li>

        <li class="nav-mobile__section">
          <span class="nav-mobile__group">{ui.nav.flowsLabel}</span>
          <ul class="nav-mobile__sublist">
            {flows.map((f) => (
              <li><a class="nav-mobile__link" href={pathFor(f.route, locale)}>{f.label}</a></li>
            ))}
          </ul>
        </li>

        <li class="nav-mobile__section">
          <span class="nav-mobile__group">{ui.nav.agencies}</span>
          <ul class="nav-mobile__sublist">
            <li><a class="nav-mobile__link" href={pathFor('agencies', locale)}>{ui.nav.agencies}</a></li>
            {agencies.map((a) => (
              <li><a class="nav-mobile__link" href={pathFor(a.route, locale)}>{a.title}</a></li>
            ))}
          </ul>
        </li>

        <li>
          <a class="nav-mobile__link" href={pathFor('how-we-work-together', locale)}>{ui.nav.howWeWork}</a>
        </li>
        <li>
          <a class="nav-mobile__link nav-mobile__link--cta btn btn--primary" href={pathFor('contact', locale)}>{ui.nav.contact}</a>
        </li>
      </ul>

      <span class="lang-switch nav-mobile__lang" aria-label="Language">
        <a href={pathFor((current as any) ?? 'home', 'en')} aria-current={locale === 'en'}>{localeShort.en}</a>
        <a href={pathFor((current as any) ?? 'home', 'fr')} aria-current={locale === 'fr'}>{localeShort.fr}</a>
        <a href={pathFor((current as any) ?? 'home', 'es')} aria-current={locale === 'es'}>{localeShort.es}</a>
        <a href={pathFor((current as any) ?? 'home', 'de')} aria-current={locale === 'de'}>{localeShort.de}</a>
        <a href={pathFor((current as any) ?? 'home', 'zh')} aria-current={locale === 'zh'}>{localeShort.zh}</a>
      </span>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.classList.toggle('is-open', open);
      menu.toggleAttribute('hidden', !open);
      document.body.classList.toggle('nav-open', open);
    };

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    // Close on link tap inside the drawer
    menu.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      if (target?.closest('a')) setOpen(false);
    });

    // Close on Escape
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // Close if window resizes back to desktop
    const mq = window.matchMedia('(min-width: 1025px)');
    mq.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>
