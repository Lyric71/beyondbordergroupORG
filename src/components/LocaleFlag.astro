---
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<svg
  class="flag"
  viewBox="0 0 24 16"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  preserveAspectRatio="xMidYMid slice"
>
  {locale === 'en' && (
    <>
      <rect width="24" height="16" fill="#B22234" />
      <g fill="#ffffff">
        <rect y="1.231" width="24" height="1.231" />
        <rect y="3.692" width="24" height="1.231" />
        <rect y="6.154" width="24" height="1.231" />
        <rect y="8.615" width="24" height="1.231" />
        <rect y="11.077" width="24" height="1.231" />
        <rect y="13.538" width="24" height="1.231" />
      </g>
      <rect width="9.6" height="8.615" fill="#3C3B6E" />
    </>
  )}

  {locale === 'fr' && (
    <>
      <rect width="8" height="16" fill="#0055A4" />
      <rect x="8" width="8" height="16" fill="#ffffff" />
      <rect x="16" width="8" height="16" fill="#EF4135" />
    </>
  )}

  {locale === 'es' && (
    <>
      <rect width="24" height="16" fill="#AA151B" />
      <rect y="4" width="24" height="8" fill="#F1BF00" />
    </>
  )}

  {locale === 'de' && (
    <>
      <rect width="24" height="5.333" fill="#000000" />
      <rect y="5.333" width="24" height="5.334" fill="#DD0000" />
      <rect y="10.667" width="24" height="5.333" fill="#FFCE00" />
    </>
  )}

  {locale === 'zh' && (
    <>
      <rect width="24" height="16" fill="#DE2910" />
      <g fill="#FFDE00">
        <polygon points="4,1 4.675,3.073 6.853,3.073 5.089,4.354 5.764,6.427 4,5.146 2.236,6.427 2.911,4.354 1.147,3.073 3.325,3.073" />
        <polygon points="10,1 10.225,1.691 10.951,1.691 10.363,2.118 10.588,2.809 10,2.382 9.412,2.809 9.637,2.118 9.049,1.691 9.775,1.691" />
        <polygon points="12,3 12.225,3.691 12.951,3.691 12.363,4.118 12.588,4.809 12,4.382 11.412,4.809 11.637,4.118 11.049,3.691 11.775,3.691" />
        <polygon points="12,6 12.225,6.691 12.951,6.691 12.363,7.118 12.588,7.809 12,7.382 11.412,7.809 11.637,7.118 11.049,6.691 11.775,6.691" />
        <polygon points="10,8 10.225,8.691 10.951,8.691 10.363,9.118 10.588,9.809 10,9.382 9.412,9.809 9.637,9.118 9.049,8.691 9.775,8.691" />
      </g>
    </>
  )}
</svg>
