---
import Layout from '../layouts/Layout.astro';
import type { Locale } from '../i18n/ui';

interface ContactCopy {
  title: string;
  description: string;
  eyebrow: string;
  heroTitle: string;
  heroLead: string;
  emailTitle: string;
  emailNote: string;
  officesTitle: string;
  officeHQ: string;
  officeHK: string;
  officeParis: string;
  officesNote: string;
  directTitle: string;
  formEyebrow: string;
  formHeading: string;
  labelName: string;
  labelEmail: string;
  labelPhone: string;
  labelWebsite: string;
  labelCompany: string;
  labelBrief: string;
  briefPlaceholder: string;
  captchaLabel: string;
  captchaPrompt: string;
  submit: string;
  sending: string;
  formHint: string;
  errMissing: string;
  errCaptchaClient: string;
  statusSending: string;
  errNetwork: string;
  errGeneric: string;
}

interface Props {
  locale: Locale;
  copy: ContactCopy;
}

const { locale, copy } = Astro.props;

const a = Math.floor(Math.random() * 8) + 2;
const b = Math.floor(Math.random() * 8) + 2;
const captchaQuestion = `${a} + ${b}`;
---

<Layout locale={locale} route="contact" title={copy.title} description={copy.description}>
  <section class="contact-split">
    <div class="contact-split__bg" aria-hidden="true"></div>
    <div class="contact-split__scrim" aria-hidden="true"></div>

    <div class="container contact-split__container">
      <div class="contact-split__grid">
        <aside class="contact-split__intro">
          <span class="eyebrow eyebrow--on-dark">{copy.eyebrow}</span>
          <h1 class="contact-split__title balance">{copy.heroTitle}</h1>
          <p class="contact-split__lead">{copy.heroLead}</p>

          <div class="contact-split__info">
            <div class="contact-split__info-block">
              <h2 class="contact-split__info-title">{copy.emailTitle}</h2>
              <p><a href="mailto:hello@beyondbordergroup.com">hello@beyondbordergroup.com</a></p>
              <p class="contact-split__info-note">{copy.emailNote}</p>
            </div>

            <div class="contact-split__info-block">
              <h2 class="contact-split__info-title">{copy.officesTitle}</h2>
              <p set:html={copy.officeHQ}></p>
              <p set:html={copy.officeHK}></p>
              <p set:html={copy.officeParis}></p>
              <p class="contact-split__info-note">{copy.officesNote}</p>
            </div>

            <div class="contact-split__info-block">
              <h2 class="contact-split__info-title">{copy.directTitle}</h2>
              <ul class="contact-split__links">
                <li><a href="https://beyondbordergroup.com/contact" target="_blank" rel="noreferrer">BeyondBorderGroup</a></li>
                <li><a href="https://theredscroll.com/contact" target="_blank" rel="noreferrer">TheRedScroll</a></li>
                <li><a href="https://chinawebfoundry.com/contact" target="_blank" rel="noreferrer">ChinaWebFoundry</a></li>
                <li><a href="https://beyondbridge.com/contact" target="_blank" rel="noreferrer">BeyondBridge</a></li>
                <li><a href="https://hubstudio.ai/contact" target="_blank" rel="noreferrer">HubStudio</a></li>
                <li><a href="https://nuvora.studio/contact" target="_blank" rel="noreferrer">Nuvora Studio</a></li>
              </ul>
            </div>
          </div>
        </aside>

        <div class="contact-split__form-col">
          <div class="contact-form-wrap">
            <header class="contact-form-header">
              <span class="eyebrow">{copy.formEyebrow}</span>
              <h2 class="balance">{copy.formHeading}</h2>
            </header>

            <form
              id="contact-form"
              class="form contact-form"
              method="post"
              action="/api/contact"
              novalidate
              data-locale={locale}
              data-err-missing={copy.errMissing}
              data-status-sending={copy.statusSending}
              data-err-network={copy.errNetwork}
              data-err-generic={copy.errGeneric}
              data-sending-label={copy.sending}
            >
              <input type="hidden" name="locale" value={locale} />

              <div class="form-row">
                <div class="form-field">
                  <label for="name">{copy.labelName} <span class="req">*</span></label>
                  <input id="name" name="name" type="text" autocomplete="name" required />
                </div>
                <div class="form-field">
                  <label for="email">{copy.labelEmail} <span class="req">*</span></label>
                  <input id="email" name="email" type="email" autocomplete="email" required />
                </div>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <label for="phone">{copy.labelPhone}</label>
                  <input id="phone" name="phone" type="tel" autocomplete="tel" />
                </div>
                <div class="form-field">
                  <label for="website">{copy.labelWebsite} <span class="req">*</span></label>
                  <input id="website" name="website" type="url" placeholder="https://" required />
                </div>
              </div>
              <div class="form-field">
                <label for="company">{copy.labelCompany} <span class="req">*</span></label>
                <input id="company" name="company" type="text" autocomplete="organization" required />
              </div>
              <div class="form-field">
                <label for="brief">{copy.labelBrief} <span class="req">*</span></label>
                <textarea id="brief" name="brief" rows="5" placeholder={copy.briefPlaceholder} required></textarea>
              </div>

              <div class="hp-field" aria-hidden="true">
                <label for="hp-website-2">Leave this field empty</label>
                <input id="hp-website-2" name="hp_field" type="text" tabindex="-1" autocomplete="off" />
              </div>

              <div class="captcha">
                <span class="captcha__label">{copy.captchaLabel}</span>
                <div class="captcha__row">
                  <span class="captcha__question" set:html={copy.captchaPrompt.replace('{q}', `<strong>${captchaQuestion}</strong>`)}></span>
                  <input
                    id="captcha-answer"
                    name="captcha_answer"
                    type="text"
                    inputmode="numeric"
                    pattern="-?[0-9]+"
                    autocomplete="off"
                    required
                    aria-label="Captcha"
                  />
                  <input type="hidden" name="captcha_question" value={captchaQuestion} />
                </div>
              </div>

              <p id="contact-status" class="form-status" role="status" aria-live="polite" hidden></p>

              <div class="btn-row contact-form__actions">
                <button id="contact-submit" class="btn btn--primary btn--lg" type="submit">{copy.submit}</button>
                <p class="muted contact-form__hint">{copy.formHint}</p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    const locale = form.dataset.locale ?? 'en';
    const msgMissing = form.dataset.errMissing ?? 'Please add your name and email so we can reach you.';
    const msgSending = form.dataset.statusSending ?? 'Sending your message…';
    const msgNetwork = form.dataset.errNetwork ?? 'Network error. Please check your connection and try again.';
    const msgGeneric = form.dataset.errGeneric ?? 'Something went wrong. Please try again.';
    const sendingLabel = form.dataset.sendingLabel ?? 'Sending…';
    const thankYouPath = locale === 'en' ? '/thank-you/' : `/${locale}/thank-you/`;

    const setStatus = (message: string, tone: 'info' | 'success' | 'error') => {
      status.hidden = false;
      status.textContent = message;
      status.dataset.tone = tone;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const data = new FormData(form);
      const payload: Record<string, string> = {};
      for (const [key, value] of data.entries()) {
        if (typeof value === 'string') payload[key] = value;
      }

      if (!payload.name || !payload.email) {
        setStatus(msgMissing, 'error');
        return;
      }

      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = sendingLabel;
      setStatus(msgSending, 'info');

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = (await response.json().catch(() => ({}))) as { error?: string };

        if (!response.ok) {
          setStatus(result.error || msgGeneric, 'error');
          submit.disabled = false;
          submit.textContent = originalLabel;
          return;
        }

        window.location.href = thankYouPath;
      } catch {
        setStatus(msgNetwork, 'error');
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  }
</script>

<style>
  .contact-split {
    position: relative;
    isolation: isolate;
    color: var(--bbg-white);
    padding: clamp(5rem, 11vh, 7.5rem) 0 clamp(4rem, 9vh, 6rem);
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .contact-split__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero-contact.webp');
    background-size: cover;
    background-position: center;
    background-color: #0a1320;
    z-index: -2;
    transform: scale(1.05);
    animation: contact-split-drift 32s ease-in-out infinite alternate;
  }
  @keyframes contact-split-drift {
    from { transform: scale(1.05) translate3d(0, 0, 0); }
    to   { transform: scale(1.10) translate3d(-1.5%, -1%, 0); }
  }
  .contact-split__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(10, 19, 32, 0.82) 0%, rgba(10, 19, 32, 0.58) 45%, rgba(10, 19, 32, 0.30) 100%),
      radial-gradient(ellipse at 25% 30%, rgba(38, 154, 218, 0.20), transparent 60%);
    z-index: -1;
  }

  .contact-split__container { width: 100%; }
  .contact-split__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-5), 4vw, var(--space-7));
    align-items: start;
  }
  @media (max-width: 960px) {
    .contact-split { min-height: 0; align-items: flex-start; }
    .contact-split__grid { grid-template-columns: 1fr; }
    .contact-split__form-col { order: 1; }
    .contact-split__intro { order: 2; max-width: none; }
    .contact-split__intro > .eyebrow,
    .contact-split__title,
    .contact-split__lead { display: none; }
    .contact-split__info { border-top: 0; padding-top: 0; }
  }

  .contact-split__intro { max-width: 560px; }
  .contact-split__title {
    font-size: clamp(2.25rem, 4.2vw + 0.5rem, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--bbg-white);
    margin: var(--space-3) 0 var(--space-4);
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.4);
  }
  .contact-split__lead {
    font-size: var(--fs-lead);
    color: rgba(255, 255, 255, 0.88);
    max-width: 50ch;
    margin: 0 0 var(--space-6);
  }

  .contact-split__info {
    display: grid;
    gap: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }
  .contact-split__info-block { color: rgba(255, 255, 255, 0.92); }
  .contact-split__info-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    margin: 0 0 var(--space-2);
  }
  .contact-split__info-block p { margin: 0 0 4px; font-size: 0.9375rem; }
  .contact-split__info-block strong { color: var(--bbg-white); font-weight: 600; }
  .contact-split__info-block a {
    color: var(--bbg-white);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    transition: border-color 0.2s var(--ease);
  }
  .contact-split__info-block a:hover { border-bottom-color: var(--bbg-white); }
  .contact-split__info-note {
    margin-top: var(--space-2) !important;
    color: rgba(255, 255, 255, 0.62);
    font-size: var(--fs-small);
  }
  .contact-split__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 18px;
    font-size: 0.9375rem;
  }
  @media (max-width: 480px) {
    .contact-split__links { grid-template-columns: 1fr; }
  }

  .contact-split__form-col { position: relative; }

  .contact-form-wrap {
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: 18px;
    padding: clamp(var(--space-5), 3.5vw, var(--space-6));
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.06),
      0 30px 60px -24px rgba(15, 23, 42, 0.35);
    color: var(--bbg-ink);
  }
  .contact-form-header { margin-bottom: var(--space-5); }
  .contact-form-header h2 {
    margin: var(--space-2) 0 0;
    font-size: clamp(1.4rem, 1.6vw + 0.6rem, 1.75rem);
  }
  .contact-form { background: transparent; border: 0; padding: 0; box-shadow: none; }

  .contact-form .form-field input,
  .contact-form .form-field select,
  .contact-form .form-field textarea {
    border-radius: 10px;
    padding: 0.8rem 1rem;
    background: #fafbfd;
    border-color: #e2e6ec;
  }
  .contact-form .form-field input:focus,
  .contact-form .form-field select:focus,
  .contact-form .form-field textarea:focus {
    background: #fff;
    border-color: var(--bbg-blue);
    box-shadow: 0 0 0 3px rgba(38, 154, 218, 0.12);
  }
  .contact-form .form-field label { font-weight: 600; color: var(--bbg-ink); font-size: 0.875rem; }
  .req { color: #c8102e; }

  .hp-field {
    position: absolute !important;
    left: -10000px !important;
    top: auto !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
  }

  .captcha {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(180deg, rgba(38, 154, 218, 0.04), rgba(38, 154, 218, 0.08));
    border: 1px solid rgba(38, 154, 218, 0.20);
    border-radius: 12px;
    margin-top: var(--space-2);
  }
  .captcha__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--bbg-blue);
  }
  .captcha__row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .captcha__question { font-size: 0.95rem; color: var(--bbg-ink); }
  .captcha__question strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--bbg-ink);
    padding: 4px 12px;
    background: var(--bbg-white);
    border: 1px solid rgba(38, 154, 218, 0.25);
    border-radius: 8px;
  }
  .captcha input[type="text"] {
    flex: 1;
    min-width: 90px;
    max-width: 140px;
    padding: 0.6rem 0.85rem;
    font: inherit;
    font-weight: 600;
    border: 1px solid #e2e6ec;
    border-radius: 8px;
    background: var(--bbg-white);
  }
  .captcha input[type="text"]:focus {
    outline: none;
    border-color: var(--bbg-blue);
    box-shadow: 0 0 0 3px rgba(38, 154, 218, 0.12);
  }

  .contact-form__actions {
    margin-top: var(--space-5);
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .contact-form__hint { margin: 0; font-size: 0.8125rem; }
  .btn--lg { padding: 0.9rem 1.5rem; font-size: 1rem; }

  .form-status {
    margin: var(--space-4) 0 0;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 14px;
    line-height: 1.5;
  }
  .form-status[data-tone='info']    { background: #f1f5f9; color: #334155; border: 1px solid #e2e8f0; }
  .form-status[data-tone='success'] { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
  .form-status[data-tone='error']   { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
</style>
