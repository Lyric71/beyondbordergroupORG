{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node script/optimize-image-hook.mjs",
            "timeout": 30,
            "statusMessage": "Optimizing image..."
          }
        ]
      }
    ]
  }
}
